---
import Layout from '~/layouts/PageLayout.astro';

const incomeData = (await import('~/data/income-data.json')).default;
const cpiData = (await import('~/data/cpi.json')).default;
const states = incomeData.states || {};

// Sort states by income descending
const stateRanking = Object.entries(states)
  .sort((a, b) => b[1].income_mean - a[1].income_mean)
  .map(([name, data], i) => ({ rank: i + 1, name, ...data }));

const nationalMean = incomeData.latest_national?.income_mean || 8479;
const nationalMedian = incomeData.latest_national?.income_median || 6338;

const highest = stateRanking[0];
const lowest = stateRanking[stateRanking.length - 1];

// Income trend (key years)
const trendYears = [1970, 1980, 1990, 2000, 2010, 2020, 2022];
const trendData = trendYears.map(y => {
  const row = incomeData.national_income?.find(r => r.date?.startsWith(String(y)));
  return row ? { year: y, mean: row.income_mean, median: row.income_median } : null;
}).filter(Boolean);

// Purchasing power
const pp = cpiData.purchasing_power || {};
const cpiLatest = cpiData.latest_cpi || 136.9;
const ppLatest = pp['2026'] || 99.5;
const rm100Value = (100 / cpiLatest * 100).toFixed(1);
const rm1000Value = (1000 / cpiLatest * 100).toFixed(1);

const year = new Date().getFullYear();

const metadata = {
  title: `Gaji Ikut Negeri Malaysia ${year} — Perbandingan Pendapatan Isi Rumah`,
  description: `Lihat purata gaji dan pendapatan isi rumah mengikut negeri di Malaysia. Data DOSM terkini (2022). Negeri termahal dan termurah.`,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Laman Utama', item: 'https://rakyathub.my/' },
    { '@type': 'ListItem', position: 2, name: 'Gaji Ikut Negeri', item: 'https://rakyathub.my/gaji-malaysia/' },
  ],
};
---

<style is:global>
  .tab-num { font-variant-numeric: tabular-nums; }
  .bar-bg { transition: width 0.6s ease-out; }
</style>

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-8 md:py-12">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-xs text-muted/60 mb-1">
      <a href="/" class="hover:text-primary">Laman Utama</a> <span>/</span> <span>Gaji Ikut Negeri</span>
    </div>
    <h1 class="text-2xl sm:text-4xl font-bold tracking-tight mb-3">💰 Gaji Ikut Negeri Malaysia 2026</h1>
    <p class="text-sm text-muted/80 max-w-3xl mb-5">
      Purata pendapatan isi rumah mengikut negeri — data rasmi <strong>DOSM</strong> (2022). Banding, ranking, dan lihat trend pendapatan negara.
    </p>

    <!-- Hero Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
      <div class="rounded-xl bg-gradient-to-br from-green-50 to-green-100/50 dark:from-green-950/30 dark:to-green-900/20 border border-green-100 dark:border-green-800/30 p-4">
        <p class="text-[10px] text-green-600 dark:text-green-400 font-semibold uppercase tracking-wider mb-0.5">Purata Nasional</p>
        <p class="text-xl font-bold text-green-700 dark:text-green-300 tab-num">RM {nationalMean.toLocaleString()}</p>
        <p class="text-[11px] text-muted/60 mt-0.5">Min</p>
      </div>
      <div class="rounded-xl bg-gradient-to-br from-blue-50 to-blue-100/50 dark:from-blue-950/30 dark:to-blue-900/20 border border-blue-100 dark:border-blue-800/30 p-4">
        <p class="text-[10px] text-blue-600 dark:text-blue-400 font-semibold uppercase tracking-wider mb-0.5">Median Nasional</p>
        <p class="text-xl font-bold text-blue-700 dark:text-blue-300 tab-num">RM {nationalMedian.toLocaleString()}</p>
        <p class="text-[11px] text-muted/60 mt-0.5">Median</p>
      </div>
      <div class="rounded-xl bg-gradient-to-br from-emerald-50 to-emerald-100/50 dark:from-emerald-950/30 dark:to-emerald-900/20 border border-emerald-100 dark:border-emerald-800/30 p-4">
        <p class="text-[10px] text-emerald-600 dark:text-emerald-400 font-semibold uppercase tracking-wider mb-0.5">Tertinggi</p>
        <p class="text-xl font-bold text-emerald-700 dark:text-emerald-300 tab-num">RM {highest?.income_mean?.toLocaleString() || '—'}</p>
        <p class="text-[11px] text-muted/60 mt-0.5">{highest?.name || ''}</p>
      </div>
      <div class="rounded-xl bg-gradient-to-br from-red-50 to-red-100/50 dark:from-red-950/30 dark:to-red-900/20 border border-red-100 dark:border-red-800/30 p-4">
        <p class="text-[10px] text-red-600 dark:text-red-400 font-semibold uppercase tracking-wider mb-0.5">Terendah</p>
        <p class="text-xl font-bold text-red-700 dark:text-red-300 tab-num">RM {lowest?.income_mean?.toLocaleString() || '—'}</p>
        <p class="text-[11px] text-muted/60 mt-0.5">{lowest?.name || ''}</p>
      </div>
    </div>

    <!-- Sorting Controls -->
    <div class="flex gap-2 mb-3">
      <button onclick="sortTable('mean')" class="sort-btn active px-3.5 py-2 rounded-lg text-xs font-semibold border border-primary bg-primary/10 text-primary" data-sort="mean">Purata</button>
      <button onclick="sortTable('median')" class="sort-btn px-3.5 py-2 rounded-lg text-xs font-semibold border border-gray-200 dark:border-slate-700 text-muted hover:border-primary/40" data-sort="median">Median</button>
      <button onclick="sortTable('name')" class="sort-btn px-3.5 py-2 rounded-lg text-xs font-semibold border border-gray-200 dark:border-slate-700 text-muted hover:border-primary/40" data-sort="name">Negeri</button>
    </div>

    <!-- Table -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm overflow-hidden mb-8">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 dark:border-slate-700/50 bg-gray-50/50 dark:bg-slate-800/30">
              <th class="text-left py-3.5 px-4 font-semibold text-muted text-[11px] uppercase tracking-wider w-10">#</th>
              <th class="text-left py-3.5 px-3 font-semibold text-muted text-[11px] uppercase tracking-wider">Negeri</th>
              <th class="text-right py-3.5 px-3 font-semibold text-muted text-[11px] uppercase tracking-wider tab-num">Min (RM)</th>
              <th class="text-right py-3.5 px-3 font-semibold text-muted text-[11px] uppercase tracking-wider tab-num hidden sm:table-cell">Median (RM)</th>
              <th class="text-right py-3.5 px-3 font-semibold text-muted text-[11px] uppercase tracking-wider tab-num hidden md:table-cell">vs Nasional</th>
            </tr>
          </thead>
          <tbody id="incomeBody">
            {stateRanking.map(s => {
              const vsNational = ((s.income_mean / nationalMean) * 100 - 100).toFixed(1);
              const isAbove = vsNational >= 0;
              const barPct = Math.min((s.income_mean / highest.income_mean) * 100, 100);
              return (
              <tr class="item-row border-b border-gray-50 dark:border-slate-800/50 transition-colors" data-mean={s.income_mean} data-median={s.income_median || 0} data-name={s.name}>
                <td class="py-3 px-4 font-bold tab-num text-muted">{s.rank}</td>
                <td class="py-3 px-3">
                  <span class="font-semibold text-gray-900 dark:text-gray-100">{s.name}</span>
                </td>
                <td class="text-right py-3 px-3 font-bold tab-num text-gray-900 dark:text-gray-100">RM {s.income_mean.toLocaleString()}</td>
                <td class="text-right py-3 px-3 hidden sm:table-cell tab-num text-muted">RM {s.income_median?.toLocaleString() || '—'}</td>
                <td class="text-right py-3 px-3 hidden md:table-cell tab-num">
                  <span class:list={['font-semibold', isAbove ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400']}>
                    {isAbove ? '+' : ''}{vsNational}%
                  </span>
                  <div class="w-24 h-1.5 bg-gray-100 dark:bg-slate-700 rounded-full mt-1 ml-auto">
                    <div class="h-full rounded-full bg-primary/60 bar-bg" style={`width: ${barPct.toFixed(0)}%`}></div>
                  </div>
                </td>
              </tr>
            )})}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Trend -->
    <h2 class="text-lg font-bold mb-3">📈 Trend Pendapatan Nasional</h2>
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-4 sm:p-6 mb-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-7 gap-3">
        {trendData.map(t => (
          <div class="text-center p-3 rounded-xl bg-gray-50 dark:bg-slate-800/40 border border-gray-100 dark:border-slate-700/30">
            <p class="text-[11px] font-semibold text-muted/60">{t.year}</p>
            <p class="text-sm font-bold text-gray-900 dark:text-gray-100 tab-num">RM {t.mean.toLocaleString()}</p>
            <p class="text-[10px] text-muted/50 tab-num">Med: RM {t.median?.toLocaleString() || '—'}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Purchasing Power -->
    <h2 class="text-lg font-bold mb-3">📉 Nilai Wang Hari Ini vs Dulu</h2>
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-4 sm:p-6 mb-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="p-4 rounded-xl bg-gradient-to-br from-amber-50 to-amber-100/50 dark:from-amber-950/30 dark:to-amber-900/20 border border-amber-100 dark:border-amber-800/30 text-center">
          <p class="text-[10px] font-semibold uppercase tracking-wider text-amber-600 dark:text-amber-400 mb-1">RM100 pada 2010</p>
          <p class="text-2xl font-bold text-amber-700 dark:text-amber-300 tab-num">RM{rm100Value}</p>
          <p class="text-[11px] text-muted/60 mt-1">nilai hari ini</p>
        </div>
        <div class="p-4 rounded-xl bg-gradient-to-br from-blue-50 to-blue-100/50 dark:from-blue-950/30 dark:to-blue-900/20 border border-blue-100 dark:border-blue-800/30 text-center">
          <p class="text-[10px] font-semibold uppercase tracking-wider text-blue-600 dark:text-blue-400 mb-1">CPI Terkini</p>
          <p class="text-2xl font-bold text-blue-700 dark:text-blue-300 tab-num">{cpiLatest.toFixed(1)}</p>
          <p class="text-[11px] text-muted/60 mt-1">indeks harga pengguna</p>
        </div>
        <div class="p-4 rounded-xl bg-gradient-to-br from-purple-50 to-purple-100/50 dark:from-purple-950/30 dark:to-purple-900/20 border border-purple-100 dark:border-purple-800/30 text-center">
          <p class="text-[10px] font-semibold uppercase tracking-wider text-purple-600 dark:text-purple-400 mb-1">Kuasa Beli {ppLatest.toFixed(1)}%</p>
          <p class="text-2xl font-bold text-purple-700 dark:text-purple-300 tab-num">RM{rm1000Value}/1000</p>
          <p class="text-[11px] text-muted/60 mt-1">nilai sebenar RM1,000</p>
        </div>
      </div>
    </div>

    <!-- About -->
    <div class="rounded-xl bg-gray-50 dark:bg-slate-800/40 border border-gray-100 dark:border-slate-700/30 p-4 mb-8 text-xs text-muted/70">
      <div class="flex items-center gap-2 mb-2">
        <span class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center text-[10px] font-bold text-primary">i</span>
        <span class="font-semibold text-muted">Sumber Data</span>
      </div>
      <p><strong>Pendapatan Isi Rumah:</strong> DOSM — Household Income & Expenditure Survey (HIES) 2022. Min = purata, Median = nilai tengah (lebih mewakili penerima tipikal). Data negeri adalah anggaran terkini yang diterbitkan DOSM.</p>
      <p class="mt-1"><strong>Kuasa Beli:</strong> Dikira menggunakan Indeks Harga Pengguna (CPI) DOSM. RM100 pada 2010 = RM{rm100Value} pada 2026 dari segi kuasa beli.</p>
      <p class="mt-1">Sumber: <a href="https://data.gov.my" class="text-primary hover:underline" target="_blank" rel="noopener">data.gov.my</a> — DOSM OpenDOSM (CC BY 4.0).</p>
    </div>
  </section>

  <script is:inline>
  function sortTable(by) {
    // Update button styles
    document.querySelectorAll('.sort-btn').forEach(b => {
      const isActive = b.getAttribute('data-sort') === by;
      b.className = 'sort-btn px-3.5 py-2 rounded-lg text-xs font-semibold border ' + (isActive ? 'border-primary bg-primary/10 text-primary' : 'border-gray-200 dark:border-slate-700 text-muted hover:border-primary/40');
      if (isActive) b.classList.add('active');
    });

    const tbody = document.getElementById('incomeBody');
    const rows = Array.from(tbody.querySelectorAll('tr'));

    rows.sort((a, b) => {
      if (by === 'name') return a.getAttribute('data-name').localeCompare(b.getAttribute('data-name'));
      const va = parseFloat(a.getAttribute('data-' + by)) || 0;
      const vb = parseFloat(b.getAttribute('data-' + by)) || 0;
      return vb - va; // descending for numbers
    });

    rows.forEach((row, i) => {
      const rankCell = row.querySelector('td:first-child');
      if (rankCell) rankCell.textContent = i + 1;
      tbody.appendChild(row);
    });
  }
  </script>
</Layout>
