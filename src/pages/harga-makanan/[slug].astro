---
import Layout from '~/layouts/PageLayout.astro';
import buildData from '~/data/harga-makanan.json';

export async function getStaticPaths() {
  const items = buildData.items || [];
  return items.map(item => {
    const slug = item.name.toLowerCase()
      .replace(/[^a-z0-9\s-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-')
      .trim();
    return { params: { slug }, props: { item } };
  });
}

const { item } = Astro.props;
const isUp = item.change > 0.01;
const isDown = item.change < -0.01;
const arrow = isUp ? '▲' : isDown ? '▼' : '➡';
const premises = (item.premises || []).slice(0, 8);

// Price range
const lowest = premises[0];
const highest = [...premises].pop();

// State breakdown
const stateCount = {};
premises.forEach(p => { stateCount[p.state] = (stateCount[p.state] || 0) + 1; });
const topStates = Object.entries(stateCount).sort((a,b) => b[1]-a[1]).slice(0,3);

const metadata = {
  title: `Harga ${item.name} Malaysia — RM${item.price.toFixed(2)} (${item.latest_date}) | RakyatHub`,
  description: `Semak harga ${item.name} Malaysia terkini: purata RM${item.price.toFixed(2)}/${item.unit||'unit'}. Termurah ${lowest?.name || '-'} RM${lowest?.price?.toFixed(2)||''}. Data KPDN PriceCatcher.`,
};
---

<style is:global>
  .tabular-nums { font-variant-numeric: tabular-nums; }
  .premise-card { transition: all .15s; }
  .premise-card:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(0,0,0,.08); }
</style>

<Layout metadata={metadata}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-8 md:py-12">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-xs text-muted/60 mb-1">
      <a href="/" class="hover:text-primary">Laman Utama</a> <span>/</span>
      <a href="/harga-makanan-hari-ini/" class="hover:text-primary">Harga Barang Runcit</a> <span>/</span>
      <span>{item.name}</span>
    </div>

    <!-- Hero -->
    <h1 class="text-2xl sm:text-4xl font-bold tracking-tight mb-2">Harga {item.name} Malaysia</h1>
    <p class="text-sm text-muted/70 mb-6">Data harian <strong>KPDN PriceCatcher</strong> — {item.latest_date} • {item.sample_size?.toLocaleString() || '-'} sampel</p>

    <!-- Price Overview Cards -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
      <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-blue-100/50 dark:from-blue-950/30 dark:to-blue-900/20 border border-blue-100 dark:border-blue-800/30 p-5 text-center">
        <p class="text-xs text-blue-600 dark:text-blue-400 font-semibold uppercase tracking-wider mb-1">Purata Nasional</p>
        <p class="text-3xl sm:text-4xl font-black text-blue-700 dark:text-blue-300 tabular-nums">RM {item.price.toFixed(2)}</p>
        <p class="text-[11px] text-muted/60 mt-1">/{item.unit || 'unit'}</p>
      </div>

      <div class={"rounded-2xl bg-gradient-to-br border p-5 text-center " + (isUp ? "from-red-50 to-red-100/50 dark:from-red-950/30 dark:to-red-900/20 border-red-100 dark:border-red-800/30" : isDown ? "from-green-50 to-green-100/50 dark:from-green-950/30 dark:to-green-900/20 border-green-100 dark:border-green-800/30" : "from-gray-50 to-gray-100/50 dark:from-gray-800/30 dark:to-gray-800/20 border-gray-200 dark:border-gray-700/30")}>
        <p class={"text-xs font-semibold uppercase tracking-wider mb-1 " + (isUp ? "text-red-600 dark:text-red-400" : isDown ? "text-green-600 dark:text-green-400" : "text-gray-600 dark:text-gray-400")}>
          {isUp ? '▲ Naik' : isDown ? '▼ Turun' : '➡ Stabil'}
        </p>
        <p class={"text-3xl sm:text-4xl font-black tabular-nums " + (isUp ? "text-red-700 dark:text-red-300" : isDown ? "text-green-700 dark:text-green-300" : "text-gray-700 dark:text-gray-300")}>
          {item.change_pct >= 0 ? '+' : ''}{item.change_pct.toFixed(1)}%
        </p>
        <p class="text-[11px] text-muted/60 mt-1">vs semalam (RM {Math.abs(item.change).toFixed(2)})</p>
      </div>

      <div class="rounded-2xl bg-gradient-to-br from-green-50 to-green-100/50 dark:from-green-950/30 dark:to-green-900/20 border border-green-100 dark:border-green-800/30 p-5 text-center">
        <p class="text-xs text-green-600 dark:text-green-400 font-semibold uppercase tracking-wider mb-1">Termurah</p>
        <p class="text-3xl sm:text-4xl font-black text-green-700 dark:text-green-300 tabular-nums">RM {(item.min_price || item.price).toFixed(2)}</p>
        <p class="text-[11px] text-muted/60 mt-1">{lowest?.name ? `di ${lowest.name.slice(0,18)}` : 'nasional'}</p>
      </div>

      <div class="rounded-2xl bg-gradient-to-br from-amber-50 to-amber-100/50 dark:from-amber-950/30 dark:to-amber-900/20 border border-amber-100 dark:border-amber-800/30 p-5 text-center">
        <p class="text-xs text-amber-600 dark:text-amber-400 font-semibold uppercase tracking-wider mb-1">Termahal</p>
        <p class="text-3xl sm:text-4xl font-black text-amber-700 dark:text-amber-300 tabular-nums">RM {(item.max_price || item.price).toFixed(2)}</p>
        <p class="text-[11px] text-muted/60 mt-1">{highest?.name ? `di ${highest.name.slice(0,18)}` : 'nasional'}</p>
      </div>
    </div>

    <!-- TEMPAT TERMURAH -->
    {premises.length > 0 && (
    <div class="mb-8">
      <h2 class="text-lg font-bold mb-4">🏪 Tempat Termurah {item.name}</h2>
      <p class="text-xs text-muted/70 mb-3">Harga terendah di premis terpilih seluruh Malaysia — {item.latest_date}</p>
      <div class="grid gap-2">
        {premises.map((p, i) => (
          <div class="premise-card rounded-xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-3.5 flex items-center justify-between">
            <div class="flex items-center gap-3 min-w-0">
              <span class={"shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold " + (i === 0 ? "bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400" : "bg-gray-100 dark:bg-slate-800 text-muted")}>
                {i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : `#${i+1}`}
              </span>
              <div class="min-w-0">
                <p class="text-sm font-semibold truncate">{p.name}</p>
                <p class="text-[11px] text-muted/60 truncate">{p.address} · {p.state}{p.type ? ` · ${p.type}` : ''}</p>
              </div>
            </div>
            <div class="shrink-0 text-right ml-3">
              <p class="text-lg font-black tabular-nums" style={i === 0 ? 'color:#059669' : ''}>RM {p.price.toFixed(2)}</p>
              {i === 0 && <p class="text-[10px] font-semibold text-green-600 dark:text-green-400">PALING MURAH</p>}
            </div>
          </div>
        ))}
      </div>
      {topStates.length > 0 && (
        <p class="text-xs text-muted/50 mt-2">Lokasi termurah banyak di: {topStates.map(([s,c]) => `${s} (${c})`).join(', ')}</p>
      )}
    </div>
    )}

    <!-- All Premises Map / Detail -->
    {premises.length > 0 && (
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-lg font-bold mb-4">📋 Senarai Harga mengikut Premis</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 dark:border-slate-700/50">
              <th class="text-left py-2 px-2 font-semibold text-muted text-[11px] uppercase">Kedai</th>
              <th class="text-left py-2 px-2 font-semibold text-muted text-[11px] uppercase hidden sm:table-cell">Lokasi</th>
              <th class="text-left py-2 px-2 font-semibold text-muted text-[11px] uppercase hidden md:table-cell">Negeri</th>
              <th class="text-right py-2 px-2 font-semibold text-muted text-[11px] uppercase">Harga</th>
            </tr>
          </thead>
          <tbody>
            {premises.map(p => (
              <tr class="border-b border-gray-50 dark:border-slate-800/50">
                <td class="py-2 px-2 font-medium">{p.name}</td>
                <td class="py-2 px-2 text-muted/70 text-xs hidden sm:table-cell truncate max-w-[200px]">{p.district || p.address}</td>
                <td class="py-2 px-2 text-muted/70 text-xs hidden md:table-cell">{p.state}</td>
                <td class="py-2 px-2 text-right font-bold tabular-nums">RM {p.price.toFixed(2)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    )}

    <!-- Ringkasan -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-lg font-bold mb-4">📊 Ringkasan Harga</h2>
      <div class="grid sm:grid-cols-2 gap-4 text-sm">
        <div>
          <div class="flex justify-between py-2 border-b border-gray-50 dark:border-slate-800"><span class="text-muted">Purata Nasional</span><span class="font-semibold">RM {item.price.toFixed(2)}</span></div>
          <div class="flex justify-between py-2 border-b border-gray-50 dark:border-slate-800"><span class="text-muted">Termurah</span><span class="font-semibold" style="color:#16a34a">RM {(item.min_price || item.price).toFixed(2)}</span></div>
          <div class="flex justify-between py-2 border-b border-gray-50 dark:border-slate-800"><span class="text-muted">Termahal</span><span class="font-semibold" style="color:#dc2626">RM {(item.max_price || item.price).toFixed(2)}</span></div>
          <div class="flex justify-between py-2"><span class="text-muted">Unit</span><span class="font-semibold">{item.unit || '—'}</span></div>
        </div>
        <div>
          <div class="flex justify-between py-2 border-b border-gray-50 dark:border-slate-800"><span class="text-muted">Trend</span><span class="font-semibold">{isUp ? '📈 Naik' : isDown ? '📉 Turun' : '➡ Stabil'}</span></div>
          <div class="flex justify-between py-2 border-b border-gray-50 dark:border-slate-800"><span class="text-muted">Perubahan</span><span class="font-semibold">{arrow} RM {Math.abs(item.change).toFixed(2)} ({item.change_pct > 0 ? '+' : ''}{item.change_pct.toFixed(1)}%)</span></div>
          <div class="flex justify-between py-2 border-b border-gray-50 dark:border-slate-800"><span class="text-muted">Sampel</span><span class="font-semibold">{item.sample_size?.toLocaleString() || '—'} rekod</span></div>
          <div class="flex justify-between py-2"><span class="text-muted">Kemas Kini</span><span class="font-semibold">{item.latest_date}</span></div>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-lg font-bold mb-4">❓ Soalan Lazim</h2>
      <div class="space-y-4 text-sm">
        <div>
          <h3 class="font-semibold mb-1">Berapa harga {item.name} hari ini?</h3>
          <p class="text-muted">Harga {item.name} adalah <strong>RM {item.price.toFixed(2)}/{item.unit || 'unit'}</strong> (purata nasional) setakat {item.latest_date}.</p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Di mana beli {item.name} paling murah?</h3>
          <p class="text-muted">
            {lowest ? `Berdasarkan data KPDN PriceCatcher, harga termurah ${item.name} adalah RM${lowest.price.toFixed(2)} di ${lowest.name} (${lowest.state}).` : 'Guna aplikasi KPDN PriceCatcher untuk banding harga di premis berhampiran.'}
            {premises.length > 0 && ` Antara premis lain yang murah: ${premises.slice(0,3).map(p => p.name).join(', ')}.`}
          </p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Harga {item.name} naik atau turun?</h3>
          <p class="text-muted">{isUp ? 'Naik ' + Math.abs(item.change_pct).toFixed(1) + '% berbanding semalam.' : isDown ? 'Turun ' + Math.abs(item.change_pct).toFixed(1) + '% berbanding semalam.' : 'Stabil berbanding semalam.'}</p>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-4 mb-8 text-xs text-muted">
      <strong>⚠️ Penafian:</strong> Harga adalah purata nasional & harga premis tertentu. Harga sebenar mungkin berbeza. Sumber: KPDN PriceCatcher — data.gov.my | CC BY 4.0.
    </div>
  </section>
</Layout>
