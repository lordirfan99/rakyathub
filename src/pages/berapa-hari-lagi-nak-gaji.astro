---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Berapa Hari Lagi Nak Gaji? — Countdown Gaji Malaysia 2026',
  description: 'Semak countdown hari lagi nak gaji. Kongsikan dengan rakan dan urus kewangan dengan lebih bijak. Kalkulator gaji bersih & tips kewangan.',
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Berapa Hari Lagi Nak Gaji? Countdown',
  url: 'https://rakyathub.my/berapa-hari-lagi-nak-gaji/',
  description: 'Interactive payday countdown for Malaysian workers',
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/kalkulator/" class="text-sm text-muted hover:text-primary transition-colors">← Semua Kalkulator</a>
    </div>

    <div class="text-center mb-10">
      <div class="text-5xl md:text-7xl mb-4">💰</div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">
        Berapa Hari Lagi Nak <span class="text-primary">Gaji</span>?
      </h1>
      <p class="text-lg md:text-xl text-muted max-w-2xl mx-auto">
        Countdown hari lagi dapat gaji. Kongsikan dengan kawan-kawan dan mula urus kewangan dengan lebih bijak.
      </p>
    </div>

    <!-- Main Countdown Card -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-6 md:p-10 mb-8 text-center">
      <p class="text-sm text-muted mb-2" id="currentDate"></p>

      <div class="flex justify-center gap-4 md:gap-8 my-8" id="countdownDisplay">
        <div class="text-center">
          <div class="text-5xl md:text-7xl font-black text-primary tabular-nums" id="days">0</div>
          <div class="text-xs text-muted uppercase tracking-widest mt-1">Hari</div>
        </div>
        <div class="text-center">
          <div class="text-5xl md:text-7xl font-black text-secondary tabular-nums" id="hours">0</div>
          <div class="text-xs text-muted uppercase tracking-widest mt-1">Jam</div>
        </div>
        <div class="text-center">
          <div class="text-5xl md:text-7xl font-black text-accent tabular-nums" id="minutes">0</div>
          <div class="text-xs text-muted uppercase tracking-widest mt-1">Minit</div>
        </div>
        <div class="text-center">
          <div class="text-5xl md:text-7xl font-black text-amber-500 tabular-nums" id="seconds">0</div>
          <div class="text-xs text-muted uppercase tracking-widest mt-1">Saat</div>
        </div>
      </div>

      <div class="inline-block rounded-full bg-primary/10 text-primary text-sm font-medium px-5 py-2 mb-4">
        🎯 Gaji seterusnya: <span id="nextPaydayDate" class="font-bold"></span>
      </div>

      <div class="max-w-md mx-auto mb-6">
        <div class="flex justify-between text-xs text-muted mb-1.5">
          <span>Gaji Lepas</span>
          <span><span id="progressPercent">0</span>%</span>
          <span>Gaji Depan</span>
        </div>
        <div class="h-3 bg-gray-200 dark:bg-slate-700 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-primary to-secondary rounded-full transition-all duration-1000" id="progressBar" style="width:0%"></div>
        </div>
      </div>

      <div class="flex flex-wrap justify-center gap-3 mt-6">
        <a id="shareWA" href="#" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-green-600 hover:bg-green-700 text-white font-medium text-sm transition-all duration-200 hover:scale-[1.02] active:scale-95">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Share WhatsApp
        </a>
        <a id="shareTG" href="#" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-sky-500 hover:bg-sky-600 text-white font-medium text-sm transition-all duration-200 hover:scale-[1.02] active:scale-95">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          Share Telegram
        </a>
        <button onclick="copyShareLink()"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gray-600 hover:bg-gray-700 text-white font-medium text-sm transition-all duration-200 hover:scale-[1.02] active:scale-95">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
          Salin Pautan
        </button>
      </div>
    </div>

    <!-- 3 cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-6 card-hover">
        <div class="text-3xl mb-3">🧮</div>
        <h3 class="font-bold text-lg mb-2">Kira Gaji Bersih</h3>
        <p class="text-muted text-sm mb-3">Berapa sebenarnya gaji bersih korang selepas KWSP, SOCSO, dan PCB?</p>
        <a href="/kalkulator/gaji-bersih/" class="text-primary font-medium hover:underline text-sm">→ Kira Sekarang</a>
      </div>
      <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-6 card-hover">
        <div class="text-3xl mb-3">📊</div>
        <h3 class="font-bold text-lg mb-2">Bajet 50/30/20</h3>
        <p class="text-muted text-sm mb-3">Bahagi gaji ikut formula 50/30/20 — keperluan, kehendak, simpanan.</p>
        <a href="/cadangan-bajet-50-30-20-di-malaysia/" class="text-primary font-medium hover:underline text-sm">→ Cuba Bajet</a>
      </div>
      <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-6 card-hover">
        <div class="text-3xl mb-3">💡</div>
        <h3 class="font-bold text-lg mb-2">Tips Urus Gaji</h3>
        <p class="text-muted text-sm mb-3">Panduan praktikal urus gaji bawah RM3,000 dan cara simpan duit.</p>
        <a href="/cara-simpan-duit-gaji-rm2500/" class="text-primary font-medium hover:underline text-sm">→ Baca Tips</a>
      </div>
    </div>

    <!-- Info section -->
    <div class="rounded-2xl bg-gradient-to-br from-amber-50 to-orange-50 dark:from-slate-800 dark:to-slate-800 border border-amber-100 dark:border-slate-700 p-6 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">📌 Kenapa Penting Tahu Bila Nak Gaji?</h2>
      <div class="grid md:grid-cols-2 gap-4 text-sm">
        <div class="flex items-start gap-3">
          <span class="text-lg">📅</span>
          <p class="text-muted">Rancang bayaran bil dan komitmen lebih awal — elak caj lewat.</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-lg">🎯</span>
          <p class="text-muted">Tetapkan sasaran simpanan sebelum gaji habis dibelanjakan.</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-lg">🧠</span>
          <p class="text-muted">Kurangkan stress kewangan dengan tahu aliran wang masuk.</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-lg">🔄</span>
          <p class="text-muted">Guna sistem auto-debit untuk simpanan sebaik je gaji masuk.</p>
        </div>
      </div>
    </div>

    <!-- Related articles -->
    <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6 md:p-8 mb-8">
      <h3 class="text-xl font-bold mb-4">📚 Artikel Popular</h3>
      <ul class="space-y-2">
        <li><a href="/kalkulator/gaji-bersih/" class="text-primary font-medium hover:underline text-sm">→ Kalkulator Gaji Bersih Malaysia</a></li>
        <li><a href="/kalkulator/pcb-cukai-pendapatan/" class="text-primary font-medium hover:underline text-sm">→ Kalkulator PCB & Cukai Pendapatan</a></li>
        <li><a href="/gaji-rm3500-breakdown-realistik/" class="text-primary font-medium hover:underline text-sm">→ Gaji RM3,500 Breakdown Realistik</a></li>
        <li><a href="/gaji-graduan-mengikut-industri-2026/" class="text-primary font-medium hover:underline text-sm">→ Gaji Graduan Ikut Industri 2026</a></li>
        <li><a href="/urus-duit-gaji-bawah-rm3000/" class="text-primary font-medium hover:underline text-sm">→ Cara Urus Duit Gaji Bawah RM3,000</a></li>
        <li><a href="/kalkulator/bajet-kahwin/" class="text-primary font-medium hover:underline text-sm">→ Kalkulator Bajet Kahwin</a></li>
      </ul>
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Kira Gaji Bersih', href: '/kalkulator/gaji-bersih/' },
      { variant: 'secondary', text: 'Kalkulator KWSP', href: '/kalkulator/kwsp/' },
    ]}
  >
    <Fragment slot="title">Nak Kira Gaji Bersih atau KWSP?</Fragment>
    <Fragment slot="subtitle">Semua kalkulator percuma — tak perlu daftar. Guna sekarang.</Fragment>
  </CallToAction>

  <script is:inline>
(function() {
  var now = new Date();
  var targetDay = 22;

  var nextPayday = new Date(now.getFullYear(), now.getMonth(), targetDay, 5, 0, 0);
  if (now >= nextPayday) {
    if (now.getDate() === targetDay && now.getHours() < 5) {
      // still waiting
    } else {
      nextPayday = new Date(now.getFullYear(), now.getMonth() + 1, targetDay, 5, 0, 0);
    }
  }

  var prevPayday = new Date(nextPayday);
  prevPayday.setMonth(prevPayday.getMonth() - 1);

  function getDiff() {
    var now = new Date();
    var diff = nextPayday - now;
    if (diff <= 0) {
      nextPayday = new Date(now.getFullYear(), now.getMonth() + 1, targetDay, 5, 0, 0);
      prevPayday = new Date(nextPayday);
      prevPayday.setMonth(prevPayday.getMonth() - 1);
      diff = nextPayday - now;
    }
    return diff;
  }

  var months = ['Januari','Februari','Mac','April','Mei','Jun','Julai','Ogos','September','Oktober','November','Disember'];
  var days = ['Ahad','Isnin','Selasa','Rabu','Khamis','Jumaat','Sabtu'];

  function updateClock() {
    var now = new Date();
    var diff = getDiff();

    var d = Math.floor(diff / (1000*60*60*24));
    var h = Math.floor((diff % (1000*60*60*24)) / (1000*60*60));
    var m = Math.floor((diff % (1000*60*60)) / (1000*60));
    var s = Math.floor((diff % (1000*60)) / 1000);

    document.getElementById('days').textContent = d;
    document.getElementById('hours').textContent = String(h).padStart(2,'0');
    document.getElementById('minutes').textContent = String(m).padStart(2,'0');
    document.getElementById('seconds').textContent = String(s).padStart(2,'0');
    document.getElementById('currentDate').textContent = days[now.getDay()] + ', ' + now.getDate() + ' ' + months[now.getMonth()] + ' ' + now.getFullYear();
    document.getElementById('nextPaydayDate').textContent = targetDay + ' ' + months[nextPayday.getMonth()] + ' ' + nextPayday.getFullYear();

    var totalCycle = nextPayday - prevPayday;
    var elapsed = now - prevPayday;
    var pct = Math.min(100, Math.max(0, (elapsed / totalCycle) * 100));
    document.getElementById('progressPercent').textContent = Math.round(pct);
    document.getElementById('progressBar').style.width = pct + '%';
  }

  updateClock();
  setInterval(updateClock, 1000);

  setInterval(function() {
    var msg = '💰 Lagi ' + document.getElementById('days').textContent + ' hari ' + document.getElementById('hours').textContent + ':' + document.getElementById('minutes').textContent + ' nak gaji! (' + document.getElementById('nextPaydayDate').textContent + ')\n\nUrus kewangan lebih bijak dengan RakyatHub:\nhttps://rakyathub.my/berapa-hari-lagi-nak-gaji/';
    document.getElementById('shareWA').href = 'https://wa.me/?text=' + encodeURIComponent(msg);
    document.getElementById('shareTG').href = 'https://t.me/share/url?url=' + encodeURIComponent('https://rakyathub.my/berapa-hari-lagi-nak-gaji/') + '&text=' + encodeURIComponent('💰 Lagi ' + document.getElementById('days').textContent + ' hari nak gaji!');
  }, 5000);
})();

function copyShareLink() {
  var url = 'https://rakyathub.my/berapa-hari-lagi-nak-gaji/';
  if (navigator.clipboard) {
    navigator.clipboard.writeText(url).then(function() {
      var btn = event.target.closest('button');
      var orig = btn.innerHTML;
      btn.innerHTML = '✅ Disalin!';
      setTimeout(function() { btn.innerHTML = orig; }, 2000);
    });
  }
}
</script>
</Layout>
