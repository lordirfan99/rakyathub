---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Harga Minyak Malaysia Terkini — RON95, RON97, Diesel 2026 | RakyatHub',
  description: 'Semak harga minyak Malaysia terkini — RON95 RM2.05, RON97 RM3.35, Diesel RM2.15. Update mingguan dari KPDN/MOF. Percuma.',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-8 md:py-12">
    <div class="flex items-center gap-2 text-xs text-muted/60 mb-1">
      <a href="/" class="hover:text-primary">Laman Utama</a> <span>/</span>
      <span>Harga Minyak Terkini</span>
    </div>

    <h1 class="text-2xl sm:text-4xl font-bold tracking-tight mb-3">Harga Minyak Malaysia 2026</h1>
    <p class="text-sm text-muted/80 max-w-3xl mb-6">
      Pantau harga minyak RON95, RON97 dan Diesel terkini di Malaysia. Data mingguan dari <strong>KPDN</strong> dan <strong>Kementerian Kewangan Malaysia</strong>.
    </p>

    <!-- Price Cards -->
    <div class="grid sm:grid-cols-3 gap-4 mb-8">
      <div class="rounded-2xl bg-gradient-to-br from-green-50 to-green-100/50 dark:from-green-950/30 dark:to-green-900/20 border border-green-100 dark:border-green-800/30 p-6 text-center">
        <div class="text-2xl mb-2">⛽</div>
        <p class="text-xs text-green-600 dark:text-green-400 font-semibold uppercase tracking-wider mb-1">RON95</p>
        <p class="text-4xl font-black text-green-700 dark:text-green-300 tabular-nums">RM 2.05</p>
        <p class="text-xs text-muted/60 mt-2">/ liter — Disubsidi kerajaan</p>
        <span class="inline-block mt-2 px-2.5 py-1 rounded-full bg-green-100 dark:bg-green-900/30 text-[10px] font-semibold text-green-700 dark:text-green-400">Nasional</span>
      </div>
      <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-blue-100/50 dark:from-blue-950/30 dark:to-blue-900/20 border border-blue-100 dark:border-blue-800/30 p-6 text-center">
        <div class="text-2xl mb-2">⛽</div>
        <p class="text-xs text-blue-600 dark:text-blue-400 font-semibold uppercase tracking-wider mb-1">RON97</p>
        <p class="text-4xl font-black text-blue-700 dark:text-blue-300 tabular-nums">RM 3.35</p>
        <p class="text-xs text-muted/60 mt-2">/ liter — Float (terkini)</p>
        <span class="inline-block mt-2 px-2.5 py-1 rounded-full bg-blue-100 dark:bg-blue-900/30 text-[10px] font-semibold text-blue-700 dark:text-blue-400">Pasaran</span>
      </div>
      <div class="rounded-2xl bg-gradient-to-br from-amber-50 to-amber-100/50 dark:from-amber-950/30 dark:to-amber-900/20 border border-amber-100 dark:border-amber-800/30 p-6 text-center">
        <div class="text-2xl mb-2">⛽</div>
        <p class="text-xs text-amber-600 dark:text-amber-400 font-semibold uppercase tracking-wider mb-1">Diesel</p>
        <p class="text-4xl font-black text-amber-700 dark:text-amber-300 tabular-nums">RM 2.15</p>
        <p class="text-xs text-muted/60 mt-2">/ liter — Disubsidi (kenderaan)</p>
        <span class="inline-block mt-2 px-2.5 py-1 rounded-full bg-amber-100 dark:bg-amber-900/30 text-[10px] font-semibold text-amber-700 dark:text-amber-400">Nasional</span>
      </div>
    </div>

    <!-- Info -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-lg font-bold mb-3">📊 Panduan Harga Minyak Malaysia</h2>
      <div class="space-y-3 text-sm text-muted">
        <p><strong>RON95 (RM 2.05/L)</strong> — Harga disubsidi kerajaan untuk rakyat Malaysia. Kumpulan B40 dan M40 menikmati harga ini. Golongan T45 dan warga asing membayar harga float (~RM 3.35/L).</p>
        <p><strong>RON97 (RM 3.35/L)</strong> — Harga apung (float) yang ditentukan mingguan berdasarkan harga minyak global. Sesuai untuk kereta berprestasi tinggi. Biasanya ~RM 1.30 lebih mahal dari RON95.</p>
        <p><strong>Diesel (RM 2.15/L)</strong> — Harga disubsidi untuk kenderaan pengangkutan dan pertanian. Subsidi柴油 disasarkan untuk pengguna tertentu.</p>
      </div>
    </div>

    <!-- Calculator -->
    <div class="rounded-2xl bg-gradient-to-br from-primary/5 to-secondary/5 border border-primary/20 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-lg font-bold mb-3">💰 Kira Kos Minyak Anda</h2>
      <p class="text-sm text-muted mb-4">Guna kalkulator kos minyak untuk anggaran perbelanjaan minyak bulanan.</p>
      <a href="/kalkulator/kos-minyak/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-primary text-white font-semibold text-sm transition hover:shadow-lg hover:shadow-primary/30">
        Kira Kos Minyak →</a>
    </div>

    <!-- Disclaimer -->
    <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-4 mb-8 text-xs text-muted">
      <strong>⚠️ Penafian:</strong> Harga minyak tertakluk kepada perubahan mingguan yang diumumkan KPDN setiap hari Rabu. Harga sebenar mungkin berbeza mengikut stesen minyak dan lokasi.
      <br /><em>Sumber: KPDN — Kementerian Perdagangan Dalam Negeri dan Kos Sara Hidup | MOF</em>
    </div>

    <!-- Related -->
    <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6 md:p-8">
      <h3 class="text-xl font-bold mb-4">📚 Alat Berkaitan</h3>
      <ul class="space-y-2">
        <li><a href="/kalkulator/kos-minyak/" class="text-primary font-medium hover:underline text-sm">→ Kalkulator Kos Minyak Bulanan</a></li>
        <li><a href="/harga-makanan-hari-ini/" class="text-primary font-medium hover:underline text-sm">→ Harga Barang Runcit Terkini</a></li>
        <li><a href="/kalkulator/cukai-jalan/" class="text-primary font-medium hover:underline text-sm">→ Kalkulator Cukai Jalan JPJ</a></li>
      </ul>
    </div>
  </section>

  <CallToAction actions={[
    { variant: 'primary', text: 'Kira Kos Minyak', href: '/kalkulator/kos-minyak' },
    { variant: 'secondary', text: 'Cukai Jalan', href: '/kalkulator/cukai-jalan' },
  ]}>
    <Fragment slot="title">Alat kenderaan percuma</Fragment>
    <Fragment slot="subtitle">Kira kos minyak, cukai jalan, dan insurans kereta.</Fragment>
  </CallToAction>
</Layout>
