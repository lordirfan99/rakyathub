---
import Layout from '~/layouts/PageLayout.astro';
import CtaBanner from '~/components/widgets/CtaBanner.astro';

const metadata = {
  title: 'Join Watch Party — World Cup 2026',
  description: 'Join watch party World Cup 2026 secara online. 1080p HD, free trial 1 minggu, full access RM20. Support Discord screen share, sorak sama-sama!',
};
---

<Layout metadata={metadata}>
  <section class="relative overflow-hidden min-h-screen flex items-center">
    {/* Background gradient */}
    <div class="absolute inset-0 bg-gradient-to-br from-[#0f172a] via-[#1e1b4b] to-[#0f172a]" />
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-1/4 -left-20 w-72 h-72 bg-[#5865F2] rounded-full blur-[100px]" />
      <div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-[#f59e0b] rounded-full blur-[120px]" />
    </div>

    {/* Content */}
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 py-12 md:py-20 text-center">

      {/* Badge */}
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/10 rounded-full px-4 py-2 mb-8">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse" />
        <span class="text-sm text-green-300 font-medium">Limited Spots Available</span>
      </div>

      {/* Main Title */}
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold tracking-tight text-white leading-tight mb-6">
        🏆 World Cup 2026
        <br />
        <span class="bg-gradient-to-r from-[#5865F2] to-[#b37efc] bg-clip-text text-transparent">
          Watch Party
        </span>
      </h1>

      {/* Subtitle */}
      <p class="text-lg sm:text-xl md:text-2xl text-slate-300 max-w-2xl mx-auto mb-4">
        Tonton semua perlawanan Piala Dunia 2026 dalam <strong>1080p HD</strong> — 
        zero buffer, sorak sekali dengan komuniti!
      </p>

      {/* Perks */}
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        {['📺 1080p HD @ 30FPS', '⚡ Zero Buffer', '🎤 Voice & Chat', '💰 RM20 Full Access'].map((item) => (
          <span class="bg-white/5 border border-white/10 rounded-full px-4 py-2 text-sm text-slate-300">
            {item}
          </span>
        ))}
      </div>

      {/* Big CTA Banner Image */}
      <a
        href="https://discord.gg/4DZDdF95MZ"
        target="_blank"
        rel="noopener noreferrer"
        onclick="return gtagSendEvent('https://discord.gg/4DZDdF95MZ');"
        class="block mb-8 hover:opacity-95 transition-opacity"
      >
        <img
          src="/images/cta-klik-diskon.jpg"
          alt="KLIK DI SINI UNTUK MENONTON"
          class="w-full rounded-2xl shadow-2xl"
          width="1280"
          height="698"
          loading="eager"
        />
      </a>

      {/* Big CTA Button */}
      <a
        href="https://discord.gg/4DZDdF95MZ"
        target="_blank"
        rel="noopener noreferrer"
        id="cta-join-discord"
        class="inline-flex items-center gap-3 bg-[#5865F2] hover:bg-[#4752c4] text-white text-xl sm:text-2xl font-bold px-10 py-5 rounded-2xl shadow-2xl shadow-[#5865F2]/30 hover:shadow-[#5865F2]/50 transition-all duration-300 hover:scale-105 active:scale-95 mb-8"
        onclick="return gtagSendEvent('https://discord.gg/4DZDdF95MZ');"
      >
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.054C1.483 12.11.637 15.653.018 19.325a.084.084 0 0 0 .036.086 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.086c-.619-3.672-1.466-7.172-3.665-14.9a.064.064 0 0 0-.031-.054zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
        Join Watch Party Now 🎉
      </a>

      {/* Pricing Cards */}
      <div class="grid md:grid-cols-3 gap-4 max-w-3xl mx-auto mb-12">
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 text-center">
          <div class="text-3xl mb-3">🎁</div>
          <h3 class="text-white font-bold text-lg mb-2">Free Trial</h3>
          <p class="text-3xl font-bold text-green-400 mb-3">RM0</p>
          <p class="text-slate-400 text-sm">1 minggu percuma<br/>Try dulu, zero risiko</p>
        </div>
        <div class="bg-[#5865F2]/10 backdrop-blur-sm border-2 border-[#5865F2] rounded-2xl p-6 text-center relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#5865F2] text-white text-xs font-bold px-4 py-1 rounded-full">POPULAR</div>
          <div class="text-3xl mb-3">🏆</div>
          <h3 class="text-white font-bold text-lg mb-2">Full Access</h3>
          <p class="text-3xl font-bold text-white mb-3">RM20</p>
          <p class="text-slate-400 text-sm">Seluruh tournament<br/>1080p HD, zero buffer</p>
        </div>
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 text-center">
          <div class="text-3xl mb-3">👥</div>
          <h3 class="text-white font-bold text-lg mb-2">Komuniti</h3>
          <p class="text-slate-300 font-bold text-lg mb-3">Priceless</p>
          <p class="text-slate-400 text-sm">Sorak sama-sama<br/>Voice chat &amp; sembang</p>
        </div>
      </div>

      {/* How It Works */}
      <div class="max-w-2xl mx-auto mb-12">
        <h2 class="text-2xl font-bold text-white mb-8">Macam Mana Nak Join?</h2>
        <div class="grid grid-cols-4 gap-2 md:gap-4">
          {[
            { step: '1', icon: '📱', title: 'Klik butang', desc: 'Klik "Join" dekat atas' },
            { step: '2', icon: '📥', title: 'Download Discord', desc: 'Free, 2 minit je' },
            { step: '3', icon: '🔗', title: 'Masuk Server', desc: 'Auto redirect' },
            { step: '4', icon: '🎬', title: 'Tonton!', desc: '1080p HD lancar' },
          ].map((item) => (
            <div class="text-center">
              <div class="w-12 h-12 md:w-16 md:h-16 bg-[#5865F2]/20 rounded-full flex items-center justify-center mx-auto mb-2 text-2xl">
                {item.icon}
              </div>
              <div class="text-white font-bold text-xs md:text-sm">{item.title}</div>
              <div class="text-slate-400 text-[10px] md:text-xs">{item.desc}</div>
            </div>
          ))}
        </div>
      </div>

      {/* Pricing Comparison */}
      <div class="max-w-xl mx-auto mb-8">
        <h2 class="text-xl font-bold text-white mb-4">Kenapa Pilih Watch Party?</h2>
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-white/10">
              <th class="py-2 text-slate-400 font-medium"></th>
              <th class="py-2 text-white font-medium text-center">Unifi TV</th>
              <th class="py-2 text-[#5865F2] font-medium text-center">Watch Party</th>
            </tr>
          </thead>
          <tbody>
            {[
              ['Harga', 'RM20-60', 'RM20 ✨'],
              ['Free Trial', '✘', '✅ 1 minggu'],
              ['Kualiti', 'HD', '1080p HD 30FPS'],
              ['Sorak', 'Sendiri', 'Komuniti 👥'],
              ['Setup', 'MyUnifi app', 'Discord 2 minit'],
            ].map(([label, unifi, wp]) => (
              <tr class="border-b border-white/5">
                <td class="py-2.5 text-slate-400">{label}</td>
                <td class="py-2.5 text-slate-500 text-center">{unifi}</td>
                <td class="py-2.5 text-green-400 font-medium text-center">{wp}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {/* Second CTA */}
      <a
        href="https://discord.gg/4DZDdF95MZ"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white font-bold px-8 py-4 rounded-xl text-lg shadow-lg transition-all hover:scale-105 active:scale-95"
        onclick="return gtagSendEvent('https://discord.gg/4DZDdF95MZ');"
      >
        🚀 Join Watch Party — Free Trial 1 Minggu
      </a>

      {/* FAQ */}
      <div class="max-w-xl mx-auto mt-16 text-left">
        <h2 class="text-xl font-bold text-white mb-6 text-center">Soalan Lazim</h2>
        {[
          ['Apa tu Discord?', 'Discord macam WhatsApp versi power — ada chat, voice call, screen share. Download free dekat app store, klik link join, terus masuk. Senang.'],
          ['Macam mana nak bayar?', 'Lepas masuk server, pergi channel #beli-pass. Admin akan guide. Bayaran dibuat secara online.'],
          ['Ada free trial ke?', 'Ya! 1 minggu percuma. Try dulu tengok kualiti & setup. Puas hati baru bayar RM20.'],
          ['Kualiti streaming macam mana?', '1080p HD @ 30FPS, buffer minimum. Server optimize untuk streaming bola.'],
        ].map(([q, a]) => (
          <details class="group border-b border-white/10 py-4">
            <summary class="text-white font-medium cursor-pointer list-none flex items-center justify-between">
              {q}
              <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <p class="text-slate-400 mt-3 text-sm leading-relaxed">{a}</p>
          </details>
        ))}
      </div>

    </div>
  </section>
</Layout>

<script>
  // Google Ads conversion tracking
  window.gtagSendEvent = function(url) {
    var callback = function () {
      if (typeof url === 'string') {
        window.location = url;
      }
    };
    gtag('event', 'conversion', {
      'send_to': 'AW-18178383181/1bTaCNGRu7kcEM26kNxD',
      'event_callback': callback,
      'event_timeout': 2000,
    });
    return false;
  };

  // Fire conversion event on page load
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof gtag === 'function') {
      gtag('event', 'conversion', {
        'send_to': 'AW-18178383181/1bTaCNGRu7kcEM26kNxD',
        'value': 20.0,
        'currency': 'MYR'
      });
      console.log('✅ Google Ads conversion event fired');
    } else {
      setTimeout(function() {
        if (typeof gtag === 'function') {
          gtag('event', 'conversion', {
            'send_to': 'AW-18178383181/1bTaCNGRu7kcEM26kNxD',
            'value': 20.0,
            'currency': 'MYR'
          });
        }
      }, 2000);
    }
  });
</script>
