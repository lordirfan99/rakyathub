---
import Layout from '~/layouts/PageLayout.astro';

import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

// Static food price data for homepage widget (no JS loading)
const foodData = (await import('~/data/harga-makanan.json')).default;
const foodItems = (foodData.items || []).slice(0, 20);
const foodDate = foodData.latest_date || '';
const foodTotal = foodData.total_records || 0;
const foodCount = foodData.items_count || foodItems.length;
function getEmoji(n) {
  const u = (n||'').toUpperCase();
  const MAP = { AYAM:'🍗', DAGING:'🥩', IKAN:'🐟', TELUR:'🥚', BERAS:'🍚', MINYAK:'🫙', GULA:'🧂', TEPUNG:'🌾', CILI:'🌶️', BAWANG:'🧅', HALIA:'🫚', KACANG:'🥜', KUBIS:'🥬', LOBAK:'🥕', TIMUN:'🥒', SANTAN:'🥥' };
  for (const [k,v] of Object.entries(MAP)) if (u.includes(k)) return v;
  return '🛒';
}
function slugify(n) { return (n||'').toLowerCase().replace(/[^a-z0-9\s-]/g,'').replace(/\s+/g,'-').replace(/-+/g,'-').trim(); }
const foodWidget = foodItems.slice(0, 6);

const CALCULATORS = [
  { icon: '🏦', name: 'KWSP', href: '/kalkulator/kwsp/', desc: 'Caruman & dividen terkini', gradient: 'from-teal-500 to-cyan-600' },
  { icon: '📈', name: 'ASB', href: '/kalkulator/asb/', desc: 'Dividen & bonus tahunan', gradient: 'from-indigo-500 to-purple-600' },
  { icon: '🪙', name: 'Emas', href: '/kalkulator/emas/', desc: 'Harga emas semasa Malaysia', gradient: 'from-amber-500 to-orange-600' },
  { icon: '🚗', name: 'Kereta', href: '/kalkulator/kereta/', desc: 'Ansuran bulanan kereta', gradient: 'from-cyan-500 to-blue-600' },
  { icon: '🏠', name: 'Loan Rumah', href: '/kalkulator/loan-rumah/', desc: 'Kelayakan & ansuran', gradient: 'from-teal-500 to-emerald-600' },
  { icon: '💵', name: 'Gaji Bersih', href: '/kalkulator/gaji-bersih/', desc: 'EPF + SOCSO + PCB', gradient: 'from-emerald-500 to-green-600' },
  { icon: '📊', name: 'Percentile Gaji', href: '/kalkulator/pendapatan-percentile/', desc: 'Kedudukan gaji anda', gradient: 'from-blue-500 to-indigo-600' },
  { icon: '🛒', name: 'Kuasa Beli', href: '/kalkulator/kuasa-beli/', desc: 'Nilai RM & inflasi', gradient: 'from-rose-500 to-pink-600' },
  { icon: '🎯', name: 'Benchmark Gaji', href: '/kalkulator/benchmark-gaji/', desc: 'Banding ikut profesion', gradient: 'from-orange-500 to-red-600' },
  { icon: '🏷️', name: 'Diskaun', href: '/kalkulator/diskaun/', desc: 'Harga selepas diskaun', gradient: 'from-violet-500 to-pink-600' },
  { icon: '🧮', name: 'Lagi Alat', href: '/kalkulator/', desc: '20+ kalkulator →', gradient: 'from-slate-500 to-slate-600' },
];

const FEATURED = [
  { icon: '💰', title: 'Bajet 50/30/20', href: '/cadangan-bajet-50-30-20-di-malaysia/', desc: 'Cara bahagi gaji bulanan' },
  { icon: '🏦', title: 'Panduan KWSP', href: '/panduan-kwsp-malaysia-2025/', desc: 'Caruman, dividen & pengeluaran' },
  { icon: '🟡', title: 'Beli Emas GAP', href: '/cara-beli-emas-public-gold/', desc: 'Panduan Public Gold lengkap' },
  { icon: '💸', title: 'Urus Gaji <RM3K', href: '/urus-duit-gaji-bawah-rm3000/', desc: 'Tips praktikal gaji kecil' },
  { icon: '🛡️', title: 'Medical Card', href: '/panduan-medical-card-malaysia-2026-first-time-buyer/', desc: 'Panduan first buyer' },
  { icon: '🎓', title: 'Gaji Graduan', href: '/gaji-graduan-mengikut-industri-2026/', desc: 'Ikut industri & negeri' },
  { icon: '🧾', title: 'E-Filing 2026', href: '/panduan-e-filing-cukai-pendapatan-2026/', desc: 'Cara isi cukai online' },
  { icon: '📱', title: 'eWallet Terbaik', href: '/gxbank-vs-bigpay-vs-tng-ewallet-dompet-digital-terbaik-2026/', desc: 'GXBank vs BigPay vs TNG' },
  { icon: '⏳', title: 'Countdown Gaji', href: '/berapa-hari-lagi-nak-gaji/', desc: 'Hari ke gaji seterusnya' },
  { icon: '🩺', title: 'Quiz Kewangan', href: '/quiz-kesihatan-kewangan/', desc: 'Uji skor kesihatan duit' },
];

const TOOLS_ROW1 = [
  { icon: '📈', title: 'Inflasi Malaysia', href: '/inflasi-malaysia/', desc: 'CPI terkini & kalkulator inflasi', sub: 'RM100 pada 2010 = RM73 hari ini', gradient: 'from-red-500 to-amber-600' },
  { icon: '🇲🇾', title: 'Bantuan Kerajaan', href: '/bantuan-kerajaan/', desc: 'STR, SARA, BUDI95 & e-Tunai', sub: 'RM8,000+ setahun — bila & berapa', gradient: 'from-emerald-500 to-teal-600' },
];

const TOOLS_ROW2 = [
  { icon: '💰', title: 'Reality Check Gaji', href: '/reality-check/', desc: 'Banding gaji ikut negeri & sektor', sub: 'Percentile ranking & potongan EPF', gradient: 'from-purple-500 to-indigo-600' },
  { icon: '📊', title: 'Gaji Ikut Negeri', href: '/gaji-malaysia/', desc: 'Ranking pendapatan 16 negeri', sub: 'Putrajaya RM13,473 vs Kelantan RM4,885', gradient: 'from-blue-500 to-cyan-600' },
  { icon: '🏪', title: 'Indeks Pasaraya', href: '/indeks-harga-pasaraya/', desc: 'Mana pasaraya termurah', sub: 'Lotus\'s, Econsave, Mydin, AEON', gradient: 'from-emerald-500 to-teal-600' },
];

const metadata = {
  title: 'RakyatHub — Panduan Kewangan & Harga Makanan Malaysia',
  ignoreTitleTemplate: true,
  description:
    'Harga barang runcit harian (KPDN PriceCatcher), kalkulator percuma KWSP, ASB, cukai & pinjaman, data inflasi dan bantuan kerajaan untuk rakyat Malaysia.',
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'RakyatHub',
  url: 'https://rakyathub.my',
  logo: 'https://rakyathub.my/rakyathub-logo.png',
  description: 'Panduan kewangan, harga makanan, KWSP, ASB, emas, bantuan kerajaan dan pelaburan untuk rakyat Malaysia.',
  sameAs: ['https://rakyathub.my/blog/'],
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <!-- ════════════════════════════════════════════════════ -->
  <!-- 🇲🇾 HERO — Malaysian sunrise, warm & bold           -->
  <!-- ════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden min-h-[70vh] flex items-center">
    <!-- Gradient background -->
    <div class="hero-gradient"></div>
    <!-- Floating orbs -->
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>
    <!-- Batik pattern overlay -->
    <div class="batik-pattern text-white"></div>
    <div class="batik-pattern-2 text-white/30"></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28 relative z-10 w-full">
      <div class="max-w-3xl">
        <!-- Tagline -->
        <p class="inline-flex items-center gap-2 text-xs sm:text-sm font-semibold text-white/70 uppercase tracking-[0.2em] mb-5 border border-white/10 rounded-full px-4 py-1.5 backdrop-blur-sm bg-white/5">
          <span class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse"></span>
          Platform Kewangan Rakyat Malaysia
        </p>

        <!-- Main headline -->
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.1]">
          <span class="text-white">Panduan</span><br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-orange-300 to-yellow-200">Kewangan</span>
          <span class="text-white/90"> & Harga Makanan</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-base sm:text-lg md:text-xl text-white/70 max-w-2xl mt-5 leading-relaxed">
          Kalkulator percuma, harga barangan harian terkini, dan panduan kewangan untuk rakyat Malaysia. <span class="text-white font-semibold">Semua dalam Bahasa Malaysia.</span>
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-3 sm:gap-4 mt-8">
          <a href="/harga-makanan-hari-ini/" class="inline-flex items-center gap-2.5 px-6 sm:px-8 py-3.5 sm:py-4 rounded-xl bg-gradient-to-r from-amber-500 to-orange-600 hover:from-amber-400 hover:to-orange-500 text-white text-sm sm:text-base font-bold transition-all hover:-translate-y-0.5 shadow-lg shadow-orange-600/25 hover:shadow-xl hover:shadow-orange-600/30 glow-pulse">
            <span>🏪</span> Harga Makanan
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
          <a href="/kalkulator/" class="inline-flex items-center gap-2.5 px-6 sm:px-8 py-3.5 sm:py-4 rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 hover:bg-white/15 text-white text-sm sm:text-base font-semibold transition-all hover:-translate-y-0.5">
            <span>🧮</span> Kalkulator
          </a>
          <a href="/inflasi-malaysia/" class="inline-flex items-center gap-2.5 px-6 sm:px-8 py-3.5 sm:py-4 rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 hover:bg-white/15 text-white/80 text-sm sm:text-base font-semibold transition-all hover:-translate-y-0.5">
            <span>📈</span> Inflasi
          </a>
        </div>

        <!-- Stats bar -->
        <div class="flex flex-wrap items-center gap-6 sm:gap-10 mt-10 pt-8 border-t border-white/10">
          <div class="flex items-center gap-2.5">
            <span class="text-2xl sm:text-3xl font-black text-white tabular-nums">{foodTotal.toLocaleString()}</span>
            <span class="text-xs sm:text-sm text-white/60">Rekod Harga</span>
          </div>
          <div class="flex items-center gap-2.5">
            <span class="text-2xl sm:text-3xl font-black text-white tabular-nums">{foodItems.length}</span>
            <span class="text-xs sm:text-sm text-white/60">Barangan Dipantau</span>
          </div>
          <div class="flex items-center gap-2.5">
            <span class="text-2xl sm:text-3xl font-black text-white tabular-nums">20+</span>
            <span class="text-xs sm:text-sm text-white/60">Kalkulator Percuma</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════ -->
  <!-- 🛒 HARGA MAKANAN — Premium card widget             -->
  <!-- ════════════════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 -mt-10 relative z-20 pb-2">
    <div class="rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden bg-white dark:bg-slate-900 shadow-xl shadow-slate-200/50 dark:shadow-black/20 card-glow">
      <!-- Premium Header -->
      <div class="px-5 sm:px-7 py-4 sm:py-5 bg-gradient-to-r from-teal-50 via-white to-orange-50 dark:bg-slate-800/80 border-b border-slate-200 dark:border-slate-700 flex items-center justify-between">
        <div class="flex items-center gap-3 sm:gap-4">
          <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-gradient-to-br from-teal-500 to-cyan-600 flex items-center justify-center text-xl sm:text-2xl shadow-sm shrink-0">🛒</div>
          <div>
            <h2 class="text-base sm:text-xl font-bold text-gray-900 dark:text-gray-100">Harga Makanan Hari Ini</h2>
            <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">Data terkini • KPDN PriceCatcher • <span class="font-semibold text-teal-600 dark:text-teal-400">{foodDate}</span></p>
          </div>
          <span class="inline-flex items-center gap-1.5 text-[10px] sm:text-xs font-semibold text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-950/40 border border-emerald-200 dark:border-emerald-800/60 px-2.5 py-1 rounded-full shrink-0">
            <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
            LANGSUNG
          </span>
        </div>
      </div>

      <!-- Price Rows -->
      <div class="divide-y divide-slate-100 dark:divide-slate-800/80">
        {foodWidget.map((item, idx) => (
          <a href={`/harga-makanan/${slugify(item.name)}/`}
             class="flex items-center justify-between px-5 sm:px-7 py-3.5 sm:py-4 hover:bg-gradient-to-r hover:from-teal-50/50 hover:to-orange-50/50 dark:hover:bg-slate-800/60 transition-all group price-row"
             style={`animation-delay: ${idx * 80}ms`}
          >
            <div class="flex items-center gap-3 sm:gap-4 min-w-0">
              <span class="text-xl w-8 text-center shrink-0 leading-none">{getEmoji(item.name||'')}</span>
              <div class="min-w-0">
                <p class="text-sm sm:text-base font-semibold text-gray-900 dark:text-gray-100 group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors truncate">{item.name}</p>
                <p class="text-[11px] text-gray-400 dark:text-gray-500 truncate">Kedai terdekat termurah</p>
              </div>
            </div>
            <div class="flex items-center gap-2 sm:gap-3 shrink-0">
              {item.change && item.change > 0.01 ? (
                <span class="hidden sm:inline-flex items-center gap-0.5 text-[11px] font-semibold text-red-500 bg-red-50 dark:bg-red-900/20 px-2 py-0.5 rounded-full border border-red-100 dark:border-red-800/30">▲ {item.change_pct.toFixed(1)}%</span>
              ) : item.change && item.change < -0.01 ? (
                <span class="hidden sm:inline-flex items-center gap-0.5 text-[11px] font-semibold text-green-500 bg-green-50 dark:bg-green-900/20 px-2 py-0.5 rounded-full border border-green-100 dark:border-green-800/30">▼ {Math.abs(item.change_pct).toFixed(1)}%</span>
              ) : null}
              <span class="text-sm sm:text-lg font-black text-teal-600 dark:text-teal-400 tabular-nums tracking-tight">RM{(item.price||0).toFixed(2)}</span>
              <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-teal-400 transition-colors shrink-0 -mr-1 sm:mr-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
            </div>
          </a>
        ))}
      </div>

      <!-- Footer -->
      <div class="px-5 sm:px-7 py-3 sm:py-4 bg-gradient-to-r from-teal-50/50 to-orange-50/50 dark:bg-slate-800/60 border-t border-slate-100 dark:border-slate-700 flex items-center justify-between flex-wrap gap-2">
        <div class="flex items-center gap-3 text-[11px] sm:text-xs text-gray-500 dark:text-gray-400">
          <span class="inline-flex items-center gap-1"><span class="font-semibold text-teal-600 dark:text-teal-400">{foodTotal.toLocaleString()}</span> rekod</span>
          <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
          <span class="inline-flex items-center gap-1"><span class="font-semibold text-teal-600 dark:text-teal-400">{foodCount}</span> barangan</span>
        </div>
        <a href="/harga-makanan-hari-ini/" class="inline-flex items-center gap-1 text-xs sm:text-sm font-semibold text-teal-600 dark:text-teal-400 hover:text-teal-700 dark:hover:text-teal-300 transition-colors">
          Semua Harga & Termurah
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════ -->
  <!-- 📊 DATA TOOLS — Inflasi & Bantuan Kerajaan          -->
  <!-- ════════════════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-10 md:py-14">
    <div class="text-center mb-8 sm:mb-10">
      <p class="inline-flex items-center gap-2 text-xs sm:text-sm font-semibold text-teal-600 dark:text-teal-400 uppercase tracking-[0.15em] mb-3">
        <span class="w-1.5 h-1.5 bg-teal-500 rounded-full"></span>
        DATA TERKINI
      </p>
      <h2 class="text-xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100">Inflasi & Bantuan Kerajaan</h2>
      <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 mt-2 max-w-2xl mx-auto">Data terkini DOSM dan pengumuman kerajaan untuk rakyat Malaysia.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
      {TOOLS_ROW1.map((tool, idx) => (
        <a href={tool.href}
           class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-700/50 bg-white dark:bg-slate-900/80 p-6 sm:p-8 premium-card-hover"
        >
          <div class="flex items-start gap-4 sm:gap-5">
            <span class={`w-12 h-12 sm:w-14 sm:h-14 rounded-2xl bg-gradient-to-br ${tool.gradient} flex items-center justify-center text-white text-xl sm:text-2xl shadow-lg shrink-0`}>
              {tool.icon}
            </span>
            <div class="min-w-0 flex-1">
              <h3 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-gray-100 group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors">{tool.title}</h3>
              <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 mt-0.5">{tool.desc}</p>
              <p class="text-xs sm:text-sm text-gray-400 dark:text-gray-500 mt-2 leading-relaxed">{tool.sub}</p>
            </div>
            <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 group-hover:text-teal-500 transition-colors shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </div>
          <div class={`absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r ${tool.gradient} opacity-0 group-hover:opacity-100 transition-opacity`}></div>
        </a>
      ))}
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════ -->
  <!-- 📊 REALITY TOOLS — Gaji & Perbandingan             -->
  <!-- ════════════════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-4 md:py-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
      {TOOLS_ROW2.map((tool, idx) => (
        <a href={tool.href}
           class="group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-700/50 bg-white dark:bg-slate-900/80 p-5 sm:p-6 premium-card-hover"
        >
          <div class="flex items-start gap-4">
            <span class={`w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-gradient-to-br ${tool.gradient} flex items-center justify-center text-white text-lg sm:text-xl shadow-md shrink-0`}>
              {tool.icon}
            </span>
            <div class="min-w-0 flex-1">
              <h3 class="text-sm sm:text-base font-bold text-gray-900 dark:text-gray-100 group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors">{tool.title}</h3>
              <p class="text-[11px] sm:text-xs text-gray-500 dark:text-gray-400 mt-0.5">{tool.desc}</p>
            </div>
          </div>
          <p class="text-xs sm:text-sm text-gray-400 dark:text-gray-500 mt-3 leading-relaxed">{tool.sub}</p>
          <div class={`absolute bottom-0 left-0 right-0 h-1 bg-gradient-to-r ${tool.gradient} opacity-0 group-hover:opacity-100 transition-opacity`}></div>
        </a>
      ))}
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════ -->
  <!-- 🧮 KALKULATOR PERCUMA — Premium grid               -->
  <!-- ════════════════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-10 md:py-16" id="kalkulator">
    <div class="text-center mb-8 sm:mb-10">
      <p class="inline-flex items-center gap-2 text-xs sm:text-sm font-semibold text-teal-600 dark:text-teal-400 uppercase tracking-[0.15em] mb-3">
        <span class="w-1.5 h-1.5 bg-teal-500 rounded-full"></span>
        KALKULATOR PERCUMA
      </p>
      <h2 class="text-xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100">Alat <span class="gradient-text-brand">Kewangan</span> Untuk Rakyat Malaysia</h2>
      <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 mt-2 max-w-2xl mx-auto">Kira simpanan KWSP, dividen ASB, harga emas, dan ansuran kereta secara percuma. Semua dalam Bahasa Malaysia.</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-5">
      {CALCULATORS.map((calc, idx) => (
        <a href={calc.href}
           class="group relative overflow-hidden rounded-2xl border border-slate-100 dark:border-slate-700/30 bg-white dark:bg-slate-900/60 p-4 sm:p-6 premium-card-hover"
           style={`animation-delay: ${idx * 60}ms`}
        >
          <div class={`w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-gradient-to-br ${calc.gradient} flex items-center justify-center text-lg sm:text-xl shadow-md mb-3 sm:mb-4 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3`}>
            {calc.icon}
          </div>
          <h3 class="text-sm sm:text-base font-bold text-gray-900 dark:text-gray-100 group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors">{calc.name}</h3>
          <p class="text-[11px] sm:text-xs text-gray-500 dark:text-gray-400 mt-1 leading-relaxed">{calc.desc}</p>
          <div class={`absolute bottom-0 left-3 right-3 h-0.5 rounded-full bg-gradient-to-r ${calc.gradient} opacity-0 group-hover:opacity-100 transition-opacity`}></div>
        </a>
      ))}
    </div>
  </section>

  <!-- Cross-sell: DocuKilat CTA -->
