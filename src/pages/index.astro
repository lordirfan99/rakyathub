---
import Layout from '~/layouts/PageLayout.astro';

import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

// Static food price data for homepage widget (no JS loading)
const foodData = (await import('~/data/harga-makanan.json')).default;
const foodItems = (foodData.items || []).slice(0, 20);
const foodDate = foodData.latest_date || '';
const foodTotal = foodData.total_records || 0;
const foodCount = foodData.items_count || foodItems.length;
function getInitial(n) {
  const u = (n||'').toUpperCase();
  return u.charAt(0) || '?';
}
function slugify(n) { return (n||'').toLowerCase().replace(/[^a-z0-9\s-]/g,'').replace(/\s+/g,'-').replace(/-+/g,'-').trim(); }
const foodWidget = foodItems.slice(0, 6);

const metadata = {
  title: 'RakyatHub — Panduan Kewangan & Harga Makanan Malaysia',
  ignoreTitleTemplate: true,
  description:
    'Harga barang runcit harian (KPDN PriceCatcher), kalkulator percuma KWSP, ASB, cukai & pinjaman, data inflasi dan bantuan kerajaan untuk rakyat Malaysia.',
};

// Organization schema for SEO
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'RakyatHub',
  url: 'https://rakyathub.my',
  logo: 'https://rakyathub.my/rakyathub-logo.png',
  description: 'Panduan kewangan, harga makanan, KWSP, ASB, emas, bantuan kerajaan dan pelaburan untuk rakyat Malaysia.',
  sameAs: ['https://rakyathub.my/blog/'],
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <!-- ═══ PREMIUM HERO — minimal, clean, bold ═══ -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-600/5 via-transparent to-amber-600/5 pointer-events-none"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-20 text-center relative">
      <p class="text-xs sm:text-sm font-semibold text-primary/70 uppercase tracking-[0.2em] mb-3">Platform Kewangan Rakyat Malaysia</p>
      <h1 class="text-3xl sm:text-5xl md:text-6xl font-extrabold tracking-tight leading-tight text-gray-900 dark:text-gray-100">
        Panduan <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-amber-500">Kewangan</span> & Harga Makanan
      </h1>
      <p class="text-sm sm:text-lg text-gray-500 dark:text-gray-400 max-w-2xl mx-auto mt-4 leading-relaxed">
        Kalkulator percuma, harga barangan harian terkini, dan panduan kewangan untuk rakyat Malaysia. Semua dalam Bahasa Malaysia.
      </p>
      <div class="flex items-center justify-center gap-3 mt-6">
        <a href="/harga-makanan-hari-ini/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold transition-all hover:shadow-lg hover:-translate-y-0.5">
          Harga Makanan
        </a>
        <a href="/kalkulator/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-gray-200 dark:border-slate-700 text-gray-700 dark:text-gray-300 text-sm font-semibold hover:bg-gray-50 dark:hover:bg-slate-800/60 transition-all">
          Kalkulator
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ HARGA MAKANAN — premium statik widget ═══ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-2">
    <div class="rounded-2xl border border-slate-200 dark:border-slate-700 overflow-hidden bg-white dark:bg-slate-900 shadow-sm">
      <!-- Premium Header -->
      <div class="px-5 sm:px-7 py-4 sm:py-5 bg-gradient-to-r from-slate-50 to-white dark:from-slate-800/60 dark:to-slate-900 border-b border-slate-200 dark:border-slate-700 flex items-center justify-between">
        <div class="flex items-center gap-3 sm:gap-4">
          <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center text-xl sm:text-2xl shrink-0">🛒</div>
          <div>
            <h2 class="text-base sm:text-xl font-bold text-gray-900 dark:text-gray-100">Harga Makanan Hari Ini</h2>
            <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400">Data terkini • KPDN PriceCatcher • <span class="font-semibold text-gray-700 dark:text-gray-300">{foodDate}</span></p>
          </div>
          <span class="inline-flex items-center gap-1.5 text-[10px] sm:text-xs font-semibold text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-950/40 border border-emerald-200 dark:border-emerald-800/60 px-2.5 py-1 rounded-full shrink-0">
            <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
            LANGSUNG
          </span>
        </div>
      </div>

      <!-- Price Rows — static, premium, clickable -->
      <div class="divide-y divide-slate-100 dark:divide-slate-800/80">
        {foodWidget.map(item => (
          <a href={`/harga-makanan/${slugify(item.name)}/`} class="flex items-center justify-between px-5 sm:px-7 py-3.5 sm:py-4 hover:bg-slate-50 dark:hover:bg-slate-800/40 transition-all group">
            <div class="flex items-center gap-3 sm:gap-4 min-w-0">
              <span class="text-lg sm:text-xl w-7 sm:w-8 text-center shrink-0">{getInitial(item.name||'')}</span>
              <div class="min-w-0">
                <p class="text-sm sm:text-base font-semibold text-gray-900 dark:text-gray-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors truncate">{item.name}</p>
              </div>
            </div>
            <div class="flex items-center gap-2 sm:gap-3 shrink-0">
              {item.change && item.change > 0.01 ? (
                <span class="hidden sm:inline-flex items-center gap-0.5 text-[11px] font-semibold text-red-500 bg-red-50 dark:bg-red-900/20 px-2 py-0.5 rounded-full border border-red-100 dark:border-red-800/30">▲ {item.change_pct.toFixed(1)}%</span>
              ) : item.change && item.change < -0.01 ? (
                <span class="hidden sm:inline-flex items-center gap-0.5 text-[11px] font-semibold text-green-500 bg-green-50 dark:bg-green-900/20 px-2 py-0.5 rounded-full border border-green-100 dark:border-green-800/30">▼ {Math.abs(item.change_pct).toFixed(1)}%</span>
              ) : null}
              <span class="text-sm sm:text-lg font-black text-blue-600 dark:text-blue-400 tabular-nums tracking-tight">RM{(item.price||0).toFixed(2)}</span>
              <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-blue-400 transition-colors shrink-0 -mr-1 sm:mr-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
            </div>
          </a>
        ))}
      </div>

      <!-- Premium Footer -->
      <div class="px-5 sm:px-7 py-3 sm:py-4 bg-gradient-to-r from-slate-50 to-white dark:from-slate-800/40 dark:to-slate-900 border-t border-slate-100 dark:border-slate-800 flex items-center justify-between flex-wrap gap-2">
        <div class="flex items-center gap-3 text-[11px] sm:text-xs text-gray-500 dark:text-gray-400">
          <span class="inline-flex items-center gap-1"><span class="font-semibold text-gray-700 dark:text-gray-300">{foodTotal.toLocaleString()}</span> rekod</span>
          <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
          <span class="inline-flex items-center gap-1"><span class="font-semibold text-gray-700 dark:text-gray-300">{foodCount}</span> barangan</span>
        </div>
        <a href="/harga-makanan-hari-ini/" class="inline-flex items-center gap-1 text-xs sm:text-sm font-semibold text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors">
          Semua Harga & Termurah
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ DATA TOOLS — Inflasi & Bantuan ═══ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-8 md:py-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a href="/inflasi-malaysia/" class="rounded-2xl bg-gradient-to-br from-red-50 to-amber-50 dark:from-red-950/20 dark:to-amber-950/20 border border-red-100 dark:border-red-800/30 p-5 sm:p-6 hover:shadow-lg hover:-translate-y-0.5 transition-all group">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-10 h-10 rounded-xl bg-gradient-to-br from-red-500 to-amber-600 flex items-center justify-center text-white text-lg shadow-sm">📈</span>
          <div>
            <h3 class="text-base font-bold text-gray-900 dark:text-gray-100 group-hover:text-red-600 transition-colors">Inflasi Malaysia</h3>
            <p class="text-xs text-muted/70">CPI terkini, nilai ringgit & kalkulator</p>
          </div>
        </div>
        <p class="text-sm text-muted/80">RM100 pada 2010 hanya bernilai RM73 hari ini. Semak data inflasi rasmi DOSM.</p>
      </a>
      <a href="/bantuan-kerajaan/" class="rounded-2xl bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-950/20 dark:to-emerald-950/20 border border-green-100 dark:border-green-800/30 p-5 sm:p-6 hover:shadow-lg hover:-translate-y-0.5 transition-all group">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-10 h-10 rounded-xl bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center text-white text-lg shadow-sm">🇲🇾</span>
          <div>
            <h3 class="text-base font-bold text-gray-900 dark:text-gray-100 group-hover:text-green-600 transition-colors">Bantuan Kerajaan 2026</h3>
            <p class="text-xs text-muted/70">STR, SARA, BUDI95, e-Tunai & banyak lagi</p>
          </div>
        </div>
        <p class="text-sm text-muted/80">Semua bantuan RM8,000+ setahun — bila bayar, berapa dapat, status terkini.</p>
      </a>
    </div>
  </section>

  <!-- ═══ KALKULATOR — premium grid ═══ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-8 md:py-12" id="kalkulator">
    <div class="text-center mb-6 sm:mb-8">
      <p class="text-xs sm:text-sm font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-[0.15em] mb-2">KALKULATOR PERCUMA</p>
      <h2 class="text-xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100">Alat Kewangan Untuk Rakyat Malaysia</h2>
      <p class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 mt-2 max-w-2xl mx-auto">Kira simpanan KWSP, dividen ASB, harga emas, dan ansuran kereta secara percuma.</p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
      {[
        { icon: 'K', name: 'KWSP', href: '/kalkulator/kwsp/', desc: 'Caruman & dividen', bg: 'from-blue-500 to-blue-600' },
        { icon: 'A', name: 'ASB', href: '/kalkulator/asb/', desc: 'Dividen & bonus', bg: 'from-indigo-500 to-indigo-600' },
        { icon: 'E', name: 'Emas', href: '/kalkulator/emas/', desc: 'Harga emas semasa', bg: 'from-amber-500 to-amber-600' },
        { icon: 'K', name: 'Kereta', href: '/kalkulator/kereta/', desc: 'Ansuran bulanan', bg: 'from-cyan-500 to-cyan-600' },
        { icon: 'R', name: 'Loan Rumah', href: '/kalkulator/loan-rumah/', desc: 'Kelayakan & ansuran', bg: 'from-teal-500 to-teal-600' },
        { icon: 'G', name: 'Gaji Bersih', href: '/kalkulator/gaji-bersih/', desc: 'EPF + SOCSO + PCB', bg: 'from-emerald-500 to-emerald-600' },
        { icon: 'D', name: 'Diskaun', href: '/kalkulator/diskaun/', desc: 'Harga selepas diskaun', bg: 'from-violet-500 to-violet-600' },
        { icon: '+', name: 'Lagi Alat', href: '/kalkulator/', desc: '20+ kalkulator \u2192', bg: 'from-slate-500 to-slate-600' },
      ].map(calc => (
        <a href={calc.href} class="rounded-xl bg-white dark:bg-slate-800/80 border border-gray-100 dark:border-slate-700/50 p-4 sm:p-5 hover:border-blue-200 dark:hover:border-blue-800/50 hover:shadow-md transition-all hover:-translate-y-0.5 group">
          <span class={`w-8 h-8 rounded-lg bg-gradient-to-br ${calc.bg} flex items-center justify-center text-white text-xs font-bold shadow-sm mb-2.5`}>{calc.icon}</span>
          <h3 class="text-sm sm:text-base font-bold text-gray-900 dark:text-gray-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{calc.name}</h3>
          <p class="text-[11px] sm:text-xs text-gray-500 dark:text-gray-400 mt-0.5">{calc.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Cross-sell: DocuKilat CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Bina Dokumen di DocuKilat',
        href: 'https://docukilat.rakyathub.my',
        icon: 'tabler:file-text',
      },
    ]}
  >
    <Fragment slot="title">
      Perlu Surat Rasmi, Invois atau Resume?
    </Fragment>

    <Fragment slot="subtitle">
      Gunakan DocuKilat — platform penjanaan dokumen AI dengan 26 template percuma. 
      Surat rasmi, invois premium, resume dan banyak lagi.
    </Fragment>
  </CallToAction>

  <!-- Featured Articles — direct links for Google crawl depth -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-8 md:py-12">
    <div class="text-center mb-6 sm:mb-8">
      <p class="text-xs sm:text-sm font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-[0.15em] mb-2">PANDUAN & TIPS</p>
      <h2 class="text-xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100">Paling Popular</h2>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
      {[
        { icon: '💰', title: 'Bajet 50/30/20', href: '/cadangan-bajet-50-30-20-di-malaysia/', desc: 'Cara bahagi gaji' },
        { icon: '🏦', title: 'Panduan KWSP', href: '/panduan-kwsp-malaysia-2025/', desc: 'Caruman & dividen' },
        { icon: '🟡', title: 'Beli Emas GAP', href: '/cara-beli-emas-public-gold/', desc: 'Panduan Public Gold' },
        { icon: '💸', title: 'Urus Gaji <RM3K', href: '/urus-duit-gaji-bawah-rm3000/', desc: 'Tips praktikal' },
        { icon: '🛡️', title: 'Medical Card', href: '/panduan-medical-card-malaysia-2026-first-time-buyer/', desc: 'Panduan first buyer' },
        { icon: '🎓', title: 'Gaji Graduan', href: '/gaji-graduan-mengikut-industri-2026/', desc: 'Ikut industri' },
        { icon: '🧾', title: 'E-Filing 2026', href: '/panduan-e-filing-cukai-pendapatan-2026/', desc: 'Cara isi cukai' },
        { icon: '📱', title: 'eWallet Terbaik', href: '/gxbank-vs-bigpay-vs-tng-ewallet-dompet-digital-terbaik-2026/', desc: 'GXBank vs BigPay' },
        { icon: '💰', title: 'Countdown Gaji', href: '/berapa-hari-lagi-nak-gaji/', desc: 'Hari ke gaji' },
        { icon: '🩺', title: 'Quiz Kewangan', href: '/quiz-kesihatan-kewangan/', desc: 'Skor kesihatan' },
      ].map(a => (
        <a href={a.href} class="rounded-xl bg-white dark:bg-slate-800/80 border border-gray-100 dark:border-slate-700/50 p-4 hover:border-blue-200 dark:hover:border-blue-800/50 hover:shadow-md transition-all hover:-translate-y-0.5 group">
          <span class="text-xl block mb-1.5">{a.icon}</span>
          <h3 class="text-xs sm:text-sm font-bold text-gray-900 dark:text-gray-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{a.title}</h3>
          <p class="text-[10px] sm:text-xs text-gray-500 dark:text-gray-400 mt-0.5">{a.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Blog Latest Posts -->
  <BlogLatestPosts
    title="Artikel Terkini"
    information="Baca panduan dan tips kewangan terkini untuk rakyat Malaysia."
  />
</Layout>
