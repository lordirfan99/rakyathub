---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Brands from '~/components/widgets/Brands.astro';

const metadata = {
  title: 'RakyatHub — Panduan Kewangan Rakyat Malaysia',
  ignoreTitleTemplate: true,
};

// Organization schema for SEO
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'RakyatHub',
  url: 'https://rakyathub.netlify.app',
  logo: 'https://rakyathub.netlify.app/_astro/favicon.vp_fBu0c.svg',
  description: 'Panduan kewangan, KWSP, ASB, emas, bantuan kerajaan dan pelaburan untuk rakyat Malaysia.',
  sameAs: ['https://rakyathub.netlify.app/blog/'],
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <!-- Hero — clean, like DocuKilat -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Teroka Kalkulator',
        href: '#kalkulator',
      },
      {
        variant: 'secondary',
        text: 'Baca Blog',
        href: '/blog/',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="hero-gradient"></div>
    </Fragment>
    <Fragment slot="title">
      RakyatHub — Panduan <span class="text-amber-300">Kewangan</span> Rakyat Malaysia
    </Fragment>

    <Fragment slot="subtitle">
        Panduan lengkap KWSP, ASB, emas, bantuan kerajaan dan pelaburan.
        Semua percuma, semua dalam Bahasa Malaysia.
    </Fragment>
  </Hero>

  <!-- Kalkulator Features — clean grid -->
  <Features
    id="kalkulator"
    tagline="Kalkulator Percuma"
    title="Alat Kewangan Untuk Rakyat Malaysia"
    subtitle="Guna kalkulator interaktif untuk kira simpanan KWSP, dividen ASB, harga emas, dan ansuran kereta."
    items={[
      {
        title: 'Kalkulator KWSP',
        description:
          'Kira caruman, pengeluaran fleksibel dan dividen KWSP. Simulasi simpanan persaraan anda.',
        icon: 'tabler:wallet',
        callToAction: {
          text: 'Kira Sekarang',
          href: '/kalkulator/kwsp',
          variant: 'primary',
        },
      },
      {
        title: 'Kalkulator ASB',
        description:
          'Kira dividen ASB, bonus dan simpanan automatik. Optimalkan pelaburan ASB loan anda.',
        icon: 'tabler:chart-bar',
        callToAction: {
          text: 'Kira Sekarang',
          href: '/kalkulator/asb',
          variant: 'primary',
        },
      },
      {
        title: 'Kalkulator Emas',
        description:
          'Semak harga emas harian, spread, dan beza harga Public Gold vs kedai emas.',
        icon: 'tabler:coins',
        callToAction: {
          text: 'Kira Sekarang',
          href: '/kalkulator/emas',
          variant: 'primary',
        },
      },
      {
        title: 'Kalkulator Kereta',
        description:
          'Kira ansuran bulanan kereta berdasarkan harga loan, kadar interest dan tempoh bayaran.',
        icon: 'tabler:car',
        callToAction: {
          text: 'Kira Sekarang',
          href: '/kalkulator/kereta',
          variant: 'primary',
        },
      },
    ]}
  />

  <!-- Blog Latest Posts -->
  <BlogLatestPosts
    title="Artikel Terkini"
    information="Baca panduan dan tips kewangan terkini untuk rakyat Malaysia."
  />

  <!-- Cross-sell: DocuKilat CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Bina Dokumen di DocuKilat',
        href: 'https://docukilat.netlify.app',
        icon: 'tabler:file-text',
      },
    ]}
  >
    <Fragment slot="title">
      Perlu Surat Rasmi, Invois atau Resume?
    </Fragment>

    <Fragment slot="subtitle">
      Gunakan DocuKilat — platform penjanaan dokumen AI dengan 26 template percuma. 
      Surat rasmi, invois premium, resume dan banyak lagi.
    </Fragment>
  </CallToAction>
</Layout>
