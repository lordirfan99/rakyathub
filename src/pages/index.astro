---
import Layout from '~/layouts/PageLayout.astro';

import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

// Static food price data for homepage widget (no JS loading)
const foodData = (await import('~/data/harga-makanan.json')).default;
const foodItems = (foodData.items || []).slice(0, 20);
const foodDate = foodData.latest_date || '';
const foodTotal = foodData.total_records || 0;
const foodCount = foodData.items_count || foodItems.length;
function getEmoji(n) {
  const u = (n||'').toUpperCase();
  const MAP = { AYAM:'🍗', DAGING:'🥩', IKAN:'🐟', TELUR:'🥚', BERAS:'🍚', MINYAK:'🫙', GULA:'🧂', TEPUNG:'🌾', CILI:'🌶️', BAWANG:'🧅', HALIA:'🫚', KACANG:'🥜', KUBIS:'🥬', LOBAK:'🥕', TIMUN:'🥒', SANTAN:'🥥' };
  for (const [k,v] of Object.entries(MAP)) if (u.includes(k)) return v;
  return '🛒';
}
function iconSVG(name) {
  const MAP = {
    calc: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z"/></svg>',
    cart: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/></svg>',
    fuel: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 7.5l10.5-4.5M12 6v13.5m9-7.5v5.25a2.25 2.25 0 01-2.25 2.25H5.25a2.25 2.25 0 01-2.25-2.25V11.25a2.25 2.25 0 012.25-2.25h13.5a2.25 2.25 0 012.25 2.25z"/></svg>',
    chart: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>',
    cash: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>',
    trend: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
    vote: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z"/></svg>',
    doc: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>',
    article: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z"/></svg>',
  };
  return MAP[name] || '';
}
function slugify(n) {
  return (n||'').toLowerCase().replace(/[^a-z0-9\s-]/g,'').replace(/\s+/g,'-').replace(/-+/g,'-').trim();
}
const foodWidget = foodItems.slice(0, 6);

const PILLARS = [
  { name: 'Kalkulator', href: '/kalkulator/', desc: '40+ alat kewangan percuma — KWSP, ASB, emas, kereta, loan rumah, zakat, BMI dan banyak lagi', icon: 'calc' },
  { name: 'Harga Barang Runcit', href: '/harga-makanan-hari-ini/', desc: 'Data KPDN PriceCatcher — harga harian ayam, ikan, sayur, telur & barangan asas', icon: 'cart' },
  { name: 'Harga Minyak Terkini', href: '/harga-minyak/', desc: 'RON95, RON97 & Diesel — kemaskini mingguan Kerajaan Malaysia', icon: 'fuel' },
  { name: 'Inflasi Malaysia', href: '/inflasi-malaysia/', desc: 'CPI terkini, kalkulator inflasi & kuasa beli ringgit dari 2010–2026', icon: 'chart' },
  { name: 'Bantuan Kerajaan', href: '/bantuan-kerajaan/', desc: 'STR, SARA, BUDI95, e-Tunai — RM8,000+ setahun bantuan tunai & subsidi', icon: 'cash' },
  { name: 'Gaji & Reality Check', href: '/reality-check/', desc: 'Banding gaji ikut negeri & sektor, percentile ranking, gaji ikut industri', icon: 'trend' },
  { name: 'Pilihan Raya', href: '/pilihan-raya/', desc: 'Keputusan PRU, PRN, profil wakil rakyat, data pengundi & kerusi', icon: 'vote' },
  { name: 'Blog & Panduan', href: '/blog/', desc: '500+ artikel — KWSP, kewangan, kerajaan, insurans, kesihatan, teknologi', icon: 'article' },
  { name: 'DocuKilat', href: 'https://docukilat.rakyathub.my', desc: 'Penjana dokumen AI — surat rasmi, invois, resume, perjanjian sewa & 26 template', icon: 'doc' },
];

const FEATURED = [
  { title: 'Panduan KWSP', href: '/panduan-kwsp-malaysia-2025/', desc: 'Caruman, dividen & pengeluaran' },
  { title: 'Bajet 50/30/20', href: '/cadangan-bajet-50-30-20-di-malaysia/', desc: 'Cara bahagi gaji bulanan' },
  { title: 'Pelepasan Cukai', href: '/pelepasan-cukai-malaysia-2026-panduan-lengkap-rebat-potongan/', desc: '25+ rebat & potongan' },
];

const metadata = {
  title: 'RakyatHub — Panduan Kewangan & Harga Makanan Malaysia',
  ignoreTitleTemplate: true,
  description:
    'Harga barang runcit harian (KPDN PriceCatcher), kalkulator percuma KWSP, ASB, cukai & pinjaman, data inflasi dan bantuan kerajaan untuk rakyat Malaysia.',
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'RakyatHub',
  url: 'https://rakyathub.my',
  logo: 'https://rakyathub.my/rakyathub-logo.png',
  description: 'Panduan kewangan, harga makanan, KWSP, ASB, emas, bantuan kerajaan dan pelaburan untuk rakyat Malaysia.',
  sameAs: ['https://rakyathub.my/blog/'],
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <!-- ════════════════════════════════════════════ -->
  <!-- 🇲🇾 HERO                                    -->
  <!-- ════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-white dark:bg-[#1a1a1a] border-b border-gray-100 dark:border-gray-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24 md:py-28">
      <div class="max-w-3xl">
        <p class="inline-flex items-center gap-2 text-xs font-semibold text-[#001F3F] dark:text-[#FFD700] uppercase tracking-[0.15em] mb-5 border border-[#001F3F]/10 dark:border-[#FFD700]/20 rounded-full px-4 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#001F3F] dark:bg-[#FFD700]"></span>
          Platform Kewangan Rakyat Malaysia
        </p>

        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.08] text-[#333] dark:text-[#F5F5F5]">
          Panduan&nbsp;<br class="sm:hidden" />
          <span class="text-[#001F3F] dark:text-[#FFD700]">Kewangan</span>
          & Harga Makanan
        </h1>

        <p class="text-base sm:text-lg text-[#666] dark:text-[#969696] max-w-2xl mt-5 leading-relaxed">
          Kalkulator percuma, harga barangan harian terkini, dan panduan kewangan untuk rakyat Malaysia.
          <span class="font-semibold text-[#333] dark:text-[#d2d2d2]">Semua dalam Bahasa Malaysia.</span>
        </p>

        <div class="flex flex-wrap items-center gap-3 mt-8">
          <a href="/kalkulator/"
             class="inline-flex items-center gap-2 px-7 sm:px-9 py-3.5 sm:py-4 rounded-lg bg-[#001F3F] hover:bg-[#002550] text-white text-sm sm:text-base font-bold transition-all hover:-translate-y-0.5">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z"/></svg>
            Semua Kalkulator
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>

        <div class="flex flex-wrap items-center gap-6 sm:gap-10 mt-10 pt-8 border-t border-gray-100 dark:border-gray-800">
          <div>
            <p class="text-2xl sm:text-3xl font-black text-[#001F3F] dark:text-[#FFD700] tabular-nums">{foodTotal.toLocaleString()}</p>
            <p class="text-xs sm:text-sm text-[#666] dark:text-[#969696]">Rekod Harga</p>
          </div>
          <div>
            <p class="text-2xl sm:text-3xl font-black text-[#001F3F] dark:text-[#FFD700] tabular-nums">{foodItems.length}</p>
            <p class="text-xs sm:text-sm text-[#666] dark:text-[#969696]">Barangan Dipantau</p>
          </div>
          <div>
            <p class="text-2xl sm:text-3xl font-black text-[#001F3F] dark:text-[#FFD700] tabular-nums">40+</p>
            <p class="text-xs sm:text-sm text-[#666] dark:text-[#969696]">Kalkulator Percuma</p>
          </div>
          <div>
            <p class="text-2xl sm:text-3xl font-black text-[#001F3F] dark:text-[#FFD700] tabular-nums">500+</p>
            <p class="text-xs sm:text-sm text-[#666] dark:text-[#969696]">Artikel & Panduan</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════ -->
  <!-- 🗺️ TEROKAI RAKYATHUB — Pillar grid          -->
  <!-- ════════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 -mt-6 relative z-10 pb-2">
    <div class="rounded-xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-[#2a2a2a] shadow-sm">
      <div class="px-5 sm:px-7 py-5 border-b border-gray-100 dark:border-gray-800">
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-lg bg-[#001F3F] dark:bg-[#FFD700] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-white dark:text-[#1a1a1a]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>
          </div>
          <div>
            <h2 class="text-base sm:text-lg font-bold text-[#333] dark:text-[#F5F5F5]">Terokai <span class="text-[#001F3F] dark:text-[#FFD700]">RakyatHub</span></h2>
            <p class="text-xs text-[#666] dark:text-[#969696]">Kalkulator, data & panduan untuk semua</p>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-gray-100 dark:bg-gray-800">
        {PILLARS.map((pillar) => (
          <a href={pillar.href}
             class="group flex items-start gap-4 px-5 sm:px-6 py-5 bg-white dark:bg-[#2a2a2a] hover:bg-[#001F3F]/[0.02] dark:hover:bg-white/[0.02] transition-colors"
          >
            <div class="w-11 h-11 rounded-lg bg-[#001F3F]/5 dark:bg-[#FFD700]/10 flex items-center justify-center shrink-0 text-[#001F3F] dark:text-[#FFD700]" set:html={iconSVG(pillar.icon)}></div>
            <div class="min-w-0 flex-1">
              <h3 class="text-sm sm:text-base font-bold text-[#333] dark:text-[#F5F5F5] group-hover:text-[#001F3F] dark:group-hover:text-[#FFD700] transition-colors">{pillar.name}</h3>
              <p class="text-xs text-[#666] dark:text-[#969696] mt-0.5 leading-relaxed">{pillar.desc}</p>
            </div>
            <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-[#001F3F] dark:group-hover:text-[#FFD700] transition-colors shrink-0 mt-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════ -->
  <!-- 🛒 HARGA MAKANAN                             -->
  <!-- ════════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pt-10 pb-2">
    <div class="rounded-xl border border-gray-100 dark:border-gray-800 overflow-hidden bg-white dark:bg-[#2a2a2a] shadow-sm">
      <div class="px-5 sm:px-7 py-4 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between">
        <div class="flex items-center gap-3 sm:gap-4">
          <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg bg-[#001F3F] dark:bg-[#FFD700] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white dark:text-[#1a1a1a]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"/></svg>
          </div>
          <div>
            <h2 class="text-base sm:text-xl font-bold text-[#333] dark:text-[#F5F5F5]">Harga Makanan Hari Ini</h2>
            <p class="text-xs sm:text-sm text-[#666] dark:text-[#969696]">Data terkini • KPDN PriceCatcher • <span class="font-semibold text-[#001F3F] dark:text-[#FFD700]">{foodDate}</span></p>
          </div>
          <span class="inline-flex items-center gap-1.5 text-[10px] sm:text-xs font-semibold text-[#001F3F] dark:text-[#FFD700] bg-[#001F3F]/5 dark:bg-[#FFD700]/10 border border-[#001F3F]/10 dark:border-[#FFD700]/20 px-2.5 py-1 rounded-full shrink-0">
            <span class="w-1.5 h-1.5 rounded-full bg-[#001F3F] dark:bg-[#FFD700]"></span>
            TERKINI
          </span>
        </div>
      </div>

      <div class="divide-y divide-gray-50 dark:divide-gray-800/60">
        {foodWidget.map((item, idx) => (
          <a href={`/harga-makanan/${slugify(item.name)}/`}
             class="flex items-center justify-between px-5 sm:px-7 py-3.5 sm:py-4 hover:bg-[#001F3F]/[0.02] dark:hover:bg-white/[0.02] transition-colors group"
          >
            <div class="flex items-center gap-3 sm:gap-4 min-w-0">
              <span class="text-lg w-7 text-center shrink-0 leading-none">{getEmoji(item.name||'')}</span>
              <div class="min-w-0">
                <p class="text-sm sm:text-base font-semibold text-[#333] dark:text-[#d2d2d2] group-hover:text-[#001F3F] dark:group-hover:text-[#FFD700] transition-colors truncate">{item.name}</p>
                <p class="text-[11px] text-[#969696] dark:text-[#969696] truncate">Kedai terdekat termurah</p>
              </div>
            </div>
            <div class="flex items-center gap-2 sm:gap-3 shrink-0">
              {item.change && item.change > 0.01 ? (
                <span class="hidden sm:inline-flex items-center gap-0.5 text-[11px] font-semibold text-[#CC0000] bg-[#CC0000]/5 dark:bg-[#FFD700]/10 px-2 py-0.5 rounded-full">▲ {item.change_pct.toFixed(1)}%</span>
              ) : item.change && item.change < -0.01 ? (
                <span class="hidden sm:inline-flex items-center gap-0.5 text-[11px] font-semibold text-[#2ECC40] bg-[#2ECC40]/5 dark:bg-[#2ECC40]/10 px-2 py-0.5 rounded-full">▼ {Math.abs(item.change_pct).toFixed(1)}%</span>
              ) : null}
              <span class="text-sm sm:text-lg font-bold text-[#001F3F] dark:text-[#FFD700] tabular-nums tracking-tight">RM{(item.price||0).toFixed(2)}</span>
              <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-[#001F3F] dark:group-hover:text-[#FFD700] transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
            </div>
          </a>
        ))}
      </div>

      <div class="px-5 sm:px-7 py-3 sm:py-4 bg-[#F5F5F5] dark:bg-white/[0.02] border-t border-gray-100 dark:border-gray-800 flex items-center justify-between flex-wrap gap-2">
        <div class="flex items-center gap-3 text-[11px] sm:text-xs text-[#666] dark:text-[#969696]">
          <span><span class="font-semibold text-[#001F3F] dark:text-[#FFD700]">{foodTotal.toLocaleString()}</span> rekod</span>
          <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
          <span><span class="font-semibold text-[#001F3F] dark:text-[#FFD700]">{foodCount}</span> barangan</span>
        </div>
        <a href="/harga-makanan-hari-ini/" class="inline-flex items-center gap-1 text-xs sm:text-sm font-semibold text-[#001F3F] dark:text-[#FFD700] hover:underline transition-colors">
          Semua Harga & Termurah
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════ -->
  <!-- 📰 ARTIKEL PILIHAN — 3 evergreen             -->
  <!-- ════════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-10 md:py-14">
    <div class="text-center mb-8">
      <p class="inline-flex items-center gap-2 text-xs font-semibold text-[#001F3F] dark:text-[#FFD700] uppercase tracking-[0.15em] mb-3">
        <span class="w-1.5 h-1.5 rounded-full bg-[#001F3F] dark:bg-[#FFD700]"></span>
        ARTIKEL PILIHAN
      </p>
      <h2 class="text-xl sm:text-3xl font-bold text-[#333] dark:text-[#F5F5F5]">Panduan & Tips Kewangan</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
      {FEATURED.map((art) => (
        <a href={art.href}
           class="group block rounded-xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-[#2a2a2a] p-6 sm:p-8 hover:shadow-md hover:border-[#001F3F]/20 dark:hover:border-[#FFD700]/20 transition-all duration-250"
        >
          <h3 class="text-base sm:text-xl font-bold text-[#333] dark:text-[#F5F5F5] group-hover:text-[#001F3F] dark:group-hover:text-[#FFD700] transition-colors leading-snug">{art.title}</h3>
          <p class="text-sm text-[#666] dark:text-[#969696] mt-2 leading-relaxed">{art.desc}</p>
        </a>
      ))}
    </div>
    <div class="text-center mt-8">
      <a href="/blog"
         class="inline-flex items-center gap-1 text-sm font-semibold text-[#001F3F] dark:text-[#FFD700] hover:underline transition-colors">
        Semua Artikel & Blog
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </section>

  <!-- ════════════════════════════════════════════ -->
  <!-- 🚀 DocuKilat CTA                             -->
  <!-- ════════════════════════════════════════════ -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-6 md:pb-10">
    <div class="rounded-xl border border-gray-100 dark:border-gray-800 bg-[#F5F5F5] dark:bg-[#2a2a2a] p-8 sm:p-12 text-center">
      <p class="inline-flex items-center gap-2 text-xs font-semibold text-[#001F3F] dark:text-[#FFD700] uppercase tracking-[0.15em] mb-3">
        <span class="w-1.5 h-1.5 rounded-full bg-[#001F3F] dark:bg-[#FFD700]"></span>
        PRODUK RAKYATHUB
      </p>
      <h2 class="text-xl sm:text-3xl font-bold text-[#333] dark:text-[#F5F5F5] mb-3">Perlu Surat Rasmi, Invois atau Resume?</h2>
      <p class="text-sm sm:text-base text-[#666] dark:text-[#969696] max-w-xl mx-auto mb-6">
        Gunakan DocuKilat — platform penjanaan dokumen AI dengan 26 template percuma.
      </p>
      <a href="https://docukilat.rakyathub.my"
         class="inline-flex items-center gap-2.5 px-8 py-3.5 rounded-lg bg-[#001F3F] hover:bg-[#002550] text-white text-sm font-bold transition-all hover:-translate-y-0.5">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
        Bina Dokumen di DocuKilat
