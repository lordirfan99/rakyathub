---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Stats from '~/components/widgets/Stats.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Brands from '~/components/widgets/Brands.astro';

const metadata = {
  title: 'RakyatHub — Panduan Kewangan Rakyat Malaysia',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Teroka Kalkulator',
        href: '#kalkulator',
      },
      { text: 'Baca Blog', href: '/blog/' },
    ]}
  >
    <Fragment slot="bg">
      <div class="hero-gradient"></div>
      <div class="hero-orb"></div>
      <div class="hero-orb"></div>
      <div class="hero-orb"></div>
    </Fragment>
    <Fragment slot="title">
      <span class="text-accent dark:text-amber-400"> RakyatHub</span> — Jawapan Kepada Soalan Kewangan Anda
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        Panduan lengkap tentang <span class="font-semibold">KWSP, ASB, emas, bantuan kerajaan</span> dan
        pelaburan untuk rakyat Malaysia.
      </span>
      <span class="block mb-1 sm:hidden font-bold text-amber-500">Kewangan. Pelaburan. Kerajaan.</span>
      Kami bantu anda buat keputusan kewangan yang lebih bijak.
    </Fragment>
  </Hero>

  <!-- Kalkulator Features Widget ******* -->
  <Features
    id="kalkulator"
    tagline="Kalkulator Percuma"
    title="Alat Kewangan Untuk Rakyat Malaysia"
    subtitle="Guna kalkulator interaktif kami untuk kira simpanan KWSP, dividen ASB, harga emas, dan ansuran kereta dengan pantas."
    items={[
      {
        title: 'Kalkulator KWSP',
        description:
          'Kira caruman, pengeluaran fleksibel dan dividen KWSP. Simulasi simpanan persaraan anda.',
        icon: 'tabler:wallet',
        callToAction: {
          text: 'Kira Sekarang',
          href: '/kalkulator/kwsp',
          variant: 'primary',
        },
      },
      {
        title: 'Kalkulator ASB',
        description:
          'Kira dividen ASB, bonus dan simpanan automatik. Optimalkan pelaburan ASB loan anda.',
        icon: 'tabler:chart-bar',
        callToAction: {
          text: 'Kira Sekarang',
          href: '/kalkulator/asb',
          variant: 'primary',
        },
      },
      {
        title: 'Kalkulator Emas',
        description:
          'Semak harga emas harian, spread, dan beza harga Public Gold vs kedai emas di Malaysia.',
        icon: 'tabler:coins',
        callToAction: {
          text: 'Kira Sekarang',
          href: '/kalkulator/emas',
          variant: 'primary',
        },
      },
      {
        title: 'Kalkulator Kereta',
        description:
          'Kira ansuran bulanan kereta berdasarkan harga loan, kadar interest dan tempoh bayaran.',
        icon: 'tabler:car',
        callToAction: {
          text: 'Kira Sekarang',
          href: '/kalkulator/kereta',
          variant: 'primary',
        },
      },
    ]}
  />

  <!-- Content Widget Why RakyatHub -->
  <Content
    isReversed
    tagline="Kenapa RakyatHub?"
    title="Kewangan Anda, Dipermudahkan"
    items={[
      {
        title: 'Informasi Terkini',
        description:
          'Kami sentiasa mengemas kini maklumat tentang dasar kerajaan, bantuan kewangan, dan peluang pelaburan yang relevan untuk rakyat Malaysia.',
      },
      {
        title: 'Kalkulator Interaktif',
        description:
          'Alat kiraan pantas untuk KWSP, ASB, emas dan kereta — semuanya percuma tanpa perlu daftar.',
      },
      {
        title: '100% Bahasa Malaysia',
        description:
          'Semua kandungan ditulis dalam Bahasa Malaysia yang mudah difahami, tanpa jargon yang mengelirukan.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Platform kewangan untuk semua rakyat Malaysia</h3>
      Kami percaya ilmu kewangan patut diakses oleh semua orang — secara percuma.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gradient-to-br from-amber-50/50 to-emerald-50/50 dark:from-transparent dark:to-transparent"></div>
    </Fragment>
  </Content>

  <!-- Blog Latest Posts -->
  <BlogLatestPosts
    title="Artikel Terkini"
    information="Baca panduan dan tips kewangan terkini untuk rakyat Malaysia."
  />

  <!-- Stats Widget ****************** -->
  <Stats
    tagline="Statistik"
    title="RakyatHub Dalam Angka"
    stats={[
      { title: 'Kalkulator', amount: '4+' },
      { title: 'Artikel', amount: '22+' },
      { title: 'Pengunjung', amount: '1K+' },
      { title: 'Alat Dokumen', amount: '33+' },
    ]}
  />

  <!-- CallToAction Widget *********** -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Langgan Percuma',
        href: '#',
        icon: 'tabler:bell',
      },
    ]}
  >
    <Fragment slot="title">
      Nak Tips Kewangan Terus ke<br class="block sm:hidden" /> E-mel Anda?
    </Fragment>

    <Fragment slot="subtitle">
      Dapatkan notifikasi tentang artikel baru, kemas kini bantuan kerajaan, dan tips pelaburan. <br class="hidden md:inline" />Percuma, tak ada spam.
    </Fragment>
  </CallToAction>
</Layout>
