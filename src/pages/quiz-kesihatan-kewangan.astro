---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Quiz Kesihatan Kewangan — Semak Skor Kewangan Anda',
  description: 'Jawab 8 soalan ringkas dan dapatkan skor kesihatan kewangan peribadi. Kongsikan keputusan dengan rakan di WhatsApp!',
};

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Quiz Kesihatan Kewangan Malaysia',
  url: 'https://rakyathub.my/quiz-kesihatan-kewangan/',
  description: 'Interactive financial health quiz for Malaysians',
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'All',
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/kalkulator/" class="text-sm text-muted hover:text-primary transition-colors">← Semua Kalkulator</a>
    </div>

    <div class="text-center mb-10">
      <div class="text-5xl md:text-7xl mb-4">🩺</div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">
        Quiz Kesihatan <span class="text-primary">Kewangan</span>
      </h1>
      <p class="text-lg md:text-xl text-muted max-w-2xl mx-auto">
        Jawab <strong>8 soalan ringkas</strong> dan dapatkan skor kesihatan kewangan peribadi. 
        Kongsikan keputusan dengan rakan di WhatsApp!
      </p>
    </div>

    <!-- Quiz Card -->
    <div id="quizContainer" class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-6 md:p-10 mb-8">
      
      <!-- Question area -->
      <div id="questionArea">
        <div class="flex items-center justify-between mb-6">
          <span class="text-sm font-medium text-primary bg-primary/10 px-3 py-1 rounded-full" id="qProgress">Soalan 1/8</span>
          <span class="text-sm text-muted" id="qCategory">💳 Simpanan</span>
        </div>
        
        <h2 class="text-xl md:text-2xl font-bold mb-6" id="qText">Loading...</h2>
        
        <div class="space-y-3" id="qOptions"></div>

        <div class="flex justify-between mt-8">
          <button id="prevBtn" class="px-5 py-2.5 rounded-xl bg-gray-200 dark:bg-slate-700 text-muted font-medium text-sm hover:bg-gray-300 dark:hover:bg-slate-600 transition disabled:opacity-30" disabled>← Sebelum</button>
          <button id="nextBtn" class="px-6 py-2.5 rounded-xl bg-gradient-to-r from-primary to-secondary text-white font-semibold text-sm hover:shadow-lg hover:shadow-primary/30 transition-all hover:scale-[1.02] active:scale-95">Seterusnya →</button>
        </div>
      </div>

      <!-- Result area (hidden initially) -->
      <div id="resultArea" class="hidden">
        <div class="text-center">
          <div class="text-6xl mb-4" id="resultEmoji">💪</div>
          <h2 class="text-2xl md:text-3xl font-bold mb-2" id="resultTitle">Skor Kesihatan Kewangan Anda</h2>
          <div class="inline-flex items-center justify-center w-32 h-32 rounded-full border-4 border-primary mb-4">
            <span class="text-4xl font-black text-primary" id="resultScore">0</span>
          </div>
          <p class="text-muted mb-2">daripada <strong>100</strong></p>
          <p class="text-lg font-semibold mb-2" id="resultGrade">C — Sederhana</p>
          <p class="text-muted text-sm max-w-lg mx-auto mb-6" id="resultDesc">Ada ruang untuk perbaiki kewangan anda.</p>
        </div>

        <!-- Breakdown -->
        <div class="grid md:grid-cols-4 gap-3 mb-8" id="breakdownCards"></div>

        <!-- Recommendations -->
        <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6 md:p-8 mb-6">
          <h3 class="text-xl font-bold mb-4">📌 Cadangan Ikut Skor Anda</h3>
          <div id="resultRecommendations" class="space-y-2 text-sm text-muted"></div>
        </div>

        <!-- Share -->
        <div class="text-center mb-6">
          <h4 class="font-semibold mb-3">Kongsikan Keputusan</h4>
          <div class="flex flex-wrap justify-center gap-3">
            <a id="shareResultWA" href="#" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-green-600 hover:bg-green-700 text-white font-medium text-sm transition-all hover:scale-[1.02]">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Share WhatsApp
            </a>
            <a id="shareResultTG" href="#" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-sky-500 hover:bg-sky-600 text-white font-medium text-sm transition-all hover:scale-[1.02]">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
              Share Telegram
            </a>
            <button onclick="retakeQuiz()"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gray-600 hover:bg-gray-700 text-white font-medium text-sm transition-all hover:scale-[1.02] active:scale-95">
              🔄 Ambil Semula
            </button>
          </div>
        </div>

        <!-- Related links -->
        <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6">
          <h3 class="text-xl font-bold mb-4">📚 Tips Ikut Skor Anda</h3>
          <ul class="space-y-2 text-sm" id="resultLinks">
            <li><a href="/kalkulator/gaji-bersih/" class="text-primary font-medium hover:underline">→ Kira Gaji Bersih</a></li>
            <li><a href="/cadangan-bajet-50-30-20-di-malaysia/" class="text-primary font-medium hover:underline">→ Panduan Bajet 50/30/20</a></li>
            <li><a href="/panduan-kwsp-malaysia-2025/" class="text-primary font-medium hover:underline">→ Panduan KWSP Lengkap</a></li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Kira Gaji Bersih', href: '/kalkulator/gaji-bersih/' },
      { variant: 'secondary', text: 'Semua Kalkulator', href: '/kalkulator/' },
    ]}
  >
    <Fragment slot="title">Nak Kira Gaji Bersih atau KWSP?</Fragment>
    <Fragment slot="subtitle">Semua kalkulator percuma — tak perlu daftar. Guna sekarang.</Fragment>
  </CallToAction>

  <script is:inline>
var questions = [
  {
    id: 'emergency',
    text: 'Berapa bulan perbelanjaan hidup yang korang ada dalam simpanan kecemasan?',
    category: '💳 Simpanan',
    options: [
      { text: 'Tak ada langsung', score: 0 },
      { text: 'Kurang 1 bulan', score: 1 },
      { text: '1-3 bulan', score: 2 },
      { text: '3-6 bulan', score: 3 },
      { text: '6 bulan atau lebih', score: 4 },
    ],
  },
  {
    id: 'budget',
    text: 'Adakah korang guna bajet bulanan untuk urus perbelanjaan?',
    category: '📊 Bajet',
    options: [
      { text: 'Tak pernah buat bajet', score: 0 },
      { text: 'Kadang-kadang je', score: 1 },
      { text: 'Ada bajet tapi tak ikut', score: 2 },
      { text: 'Ada bajet dan ikut kebanyakan', score: 3 },
      { text: 'Ada bajet dan track setiap sen', score: 4 },
    ],
  },
  {
    id: 'debt',
    text: 'Berapa banyak komitmen hutang korang setiap bulan (% dari gaji)?',
    category: '🏦 Hutang',
    options: [
      { text: '40% ke atas — sangat tinggi', score: 0 },
      { text: '30-40% — agak tinggi', score: 1 },
      { text: '20-30% — sederhana', score: 2 },
      { text: '10-20% — rendah', score: 3 },
      { text: 'Kurang 10% atau tiada hutang', score: 4 },
    ],
  },
  {
    id: 'insurance',
    text: 'Adakah korang ada perlindungan insurans atau takaful?',
    category: '🛡️ Insurans',
    options: [
      { text: 'Tiada langsung', score: 0 },
      { text: 'Ada medical card dari majikan je', score: 1 },
      { text: 'Ada medical card sendiri', score: 2 },
      { text: 'Ada medical card + insurans hayat', score: 3 },
      { text: 'Ada perlindungan lengkap (hayat, kritikal, medical)', score: 4 },
    ],
  },
  {
    id: 'investment',
    text: 'Berapa peratus gaji korang labur atau simpan setiap bulan?',
    category: '📈 Pelaburan',
    options: [
      { text: '0% — tak simpan langsung', score: 0 },
      { text: 'Kurang 5%', score: 1 },
      { text: '5-10%', score: 2 },
      { text: '10-20%', score: 3 },
      { text: '20% ke atas', score: 4 },
    ],
  },
  {
    id: 'kwsp',
    text: 'Adakah korang buat caruman KWSP tambahan atau cuma caruman wajib?',
    category: '🏦 Persaraan',
    options: [
      { text: 'Tak tahu pasal KWSP', score: 0 },
      { text: 'Cuma caruman wajib 11%', score: 1 },
      { text: 'Pernah topup sekali-sekala', score: 2 },
      { text: 'Caruman wajib + simpanan persaraan lain', score: 3 },
      { text: 'Caruman tambahan konsisten + pelbagai account', score: 4 },
    ],
  },
  {
    id: 'bill',
    text: 'Berapa kerap korang lambat bayar bil atau komitmen?',
    category: '📅 Disiplin',
    options: [
      { text: 'Setiap bulan ada je tertunggak', score: 0 },
      { text: 'Kerap lambat beberapa hari', score: 1 },
      { text: 'Kadang-kadang je lupa', score: 2 },
      { text: 'Jarang lambat — auto-debit kebanyakan', score: 3 },
      { text: 'Tak pernah lambat — semua auto-debit/scheduled', score: 4 },
    ],
  },
  {
    id: 'goal',
    text: 'Adakah korang ada matlamat kewangan yang jelas?',
    category: '🎯 Matlamat',
    options: [
      { text: 'Tak ada langsung', score: 0 },
      { text: 'Ada fikiran tapi tak tertulis', score: 1 },
      { text: 'Ada 1-2 matlamat umum', score: 2 },
      { text: 'Ada matlamat khusus dengan tarikh', score: 3 },
      { text: 'Ada pelan kewangan bertulis + track progress', score: 4 },
    ],
  },
];

var currentQ = 0;
var answers = new Array(questions.length).fill(-1);

function renderQuestion() {
  var q = questions[currentQ];
  document.getElementById('qProgress').textContent = 'Soalan ' + (currentQ + 1) + '/' + questions.length;
  document.getElementById('qCategory').textContent = q.category;
  document.getElementById('qText').textContent = q.text;
  
  var opts = document.getElementById('qOptions');
  opts.innerHTML = '';
  
  q.options.forEach(function(opt, i) {
    var label = document.createElement('label');
    label.className = 'flex items-start gap-3 p-4 rounded-xl border border-gray-200 dark:border-slate-700 cursor-pointer transition-all hover:border-primary/50 hover:bg-primary/[0.02] ' + (answers[currentQ] === i ? 'border-primary bg-primary/5 ring-2 ring-primary/20' : '');
    
    var radio = document.createElement('input');
    radio.type = 'radio';
    radio.name = 'q' + currentQ;
    radio.value = i;
    radio.className = 'mt-0.5';
    if (answers[currentQ] === i) radio.checked = true;
    
    radio.addEventListener('change', function() {
      answers[currentQ] = parseInt(this.value);
      uncheckOthers(currentQ);
      renderQuestion();
    });
    
    var span = document.createElement('span');
    span.className = 'text-sm text-default';
    span.textContent = opt.text;
    
    label.appendChild(radio);
    label.appendChild(span);
    opts.appendChild(label);
  });
  
  // Navigation
  document.getElementById('prevBtn').disabled = currentQ === 0;
  var nextBtn = document.getElementById('nextBtn');
  if (currentQ === questions.length - 1) {
    if (answers[currentQ] >= 0) {
      nextBtn.textContent = '🎉 Lihat Keputusan';
      nextBtn.onclick = showResult;
    } else {
      nextBtn.textContent = 'Seterusnya →';
      nextBtn.onclick = function() {};
    }
  } else {
    nextBtn.textContent = answers[currentQ] >= 0 ? 'Seterusnya →' : 'Seterusnya →';
    nextBtn.onclick = function() {
      if (answers[currentQ] < 0) {
        alert('Sila pilih jawapan dahulu.');
        return;
      }
      currentQ++;
      renderQuestion();
    };
  }
}

function uncheckOthers(idx) {
  var radios = document.querySelectorAll('input[name="q' + idx + '"]');
  radios.forEach(function(r) { if (!r.checked) {} });
}

document.getElementById('prevBtn').addEventListener('click', function() {
  if (currentQ > 0) { currentQ--; renderQuestion(); }
});

function showResult() {
  // Check all answered
  var unanswered = answers.indexOf(-1);
  if (unanswered >= 0) {
    currentQ = unanswered;
    renderQuestion();
    return;
  }
  
  var total = answers.reduce(function(a,b){return a+b;}, 0);
  var maxScore = questions.length * 4;
  var pct = Math.round((total / maxScore) * 100);
  
  document.getElementById('questionArea').classList.add('hidden');
  document.getElementById('resultArea').classList.remove('hidden');
  
  // Score
  document.getElementById('resultScore').textContent = pct;
  
  // Grade
  var grade, emoji, desc, recs, links;
  if (pct >= 85) {
    grade = 'A — Cemerlang! 🏆';
    emoji = '🏆';
    desc = 'Tahniah! Kewangan korang dalam keadaan sangat sihat. Teruskan usaha dan bantu rakan-rakan yang lain.';
    recs = ['Tingkatkan pelaburan untuk pulangan lebih tinggi', 'Pertimbangkan diversifikasi aset (emas, saham, hartanah)', 'Bantu keluarga dan rakan dengan ilmu kewangan'];
    links = [{t:'Pelaburan Emas vs ASB vs FD',h:'/kalkulator/pelaburan/'},{t:'Cara Mula Melabur Saham',h:'/cara-mula-melabur-saham-bursa-malaysia-panduan-pemula-2026/'},{t:'Panduan Perancangan Persaraan',h:'/panduan-kwsp-malaysia-2025/'}];
  } else if (pct >= 65) {
    grade = 'B — Baik 👍';
    emoji = '👍';
    desc = 'Kewangan korang dalam keadaan baik, tapi masih ada ruang untuk improve. Fokus pada emergency fund dan pelaburan.';
    recs = ['Tambah emergency fund ke 6 bulan perbelanjaan', 'Mula atau tingkatkan pelaburan bulanan', 'Semak coverage insurans — cukup ke?'];
    links = [{t:'Kalkulator Gaji Bersih',h:'/kalkulator/gaji-bersih/'},{t:'Panduan Medical Card 2026',h:'/panduan-medical-card-malaysia-2026-first-time-buyer/'},{t:'Cara Simpan Duit RM2,500',h:'/cara-simpan-duit-gaji-rm2500/'}];
  } else if (pct >= 45) {
    grade = 'C — Sederhana 📊';
    emoji = '📊';
    desc = 'Kewangan korang perlukan perhatian. Mula dengan asas — buat bajet, kurangkan hutang, dan bina emergency fund.';
    recs = ['Buat bajet bulanan guna formula 50/30/20', 'Targetkan emergency fund minimum 1 bulan dulu', 'Kurangkan hutang — cuba DSR bawah 30%'];
    links = [{t:'Bajet 50/30/20 Panduan',h:'/cadangan-bajet-50-30-20-di-malaysia/'},{t:'Kalkulator DSR Pinjaman',h:'/kalkulator/dsr/'},{t:'Urus Gaji Bawah RM3,000',h:'/urus-duit-gaji-bawah-rm3000/'}];
  } else {
    grade = 'D — Perlu Tindakan Segera ⚠️';
    emoji = '⚠️';
    desc = 'Kewangan korang dalam zon bahaya. Jangan risau — ramai orang mula dari sini. Ikut langkah asas dan korang akan nampak perubahan.';
    recs = ['HENTIKAN hutang baru — fokus bayar hutang sedia ada', 'Buat bajet paling basic — senarai pendapatan vs perbelanjaan', 'Target simpan RM50-100 sebulan untuk emergency fund dulu'];
    links = [{t:'Urus Gaji Bawah RM3,000',h:'/urus-duit-gaji-bawah-rm3000/'},{t:'Kalkulator DSR',h:'/kalkulator/dsr/'},{t:'Cara Simpan Duit Gaji RM2,500',h:'/cara-simpan-duit-gaji-rm2500/'},{t:'Panduan Elak Scam Pinjaman',h:'/cara-elak-scam-pinjaman-online-panduan-lengkap-tips-selamat/'}];
  }
  
  document.getElementById('resultEmoji').textContent = emoji;
  document.getElementById('resultGrade').textContent = grade;
  document.getElementById('resultDesc').textContent = desc;
  
  // Breakdown
  var cats = ['💳 Simpanan','📊 Bajet','🏦 Hutang','🛡️ Insurans','📈 Pelaburan','🏦 Persaraan','📅 Disiplin','🎯 Matlamat'];
  var bd = document.getElementById('breakdownCards');
  bd.innerHTML = '';
  answers.forEach(function(a, i) {
    var card = document.createElement('div');
    card.className = 'rounded-xl p-4 text-center border ' + (a >= 3 ? 'bg-emerald-50 dark:bg-emerald-900/20 border-emerald-200 dark:border-emerald-800' : a >= 2 ? 'bg-amber-50 dark:bg-amber-900/20 border-amber-200 dark:border-amber-800' : 'bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-800');
    card.innerHTML = '<div class="text-lg mb-1">' + cats[i] + '</div><div class="font-bold text-sm">' + a + '/4</div>';
    bd.appendChild(card);
  });
  
  // Recommendations
  var recDiv = document.getElementById('resultRecommendations');
  recDiv.innerHTML = '';
  recs.forEach(function(r) {
    var p = document.createElement('p');
    p.className = 'flex items-start gap-2';
    p.innerHTML = '<span class="text-primary mt-0.5">•</span> ' + r;
    recDiv.appendChild(p);
  });
  
  // Links
  var linkDiv = document.getElementById('resultLinks');
  linkDiv.innerHTML = '';
  links.forEach(function(l) {
    var li = document.createElement('li');
    li.innerHTML = '<a href="' + l.h + '/" class="text-primary font-medium hover:underline text-sm">→ ' + l.t + '</a>';
    linkDiv.appendChild(li);
  });
  
  // Share links
  var shareMsg = '🩺 Skor Kesihatan Kewangan Saya: ' + pct + '/100 (' + grade.split(' — ')[0] + ')\n\nCuba quiz ni — https://rakyathub.my/quiz-kesihatan-kewangan/';
  document.getElementById('shareResultWA').href = 'https://wa.me/?text=' + encodeURIComponent(shareMsg);
  document.getElementById('shareResultTG').href = 'https://t.me/share/url?url=' + encodeURIComponent('https://rakyathub.my/quiz-kesihatan-kewangan/') + '&text=' + encodeURIComponent('🩺 Skor Kesihatan Kewangan Saya: ' + pct + '/100. Cuba!');
  
  // Scroll to top
  window.scrollTo({top: 0, behavior: 'smooth'});
}

function retakeQuiz() {
  answers = new Array(questions.length).fill(-1);
  currentQ = 0;
  document.getElementById('questionArea').classList.remove('hidden');
  document.getElementById('resultArea').classList.add('hidden');
  renderQuestion();
  window.scrollTo({top: 0, behavior: 'smooth'});
}

renderQuestion();
</script>
</Layout>
