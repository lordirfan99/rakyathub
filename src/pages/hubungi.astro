---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Hubungi Kami',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">Hubungi Kami</h1>
    <p class="text-xl text-muted mb-12">
      Ada soalan, cadangan, atau nak bekerjasama? Jom hubungi kami.
    </p>
    <div class="grid md:grid-cols-2 gap-8">
      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-amber-100 dark:bg-amber-900/30 rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">E-mel</h3>
            <p class="text-muted">hello@rakyathub.com</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-amber-100 dark:bg-amber-900/30 rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Alamat</h3>
            <p class="text-muted">Semenyih, Selangor<br/>Malaysia</p>
          </div>
        </div>
      </div>
      <div class="bg-gray-50 dark:bg-slate-800/50 rounded-2xl p-6">
        <form netlify name="contact" method="POST" class="space-y-4">
          <input type="hidden" name="form-name" value="contact" />
          <div>
            <label class="block text-sm font-medium mb-1">Nama</label>
            <input type="text" name="name" required class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-700 focus:ring-2 focus:ring-amber-500 focus:border-transparent outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">E-mel</label>
            <input type="email" name="email" required class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-700 focus:ring-2 focus:ring-amber-500 focus:border-transparent outline-none" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Mesej</label>
            <textarea name="message" rows="4" required class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-700 focus:ring-2 focus:ring-amber-500 focus:border-transparent outline-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2.5 px-6 rounded-lg transition-colors">Hantar Mesej</button>
        </form>
      </div>
    </div>
  </section>
</Layout>
