        { icon: '📺', title: '1080p HD', desc: 'Streaming lancar 30FPS. Zero buffer, zero pening.' },
        { icon: '💰', title: 'RM20 Sahaja', desc: 'Seluruh kejohanan. Lagi murah dari daily pass lain.' },
