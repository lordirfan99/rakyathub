---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Pesta Bola 2026 — Streaming HD & Komuniti Online Malaysia',
  description: 'Tonton kejohanan bola sepak antarabangsa 2026 secara online. 1080p HD, free trial, full access RM20. Streaming lancar, sorak sama-sama komuniti!',
};
---

<Layout metadata={metadata}>

<style>
  .hero-glow-1 { background: radial-gradient(600px circle at 20% 30%, rgba(99,102,241,0.15), transparent 70%); }
  .hero-glow-2 { background: radial-gradient(500px circle at 80% 70%, rgba(251,191,36,0.10), transparent 70%); }
  .hero-glow-3 { background: radial-gradient(400px circle at 50% 50%, rgba(16,185,129,0.08), transparent 70%); }
  .feature-card {
    border: 1px solid rgba(255,255,255,0.06);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .feature-card:hover {
    border-color: rgba(99,102,241,0.3);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(99,102,241,0.15);
  }
  .pricing-card {
    border: 1px solid rgba(255,255,255,0.08);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .pricing-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 80px rgba(99,102,241,0.2);
  }
  .pricing-featured {
    border: 2px solid rgba(99,102,241,0.4);
    background: linear-gradient(180deg, rgba(99,102,241,0.08) 0%, transparent 100%);
  }
  .stat-card {
    border: 1px solid rgba(255,255,255,0.05);
    backdrop-filter: blur(8px);
  }
  .glass-card {
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.06);
  }
  details.faq-item summary::-webkit-details-marker { display: none; }
  .cta-pulse { position: relative; }
  .cta-pulse::before {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 16px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6, #6366f1);
    background-size: 200% 200%;
    animation: shimmer 3s ease-in-out infinite;
    z-index: -1;
    opacity: 0.5;
  }
  @keyframes shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
</style>

<!-- ===== HERO ===== -->
<section class="relative overflow-hidden min-h-screen flex items-center">
  <div class="absolute inset-0 bg-gradient-to-br from-[#0a0f1e] via-[#0f172a] to-[#0a0f1e]" />
  <div class="absolute inset-0 hero-glow-1 hero-glow-2 hero-glow-3" />

  <div class="relative z-10 w-full max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-24">

    <div class="flex items-center justify-center gap-2 mb-8">
      <div class="w-8 h-8 bg-gradient-to-br from-[#6366f1] to-[#8b5cf6] rounded-lg flex items-center justify-center">
        <span class="text-white font-bold text-sm">R</span>
      </div>
      <span class="text-slate-400 text-sm font-medium tracking-wider uppercase">RakyatHub • Official Partner</span>
    </div>

    <div class="text-center mb-6">
      <span class="inline-flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/20 rounded-full px-5 py-1.5">
        <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse" />
        <span class="text-emerald-300 text-sm font-semibold tracking-wide">Jun — Julai 2026</span>
      </span>
    </div>

    <div class="text-center mb-6">
      <h1 class="text-5xl sm:text-6xl md:text-8xl font-black tracking-tight text-white leading-[1.1] mb-4">
        Pesta Bola
        <br />
        <span class="bg-gradient-to-r from-[#f59e0b] via-[#f97316] to-[#ef4444] bg-clip-text text-transparent">
          2026
        </span>
      </h1>
      <p class="text-xl sm:text-2xl md:text-3xl text-slate-300 font-light">
        Tonton Semua Perlawanan — <span class="text-white font-semibold">1080p HD, Zero Buffer</span>
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-4 sm:gap-6 mb-10">
      {[
        { label: 'Pasukan Bertanding', value: '48' },
        { label: 'Perlawanan', value: '104+' },
        { label: 'Negara Tuan Rumah', value: '3' },
        { label: 'Harga', value: 'RM20' },
      ].map((stat) => (
        <div class="stat-card bg-white/5 rounded-2xl px-6 py-4 text-center min-w-[120px]">
          <div class="text-2xl sm:text-3xl font-bold text-white">{stat.value}</div>
          <div class="text-xs sm:text-sm text-slate-400 mt-1">{stat.label}</div>
        </div>
      ))}
    </div>

    <p class="text-base sm:text-lg text-slate-400 max-w-2xl mx-auto text-center mb-10 leading-relaxed">
      Kejohanan bola sepak terbesar dunia kembali dengan <strong class="text-white">48 pasukan</strong> dari seluruh pelusuk dunia bertanding di 
      <strong class="text-white">3 negara</strong> — Amerika Syarikat, Kanada & Mexico. 
      Jangan ketinggalan walau satu perlawanan. Streaming lancar, kualiti premium, 
      harga berpatutan.
    </p>

    <div class="text-center mb-16">
      <a
        href="https://s.shopee.com.my/Lkj8tCGZ2"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-pulse inline-flex items-center gap-3 bg-gradient-to-r from-[#6366f1] to-[#8b5cf6] text-white text-lg sm:text-xl font-bold px-10 py-5 rounded-2xl shadow-2xl shadow-indigo-500/25 hover:shadow-indigo-500/40 transition-all duration-300 hover:scale-[1.03] active:scale-95"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Dapatkan Akses Penuh — RM20 Sahaja
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
      <p class="text-slate-500 text-sm mt-3">✅ Bayar Selepasi Puas Hati • Free Trial 1 Minggu</p>
    </div>

    <a
      href="https://s.shopee.com.my/Lkj8tCGZ2"
      target="_blank"
      rel="noopener noreferrer"
      class="block max-w-3xl mx-auto rounded-2xl overflow-hidden shadow-2xl hover:shadow-indigo-500/10 transition-all duration-500 hover:scale-[1.01] mb-8"
    >
      <img
        src="/images/cta-klik-diskon.jpg"
        alt="KLIK UNTUK DAPATKAN AKSES STREAMING"
        class="w-full"
        width="1280"
        height="698"
        loading="eager"
      />
    </a>

  </div>
</section>

<!-- ===== KENAPA PILIH KAMI ===== -->
