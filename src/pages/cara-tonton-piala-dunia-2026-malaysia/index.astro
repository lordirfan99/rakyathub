        { icon: '🛡️', title: 'Trusted Seller', desc: 'Beli dekat Shopee — rating tinggi, buyer puas hati.' },
      ].map((item) => (
        <div class="feature-card glass-card rounded-2xl p-6 md:p-8 text-center">
          <div class="text-4xl mb-4">{item.icon}</div>
          <h3 class="text-white font-bold text-lg mb-2">{item.title}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{item.desc}</p>
