---
import PageLayout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Kerusi Pilihan Raya — Keputusan & Sejarah | RakyatHub',
  description: 'Semak keputusan pilihan raya bagi mana-mana kerusi Parlimen atau DUN di Malaysia. Data dari ElectionData.MY (CC0).',
};
---

<PageLayout metadata={metadata}>
<section class="max-w-4xl mx-auto px-4 sm:px-6 py-8 md:py-12">
  <div class="flex items-center gap-2 text-xs text-muted/60 mb-1 flex-wrap">
    <a href="/" class="hover:text-primary">Laman Utama</a><span>/</span>
    <a href="/pilihan-raya/" class="hover:text-primary">Pilihan Raya</a><span>/</span>
    <a href="/pilihan-raya/cek-wakil-rakyat/" class="hover:text-primary">Cek Wakil Rakyat</a><span>/</span>
    <span id="breadcrumb-end">Kerusi</span>
  </div>

  <div id="header-area" class="flex items-start gap-4 mb-6">
    <div class="w-12 h-12 rounded-2xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-xl shrink-0" id="type-icon">🏛️</div>
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2 mb-1">
        <span id="type-badge" class="px-2 py-0.5 rounded text-xs font-bold bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400">Parlimen</span>
        <span id="state-name" class="text-xs text-muted/50"></span>
      </div>
      <h1 id="seat-title" class="text-xl sm:text-3xl font-bold tracking-tight">Pilih Kerusi</h1>
      <p id="seat-slug" class="text-xs text-muted/50 font-mono mt-0.5"></p>
    </div>
  </div>

  <div id="seat-results" class="space-y-4">
    <!-- Prompt to select a seat -->
    <div id="prompt-state" class="rounded-2xl bg-amber-50 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-800/30 p-6 text-center">
      <p class="text-3xl mb-3">👆</p>
      <p class="text-sm font-medium text-amber-800 dark:text-amber-300 mb-1">Pilih kerusi dari carian</p>
      <p class="text-xs text-amber-700 dark:text-amber-400/70">Klik mana-mana kerusi di halaman Cek Wakil Rakyat untuk lihat keputusan di sini.</p>
      <a href="/pilihan-raya/cek-wakil-rakyat/" class="inline-block mt-4 px-4 py-2 rounded-lg bg-primary text-white text-sm font-semibold no-underline hover:opacity-90 transition-opacity">Cari Kerusi</a>
    </div>

    <!-- Skeleton loader (hidden initially) -->
    <div id="skeleton" class="hidden space-y-4">
      <div class="rounded-2xl bg-gradient-to-br from-slate-800 to-slate-900 text-white p-6 sm:p-8 animate-pulse">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {[1,2,3,4].map(i => (
            <div class="bg-white/5 rounded-xl p-3.5">
              <div class="h-3 w-16 bg-white/10 rounded mb-2"></div>
              <div class="h-6 w-20 bg-white/10 rounded"></div>
            </div>
          ))}
        </div>
      </div>
      <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 p-5">
        <div class="h-4 w-40 bg-gray-200 dark:bg-slate-700 rounded mb-4"></div>
        {[1,2,3].map(i => (
          <div class="flex gap-3 py-2.5 border-b border-gray-100 dark:border-slate-800/60">
            <div class="h-4 w-24 bg-gray-200 dark:bg-slate-700 rounded"></div>
            <div class="h-4 w-16 bg-gray-200 dark:bg-slate-700 rounded ml-auto"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Real content (hidden initially) -->
    <div id="real-content" class="hidden"></div>

    <!-- Error state -->
    <div id="error-state" class="hidden rounded-2xl bg-amber-50 dark:bg-amber-900/10 border border-amber-200 dark:border-amber-800/30 p-6 text-center">
      <p class="text-2xl mb-2">🤷</p>
      <p class="text-sm font-medium text-amber-800 dark:text-amber-300 mb-1">Data tidak dapat dimuatkan</p>
      <p class="text-xs text-amber-700 dark:text-amber-400/70">Sila cuba sebentar lagi.</p>
    </div>
  </div>

  <div class="mt-8">
    <a href="/pilihan-raya/cek-wakil-rakyat/" class="inline-flex items-center gap-1.5 text-sm text-muted/70 hover:text-primary transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Kembali ke carian
    </a>
  </div>
</section>

<script is:inline>
const API_KEY = 'edmy_904c82017962b63ff00dc9509d0765646c44c9e8';
const SLUG = new URLSearchParams(window.location.search).get('slug');

if (SLUG) {
  document.getElementById('prompt-state').classList.add('hidden');
  document.getElementById('skeleton').classList.remove('hidden');

  // Update breadcrumb and title
  document.getElementById('breadcrumb-end').textContent = SLUG;

  // Load seat data from the cached JS file
  const loadSeatData = () => {
    return new Promise((resolve) => {
      if (window.ELECTION_SEATS) {
        resolve(window.ELECTION_SEATS.find(s => s.slug === SLUG));
      } else {
        const script = document.createElement('script');
        script.src = '/data/election-seats.js';
        script.onload = () => resolve(window.ELECTION_SEATS?.find(s => s.slug === SLUG));
        document.head.appendChild(script);
      }
    });
  };

  loadSeatData().then(seat => {
    if (seat) {
      const isParlimen = seat.type === 'parlimen';
      document.getElementById('type-icon').textContent = isParlimen ? '🏛️' : '🏠';
      document.getElementById('type-badge').textContent = isParlimen ? 'Parlimen' : 'DUN';
      document.getElementById('type-badge').className = 'px-2 py-0.5 rounded text-xs font-bold ' +
        (isParlimen ? 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400' : 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400');
      document.getElementById('state-name').textContent = (seat.seat.split(', ')[1] || '');
      document.getElementById('seat-title').textContent = seat.seat;
      document.getElementById('seat-slug').textContent = seat.slug;
    }
  });

  // Fetch results from API
  fetch(`https://api.electiondata.my/v1/seats/results?slug=${encodeURIComponent(SLUG)}&lineage=true`, {
    headers: { 'Authorization': `Bearer ${API_KEY}` }
  })
  .then(r => r.ok ? r.json() : Promise.reject('HTTP ' + r.status))
  .then(data => {
    const elections = (data.results || []).filter(r => r.election_name);
    if (!elections.length) throw new Error('No data');

    const latest = elections[0];
    const pc = (p) => {
      const m = {PH:'bg-red-100 text-red-700',BN:'bg-blue-100 text-blue-700',PN:'bg-green-100 text-green-700',PAS:'bg-green-100 text-green-700',DAP:'bg-red-100 text-red-700',PKR:'bg-blue-100 text-blue-700',UMNO:'bg-red-100 text-red-700',BEBAS:'bg-gray-100 text-gray-600',WARISAN:'bg-orange-100 text-orange-700',GPS:'bg-purple-100 text-purple-700',GRS:'bg-indigo-100 text-indigo-700'};
      for (const [k,v] of Object.entries(m)) { if (p?.toUpperCase().includes(k)) return v; }
      return 'bg-gray-100 text-gray-700';
    };

    let html = '<div class="rounded-2xl bg-gradient-to-br from-slate-800 to-slate-900 text-white p-6 sm:p-8">';
    html += '<p class="text-xs text-slate-400 font-semibold uppercase tracking-wider mb-1">Penyandang Terkini — ' + latest.election_name + '</p>';
    html += '<p class="text-xs text-slate-400/70 mb-4">' + latest.date + '</p>';
    html += '<div class="grid grid-cols-2 sm:grid-cols-4 gap-4">';
    html += '<div class="bg-white/10 rounded-xl p-3.5"><p class="text-[10px] text-slate-400 uppercase tracking-wider">Pemenang</p><p class="text-lg sm:text-xl font-bold mt-0.5">' + (latest.name || '?') + '</p><p class="text-[11px] text-slate-400/80">' + (latest.party || '') + '</p></div>';
    html += '<div class="bg-white/10 rounded-xl p-3.5"><p class="text-[10px] text-slate-400 uppercase tracking-wider">Parti</p><span class="inline-flex px-2 py-0.5 rounded text-xs font-bold mt-1 ' + pc(latest.party) + '">' + (latest.party || '?') + '</span></div>';
    if (latest.voters_total) html += '<div class="bg-white/10 rounded-xl p-3.5"><p class="text-[10px] text-slate-400 uppercase tracking-wider">Pengundi</p><p class="text-lg sm:text-xl font-bold mt-0.5">' + latest.voters_total.toLocaleString() + '</p><p class="text-[11px] text-slate-400/80">berdaftar</p></div>';
    if (latest.voter_turnout_perc) html += '<div class="bg-white/10 rounded-xl p-3.5"><p class="text-[10px] text-slate-400 uppercase tracking-wider">Turnout</p><p class="text-lg sm:text-xl font-bold mt-0.5">' + latest.voter_turnout_perc.toFixed(1) + '%</p><p class="text-[11px] text-slate-400/80">' + (latest.voter_turnout?.toLocaleString() || '') + ' undi</p></div>';
    html += '</div></div>';

    if (elections.length > 1) {
      html += '<div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 p-5 mt-4">';
      html += '<h2 class="font-semibold text-base mb-3">Sejarah Pilihan Raya</h2>';
      html += '<table class="w-full text-sm"><thead><tr class="border-b border-gray-200 dark:border-slate-700 text-left text-xs text-muted/60 font-semibold uppercase tracking-wider"><th class="pb-2 pr-2">PRU</th><th class="pb-2 pr-2">Tarikh</th><th class="pb-2 pr-2">Pemenang</th><th class="pb-2 pr-2">Parti</th></tr></thead><tbody>';
      elections.forEach(e => {
        html += '<tr class="border-b border-gray-100 dark:border-slate-800/60 hover:bg-gray-50 dark:hover:bg-slate-800/40 transition-colors">';
        html += '<td class="py-2 pr-2 font-medium text-xs">' + (e.election_name || '-') + '</td>';
        html += '<td class="py-2 pr-2 text-xs text-muted/70">' + (e.date || '-') + '</td>';
        html += '<td class="py-2 pr-2 text-sm">' + (e.name || '-') + '</td>';
        html += '<td class="py-2 pr-2"><span class="inline-flex px-1.5 py-0.5 rounded text-xs font-semibold ' + pc(e.party) + '">' + (e.party || '-') + '</span></td></tr>';
      });
      html += '</tbody></table></div>';
    }

    document.getElementById('real-content').innerHTML = html;
    document.getElementById('skeleton').classList.add('hidden');
    document.getElementById('real-content').classList.remove('hidden');
  })
  .catch(err => {
    console.error(err);
    document.getElementById('skeleton').classList.add('hidden');
    document.getElementById('error-state').classList.remove('hidden');
  });
}
</script>

<style is:global>
  .animate-pulse { animation: pulse 2s cubic-bezier(0.4,0,0.6,1) infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
</style>
</PageLayout>
