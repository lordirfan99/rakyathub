---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator KWSP',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/" class="text-sm text-muted hover:text-amber-600 transition-colors">← Laman Utama</a>
    </div>
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
      <span class="text-4xl mr-2">📊</span> Kalkulator KWSP
    </h1>
    <p class="text-xl text-muted mb-8">
      Kira caruman, pengeluaran fleksibel dan dividen KWSP anda. Simulasi simpanan persaraan dengan mudah.
    </p>

    <div class="bg-amber-50 dark:bg-slate-800/50 rounded-2xl p-8 mb-8 text-center">
      <p class="text-lg text-muted">Kalkulator interaktif sedang dibina. Nantikan!</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6">
        <h3 class="font-semibold text-lg mb-2">🧮 Caruman Bulanan</h3>
        <p class="text-muted text-sm">Kira jumlah caruman KWSP berdasarkan gaji anda (11% pekerja + 12% majikan).</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6">
        <h3 class="font-semibold text-lg mb-2">💸 Pengeluaran Fleksibel</h3>
        <p class="text-muted text-sm">Kira jumlah yang boleh dikeluarkan dari Akaun Fleksibel KWSP 2025.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6">
        <h3 class="font-semibold text-lg mb-2">📈 Dividen Tahunan</h3>
        <p class="text-muted text-sm">Simulasi dividen KWSP berdasarkan simpanan semasa dan kadar dividen tahunan.</p>
      </div>
    </div>

    <div class="bg-gradient-to-r from-amber-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 rounded-2xl p-8">
      <h3 class="text-xl font-bold mb-2">📚 Artikel Berkaitan KWSP</h3>
      <p class="text-muted mb-4">Baca panduan lengkap tentang KWSP di blog kami.</p>
      <a href="/blog/kwsp" class="inline-flex items-center text-amber-600 font-medium hover:underline">Lihat Artikel KWSP →</a>
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Kalkulator Lain', href: '/' },
    ]}
  >
    <Fragment slot="title">Nak Kira ASB atau Emas?</Fragment>
    <Fragment slot="subtitle">Kami ada kalkulator ASB, emas dan kereta — semuanya percuma.</Fragment>
  </CallToAction>
</Layout>
