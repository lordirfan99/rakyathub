---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Direktori Kad Kredit Malaysia — RakyatHub',
  description: 'Bandingkan 50+ kad kredit dari Maybank, CIMB, RHB, Public Bank dan bank-bank utama Malaysia. Cari kad dengan cashback tertinggi, annual fee paling rendah.',
};

// ── Full card data from existing database ──
import allCards from '~/data/cashback-cards.json';

/** Derive a friendly cashback label from the card's cashback rules */
function cashbackLabel(card) {
  const cbs = card.cashback || [];
  if (!cbs.length) return '';
  // Find highest rate
  let maxRate = 0;
  let bestCat = '';
  for (const cb of cbs) {
    if (cb.rate > maxRate) { maxRate = cb.rate; bestCat = cb.category; }
  }
  const rateStr = maxRate >= 1 ? maxRate : maxRate * 100;
  if (bestCat === '*') return `${rateStr}% all spend`;
  if (bestCat === 'petrol' && maxRate >= 5) return `${rateStr}% Petrol`;
  if (bestCat === 'online' && maxRate >= 5) return `${rateStr}% Online`;
  if (bestCat === 'dining' && maxRate >= 5) return `${rateStr}% Dining`;
  if (maxRate >= 5) return `${rateStr}% selected`;
  return `${rateStr}% base`;
}

/** Get pool cap display */
function poolCapDisplay(card) {
  return (card.pool_cap || 0) > 0 ? card.pool_cap : 0;
}

/** Derive network label from card name or logo */
function detectNetwork(card) {
  const n = (card.name + ' ' + card.logoLabel).toLowerCase();
  if (n.includes('amex') || n.includes('american express')) return 'Amex';
  if (n.includes('mastercard') || n.includes('mc')) return 'Mastercard';
  return 'Visa'; // Most Malaysian cards are Visa
}

/** Derive minimum income hint */
function minIncomeHint(card) {
  // Rough estimate based on card type
  if ((card.annual_fee || 0) >= 800) return 'RM 100k';
  if ((card.annual_fee || 0) >= 300) return 'RM 60k';
  if (card.pool_cap >= 100) return 'RM 36k';
  return 'RM 24k';
}

// Map cards with available images
const CARDS_DATA = allCards.cards
  .filter(c => c.imageUrl) // only cards that have images
  .map(c => ({
    id: c.id,
    bank: c.bank,
    name: c.name,
    img: c.imageUrl,
    network: detectNetwork(c),
    cashback: cashbackLabel(c),
    fee: (c.annual_fee || 0) === 0 ? 'RM 0' : `RM ${c.annual_fee}`,
    minIncome: minIncomeHint(c),
    hex: c.primaryHex || '#333',
    poolCap: poolCapDisplay(c),
  }));

const BANKS = [...new Set(CARDS_DATA.map(c => c.bank))].sort();
const NETWORKS = [...new Set(CARDS_DATA.map(c => c.network))].sort();
const CARD_COUNT = CARDS_DATA.length;
const cardsJson = JSON.stringify(CARDS_DATA);
const banksJson = JSON.stringify(BANKS);
const networksJson = JSON.stringify(NETWORKS);
---

<Layout metadata={metadata}>
  <!-- ════════════════════════════════════════════════════════════════
       HERO SECTION
       ════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-950 via-slate-900 to-teal-950">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-teal-500/10 via-transparent to-transparent"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_var(--tw-gradient-stops))] from-orange-500/5 via-transparent to-transparent"></div>
    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image:url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 text-white/80 text-xs font-semibold backdrop-blur-sm mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-teal-400 animate-pulse"></span>
          {CARD_COUNT} Kad Kredit
        </div>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white leading-[1.1]">
          Direktori Kad<br class="sm:hidden" />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-300 to-orange-300">Kredit Malaysia</span>
        </h1>
        <p class="mt-4 text-lg md:text-xl text-white/60 max-w-2xl leading-relaxed">
          Bandingkan <strong class="text-white/90">{CARD_COUNT}+ kad kredit</strong> dari bank-bank utama Malaysia.
          Tapis mengikut bank, jaringan, dan cari yang paling sesuai dengan gaya perbelanjaan anda.
        </p>
      </div>
    </div>
    <!-- Soft divider -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════
       FILTER + GRID SECTION
       ════════════════════════════════════════════════════════════════ -->
  <section class="bg-gradient-to-b from-slate-50 to-white dark:from-slate-950 dark:to-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 md:pb-24">

      <!-- ── Sticky Glassmorphism Filter Bar ── -->
      <div id="filterBar" class="sticky top-0 z-30 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 pt-4 pb-3 transition-all duration-300">
        <div class="rounded-2xl border border-white/20 dark:border-white/5 bg-white/70 dark:bg-slate-900/70 backdrop-blur-xl backdrop-saturate-150 shadow-lg shadow-black/5 dark:shadow-black/20 p-4">
          <div class="flex flex-wrap items-center gap-3">
            <!-- Search -->
            <div class="relative flex-1 min-w-[200px]">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              <input
                id="searchInput"
                type="text"
                placeholder="Cari kad kredit..."
                class="w-full pl-9 pr-3 py-2.5 rounded-xl bg-white/60 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700/50 text-sm text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-teal-500/30 focus:border-teal-500/50 transition"
                oninput="filterCards()"
              />
            </div>

            <!-- Bank filter -->
            <div class="relative">
              <select
                id="bankFilter"
                class="appearance-none pl-3 pr-8 py-2.5 rounded-xl bg-white/60 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700/50 text-sm text-slate-700 dark:text-slate-300 focus:outline-none focus:ring-2 focus:ring-teal-500/30 focus:border-teal-500/50 transition cursor-pointer"
                onchange="filterCards()"
              >
                <option value="all">Semua Bank</option>
                <!-- populated by JS -->
              </select>
              <svg class="absolute right-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>

            <!-- Network filter -->
            <div class="relative">
              <select
                id="networkFilter"
                class="appearance-none pl-3 pr-8 py-2.5 rounded-xl bg-white/60 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700/50 text-sm text-slate-700 dark:text-slate-300 focus:outline-none focus:ring-2 focus:ring-teal-500/30 focus:border-teal-500/50 transition cursor-pointer"
                onchange="filterCards()"
              >
                <option value="all">Semua Jaringan</option>
                <!-- populated by JS -->
              </select>
              <svg class="absolute right-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>

            <!-- Result count -->
            <div class="text-xs text-slate-400 dark:text-slate-500 whitespace-nowrap">
              <span id="resultCount">{CARD_COUNT}</span> kad
            </div>

            <!-- Reset -->
            <button
              onclick="resetFilters()"
              class="px-3 py-2.5 rounded-xl text-xs font-medium text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition"
            >
              <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              Reset
            </button>
          </div>
        </div>
      </div>

      <!-- ── Skeleton Loaders (shown while JS initialises) ── -->
      <div id="skeletonGrid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 mt-8">
        {Array.from({ length: 15 }).map((_, i) => (
          <div class="animate-pulse">
            <div class="rounded-2xl bg-slate-200 dark:bg-slate-800/60" style="aspect-ratio:1.586/1"></div>
            <div class="mt-2.5 space-y-1.5">
              <div class="h-2.5 w-16 rounded-full bg-slate-200 dark:bg-slate-800/60"></div>
              <div class="h-3.5 w-3/4 rounded-full bg-slate-200 dark:bg-slate-800/60"></div>
            </div>
          </div>
        ))}
      </div>

      <!-- ── Card Grid ── -->
      <div id="cardGrid" class="hidden grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 mt-8"></div>

      <!-- ── Empty state ── -->
      <div id="emptyState" class="hidden mt-16 text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-slate-100 dark:bg-slate-800 mb-4">
          <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3 class="text-lg font-bold text-slate-700 dark:text-slate-300">Tiada kad dijumpai</h3>
        <p class="text-sm text-slate-500 mt-1">Cuba tukar filter atau carian anda.</p>
        <button onclick="resetFilters()" class="mt-4 px-5 py-2.5 rounded-xl bg-teal-500 text-white text-sm font-semibold hover:bg-teal-600 transition">Reset Filter</button>
      </div>

    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════
       DATA STORE (hidden)
       ════════════════════════════════════════════════════════════════ -->
  <div id="cardStore" data-cards={cardsJson} data-banks={banksJson} data-networks={networksJson} style="display:none"></div>
</Layout>

<script is:inline>
// ═══════════════════════════════════════════════════════════════════════
// PREMIUM CREDIT CARD DIRECTORY — RakyatHub
// Architecture: Vanilla JS + CSS transforms + requestAnimationFrame
// ═══════════════════════════════════════════════════════════════════════

(function () {
  "use strict";

  /* ── State ── */
  const CARDS = JSON.parse(
    document.getElementById("cardStore")?.getAttribute("data-cards") || "[]"
  );
  const BANKS = JSON.parse(
    document.getElementById("cardStore")?.getAttribute("data-banks") || "[]"
  );
  const NETWORKS = JSON.parse(
    document.getElementById("cardStore")?.getAttribute("data-networks") || "[]"
  );
  const grid = document.getElementById("cardGrid");
  const skeleton = document.getElementById("skeletonGrid");
  const empty = document.getElementById("emptyState");
  const countEl = document.getElementById("resultCount");

  /* ── Populate filter dropdowns ── */
  function populateFilters() {
    const bankSel = document.getElementById("bankFilter");
    BANKS.forEach((b) => {
      const opt = document.createElement("option");
      opt.value = b;
      opt.textContent = b;
      bankSel.appendChild(opt);
    });

    const netSel = document.getElementById("networkFilter");
    NETWORKS.forEach((n) => {
      const opt = document.createElement("option");
      opt.value = n;
      opt.textContent = n;
      netSel.appendChild(opt);
    });
  }

  /* ── Build a single card element ── */
  function createCard(card, index) {
    const article = document.createElement("article");
    // Staggered animation class
    article.className =
      "card-item opacity-0 translate-y-4 transition-all duration-500 ease-out";
    article.style.transitionDelay = `${(index % 10) * 40}ms`;

    article.innerHTML = `
      <div class="relative group cursor-pointer">
        <!-- Card image container with 3D tilt target -->
        <div class="tilt-root relative rounded-2xl overflow-hidden shadow-xl shadow-black/10 dark:shadow-black/30 bg-white dark:bg-slate-800 transition-shadow duration-300 group-hover:shadow-2xl group-hover:shadow-black/20 dark:group-hover:shadow-black/40"
             style="aspect-ratio:1.586/1; perspective: 800px;">
          <div class="tilt-inner w-full h-full transition-transform duration-200 ease-out"
               style="transform-style: preserve-3d;">
            <img src="${card.img}"
                 alt="${card.name}"
                 loading="lazy"
                 class="w-full h-full object-contain p-2"
                 onerror="this.parentElement.innerHTML='<div class=\\'w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-100 to-slate-200 dark:from-slate-800 dark:to-slate-900\\'><span class=\\'text-2xl font-bold text-slate-400 dark:text-slate-600\\'>${card.bank.substring(0, 4).toUpperCase()}</span></div>'" />

            <!-- Hover overlay — slides up with info -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent
                        opacity-0 group-hover:opacity-100 transition-all duration-300 ease-out
                        translate-y-4 group-hover:translate-y-0
                        flex flex-col justify-end p-3 sm:p-4">
              <div class="space-y-1.5 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300 delay-75">
                <div class="flex items-center gap-2">
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-teal-500/90 text-[10px] font-bold text-white uppercase tracking-wider">
                    ${card.cashback}
                  </span>
                </div>
                <div class="flex items-center gap-2 text-[11px] text-white/80">
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    ${card.fee}
                  </span>
                  <span class="text-white/40">·</span>
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                    Cap RM ${card.poolCap}
                  </span>
                </div>
                <div class="text-[10px] text-white/50">Min pendapatan: ${card.minIncome}</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card info below image -->
        <div class="mt-2.5 px-0.5">
          <div class="text-[11px] font-semibold text-teal-600 dark:text-teal-400 uppercase tracking-wider">
            ${card.bank}
          </div>
          <h3 class="text-sm font-bold text-slate-800 dark:text-white leading-tight truncate">
            ${card.name}
          </h3>
          <div class="flex items-center gap-2 mt-1">
            <span class="inline-block px-1.5 py-0.5 rounded text-[9px] font-semibold uppercase tracking-wider
                        ${card.network === "Visa" ? "bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300" :
                          card.network === "Mastercard" ? "bg-orange-100 text-orange-700 dark:bg-orange-900/40 dark:text-orange-300" :
                          "bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-300"}">
              ${card.network}
            </span>
            <span class="text-[11px] text-slate-400">${card.cashback}</span>
          </div>
        </div>
      </div>
    `;

    return article;
  }

  /* ── Render filtered cards with nice animation ── */
  let currentFilter = "";

  function filterCards() {
    const query = document.getElementById("searchInput").value.trim().toLowerCase();
    const bank = document.getElementById("bankFilter").value;
    const network = document.getElementById("networkFilter").value;

    const filtered = CARDS.filter((c) => {
      if (bank !== "all" && c.bank !== bank) return false;
      if (network !== "all" && c.network !== network) return false;
      if (query && !c.name.toLowerCase().includes(query) && !c.bank.toLowerCase().includes(query))
        return false;
      return true;
    });

    // Update count
    countEl.textContent = filtered.length;

    // Empty state
    if (filtered.length === 0) {
      grid.classList.add("hidden");
      empty.classList.remove("hidden");
      return;
    }
    empty.classList.add("hidden");

    // Batch DOM update: build all new cards, then swap
    const fragment = document.createDocumentFragment();
    filtered.forEach((card, i) => {
      fragment.appendChild(createCard(card, i));
    });

    // Save scroll position of first card
    const firstCard = grid.querySelector(".card-item");
    const prevTop = firstCard?.getBoundingClientRect().top;

    grid.innerHTML = "";
    grid.appendChild(fragment);
    grid.classList.remove("hidden");

    // Trigger staggered entrance animation
    requestAnimationFrame(() => {
      grid.querySelectorAll(".card-item").forEach((el) => {
        el.classList.remove("opacity-0", "translate-y-4");
      });
    });

    // Try to maintain scroll position
    if (prevTop !== undefined && prevTop < window.innerHeight) {
      window.scrollBy(0, 1);
    }

    // Re-attach tilt handlers
    attachTilt();
  }

  /* ── Reset all filters ── */
  function resetFilters() {
    document.getElementById("searchInput").value = "";
    document.getElementById("bankFilter").value = "all";
    document.getElementById("networkFilter").value = "all";
    filterCards();
  }

  /* ── 3D Tilt Effect (pure CSS transforms, no lib) ── */
  let tiltActive = true;

  function attachTilt() {
    document.querySelectorAll(".tilt-root").forEach((root) => {
      // Remove old listeners to avoid duplicates
      root._tiltHandler && root.removeEventListener("mousemove", root._tiltHandler);
      root._tiltLeave && root.removeEventListener("mouseleave", root._tiltLeave);

      const inner = root.querySelector(".tilt-inner");
      if (!inner) return;

      const handler = (e) => {
        if (!tiltActive) return;
        const rect = root.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        // Max 12deg rotate, heavier on X axis
        const rotateY = ((x - centerX) / centerX) * 8;
        const rotateX = ((centerY - y) / centerY) * 6;
        inner.style.transform =
          `rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02,1.02,1.02)`;
      };

      const leave = () => {
        inner.style.transform = "rotateX(0deg) rotateY(0deg) scale3d(1,1,1)";
      };

      root.addEventListener("mousemove", handler);
      root.addEventListener("mouseleave", leave);
      root._tiltHandler = handler;
      root._tiltLeave = leave;
    });
  }

  /* ── Sticky filter bar shadow on scroll ── */
  function initStickyFilter() {
    const bar = document.getElementById("filterBar");
    let ticking = false;
    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            bar?.classList.toggle("shadow-xl", window.scrollY > 80);
            bar?.classList.toggle("shadow-black/10", window.scrollY > 80);
            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true }
    );
  }

  /* ── Init ── */
  document.addEventListener("DOMContentLoaded", () => {
    if (!CARDS.length) return;

    populateFilters();

    // Initial render with slight delay to show skeleton
    setTimeout(() => {
      skeleton?.classList.add("hidden");
      filterCards();
      initStickyFilter();
    }, 400);

    // Expose for inline onchange attrs
    window.filterCards = filterCards;
    window.resetFilters = resetFilters;
  });
})();
</script>
