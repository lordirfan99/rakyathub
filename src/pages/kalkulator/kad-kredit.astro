---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Direktori Kad Kredit Malaysia — 281+ Kad | RakyatHub',
  description: 'Bandingkan 281+ kad kredit dari Maybank, CIMB, RHB, Public Bank, Hong Leong dan bank-bank utama Malaysia. Tapis ikut bank, jaringan, dan jenis kad.',
};

// ── Full card data from scraped DuitGain DB (281 cards) ──
import allCards from '~/data/duitgain-cards.json';

/** Detect network from card data */
function detectNetwork(c) {
  const nets = c.networks || [];
  if (nets.length > 0) return nets[0];
  return 'Visa';
}

/** Format annual fee */
function feeLabel(c) {
  const f = c.annual_fee || 0;
  if (f === 0 && c.free_for_life) return 'Percuma';
  if (f === 0) return 'RM 0';
  return `RM ${f.toLocaleString()}`;
}

/** Get min income label */
function incomeLabel(c) {
  const i = c.min_income || 0;
  if (i >= 120000) return 'RM 120k';
  if (i >= 100000) return 'RM 100k';
  if (i >= 60000) return 'RM 60k';
  if (i >= 36000) return 'RM 36k';
  if (i >= 24000) return 'RM 24k';
  return 'RM 18k';
}

/** Get max cashback rate for display */
function maxCashback(c) {
  let max = 0;
  let label = '';
  for (const [k, v] of Object.entries(c)) {
    if (k.startsWith('cb_') && typeof v === 'number' && v > max) {
      max = v;
      label = k.replace('cb_', '').replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
    }
  }
  if (max === 0) return '';
  if (max >= 1) return `${max}% ${label}`;
  return `${(max * 100).toFixed(1)}% ${label}`;
}

// Build card data for client-side
const CARDS_DATA = allCards
  .filter(c => c.image) // only cards with images
  .map(c => ({
    id: c.id || c.slug,
    bank: c.bank || 'Unknown',
    name: c.name,
    img: c.image,
    image_url: c.image_url || c.image,
    image_alt: c.image_alt || c.name,
    network: detectNetwork(c),
    cashback: maxCashback(c),
    fee: feeLabel(c),
    annual_fee_num: c.annual_fee || 0,
    minIncome: incomeLabel(c),
    free_for_life: c.free_for_life || false,
    islamic: c.islamic || false,
    card_type: c.card_type || '',
    card_type_cash_back: c.card_type_cash_back || false,
    card_type_mileage: c.card_type_mileage || false,
  }));

const BANKS = [...new Set(CARDS_DATA.map(c => c.bank))].sort();
const NETWORKS = [...new Set(CARDS_DATA.map(c => c.network))].sort();
const CARD_COUNT = CARDS_DATA.length;
const cardsJson = JSON.stringify(CARDS_DATA);
const banksJson = JSON.stringify(BANKS);
const networksJson = JSON.stringify(NETWORKS);
---

<Layout metadata={metadata}>
  <!-- ════════════════════════════════════════════════════════════════
       HERO SECTION
       ════════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-950 via-slate-900 to-teal-950">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-teal-500/10 via-transparent to-transparent"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_var(--tw-gradient-stops))] from-orange-500/5 via-transparent to-transparent"></div>
    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image:url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 text-white/80 text-xs font-semibold backdrop-blur-sm mb-5">
          <span class="w-1.5 h-1.5 rounded-full bg-teal-400 animate-pulse"></span>
          {CARD_COUNT} Kad Kredit
        </div>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-white leading-[1.1]">
          Direktori Kad<br class="sm:hidden" />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-300 to-orange-300">Kredit Malaysia</span>
        </h1>
        <p class="mt-4 text-lg md:text-xl text-white/60 max-w-2xl leading-relaxed">
          Bandingkan <strong class="text-white/90">{CARD_COUNT}+ kad kredit</strong> dari bank-bank utama Malaysia.
          Tapis mengikut bank, jaringan, dan cari yang paling sesuai dengan gaya perbelanjaan anda.
        </p>
      </div>
    </div>
    <!-- Soft divider -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════
       FILTER + GRID SECTION
       ════════════════════════════════════════════════════════════════ -->
  <section class="bg-gradient-to-b from-slate-50 to-white dark:from-slate-950 dark:to-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 md:pb-24">

      <!-- ── Sticky Glassmorphism Filter Bar ── -->
      <div id="filterBar" class="sticky top-0 z-30 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 pt-4 pb-3 transition-all duration-300">
        <div class="rounded-2xl border border-white/20 dark:border-white/5 bg-white/70 dark:bg-slate-900/70 backdrop-blur-xl backdrop-saturate-150 shadow-lg shadow-black/5 dark:shadow-black/20 p-4">
          <div class="flex flex-wrap items-center gap-3">
            <!-- Search -->
            <div class="relative flex-1 min-w-[200px]">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              <input
                id="searchInput"
                type="text"
                placeholder="Cari kad kredit..."
                class="w-full pl-9 pr-3 py-2.5 rounded-xl bg-white/60 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700/50 text-sm text-slate-900 dark:text-white placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-teal-500/30 focus:border-teal-500/50 transition"
                oninput="filterCards()"
              />
            </div>

            <!-- Bank filter -->
            <div class="relative">
              <select
                id="bankFilter"
                class="appearance-none pl-3 pr-8 py-2.5 rounded-xl bg-white/60 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700/50 text-sm text-slate-700 dark:text-slate-300 focus:outline-none focus:ring-2 focus:ring-teal-500/30 focus:border-teal-500/50 transition cursor-pointer"
                onchange="filterCards()"
              >
                <option value="all">Semua Bank</option>
                <!-- populated by JS -->
              </select>
              <svg class="absolute right-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>

            <!-- Network filter -->
            <div class="relative">
              <select
                id="networkFilter"
                class="appearance-none pl-3 pr-8 py-2.5 rounded-xl bg-white/60 dark:bg-slate-800/60 border border-slate-200 dark:border-slate-700/50 text-sm text-slate-700 dark:text-slate-300 focus:outline-none focus:ring-2 focus:ring-teal-500/30 focus:border-teal-500/50 transition cursor-pointer"
                onchange="filterCards()"
              >
                <option value="all">Semua Jaringan</option>
                <!-- populated by JS -->
              </select>
              <svg class="absolute right-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>

            <!-- Result count -->
            <div class="text-xs text-slate-400 dark:text-slate-500 whitespace-nowrap">
              <span id="resultCount">{CARD_COUNT}</span> kad
            </div>

            <!-- Reset -->
            <button
              onclick="resetFilters()"
              class="px-3 py-2.5 rounded-xl text-xs font-medium text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition"
            >
              <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              Reset
            </button>
          </div>
        </div>
      </div>

      <!-- ── Skeleton Loaders (shown while JS initialises) ── -->
      <div id="skeletonGrid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 mt-8">
        {Array.from({ length: 15 }).map((_, i) => (
          <div class="animate-pulse">
            <div class="rounded-2xl bg-slate-200 dark:bg-slate-800/60" style="aspect-ratio:1.586/1"></div>
            <div class="mt-2.5 space-y-1.5">
              <div class="h-2.5 w-16 rounded-full bg-slate-200 dark:bg-slate-800/60"></div>
              <div class="h-3.5 w-3/4 rounded-full bg-slate-200 dark:bg-slate-800/60"></div>
            </div>
          </div>
        ))}
      </div>

      <!-- ── Card Grid (populated by JS) ── -->
      <div id="cardGrid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 mt-8" style="display:none"></div>
    </div>
  </section>

  <script is:inline>
  var CARDS = JSON.parse('{cardsJson}');
  var BANKS_LIST = JSON.parse('{banksJson}');
  var NETWORKS_LIST = JSON.parse('{networksJson}');

  // Populate filters
  BANKS_LIST.forEach(function(b) {
    var opt = document.createElement('option');
    opt.value = b; opt.textContent = b;
    document.getElementById('bankFilter').appendChild(opt);
  });
  NETWORKS_LIST.forEach(function(n) {
    var opt = document.createElement('option');
    opt.value = n; opt.textContent = n;
    document.getElementById('networkFilter').appendChild(opt);
  });

  function filterCards() {
    var q = document.getElementById('searchInput').value.toLowerCase().trim();
    var bank = document.getElementById('bankFilter').value;
    var net = document.getElementById('networkFilter').value;

    var filtered = CARDS.filter(function(c) {
      if (bank !== 'all' && c.bank !== bank) return false;
      if (net !== 'all' && c.network !== net) return false;
      if (q) {
        var haystack = (c.bank + ' ' + c.name + ' ' + c.cashback).toLowerCase();
        if (haystack.indexOf(q) < 0) return false;
      }
      return true;
    });

    var grid = document.getElementById('cardGrid');
    var skeleton = document.getElementById('skeletonGrid');
    skeleton.style.display = 'none';
    grid.style.display = '';

    document.getElementById('resultCount').textContent = filtered.length;

    if (filtered.length === 0) {
      grid.innerHTML = '<div class="col-span-full text-center py-16"><p class="text-lg text-slate-400">Tiada kad dijumpai.</p></div>';
      return;
    }

    var html = '';
    filtered.forEach(function(c) {
      html += '<a href="#" class="group block rounded-2xl overflow-hidden bg-white dark:bg-slate-900/60 border border-slate-100 dark:border-slate-800/50 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200" onclick="event.preventDefault();showDetail(' + JSON.stringify(c).replace(/"/g, '&quot;') + ')">';
      html += '<div class="aspect-[1.586/1] bg-white dark:bg-slate-800/40 flex items-center justify-center p-4">';
      html += '<img src="' + c.img + '" alt="' + c.image_alt + '" class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-300" loading="lazy" />';
      html += '</div>';
      html += '<div class="p-3">';
      html += '<p class="text-[10px] font-semibold uppercase tracking-wider text-slate-400">' + c.bank + '</p>';
      html += '<p class="text-sm font-semibold text-slate-800 dark:text-white leading-tight mt-0.5 line-clamp-2">' + c.name + '</p>';
      html += '<div class="flex items-center gap-2 mt-2">';
      html += '<span class="inline-flex items-center gap-1 text-[10px] font-medium text-teal-600 bg-teal-50 dark:bg-teal-900/30 dark:text-teal-400 px-2 py-0.5 rounded-full">' + c.network + '</span>';
      if (c.cashback) html += '<span class="inline-flex items-center gap-1 text-[10px] font-medium text-orange-600 bg-orange-50 dark:bg-orange-900/30 dark:text-orange-400 px-2 py-0.5 rounded-full">' + c.cashback + '</span>';
      html += '</div>';
      html += '<p class="text-xs text-slate-400 mt-1.5">' + c.fee + ' · ' + c.minIncome + '</p>';
      html += '</div></a>';
    });
    grid.innerHTML = html;
  }

  function resetFilters() {
    document.getElementById('searchInput').value = '';
    document.getElementById('bankFilter').value = 'all';
    document.getElementById('networkFilter').value = 'all';
    filterCards();
  }

  function showDetail(card) {
    var d = '<div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50" onclick="event.target===this&&closeDetail()">' +
      '<div class="relative bg-white dark:bg-slate-900 rounded-2xl max-w-md w-full mx-4 p-6 shadow-2xl max-h-[90vh] overflow-y-auto">' +
      '<button onclick="closeDetail()" class="absolute top-3 right-3 w-8 h-8 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 hover:text-slate-700">✕</button>' +
      '<div class="aspect-[1.586/1] bg-white dark:bg-slate-800/40 rounded-xl flex items-center justify-center p-4 mb-4">' +
      '<img src="' + card.img + '" alt="' + card.image_alt + '" class="max-w-full max-h-full object-contain" />' +
      '</div>' +
      '<p class="text-xs font-semibold uppercase tracking-wider text-slate-400">' + card.bank + '</p>' +
      '<p class="text-lg font-bold text-slate-800 dark:text-white mt-1">' + card.name + '</p>' +
      '<div class="flex flex-wrap gap-2 mt-3">' +
      '<span class="text-xs font-medium px-2.5 py-1 rounded-full bg-teal-50 dark:bg-teal-900/30 text-teal-600 dark:text-teal-400">' + card.network + '</span>' +
      (card.islamic ? '<span class="text-xs font-medium px-2.5 py-1 rounded-full bg-emerald-50 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400">Islamic</span>' : '') +
      (card.free_for_life ? '<span class="text-xs font-medium px-2.5 py-1 rounded-full bg-purple-50 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400">Free For Life</span>' : '') +
      '</div>' +
      '<div class="grid grid-cols-2 gap-3 mt-4">' +
      '<div class="rounded-xl bg-slate-50 dark:bg-slate-800/40 p-3"><p class="text-[10px] text-slate-400 uppercase">Annual Fee</p><p class="text-sm font-bold text-slate-800 dark:text-white">' + card.fee + '</p></div>' +
      '<div class="rounded-xl bg-slate-50 dark:bg-slate-800/40 p-3"><p class="text-[10px] text-slate-400 uppercase">Min Income</p><p class="text-sm font-bold text-slate-800 dark:text-white">' + card.minIncome + '</p></div>' +
      '</div>' +
      (card.cashback ? '<div class="mt-3 rounded-xl bg-slate-50 dark:bg-slate-800/40 p-3"><p class="text-[10px] text-slate-400 uppercase">Top Cashback</p><p class="text-sm font-bold text-teal-600">' + card.cashback + '</p></div>' : '') +
      '</div></div>';
    var el = document.createElement('div');
    el.innerHTML = d;
    document.body.appendChild(el.firstElementChild);
  }

  function closeDetail() {
    var d = document.querySelector('.fixed.inset-0.z-50');
    if (d) d.remove();
  }

  // Init
  filterCards();
  </script>
</Layout>
