---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator Emas — Harga & Spread Emas Malaysia',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/" class="text-sm text-muted hover:text-primary transition-colors">← Laman Utama</a>
    </div>

    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">
      Kalkulator Emas
    </h1>
    <p class="text-lg md:text-xl text-muted mb-8">
      Semak harga emas Public Gold terkini dan graf pergerakan harga.
    </p>

    <!-- Calculator Card -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <div class="grid md:grid-cols-2 gap-4 md:gap-6">
        <div>
          <label for="harga" class="block text-sm font-semibold text-default mb-1.5">Harga Emas Semasa (RM/g)</label>
          <input type="number" id="harga" value="420" min="0" step="1"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="berat" class="block text-sm font-semibold text-default mb-1.5">Berat Emas (gram)</label>
          <input type="number" id="berat" value="20" min="0" step="1"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
      </div>

      <!-- Results grid -->
      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Harga Belian</p>
          <p class="text-lg font-bold text-default" id="hasilBeli">RM 0.00</p>
        </div>
        <div class="rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Harga Jualan</p>
          <p class="text-lg font-bold text-emerald-700" id="hasilJual">RM 0.00</p>
        </div>
        <div class="rounded-xl bg-blue-50 dark:bg-blue-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Nilai Pelaburan</p>
          <p class="text-lg font-bold text-primary" id="hasilNilai">RM 0.00</p>
        </div>
      </div>

      <!-- Public Gold Card -->
      <div class="mt-6">
        <div class="rounded-xl border border-amber-200 dark:border-amber-800 bg-white dark:bg-slate-800 p-5">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-3 h-3 rounded-full bg-amber-500"></span>
            <h3 class="font-semibold">Public Gold GAP 24K</h3>
          </div>
          <p class="text-sm text-muted">Harga Beli: <span class="font-semibold text-default" id="pgBeli">RM 0.00</span></p>
          <p class="text-sm text-muted">Harga Jual: <span class="font-semibold text-default" id="pgJual">RM 0.00</span></p>
        </div>
      </div>
    </div>

    <!-- Harga PG terkini badge -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8 text-center">
      <h2 class="text-xl font-bold mb-4">🟡 Harga Public Gold GAP 24K</h2>
      <div class="grid grid-cols-2 gap-3 max-w-sm mx-auto">
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center">
          <p class="text-xs text-muted">Harga Beli</p>
          <p class="text-2xl font-bold text-amber-600" id="rujPgBeli">RM 0</p>
          <p class="text-[10px] text-muted">/gram</p>
        </div>
        <div class="rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4 text-center">
          <p class="text-xs text-muted">Harga Jual (GAP)</p>
          <p class="text-2xl font-bold text-emerald-700" id="rujPgJual">RM 0</p>
          <p class="text-[10px] text-muted">/gram</p>
        </div>
      </div>
    </div>

    <!-- Gold Price Chart -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">📈 Graf Harga Emas (XAU/USD)</h2>
      <div class="flex gap-2 mb-4" id="chartTabs">
        <button data-int="D" class="chart-tab active px-4 py-1.5 rounded-lg text-sm font-semibold bg-primary text-white">Harian</button>
        <button data-int="W" class="chart-tab px-4 py-1.5 rounded-lg text-sm font-semibold bg-gray-100 dark:bg-slate-700 text-muted hover:bg-gray-200">Mingguan</button>
        <button data-int="M" class="chart-tab px-4 py-1.5 rounded-lg text-sm font-semibold bg-gray-100 dark:bg-slate-700 text-muted hover:bg-gray-200">Bulanan</button>
      </div>
      <div id="tvchart" style="height:400px;border-radius:12px;overflow:hidden;"></div>
    </div>

    <!-- DocuKilat CTA -->
    <div class="rounded-2xl bg-gradient-to-br from-primary/10 via-primary/[0.03] to-secondary/10 border border-primary/20 p-6 md:p-8 text-center mb-8">
      <h3 class="text-xl md:text-2xl font-bold mb-2">📄 Nak Simpan Rekod Pelaburan Emas?</h3>
      <p class="text-muted mb-4">Guna DocuKilat untuk buat resume portfolio, surat pengesahan, atau invois jualan emas.</p>
      <a href="https://docukilat.netlify.app" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-primary to-secondary text-white font-semibold text-sm transition-all duration-300 hover:shadow-lg hover:shadow-primary/30 hover:scale-[1.02]">
        Bina Dokumen di DocuKilat
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

    <!-- Info Cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">🟡 Harga PG GAP 24K</h3>
        <p class="text-muted text-sm">Harga emas Public Gold dikemaskini setiap hari jam 12 malam dari laman rasmi PG.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">📈 Graf Interaktif</h3>
        <p class="text-muted text-sm">Graf harga emas dunia (XAU/USD) masa sebenar — harian, mingguan, bulanan.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">💎 GAP Sama Harga</h3>
        <p class="text-muted text-sm">Akaun GAP Public Gold — harga beli dan jual adalah sama, tanpa spread.</p>
      </div>
    </div>

    <!-- Artikel -->
    <div class="rounded-2xl bg-gradient-to-br from-amber-50 to-orange-50 dark:from-slate-800 dark:to-slate-800 border border-amber-100 dark:border-slate-700 p-6 md:p-8">
      <h3 class="text-xl font-bold mb-4">📚 Artikel Berkaitan Emas</h3>
      <ul class="space-y-2">
        <li>
          <a href="/cara-beli-emas-public-gold/" class="text-primary font-medium hover:underline text-sm">
            → Cara Beli Emas Public Gold — Panduan Lengkap
          </a>
        </li>
        <li>
          <a href="/strategi-dca-vs-lump-sum-pilihan-pelaburan-bijak-untuk-orang-muda/" class="text-primary font-medium hover:underline text-sm">
            → Strategi DCA vs Lump Sum — Mana Lebih Bijak?
          </a>
        </li>
        <li>
          <a href="/cadangan-bajet-50-30-20-di-malaysia/" class="text-primary font-medium hover:underline text-sm">
            → Panduan Bajet 50/30/20 — Cara Urus Gaji Bulanan
          </a>
        </li>
      </ul>
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Kalkulator Kereta', href: '/kalkulator/kereta' },
      { variant: 'secondary', text: 'Kalkulator KWSP', href: '/kalkulator/kwsp' },
    ]}
  >
    <Fragment slot="title">Nak Kira Kereta atau KWSP?</Fragment>
    <Fragment slot="subtitle">Semua kalkulator percuma, tak perlu daftar.</Fragment>
  </CallToAction>
  <script is:inline>
// Gold price fetcher
var PG_HARGA = 420;
// Store actual PG prices from API for reference table
var PG_API = { beli: 0, jual: 0 };
(function() {
  var x = new XMLHttpRequest();
  x.open('GET', '/.netlify/functions/kewangan', true);
  x.onload = function() {
    if (x.status === 200) {
      try {
        var d = JSON.parse(x.responseText);
        if (d.emas && d.emas.harga_pg_beli) {
          PG_HARGA = Math.round(d.emas.harga_pg_beli);
          PG_API.beli = d.emas.harga_pg_beli || PG_HARGA;
          PG_API.jual = (d.emas.harga_pg_jual != null) ? d.emas.harga_pg_jual : PG_HARGA;
          // Always update harga from API
          var hi = document.getElementById('harga');
          if (hi) hi.value = PG_HARGA;
          calc();
          // Update reference badges
          document.getElementById('rujPgBeli').textContent = fmt(PG_API.beli);
          document.getElementById('rujPgJual').textContent = fmt(PG_API.jual);
        }
      } catch(e) {}
    }
  };
  x.send();
})();

function fmt(v) { return 'RM ' + (typeof v === 'number' && !isNaN(v) && isFinite(v) ? v.toLocaleString('ms-MY', {minimumFractionDigits:2,maximumFractionDigits:2}) : '0.00'); }
function sn(v, d) { var n = parseFloat(v); return (!isNaN(n) && isFinite(n) && n >= 0) ? n : d || 0; }

function calc() {
  var harga = sn(document.getElementById('harga').value, PG_HARGA);
  var berat = sn(document.getElementById('berat').value, 20);

  if (harga === 0 || berat === 0) {
    ['hasilBeli','hasilJual','hasilNilai','pgBeli','pgJual'].forEach(function(id) {
      document.getElementById(id).textContent = 'RM 0.00';
    });
    return;
  }

  var nilaiPokok = harga * berat;

  document.getElementById('hasilBeli').textContent = fmt(nilaiPokok);
  document.getElementById('hasilJual').textContent = fmt(nilaiPokok);
  document.getElementById('hasilNilai').textContent = fmt(nilaiPokok);
  document.getElementById('pgBeli').textContent = fmt(nilaiPokok);
  document.getElementById('pgJual').textContent = fmt(nilaiPokok);
}

// Input events
['harga','berat'].forEach(function(id) {
  var el = document.getElementById(id);
  if (el) { el.addEventListener('input', calc); el.addEventListener('change', calc); }
});
calc();

// TradingView Chart — iframe embed (works with Brave/ad blockers)
(function() {
  var iframe = document.createElement('iframe');
  var intervals = {D:'D', W:'W', M:'M'};
  var cur = 'D';

  function loadChart(intv) {
    var src = 'https://www.tradingview.com/widgetembed/?symbol=OANDA%3AXAUUSD&interval=' + intv + '&hidesidetoolbar=1&symboledit=0&saveimage=0&toolbarbg=f1f3f6&theme=light&timezone=Asia%2FKuala_Lumpur&locale=en';
    iframe.src = src;
  }

  iframe.style.cssText = 'width:100%;height:400px;border:none;border-radius:12px;';
  iframe.allow = 'fullscreen';
  iframe.loading = 'lazy';
  document.getElementById('tvchart').appendChild(iframe);
  loadChart('D');

  document.querySelectorAll('.chart-tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.chart-tab').forEach(function(b) {
        b.classList.remove('active','bg-primary','text-white');
        b.classList.add('bg-gray-100','dark:bg-slate-700','text-muted');
      });
      this.classList.add('active','bg-primary','text-white');
      this.classList.remove('bg-gray-100','dark:bg-slate-700','text-muted');
      var intv = this.getAttribute('data-int');
      if (intv !== cur) { cur = intv; loadChart(intv); }
    });
  });
})();
</script>
</Layout>
