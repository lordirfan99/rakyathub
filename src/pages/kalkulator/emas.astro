---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator Emas',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/" class="text-sm text-muted hover:text-amber-600 transition-colors">← Laman Utama</a>
    </div>
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
      <span class="text-4xl mr-2">📈</span> Kalkulator Emas
    </h1>
    <p class="text-xl text-muted mb-8">
      Semak harga emas harian, spread, dan beza harga Public Gold vs kedai emas.
    </p>

    <div class="bg-amber-50 dark:bg-slate-800/50 rounded-2xl p-8 mb-8 text-center">
      <p class="text-lg text-muted">Kalkulator interaktif sedang dibina. Nantikan!</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6">
        <h3 class="font-semibold text-lg mb-2">🟡 Harga Harian</h3>
        <p class="text-muted text-sm">Semak harga emas 24K, 22K dan 18K terkini di Malaysia.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6">
        <h3 class="font-semibold text-lg mb-2">📊 Kira Spread</h3>
        <p class="text-muted text-sm">Bandingkan spread antara Public Gold, kedai emas dan GAP.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6">
        <h3 class="font-semibold text-lg mb-2">💎 Pulangan Pelaburan</h3>
        <p class="text-muted text-sm">Kira pulangan pelaburan emas berdasarkan harga belian semasa.</p>
      </div>
    </div>

    <div class="bg-gradient-to-r from-amber-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 rounded-2xl p-8">
      <h3 class="text-xl font-bold mb-2">📚 Artikel Berkaitan Emas</h3>
      <p class="text-muted mb-4">Baca panduan lengkap tentang pelaburan emas di blog kami.</p>
      <a href="/blog/emas" class="inline-flex items-center text-amber-600 font-medium hover:underline">Lihat Artikel Emas →</a>
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Kalkulator Lain', href: '/' },
    ]}
  >
    <Fragment slot="title">Nak Kira ASB atau KWSP?</Fragment>
    <Fragment slot="subtitle">Semua kalkulator percuma, tak perlu daftar.</Fragment>
  </CallToAction>
</Layout>
