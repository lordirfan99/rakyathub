---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator Gaji Bersih Malaysia — Take-Home Pay',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/kalkulator" class="text-sm text-muted hover:text-primary transition-colors">← Semua Kalkulator</a>
    </div>

    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">
      Kalkulator Gaji Bersih Malaysia
    </h1>
    <p class="text-lg md:text-xl text-muted mb-8">
      Kira gaji bersih selepas potongan KWSP, SOCSO, EIS dan PCB. Hasil anggaran berdasarkan kadar 2025/2026.
    </p>

    <!-- Calculator Card -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <div class="grid md:grid-cols-2 gap-4 md:gap-6">
        <div>
          <label for="gaji" class="block text-sm font-semibold text-default mb-1.5">Gaji Pokok (RM)</label>
          <input type="number" id="gaji" value="3500" min="0" step="100"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="kwsp" class="block text-sm font-semibold text-default mb-1.5">Caruman KWSP Pekerja</label>
          <select id="kwsp"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
            <option value="11">11% (Standard)</option>
            <option value="9">9% (Opsional)</option>
            <option value="7">7% (Kurang)</option>
            <option value="5">5% (Minimum)</option>
            <option value="0">0% (Tiada)</option>
          </select>
        </div>
        <div>
          <label for="bonus" class="block text-sm font-semibold text-default mb-1.5">Bonus (RM) - jika ada</label>
          <input type="number" id="bonus" value="0" min="0" step="100"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="pcb" class="block text-sm font-semibold text-default mb-1.5">PCB (Cukai Bulanan)</label>
          <select id="pcb"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
            <option value="auto">Kira Automatik</option>
            <option value="0">Tiada PCB</option>
            <option value="50">RM 50/bln</option>
            <option value="100">RM 100/bln</option>
            <option value="200">RM 200/bln</option>
            <option value="500">RM 500/bln</option>
          </select>
        </div>
      </div>

      <!-- Results -->
      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl bg-blue-50 dark:bg-blue-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Gaji Pokok</p>
          <p class="text-lg font-bold text-default" id="gbGaji">RM 3,500.00</p>
        </div>
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Jumlah Potongan</p>
          <p class="text-lg font-bold text-amber-600" id="gbPotongan">RM 0.00</p>
        </div>
        <div class="rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">KWSP + SOCSO</p>
          <p class="text-lg font-bold text-emerald-700" id="gbKwsp">RM 0.00</p>
        </div>
        <div class="rounded-xl bg-primary/10 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Gaji Bersih</p>
          <p class="text-lg font-bold text-primary" id="gbBersih">RM 0.00</p>
        </div>
      </div>

      <div class="mt-6 p-5 rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/5 border border-primary/20 text-center">
        <p class="text-sm text-muted" id="gbLabel">Take-Home Pay</p>
        <p class="text-3xl md:text-4xl font-bold text-primary" id="gbProjected">RM 0</p>
        <p class="text-xs text-muted mt-1" id="gbDetail">*Anggaran berdasarkan kadar 2026.</p>
      </div>
    </div>

    <!-- Deduction Table -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">📊 Pecahan Potongan</h2>
      <div class="overflow-x-auto -mx-5 md:-mx-0">
        <div class="min-w-[400px] px-5 md:px-0">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100 dark:border-slate-700">
                <th class="text-left py-3 px-2 font-semibold text-muted">Komponen</th>
                <th class="text-right py-3 px-2 font-semibold text-muted">Jumlah (RM)</th>
              </tr>
            </thead>
            <tbody id="gbTable"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- DocuKilat CTA -->
    <div class="rounded-2xl bg-gradient-to-br from-primary/10 via-primary/[0.03] to-secondary/10 border border-primary/20 p-6 md:p-8 text-center mb-8">
      <h3 class="text-xl md:text-2xl font-bold mb-2">📄 Perlu Slip Gaji atau Surat Tawaran Kerja?</h3>
      <p class="text-muted mb-4">Guna DocuKilat untuk bina surat rasmi berkaitan pekerjaan dengan AI.</p>
      <a href="https://docukilat.rakyathub.my" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-primary to-secondary text-white font-semibold text-sm transition-all duration-300 hover:shadow-lg hover:shadow-primary/30 hover:scale-[1.02]">
        Bina Dokumen di DocuKilat
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

    <!-- Info Cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">🏦 KWSP</h3>
        <p class="text-muted text-sm">Caruman wajib 11% pekerja + 12% majikan untuk simpanan persaraan.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">🛡️ SOCSO &amp; EIS</h3>
        <p class="text-muted text-sm">Perlindungan sosial dan insurans pekerjaan mengikut kadar gaji semasa.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">💰 PCB</h3>
        <p class="text-muted text-sm">Potongan Cukai Bulanan — dikira automatik berdasarkan julat gaji anda.</p>
      </div>
    </div>

    <!-- Related Articles -->
    <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6 md:p-8">
      <h3 class="text-xl font-bold mb-4">📚 Artikel Berkaitan</h3>
      <ul class="space-y-2">
        <li>
          <a href="/gaji-rm1800-breakdown-realistik/" class="text-primary font-medium hover:underline text-sm">
            → Gaji RM1,800 Sebulan — Nak Hidup &amp; Jimat Duit?
          </a>
        </li>
        <li>
          <a href="/cadangan-bajet-50-30-20-di-malaysia/" class="text-primary font-medium hover:underline text-sm">
            → Bajet 50/30/20 — Cara Urus Wang Dengan Bijak
          </a>
        </li>
        <li>
          <a href="/cara-simpan-duit-gaji-rm2500/" class="text-primary font-medium hover:underline text-sm">
            → Cara Simpan Duit Gaji RM2,500 Sebulan
          </a>
        </li>
      </ul>
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'STR &amp; SARA Checker', href: '/kalkulator/str-sara' },
      { variant: 'secondary', text: 'Kalkulator SST', href: '/kalkulator/sst' },
    ]}
  >
    <Fragment slot="title">Nak Kira STR/SARA atau SST?</Fragment>
    <Fragment slot="subtitle">Semua kalkulator percuma — guna sekarang.</Fragment>
  </CallToAction>
  <script is:inline>
function fmt(v) { return 'RM ' + (typeof v === 'number' && !isNaN(v) && isFinite(v) ? v.toLocaleString('ms-MY', {minimumFractionDigits:2,maximumFractionDigits:2}) : '0.00'); }
function sn(v, d) { var n = parseFloat(v); return (!isNaN(n) && isFinite(n) && n >= 0) ? n : (d || 0); }
function calc() {
  var g = sn(document.getElementById('gaji').value, 3500);
  var kw = parseInt(document.getElementById('kwsp').value) || 11;
  var b = sn(document.getElementById('bonus').value, 0);
  var pv = document.getElementById('pcb').value;
  var ks = Math.round(g*kw/100);
  var soc=0;
  if(g<=30)soc=2.5;else if(g<=100)soc=5;else if(g<=200)soc=10;else if(g<=400)soc=18;else if(g<=600)soc=28;else if(g<=800)soc=38;else if(g<=1000)soc=47;else if(g<=1200)soc=56;else if(g<=1400)soc=63;else if(g<=1600)soc=70;else if(g<=1800)soc=76;else if(g<=2000)soc=82;else if(g<=2200)soc=88;else if(g<=2400)soc=93;else if(g<=2600)soc=97;else if(g<=2800)soc=101;else if(g<=3000)soc=105;else if(g<=3200)soc=109;else if(g<=3400)soc=112;else if(g<=3600)soc=115;else if(g<=3800)soc=118;else if(g<=4000)soc=121;else if(g<=4200)soc=124;else if(g<=4400)soc=127;else if(g<=4600)soc=130;else if(g<=4800)soc=132;else if(g<=5000)soc=134;else soc=Math.round(g*0.028);
  soc=Math.round(soc);
  var eis=0;
  if(g<=30)eis=0.5;else if(g<=100)eis=1;else if(g<=200)eis=2;else if(g<=400)eis=3;else if(g<=600)eis=5;else if(g<=800)eis=7;else if(g<=1000)eis=8;else if(g<=1200)eis=10;else if(g<=1400)eis=11;else if(g<=1600)eis=13;else if(g<=1800)eis=14;else if(g<=2000)eis=15;else if(g<=2200)eis=17;else if(g<=2400)eis=18;else if(g<=2600)eis=19;else if(g<=2800)eis=20;else if(g<=3000)eis=21;else if(g<=3200)eis=22;else if(g<=3400)eis=23;else if(g<=3600)eis=24;else if(g<=3800)eis=25;else if(g<=4000)eis=26;else if(g<=4200)eis=27;else if(g<=4400)eis=28;else if(g<=4600)eis=29;else if(g<=4800)eis=30;else if(g<=5000)eis=31;else eis=Math.round(g*0.006);
  eis=Math.round(eis);
  var pcb=0;
  if(pv==='auto'){if(g>5000)pcb=Math.round(g*0.08);else if(g>4000)pcb=Math.round(g*0.04);else if(g>3000)pcb=Math.round(g*0.02);else pcb=0;}
  else pcb=parseInt(pv);
  var tp = ks+soc+eis+pcb;
  var gajiBersih = g - tp;
  document.getElementById('gbGaji').textContent = fmt(g);
  document.getElementById('gbPotongan').textContent = fmt(tp);
  document.getElementById('gbKwsp').textContent = fmt(ks+soc);
  document.getElementById('gbBersih').textContent = fmt(gajiBersih);
  document.getElementById('gbProjected').textContent = fmt(gajiBersih);
  document.getElementById('gbLabel').textContent = 'Take-Home Pay: RM ' + gajiBersih.toLocaleString() + ' dari RM ' + g.toLocaleString();
  document.getElementById('gbDetail').textContent = 'Potongan ' + Math.round(tp/g*100) + '% untuk KWSP (' + kw + '%), SOCSO, EIS & PCB';
  var tb = document.getElementById('gbTable');
  var fr = document.createDocumentFragment();
  var items = [
    {l:'Gaji Pokok',v:g,p:false},
    {l:'KWSP Pekerja ('+kw+'%)',v:ks,p:true},
    {l:'SOCSO',v:soc,p:true},
    {l:'EIS',v:eis,p:true},
    {l:'PCB',v:pcb,p:true},
    {l:'JUMLAH POTONGAN',v:tp,p:true,hl:true},
    {l:'GAJI BERSIH',v:gajiBersih,p:false,hl:true},
  ];
  items.forEach(function(i){
    var tr=document.createElement('tr');
    tr.className=(i.hl?'font-bold bg-primary/5':'border-b border-gray-50 dark:border-slate-800');
    var td1=document.createElement('td'); td1.className='py-2.5 px-2'; td1.textContent=i.l;
    var td2=document.createElement('td'); 
    td2.className='text-right py-2.5 px-2 text-default'+(i.p?' text-amber-600':''); 
    td2.textContent=(i.p?'-':'')+fmt(i.v);
    tr.appendChild(td1); tr.appendChild(td2); fr.appendChild(tr);
  });
  tb.textContent=''; tb.appendChild(fr);
}
['gaji','kwsp','bonus','pcb'].forEach(function(id){var el=document.getElementById(id);if(el){el.addEventListener('input',calc);el.addEventListener('change',calc);}});
calc();
</script>
</Layout>
