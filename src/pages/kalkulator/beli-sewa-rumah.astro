---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Beli vs Sewa Rumah — Perbandingan Kos',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8"><a href="/kalkulator" class="text-sm text-muted hover:text-primary transition-colors">← Semua Kalkulator</a></div>
    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Beli vs Sewa Rumah</h1>
    <p class="text-lg md:text-xl text-muted mb-8">Bandingkan kos membeli rumah vs menyewa dalam tempoh 5, 10 atau 20 tahun. Kiraan termasuk faedah pinjaman, guaman dan kenaikan sewa tahunan.</p>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <div class="grid md:grid-cols-2 gap-4 md:gap-6">
        <div><label for="bh" class="block text-sm font-semibold text-default mb-1.5">Harga Rumah (RM)</label><input type="number" id="bh" value="400000" min="0" step="10000" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"></div>
        <div><label for="bs" class="block text-sm font-semibold text-default mb-1.5">Sewa Bulanan (RM)</label><input type="number" id="bs" value="1500" min="0" step="100" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"></div>
        <div><label for="bt" class="block text-sm font-semibold text-default mb-1.5">Tempoh (tahun)</label><input type="number" id="bt" value="10" min="1" max="35" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"></div>
        <div><label for="bf" class="block text-sm font-semibold text-default mb-1.5">Kadar Faedah (% setahun)</label><input type="number" id="bf" value="4.0" min="0" step="0.1" max="10" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"></div>
        <div><label for="bm" class="block text-sm font-semibold text-default mb-1.5">Bayaran Muka (RM)</label><input type="number" id="bm" value="40000" min="0" step="5000" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"></div>
        <div><label for="bn" class="block text-sm font-semibold text-default mb-1.5">Kenaikan Sewa (% setahun)</label><input type="number" id="bn" value="3" min="0" step="0.5" max="20" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"></div>
      </div>

      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl bg-blue-50 dark:bg-blue-900/20 p-4 text-center"><p class="text-xs text-muted uppercase tracking-wide">Beli (total)</p><p class="text-lg font-bold text-default" id="blTotalBeli">RM 0</p></div>
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center"><p class="text-xs text-muted uppercase tracking-wide">Sewa (total)</p><p class="text-lg font-bold text-amber-600" id="blTotalSewa">RM 0</p></div>
        <div class="rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4 text-center"><p class="text-xs text-muted uppercase tracking-wide">Ekuiti</p><p class="text-lg font-bold text-emerald-700" id="blEkuiti">RM 0</p></div>
        <div class="rounded-xl bg-primary/10 p-4 text-center"><p class="text-xs text-muted uppercase tracking-wide">Lebih Jimat</p><p class="text-lg font-bold text-primary" id="blJimat">-</p></div>
      </div>

      <div class="mt-6 p-5 rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/5 border border-primary/20 text-center">
        <p class="text-sm text-muted" id="blLabel">Kesimpulan</p>
        <p class="text-3xl md:text-4xl font-bold text-primary" id="blProjected">RM 0</p>
        <p class="text-xs text-muted mt-1" id="blDetail">*Kos termasuk guaman &amp; penyelenggaraan.</p>
      </div>
    </div>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">📊 Perbandingan Tahunan</h2>
      <div class="overflow-x-auto -mx-5 md:-mx-0"><div class="min-w-[500px] px-5 md:px-0">
        <table class="w-full text-sm"><thead><tr class="border-b border-gray-100 dark:border-slate-700"><th class="text-left py-3 px-2 font-semibold text-muted">Tahun</th><th class="text-right py-3 px-2 font-semibold text-muted">Beli (RM)</th><th class="text-right py-3 px-2 font-semibold text-muted">Sewa (RM)</th><th class="text-right py-3 px-2 font-semibold text-muted">Baki Pinjaman</th></tr></thead><tbody id="blTable"></tbody></table>
      </div></div>
    </div>

    <div class="rounded-2xl bg-gradient-to-br from-primary/10 via-primary/[0.03] to-secondary/10 border border-primary/20 p-6 md:p-8 text-center mb-8">
      <h3 class="text-xl md:text-2xl font-bold mb-2">📄 Perlu Surat Tawaran Rumah atau Perjanjian Sewa?</h3>
      <p class="text-muted mb-4">Guna DocuKilat untuk bina dokumen hartanah seperti surat tawaran dan perjanjian sewa.</p>
      <a href="https://docukilat.netlify.app" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-primary to-secondary text-white font-semibold text-sm transition-all duration-300 hover:shadow-lg hover:shadow-primary/30 hover:scale-[1.02]">Bina Dokumen di DocuKilat<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg></a>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover"><h3 class="font-semibold text-lg mb-2">🏠 Kos Beli</h3><p class="text-muted text-sm">Termasuk muka, ansuran, guaman &amp; duti setem (~5%), penyelenggaraan 0.5%/thn.</p></div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover"><h3 class="font-semibold text-lg mb-2">🔑 Kos Sewa</h3><p class="text-muted text-sm">Pembayaran bulanan dengan kenaikan 3% setahun. Tiada ekuiti terkumpul.</p></div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover"><h3 class="font-semibold text-lg mb-2">⚖️ Keputusan</h3><p class="text-muted text-sm">Bandingkan jumlah kos dan tentukan pilihan paling jimat.</p></div>
    </div>

    <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6 md:p-8">
      <h3 class="text-xl font-bold mb-4">📚 Artikel Berkaitan</h3>
      <ul class="space-y-2">
        <li><a href="/cadangan-bajet-50-30-20-di-malaysia/" class="text-primary font-medium hover:underline text-sm">→ Bajet 50/30/20 — Cara Urus Wang Dengan Bijak</a></li>
        <li><a href="/cara-simpan-duit-gaji-rm2500/" class="text-primary font-medium hover:underline text-sm">→ Cara Simpan Duit Gaji RM2,500 Sebulan</a></li>
        <li><a href="/7-kelebihan-simpanan-asb-pelaburan-bijak/" class="text-primary font-medium hover:underline text-sm">→ 7 Kelebihan Simpanan ASB Yang Ramai Tak Tahu</a></li>
      </ul>
    </div>
  </section>

  <CallToAction actions={[ { variant: 'primary', text: 'Kalkulator Gaji Bersih', href: '/kalkulator/gaji-bersih' }, { variant: 'secondary', text: 'STR &amp; SARA Checker', href: '/kalkulator/str-sara' } ]}>
    <Fragment slot="title">Nak Kira Gaji Bersih?</Fragment>
    <Fragment slot="subtitle">Semua kalkulator percuma — guna sekarang.</Fragment>
  </CallToAction>
  <script is:inline>
function fmt(v) { return 'RM ' + (typeof v === 'number' && !isNaN(v) && isFinite(v) ? v.toLocaleString('ms-MY', {minimumFractionDigits:2,maximumFractionDigits:2}) : '0.00'); }
function sn(v, d) { var n = parseFloat(v); return (!isNaN(n) && isFinite(n) && n >= 0) ? n : (d || 0); }
function calc() {
  var h=sn(document.getElementById('bh').value,400000);var s=sn(document.getElementById('bs').value,1500);
  var t=parseInt(document.getElementById('bt').value)||10;var f=sn(document.getElementById('bf').value,4);
  var m=sn(document.getElementById('bm').value,40000);var ns=sn(document.getElementById('bn').value,3);
  var loan=h-m;var r=f/100/12;var n=t*12;
  var bulanan=(loan*(r*Math.pow(1+r,n)))/(Math.pow(1+r,n)-1);
  var totalBeli=m+h*0.05;for(var y=1;y<=t;y++){for(var mo=1;mo<=12;mo++){totalBeli+=bulanan;}totalBeli+=h*0.005;}totalBeli=Math.round(totalBeli);
  var totalSewa=0,sewaNow=s;for(var y=1;y<=t;y++){for(var mo=1;mo<=12;mo++){totalSewa+=sewaNow;}sewaNow*=(1+ns/100);}totalSewa=Math.round(totalSewa);
  var balance=loan;for(var i=1;i<=n;i++){balance-=(bulanan-balance*r);}
  var equity=h-Math.max(0,balance);var better=totalBeli<totalSewa?'BELI':'SEWA';var saving=Math.abs(totalBeli-totalSewa);
  document.getElementById('blTotalBeli').textContent=fmt(totalBeli);
  document.getElementById('blTotalSewa').textContent=fmt(totalSewa);
  document.getElementById('blEkuiti').textContent=fmt(Math.max(0,equity));
  document.getElementById('blJimat').textContent=better+' (jimat RM '+saving.toLocaleString()+')';
  document.getElementById('blProjected').textContent=fmt(Math.min(totalBeli,totalSewa));
  document.getElementById('blLabel').textContent='Paling Jimat: '+better+' Rumah - Ansuran RM '+Math.round(bulanan).toLocaleString()+'/bln vs Sewa RM '+Math.round(s).toLocaleString()+'/bln';
  document.getElementById('blDetail').textContent='Beza RM '+saving.toLocaleString()+' dalam '+t+' tahun';
  var tb=document.getElementById('blTable');var fr=document.createDocumentFragment();var bal=loan;
  for(var y=1;y<=t;y++){
    var yrBeli=0;for(var mo=1;mo<=12;mo++){var inter=bal*r;var prin=bulanan-inter;bal-=prin;yrBeli+=bulanan;}
    var yrSewa=s*12;s*=1+ns/100;
    var tr=document.createElement('tr');tr.className=(y===t?'font-bold bg-primary/5':'border-b border-gray-50 dark:border-slate-800');
    [y,Math.round(yrBeli),Math.round(yrSewa),Math.round(Math.max(0,bal))].forEach(function(v,i){
      var td=document.createElement('td');td.className='py-2.5 px-2'+(i>0?' text-right':'');td.textContent=i>0?fmt(v):String(v);tr.appendChild(td);
    });fr.appendChild(tr);
  }
  tb.textContent='';tb.appendChild(fr);
}
['bh','bs','bt','bf','bm','bn'].forEach(function(id){var el=document.getElementById(id);if(el){el.addEventListener('input',calc);el.addEventListener('change',calc);}});calc();
</script>
<script is:inline>
(function(){var x=new XMLHttpRequest();x.open('GET','/data/kewangan-harga.json',true);x.onload=function(){if(x.status!==200)return;try{var d=JSON.parse(x.responseText);if(!d)return;if(d.kadar&&d.kadar.housing_loan_pct){['interest','bf'].forEach(function(id){var el=document.getElementById(id);if(!el)return;var v=parseFloat(el.value);if(id==='interest'&&(v===4.5||v===4||v===4.25))el.value=d.kadar.housing_loan_pct;if(id==='bf'&&(v===4||v===4.5||v===3.5))el.value=d.kadar.housing_loan_pct;});}if(typeof calc==='function')calc();}catch(e){}};x.send();})();
</script>
</Layout>
