---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator PCB & Cukai Pendapatan — Anggaran Cukai 2026',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/kalkulator" class="text-sm text-muted hover:text-primary transition-colors">← Semua Kalkulator</a>
    </div>

    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">
      Kalkulator PCB & Cukai Pendapatan
    </h1>
    <p class="text-lg md:text-xl text-muted mb-8">
      Kira anggaran PCB bulanan dan cukai pendapatan tahunan berdasarkan gaji dan pelepasan mengikut jadual LHDN 2026.
    </p>

    <!-- Calculator Card -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <div class="grid md:grid-cols-2 gap-4 md:gap-6">
        <div>
          <label for="gaji" class="block text-sm font-semibold text-default mb-1.5">Gaji Bulanan (RM)</label>
          <input type="number" id="gaji" value="4000" min="500" step="100"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="bonus" class="block text-sm font-semibold text-default mb-1.5">Bonus Tahunan (RM)</label>
          <input type="number" id="bonus" value="0" min="0" step="500"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="pelepasan" class="block text-sm font-semibold text-default mb-1.5">Jumlah Pelepasan Cukai (RM/thn)</label>
          <input type="number" id="pelepasan" value="13000" min="0" step="500"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="status" class="block text-sm font-semibold text-default mb-1.5">Status Cukai</label>
          <select id="status"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
            <option value="ka" selected>Bujang (KA)</option>
            <option value="kb">Kahwin tiada tanggungan (KB)</option>
            <option value="kc">Kahwin & pasangan kerja (KC / KCCC)</option>
            <option value="kd">Kahwin 1-3 anak (KD)</option>
            <option value="ke">Kahwin 4+ anak (KE)</option>
          </select>
        </div>
      </div>

      <!-- Results -->
      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl bg-blue-50 dark:bg-blue-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Pendapatan Tahunan</p>
          <p class="text-lg font-bold text-default" id="hasilPendapatan">RM 48,000</p>
        </div>
        <div class="rounded-xl bg-primary/10 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Anggaran PCB Bulanan</p>
          <p class="text-lg font-bold text-primary" id="hasilPCB">RM 0.00</p>
        </div>
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Cukai Kena Bayar</p>
          <p class="text-lg font-bold text-amber-600" id="hasilCukai">RM 0.00</p>
        </div>
        <div class="rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Rebat / Lebihan</p>
          <p class="text-lg font-bold text-emerald-700" id="hasilRebat">RM 0.00</p>
        </div>
      </div>

      <!-- Summary Cards -->
      <div class="mt-6 grid md:grid-cols-2 gap-4">
        <div class="p-5 rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/5 border border-primary/20 text-center">
          <p class="text-sm text-muted">Pendapatan Bercukai</p>
          <p class="text-3xl md:text-4xl font-bold text-primary" id="hasilBercukai">RM 0</p>
        </div>
        <div class="p-5 rounded-2xl bg-gradient-to-br from-amber-50 to-amber-100/10 dark:from-amber-900/20 dark:to-amber-900/5 border border-amber-200/30 text-center">
          <p class="text-sm text-muted">Kadar Cukai Efektif</p>
          <p class="text-3xl md:text-4xl font-bold text-amber-600" id="hasilKadar">0%</p>
        </div>
      </div>
    </div>

    <!-- Bracket Table -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">Jadual Kadar Cukai 2026 (Individu)</h2>
      <div class="overflow-x-auto -mx-5 md:-mx-0">
        <div class="min-w-[500px] px-5 md:px-0">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100 dark:border-slate-700">
                <th class="text-left py-2 px-2 font-semibold text-muted">Pendapatan Bercukai</th>
                <th class="text-right py-2 px-2 font-semibold text-muted">Kadar</th>
                <th class="text-right py-2 px-2 font-semibold text-muted">Cukai Asas</th>
                <th class="text-right py-2 px-2 font-semibold text-muted">Cukai Atas Lebihan</th>
              </tr>
            </thead>
            <tbody id="bracketTable">
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- DocuKilat CTA -->
    <div class="rounded-2xl bg-gradient-to-br from-primary/10 via-primary/[0.03] to-secondary/10 border border-primary/20 p-6 md:p-8 text-center mb-8">
      <h3 class="text-xl md:text-2xl font-bold mb-2">Nak Hantar e-Filing?</h3>
      <p class="text-muted mb-4">Guna DocuKilat untuk buat resume, surat pengesahan pendapatan, atau dokumen sokongan cukai anda.</p>
      <a href="/docukilat/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-primary to-secondary text-white font-semibold text-sm transition-all duration-300 hover:shadow-lg hover:shadow-primary/30 hover:scale-[1.02]">
        Bina Dokumen di DocuKilat
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

    <!-- Info Cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">Pelepasan Cukai 2026</h3>
        <p class="text-muted text-sm">Individu: RM9,000 · SSPN: RM8,000 · Insurans: RM3,000 · KWSP: RM4,000 · Gaya hidup: RM2,500. Isi pelepasan mengikut kelayakan.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">Rebat Cukai</h3>
        <p class="text-muted text-sm">Rebat RM400 jika pendapatan bercukai ≤ RM35,000. Isteri/Suami: RM4,000. Anak bawah 18: RM2,000 setiap seorang.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">e-Filing Deadline</h3>
        <p class="text-muted text-sm">e-Filing untuk individu (tiada perniagaan): 30 April 2027. Jangan tunggu last minute!</p>
      </div>
    </div>

    <!-- Related -->
    <div class="rounded-2xl bg-gradient-to-br from-amber-50 to-orange-50 dark:from-slate-800 dark:to-slate-800 border border-amber-100 dark:border-slate-700 p-6 md:p-8 mb-8">
      <h3 class="text-xl font-bold mb-4">Artikel Berkaitan Cukai</h3>
      <ul class="space-y-2">
        <li>
          <a href="/panduan-e-filing-cukai-pendapatan-2026/" class="text-primary font-medium hover:underline text-sm">
            → Panduan e-Filing Cukai Pendapatan 2026
          </a>
        </li>
        <li>
          <a href="/pelepasan-cukai-malaysia-2026-panduan-lengkap-rebat-potongan/" class="text-primary font-medium hover:underline text-sm">
            → Pelepasan Cukai Malaysia 2026 – Rebat & Potongan
          </a>
        </li>
        <li>
          <a href="/kalkulator/gaji-bersih/" class="text-primary font-medium hover:underline text-sm">
            → Kalkulator Gaji Bersih
          </a>
        </li>
      </ul>
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Kalkulator Gaji Bersih', href: '/kalkulator/gaji-bersih/' },
      { variant: 'secondary', text: 'Kalkulator KWSP', href: '/kalkulator/kwsp/' },
    ]}
  >
    <Fragment slot="title">Nak Kira Gaji Bersih atau KWSP?</Fragment>
    <Fragment slot="subtitle">Semua kalkulator percuma, tak perlu daftar.</Fragment>
  </CallToAction>

  <script is:inline>
// Tax brackets Malaysia 2026 (individual — progressive)
var BRACKETS = [
  { max: 5000, rate: 0, base: 0 },
  { max: 20000, rate: 1, base: 0 },
  { max: 35000, rate: 3, base: 150 },
  { max: 50000, rate: 8, base: 600 },
  { max: 70000, rate: 14, base: 1800 },
  { max: 100000, rate: 21, base: 4600 },
  { max: 250000, rate: 24, base: 10900 },
  { max: 400000, rate: 25, base: 46900 },
  { max: 600000, rate: 26, base: 84400 },
  { max: 1000000, rate: 28, base: 136400 },
  { max: 2000000, rate: 30, base: 248400 },
  { max: Infinity, rate: 33, base: 548400 },
];

// Rebate threshold
var REBATE_MAX_INCOME = 35000;
var REBATE_AMOUNT = 400;

function fmt(v) {
  return 'RM ' + (typeof v === 'number' && !isNaN(v) && isFinite(v) ? v.toLocaleString('ms-MY', {minimumFractionDigits:2,maximumFractionDigits:2}) : '0.00');
}

function fmtInt(v) {
  return 'RM ' + (typeof v === 'number' && !isNaN(v) && isFinite(v) ? Math.round(v).toLocaleString('ms-MY') : '0');
}

function sn(v, d) {
  var n = parseFloat(v);
  return (!isNaN(n) && isFinite(n) && n >= 0) ? n : (d || 0);
}

function calcTax(income) {
  if (income <= 0) return 0;
  for (var i = 0; i < BRACKETS.length; i++) {
    if (income <= BRACKETS[i].max) {
      var prevMax = i > 0 ? BRACKETS[i-1].max : 0;
      return BRACKETS[i].base + ((income - prevMax) * BRACKETS[i].rate / 100);
    }
  }
  return BRACKETS[BRACKETS.length-1].base + ((income - BRACKETS[BRACKETS.length-1].max) * BRACKETS[BRACKETS.length-1].rate / 100);
}

function calc() {
  var gajiBulanan = sn(document.getElementById('gaji').value, 4000);
  var bonusTahunan = sn(document.getElementById('bonus').value, 0);
  var pelepasan = sn(document.getElementById('pelepasan').value, 13000);
  var status = document.getElementById('status').value;

  var gajiTahunan = gajiBulanan * 12 + bonusTahunan;
  var pendapatanBercukai = Math.max(0, gajiTahunan - pelepasan);

  // Personal relief RM9,000 is included in pelepasan input
  var cukai = calcTax(pendapatanBercukai);

  // Rebate
  var rebat = 0;
  if (pendapatanBercukai <= REBATE_MAX_INCOME && cukai > 0) {
    rebat = Math.min(REBATE_AMOUNT, cukai);
  }

  var cukaiFinal = cukai - rebat;
  var pcbBulanan = cukaiFinal / 12;

  // Display
  document.getElementById('hasilPendapatan').textContent = fmtInt(gajiTahunan);
  document.getElementById('hasilPCB').textContent = fmt(pcbBulanan);
  document.getElementById('hasilCukai').textContent = fmt(cukaiFinal);
  document.getElementById('hasilRebat').textContent = fmt(rebat);
  document.getElementById('hasilBercukai').textContent = fmtInt(pendapatanBercukai);
  document.getElementById('hasilKadar').textContent = (gajiTahunan > 0 ? (cukaiFinal / gajiTahunan * 100).toFixed(1) : '0.0') + '%';
}

// Input events
['gaji','bonus','pelepasan','status'].forEach(function(id) {
  var el = document.getElementById(id);
  if (el) { el.addEventListener('input', calc); el.addEventListener('change', calc); }
});

// Render bracket table
(function() {
  var tbody = document.getElementById('bracketTable');
  var prev = 0;
  for (var i = 0; i < BRACKETS.length; i++) {
    var b = BRACKETS[i];
    var range = (b.max === Infinity) ? 'RM ' + prev.toLocaleString('ms-MY') + ' +' : 'RM ' + prev.toLocaleString('ms-MY') + ' — ' + b.max.toLocaleString('ms-MY');
    var tr = document.createElement('tr');
    tr.className = 'border-b border-gray-50 dark:border-slate-700/50';
    tr.innerHTML = '<td class="py-2 px-2 text-default">' + range + '</td>'
      + '<td class="py-2 px-2 text-right text-muted">' + b.rate + '%</td>'
      + '<td class="py-2 px-2 text-right text-muted">' + (b.base > 0 ? 'RM ' + b.base.toLocaleString('ms-MY') : 'RM 0') + '</td>'
      + '<td class="py-2 px-2 text-right text-muted">' + b.rate + '%</td>';
    tbody.appendChild(tr);
    prev = b.max;
  }
})();

calc();
</script>
</Layout>
