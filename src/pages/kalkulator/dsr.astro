---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator DSR — Debt Service Ratio Malaysia',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/kalkulator" class="text-sm text-muted hover:text-primary transition-colors">← Semua Kalkulator</a>
    </div>

    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">
      Kalkulator DSR (Debt Service Ratio)
    </h1>
    <p class="text-lg md:text-xl text-muted mb-8">
      Kira nisbah komitmen bulanan vs pendapatan — bank guna DSR untuk kelulusan pinjaman rumah, kereta, dan personal loan.
    </p>

    <!-- Calculator Card -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <div class="grid md:grid-cols-2 gap-4 md:gap-6">
        <div class="md:col-span-2">
          <label for="gaji" class="block text-sm font-semibold text-default mb-1.5">Pendapatan Bersih Bulanan (RM)</label>
          <input type="number" id="gaji" value="3000" min="0" step="100"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="kereta" class="block text-sm font-semibold text-default mb-1.5">Kereta (RM)</label>
          <input type="number" id="kereta" value="0" min="0" step="50"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="rumah" class="block text-sm font-semibold text-default mb-1.5">Rumah (RM)</label>
          <input type="number" id="rumah" value="0" min="0" step="50"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="ptptn" class="block text-sm font-semibold text-default mb-1.5">PTPTN (RM)</label>
          <input type="number" id="ptptn" value="0" min="0" step="10"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="kadKredit" class="block text-sm font-semibold text-default mb-1.5">Kad Kredit (min payment) (RM)</label>
          <input type="number" id="kadKredit" value="0" min="0" step="50"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="personalLoan" class="block text-sm font-semibold text-default mb-1.5">Personal Loan (RM)</label>
          <input type="number" id="personalLoan" value="0" min="0" step="50"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="lain" class="block text-sm font-semibold text-default mb-1.5">Lain-lain Komitmen (RM)</label>
          <input type="number" id="lain" value="0" min="0" step="50"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
      </div>

      <!-- Results -->
      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl bg-blue-50 dark:bg-blue-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Pendapatan</p>
          <p class="text-lg font-bold text-default" id="hasilGaji">RM 3,000.00</p>
        </div>
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Total Komitmen</p>
          <p class="text-lg font-bold text-amber-600" id="hasilKomitmen">RM 0.00</p>
        </div>
        <div class="rounded-xl bg-primary/10 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">DSR</p>
          <p class="text-2xl font-bold text-primary" id="hasilDSR">0%</p>
        </div>
        <div class="rounded-xl p-4 text-center" id="statusCard">
          <p class="text-xs text-muted uppercase tracking-wide">Status</p>
          <p class="text-lg font-bold" id="hasilStatus">—</p>
        </div>
      </div>

      <!-- DSR Bar Indicator -->
      <div class="mt-4">
        <div class="w-full bg-gray-200 dark:bg-slate-700 rounded-full h-4 overflow-hidden">
          <div id="barDSR" class="h-full rounded-full transition-all duration-500" style="width:0%"></div>
        </div>
        <div class="flex justify-between text-xs text-muted mt-1">
          <span>0%</span>
          <span>60% (Selamat)</span>
          <span>70% (Sempadan)</span>
          <span>100%</span>
        </div>
      </div>
    </div>

    <!-- Info -->
    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">✅ DSR &lt; 60%</h3>
        <p class="text-muted text-sm">Komitmen terkawal. Bank akan lebih mudah meluluskan pinjaman baru. Peluang kelulusan tinggi.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">⚠️ DSR 60% – 70%</h3>
        <p class="text-muted text-sm">Sempadan. Mungkin kena cari cara kurangkan komitmen atau tambah pendapatan sebelum apply loan baru.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">❌ DSR &gt; 70%</h3>
        <p class="text-muted text-sm">Komitmen tinggi. Bank mungkin tolak permohonan pinjaman. Fokus kurangkan hutang dulu.</p>
      </div>
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Kalkulator Gaji Bersih', href: '/kalkulator/gaji-bersih' },
      { variant: 'secondary', text: 'Kalkulator Kereta', href: '/kalkulator/kereta' },
    ]}
  >
    <Fragment slot="title">Nak Kira Kelayakan Pinjaman?</Fragment>
    <Fragment slot="subtitle">Guna kalkulator percuma kami — semua dalam satu tempat.</Fragment>
  </CallToAction>
  <script is:inline>
function fmt(v) { return 'RM ' + (typeof v === 'number' && !isNaN(v) && isFinite(v) ? v.toLocaleString('ms-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) : '0.00'); }
function sn(v, d) { var n = parseFloat(v); return (!isNaN(n) && isFinite(n) && n >= 0) ? n : d || 0; }

function calc() {
  var gaji = sn(document.getElementById('gaji').value, 3000);
  var kereta = sn(document.getElementById('kereta').value, 0);
  var rumah = sn(document.getElementById('rumah').value, 0);
  var ptptn = sn(document.getElementById('ptptn').value, 0);
  var kadKredit = sn(document.getElementById('kadKredit').value, 0);
  var personalLoan = sn(document.getElementById('personalLoan').value, 0);
  var lain = sn(document.getElementById('lain').value, 0);

  var total = kereta + rumah + ptptn + kadKredit + personalLoan + lain;
  var dsr = gaji > 0 ? (total / gaji) * 100 : 0;

  document.getElementById('hasilGaji').textContent = fmt(gaji);
  document.getElementById('hasilKomitmen').textContent = fmt(total);
  document.getElementById('hasilDSR').textContent = dsr.toFixed(1) + '%';

  var statusEl = document.getElementById('hasilStatus');
  var statusCard = document.getElementById('statusCard');
  var barEl = document.getElementById('barDSR');
  var barPct = Math.min(dsr, 100);

  if (dsr < 60) {
    statusEl.textContent = '✅ Selamat';
    statusCard.className = 'rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4 text-center';
    statusEl.className = 'text-lg font-bold text-emerald-700';
    barEl.style.width = barPct + '%';
    barEl.className = 'h-full rounded-full transition-all duration-500 bg-gradient-to-r from-emerald-400 to-emerald-600';
  } else if (dsr < 70) {
    statusEl.textContent = '⚠️ Sempadan';
    statusCard.className = 'rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center';
    statusEl.className = 'text-lg font-bold text-amber-600';
    barEl.style.width = barPct + '%';
    barEl.className = 'h-full rounded-full transition-all duration-500 bg-gradient-to-r from-amber-400 to-orange-500';
  } else {
    statusEl.textContent = '❌ Tinggi Risiko';
    statusCard.className = 'rounded-xl bg-red-50 dark:bg-red-900/20 p-4 text-center';
    statusEl.className = 'text-lg font-bold text-red-600';
    barEl.style.width = barPct + '%';
    barEl.className = 'h-full rounded-full transition-all duration-500 bg-gradient-to-r from-red-400 to-red-600';
  }
}

['gaji','kereta','rumah','ptptn','kadKredit','personalLoan','lain'].forEach(function(id) {
  var el = document.getElementById(id);
  if (el) { el.addEventListener('input', calc); el.addEventListener('change', calc); }
});
calc();
</script>
</Layout>
