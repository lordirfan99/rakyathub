---
import Layout from '~/layouts/PageLayout.astro';
import { DESTINATIONS, ENRICH_ZONES } from '~/data/enrich-library';

const metadata = {
  title: 'Enrich Points Library — Redemption Rates & Destinations | RakyatHub',
  description: 'Semak kadar penebusan Enrich points untuk penerbangan Malaysia Airlines. Banding Economy, Business Saver & Flex rates untuk semua destinasi.',
};

const zonesJson = JSON.stringify(ENRICH_ZONES);
const destsJson = JSON.stringify(DESTINATIONS);
---

<Layout metadata={metadata}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-8 md:py-12">
    <a href="/kalkulator" class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-primary transition-colors mb-6">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Semua Kalkulator
    </a>

    <div class="flex items-center gap-3 mb-6">
      <div class="w-12 h-12 rounded-xl bg-[#001F3F]/5 flex items-center justify-center text-2xl shrink-0">📚</div>
      <div>
        <h1 class="text-2xl sm:text-4xl font-bold tracking-tight">Enrich Points Library</h1>
        <p class="text-sm text-muted mt-1">Kadar penebusan Enrich points untuk penerbangan Malaysia Airlines. Semua destinasi, satu halaman.</p>
      </div>
    </div>

    <!-- Zone Filter -->
    <div class="flex flex-wrap gap-1.5 mb-4" id="zoneFilters">
      <button onclick="filterZone('all')" class="px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors bg-[#001F3F] text-white" id="zone-all">Semua</button>
      {ENRICH_ZONES.map(z => (
        <button onclick={"filterZone('" + z.id + "')"} id={"zone-" + z.id} class="px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors bg-gray-100 dark:bg-slate-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-slate-700">{z.label}</button>
      ))}
    </div>

    <!-- Search -->
    <input type="text" id="searchDest" oninput="filterZone(currentZone)" placeholder="Cari destinasi..." class="w-full px-4 py-2.5 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800/60 text-sm mb-4 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none" />

    <!-- Destinations Table -->
    <div class="rounded-xl border border-gray-100 dark:border-slate-700/30 overflow-hidden bg-white dark:bg-slate-900/40">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 dark:bg-slate-800/60 text-left text-xs text-muted font-semibold uppercase tracking-wider">
              <th class="p-3">Destinasi</th>
              <th class="p-3">Zon</th>
              <th class="p-3 text-right">Economy Saver</th>
              <th class="p-3 text-right">Business Saver</th>
              <th class="p-3 text-right">Economy Flex</th>
              <th class="p-3 text-right">Business Flex</th>
            </tr>
          </thead>
          <tbody id="destTable">
            {DESTINATIONS.filter(d => d.economySaver > 0).map(d => (
              <tr class="dest-row border-t border-gray-100 dark:border-slate-800/60 hover:bg-gray-50 dark:hover:bg-slate-800/40 transition-colors" 
                  data-zone={d.zone} data-search={d.city + ' ' + d.country + ' ' + d.zone}>
                <td class="p-3 font-medium">{d.city}, <span class="text-muted text-xs">{d.country}</span></td>
                <td class="p-3 text-xs text-muted">{ENRICH_ZONES.find(z => z.id === d.zone)?.label || d.zone}</td>
                <td class="p-3 text-right tabular-nums font-semibold">{d.economySaver.toLocaleString()}</td>
                <td class="p-3 text-right tabular-nums font-semibold">{d.businessSaver.toLocaleString()}</td>
                <td class="p-3 text-right tabular-nums">{d.economyFlex.toLocaleString()}</td>
                <td class="p-3 text-right tabular-nums">{d.businessFlex.toLocaleString()}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <p class="text-xs text-muted mt-4">*Saver rates adalah lowest available tier dengan limited seat availability. Taxes, fees & surcharges tidak termasuk. Sumber: Malaysia Airlines Enrich portal.</p>
  </section>

  <script is:inline>
  var currentZone = 'all';
  function filterZone(zone) {
    currentZone = zone;
    document.querySelectorAll('#zoneFilters button').forEach(function(b) {
      b.className = 'px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors bg-gray-100 dark:bg-slate-800 text-gray-600 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-slate-700';
    });
    var btn = document.getElementById('zone-' + zone) || document.getElementById('zone-all');
    if (btn) btn.className = 'px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors bg-[#001F3F] text-white';

    var q = document.getElementById('searchDest').value.toLowerCase().trim();
    document.querySelectorAll('.dest-row').forEach(function(row) {
      var matchZone = zone === 'all' || row.getAttribute('data-zone') === zone;
      var matchSearch = !q || row.getAttribute('data-search').toLowerCase().indexOf(q) >= 0;
      row.style.display = (matchZone && matchSearch) ? '' : 'none';
    });
  }
  </script>
</Layout>
