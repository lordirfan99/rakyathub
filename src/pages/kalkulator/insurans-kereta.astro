---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import InsuranceCalculator from '~/components/blog/InsuranceCalculator.astro';

const metadata = {
  title: 'Insurans Kereta — Kira Premium & Cukai Jalan 2026',
  description: 'Kira premium insurans kereta komprehensif, 3rd party, dan cukai jalan. Guna BNM Motor Tariff — dapatkan anggaran segera tanpa isi borang.',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/kalkulator/" class="text-sm text-muted hover:text-primary transition-colors">← Kalkulator</a>
    </div>

    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Kalkulator Insurans Kereta Malaysia 2026
    </h1>
    <p class="text-lg md:text-xl text-muted mb-8">
      Kira premium insurans kereta ikut jenis kenderaan, CC, NCD, dan lokasi. Bandingkan komprehensif vs 3rd party. Dapatkan anggaran segera.
    </p>

    <!-- Premium Calculator (reused component) -->
    <InsuranceCalculator title="Kira Premium Sekarang" />

    <!-- How It Works -->
    <div class="grid md:grid-cols-3 gap-6 my-10">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover text-center">
        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary/20 to-indigo-500/20 flex items-center justify-center mx-auto mb-3">
          <span class="text-xl">💰</span>
        </div>
        <h3 class="font-semibold text-lg mb-2">Premium Insurans</h3>
        <p class="text-muted text-sm">Kira premium komprehensif dan 3rd party berdasarkan BNM Motor Tariff. Bandingkan sebelum renew.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover text-center">
        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-emerald-500/20 to-teal-500/20 flex items-center justify-center mx-auto mb-3">
          <span class="text-xl">📋</span>
        </div>
        <h3 class="font-semibold text-lg mb-2">NCD Auto-Calculated</h3>
        <p class="text-muted text-sm">Diskaun NCB 0%-55% dikira automatik. Tengok berapa anda boleh jimat dengan rekod bersih.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover text-center">
        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-amber-500/20 to-orange-500/20 flex items-center justify-center mx-auto mb-3">
          <span class="text-xl">🛣️</span>
        </div>
        <h3 class="font-semibold text-lg mb-2">Cukai Jalan</h3>
        <p class="text-muted text-sm">Kira cukai jalan ikut kapasiti enjin. Untuk renew online di MyJPJ, Shopee atau MyEG.</p>
      </div>
    </div>

    <!-- NCD Table -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">Jadual NCD (No Claim Discount)</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 dark:border-slate-700">
              <th class="text-left py-3 px-2 font-semibold text-muted">Tahun Tanpa Tuntutan</th>
              <th class="text-right py-3 px-2 font-semibold text-muted">Diskaun NCD</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-50 dark:border-slate-800"><td class="py-2.5 px-2">Baru / Selepas tuntutan</td><td class="text-right py-2.5 px-2">0%</td></tr>
            <tr class="border-b border-gray-50 dark:border-slate-800"><td class="py-2.5 px-2">1 tahun</td><td class="text-right py-2.5 px-2">25%</td></tr>
            <tr class="border-b border-gray-50 dark:border-slate-800"><td class="py-2.5 px-2">2 tahun</td><td class="text-right py-2.5 px-2">30%</td></tr>
            <tr class="border-b border-gray-50 dark:border-slate-800"><td class="py-2.5 px-2">3 tahun</td><td class="text-right py-2.5 px-2">38.33%</td></tr>
            <tr class="border-b border-gray-50 dark:border-slate-800"><td class="py-2.5 px-2">4 tahun</td><td class="text-right py-2.5 px-2">45%</td></tr>
            <tr class="bg-primary/5 font-bold"><td class="py-2.5 px-2">5+ tahun (Maksimum)</td><td class="text-right py-2.5 px-2">55%</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Comparison Table -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">3rd Party vs Komprehensif — Mana Pilihan Tepat?</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 dark:border-slate-700">
              <th class="text-left py-3 px-2 font-semibold text-muted">Perlindungan</th>
              <th class="text-center py-3 px-2 font-semibold text-muted">3rd Party</th>
              <th class="text-center py-3 px-2 font-semibold text-muted">Komprehensif</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-50 dark:border-slate-800"><td class="py-2.5 px-2">Kerosakan Pihak Ketiga</td><td class="text-center py-2.5 px-2 text-emerald-600 font-bold">✓</td><td class="text-center py-2.5 px-2 text-emerald-600 font-bold">✓</td></tr>
            <tr class="border-b border-gray-50 dark:border-slate-800"><td class="py-2.5 px-2">Kerosakan Kereta Sendiri</td><td class="text-center py-2.5 px-2 text-red-500 font-bold">✗</td><td class="text-center py-2.5 px-2 text-emerald-600 font-bold">✓</td></tr>
            <tr class="border-b border-gray-50 dark:border-slate-800"><td class="py-2.5 px-2">Kecurian</td><td class="text-center py-2.5 px-2 text-red-500 font-bold">✗</td><td class="text-center py-2.5 px-2 text-emerald-600 font-bold">✓</td></tr>
            <tr class="border-b border-gray-50 dark:border-slate-800"><td class="py-2.5 px-2">Kebakaran</td><td class="text-center py-2.5 px-2 text-red-500 font-bold">✗</td><td class="text-center py-2.5 px-2 text-emerald-600 font-bold">✓</td></tr>
            <tr class="border-b border-gray-50 dark:border-slate-800"><td class="py-2.5 px-2">Banjir (add-on)</td><td class="text-center py-2.5 px-2 text-gray-400">Add-on</td><td class="text-center py-2.5 px-2 text-gray-400">Add-on</td></tr>
            <tr><td class="py-2.5 px-2 font-semibold">Premium</td><td class="text-center py-2.5 px-2 text-emerald-700 font-semibold">Paling murah</td><td class="text-center py-2.5 px-2 text-amber-700 font-semibold">Lebih mahal</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- FAQ -->
    <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">Soalan Lazim</h2>
      <div class="space-y-4 text-sm">
        <div><strong class="text-default">Berapa minimum premium insurans kereta?</strong><p class="text-muted mt-1">Insurans 3rd party untuk kereta kecil seperti Axia atau Myvi bermula dari RM150-300/tahun. Komprehensif bergantung pada nilai pasaran — Myvi RM70,000 boleh cecah RM1,200-1,800/tahun. Dengan NCD 55%, premium boleh turun separuh.</p></div>
        <div><strong class="text-default">Adakah NCD hilang kalau buat tuntutan?</strong><p class="text-muted mt-1">Ya. NCD akan reset ke 0% selepas tuntutan. Untuk tuntutan kecil bawah RM1,000, lebih jimat bayar sendiri daripada hilang NCD.</p></div>
        <div><strong class="text-default">Boleh renew insurans kereta online?</strong><p class="text-muted mt-1">Ya. Shopee Insurance, Qoala, PolicyStreet, MyEG, dan Bjak. Shopee ada baucar cukai jalan percuma + cashback RM25.</p></div>
      </div>
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Kalkulator Pinjaman Kereta', href: '/kalkulator/kereta' },
      { variant: 'secondary', text: 'Kalkulator Loan Rumah', href: '/kalkulator/loan-rumah' },
    ]}
  >
    <Fragment slot="title">Nak kira loan kereta atau rumah?</Fragment>
    <Fragment slot="subtitle">Semua kalkulator percuma — guna sekarang.</Fragment>
  </CallToAction>
</Layout>
