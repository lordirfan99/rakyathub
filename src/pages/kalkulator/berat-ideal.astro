---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator Berat Badan Ideal — BMI Ideal Malaysia | RakyatHub',
  description: 'Kira berat badan ideal Malaysia berdasarkan tinggi dan jantina. Guna formula Devine & BMI Asian normal. Percuma.',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8"><a href="/kalkulator" class="text-sm text-muted hover:text-primary transition-colors">← Semua Kalkulator</a></div>
    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Kalkulator Berat Badan Ideal</h1>
    <p class="text-lg md:text-xl text-muted mb-8">Ketahui julat berat badan ideal anda berdasarkan tinggi dan jantina. Guna standard BMI Asian (18.5–22.9) dan formula Devine.</p>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <div class="grid md:grid-cols-2 gap-4 md:gap-6">
        <div><label for="idTinggi" class="block text-sm font-semibold text-default mb-1.5">Tinggi (cm)</label><input type="number" id="idTinggi" value="170" min="50" max="300" step="0.5" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" /></div>
        <div><label class="block text-sm font-semibold text-default mb-1.5">Jantina</label><div class="flex gap-3"><button id="idLelaki" class="flex-1 rounded-xl border-2 border-primary bg-primary/10 px-4 py-3 text-sm font-semibold text-primary" onclick="setGender(true)">Lelaki</button><button id="idPerempuan" class="flex-1 rounded-xl border-2 border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm font-semibold text-default" onclick="setGender(false)">Perempuan</button></div></div>
      </div>
      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl bg-blue-50 dark:bg-blue-900/20 p-4 text-center"><p class="text-xs text-muted uppercase tracking-wide">Devine Formula</p><p class="text-lg font-bold text-default" id="idDevine">65.9 kg</p></div>
        <div class="rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4 text-center"><p class="text-xs text-muted uppercase tracking-wide">Min Ideal (Asian)</p><p class="text-lg font-bold text-emerald-700" id="idMin">53.5 kg</p></div>
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center"><p class="text-xs text-muted uppercase tracking-wide">Maks Ideal (Asian)</p><p class="text-lg font-bold text-amber-700" id="idMax">66.2 kg</p></div>
        <div class="rounded-xl bg-primary/10 p-4 text-center"><p class="text-xs text-muted uppercase tracking-wide">Julat Ideal</p><p class="text-lg font-bold text-primary" id="idJulat">53.5 — 66.2 kg</p></div>
      </div>
      <div class="mt-4 p-5 rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/5 border border-primary/20 text-center"><p class="text-sm text-muted">Untuk tinggi <strong id="idTinggiLabel">170 cm</strong></p><p class="text-3xl md:text-4xl font-bold text-primary" id="idKesimpulan">53.5 kg — 66.2 kg</p></div>
    </div>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">Cara Kira Berat Ideal</h2>
      <ul class="text-muted text-sm space-y-1 mb-3">
        <li>• <strong>Lelaki:</strong> 50 kg + 0.9 kg setiap cm lebih dari 152.4 cm</li>
        <li>• <strong>Perempuan:</strong> 45.5 kg + 0.9 kg setiap cm lebih dari 152.4 cm</li>
        <li>• Julat Asian Normal: BMI 18.5–22.9 × [tinggi(m)]²</li>
      </ul>
      <p class="text-muted text-sm">WHO syorkan ambang lebih rendah untuk Asia — risiko penyakit kronik mula meningkat pada BMI 23 untuk orang Asia.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-8">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover"><h3 class="font-semibold text-lg mb-2">Kenapa BMI Asian Rendah?</h3><p class="text-muted text-sm">Populasi Asia ada peratus lemak lebih tinggi pada BMI sama. Risiko diabetes dan hipertensi mula naik pada BMI 23 untuk orang Asia.</p></div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover"><h3 class="font-semibold text-lg mb-2">Otot vs Lemak</h3><p class="text-muted text-sm">Atlet dengan otot tinggi mungkin melebihi julat ideal tapi sihat. Komposisi badan lebih tepat dari BMI.</p></div>
    </div>

    <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-4 mb-8 text-xs text-muted">
      <strong>Penafian:</strong> Anggaran sahaja. Rujuk doktor untuk sasaran berat peribadi.
      <br /><em>Sumber: Devine BJ, 1974 — WHO 2004 (doi.org/10.1016/S0140-6736(04)16352-8)</em>
    </div>

    <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6 md:p-8">
      <h3 class="text-xl font-bold mb-4">Alat Kesihatan Lain</h3>
      <ul class="space-y-2"><li><a href="/kalkulator/bmi/" class="text-primary font-medium hover:underline text-sm">→ Kalkulator BMI</a></li><li><a href="/kalkulator/bmr/" class="text-primary font-medium hover:underline text-sm">→ Kalkulator BMR & Kalori Harian</a></li></ul>
    </div>
  </section>

  <CallToAction actions={[{ variant: 'primary', text: 'Kira BMI', href: '/kalkulator/bmi' },{ variant: 'secondary', text: 'Kira BMR', href: '/kalkulator/bmr' }]}>
    <Fragment slot="title">Semak BMI dan keperluan kalori harian</Fragment><Fragment slot="subtitle">Alat kesihatan percuma untuk rakyat Malaysia.</Fragment>
  </CallToAction>

  <script is:inline>
function fmtKg(v) { return typeof v === 'number' && !isNaN(v) && isFinite(v) ? v.toFixed(1) + ' kg' : '—'; }
function sn(v, d) { var n = parseFloat(v); return (!isNaN(n) && isFinite(n) && n >= 0) ? n : (d || 0); }
var isMale = true;
function setGender(male) {
  isMale = male;
  var l = document.getElementById('idLelaki'), p = document.getElementById('idPerempuan');
  if (male) { l.className='flex-1 rounded-xl border-2 border-primary bg-primary/10 px-4 py-3 text-sm font-semibold text-primary'; p.className='flex-1 rounded-xl border-2 border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm font-semibold text-default'; }
  else { p.className='flex-1 rounded-xl border-2 border-primary bg-primary/10 px-4 py-3 text-sm font-semibold text-primary'; l.className='flex-1 rounded-xl border-2 border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm font-semibold text-default'; }
  calc();
}
function calc() {
  var h = sn(document.getElementById('idTinggi').value, 170);
  if (h===0) { ['idDevine','idMin','idMax','idJulat'].forEach(function(id){document.getElementById(id).textContent='—'}); document.getElementById('idKesimpulan').textContent='Sila masukkan tinggi'; return; }
  var hm = h/100, excess = Math.max(0,h-152.4);
  var devine = isMale ? (50+excess*0.9) : (45.5+excess*0.9);
  document.getElementById('idDevine').textContent = fmtKg(devine);
  document.getElementById('idMin').textContent = fmtKg(18.5*hm*hm);
  document.getElementById('idMax').textContent = fmtKg(22.9*hm*hm);
  document.getElementById('idJulat').textContent = (18.5*hm*hm).toFixed(1)+' — '+(22.9*hm*hm).toFixed(1)+' kg';
  document.getElementById('idTinggiLabel').textContent = h+' cm';
  document.getElementById('idKesimpulan').textContent = (18.5*hm*hm).toFixed(1)+' kg — '+(22.9*hm*hm).toFixed(1)+' kg';
}
['idTinggi'].forEach(function(id){var el=document.getElementById(id);if(el){el.addEventListener('input',calc);el.addEventListener('change',calc);}});
calc();
</script>
</Layout>
