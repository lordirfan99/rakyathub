---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator Zakat Simpanan — Kira Zakat Wang Malaysia | RakyatHub',
  description: 'Kira zakat simpanan tahunan anda. Semak kelayakan nisab dan haul. Kadar 2.5% ikut panduan PPZ / JAKIM. Percuma.',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8"><a href="/kalkulator" class="text-sm text-muted hover:text-primary transition-colors">← Semua Kalkulator</a></div>
    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Kalkulator Zakat Simpanan</h1>
    <p class="text-lg md:text-xl text-muted mb-8">Kira zakat atas simpanan wang (ASB, KWSP, Tabung Haji, bank) mengikut panduan PPZ dan JAKIM. Kadar 2.5% — semak nisab dan haul.</p>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <div class="grid md:grid-cols-2 gap-4 md:gap-6">
        <div>
          <label for="zsBaki" class="block text-sm font-semibold text-default mb-1.5">Baki Simpanan (RM)</label>
          <input type="number" id="zsBaki" value="10000" min="0" step="100"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
          <p class="text-[10px] text-muted mt-1">*Jumlah baki di bank, ASB, KWSP, Tabung Haji, dll</p>
        </div>
        <div>
          <label for="zsNisab" class="block text-sm font-semibold text-default mb-1.5">Nisab Semasa (RM)</label>
          <input type="number" id="zsNisab" value="49000" min="0" step="100"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
          <p class="text-[10px] text-muted mt-1">*Nilai 85g emas semasa (~RM49,000)</p>
        </div>
      </div>

      <div class="mt-4">
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" id="zsHaul" checked onchange="calc()" class="w-5 h-5 rounded border-gray-300 text-primary focus:ring-primary" />
          <span class="text-sm font-semibold text-default">Cukup haul (disimpan 1 tahun qamariah / 354 hari)</span>
        </label>
      </div>

      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl bg-blue-50 dark:bg-blue-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Status</p>
          <p class="text-lg font-bold text-default" id="zsStatus">—</p>
        </div>
        <div class="rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Baki Kena Zakat</p>
          <p class="text-lg font-bold text-emerald-700" id="zsBakiZakat">RM 0</p>
        </div>
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Zakat (2.5%)</p>
          <p class="text-lg font-bold text-amber-700" id="zsZakat">RM 0.00</p>
        </div>
        <div class="rounded-xl bg-primary/10 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Kadar</p>
          <p class="text-lg font-bold text-primary">2.5%</p>
        </div>
      </div>

      <div class="mt-4 p-5 rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/5 border border-primary/20 text-center">
        <p class="text-sm text-muted" id="zsKeterangan">Sila masukkan baki simpanan</p>
        <p class="text-3xl md:text-4xl font-bold text-primary" id="zsFinal">RM 0.00</p>
      </div>
    </div>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">Syarat Wajib Zakat Simpanan</h2>
      <ul class="text-muted text-sm space-y-2">
        <li>1️⃣ <strong>Islam</strong> dan merdeka</li>
        <li>2️⃣ <strong>Nisab:</strong> Mencapai nilai 85g emas (~RM49,000 pada 2026 — kadarnya berubah ikut harga emas semasa)</li>
        <li>3️⃣ <strong>Haul:</strong> Telah disimpan selama 1 tahun qamariah (354 hari)</li>
        <li>4️⃣ <strong>Milik penuh:</strong> Wang tersebut adalah milik anda dan bebas dari hutang</li>
      </ul>
      <p class="text-muted text-sm mt-3">Kadar zakat: 2.5% daripada jumlah baki simpanan yang layak. Contoh: Simpanan RM50,000 × 2.5% = <strong>RM1,250</strong>.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-8">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">KWSP & ASB</h3>
        <p class="text-muted text-sm">Zakat ke atas KWSP atau ASB wajib dikeluarkan bila duit dikeluarkan atau setiap tahun atas dividen yang diterima. Rujuk pusat zakat negeri masing-masing untuk panduan spesifik.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">Bayar Zakat</h3>
        <p class="text-muted text-sm">Zakat simpanan boleh dibayar di Pusat Pungutan Zakat (PPZ), Lembaga Zakat negeri masing-masing, atau secara online melalui portal zakat. Bayaran zakat layak untuk pelepasan cukai LHDN.</p>
      </div>
    </div>

    <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-4 mb-8 text-xs text-muted">
      <strong>Penafian:</strong> Pengiraan zakat berdasarkan panduan umum PPZ dan JAKIM. Hukum zakat boleh berbeza mengikut negeri dan mazhab. Rujuk pusat zakat negeri masing-masing untuk fatwa tepat.
      <br /><em>Sumber: PPZ — zakat.com.my | JAKIM</em>
    </div>

    <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6 md:p-8">
      <h3 class="text-xl font-bold mb-4">Zakat Lain</h3>
      <ul class="space-y-2">
        <li><a href="/kalkulator/zakat-pendapatan/" class="text-primary font-medium hover:underline text-sm">→ Zakat Pendapatan</a></li>
        <li><a href="/kalkulator/zakat-emas/" class="text-primary font-medium hover:underline text-sm">→ Zakat Emas</a></li>
        <li><a href="/kalkulator/zakat-fitrah/" class="text-primary font-medium hover:underline text-sm">→ Zakat Fitrah</a></li>
      </ul>
    </div>
  </section>

  <CallToAction actions={[
    { variant: 'primary', text: 'Zakat Emas', href: '/kalkulator/zakat-emas' },
    { variant: 'secondary', text: 'Zakat Fitrah', href: '/kalkulator/zakat-fitrah' },
  ]}>
    <Fragment slot="title">Kira zakat lain yang wajib dibayar</Fragment>
    <Fragment slot="subtitle">Zakat emas, zakat fitrah — semuanya ada.</Fragment>
  </CallToAction>

  <script is:inline>
function fmt(v) { return 'RM ' + (typeof v === 'number' && !isNaN(v) && isFinite(v) ? v.toLocaleString('ms-MY', {minimumFractionDigits:2,maximumFractionDigits:2}) : '0.00'); }
function sn(v, d) { var n = parseFloat(v); return (!isNaN(n) && isFinite(n) && n >= 0) ? n : (d || 0); }
function calc() {
  var baki = sn(document.getElementById('zsBaki').value, 10000);
  var nisab = sn(document.getElementById('zsNisab').value, 49000);
  var haul = document.getElementById('zsHaul').checked;
  if (!haul) {
    document.getElementById('zsStatus').textContent = 'Belum cukup haul';
    document.getElementById('zsStatus').className = 'text-lg font-bold text-red-600';
    document.getElementById('zsBakiZakat').textContent = 'RM 0';
    document.getElementById('zsZakat').textContent = 'RM 0.00';
    document.getElementById('zsKeterangan').textContent = 'Belum cukup haul (perlu 354 hari / 1 tahun qamariah)';
    document.getElementById('zsFinal').textContent = 'RM 0.00';
    return;
  }
  if (baki < nisab) {
    document.getElementById('zsStatus').textContent = 'Bawah nisab';
    document.getElementById('zsStatus').className = 'text-lg font-bold text-red-600';
    document.getElementById('zsBakiZakat').textContent = 'RM 0';
    document.getElementById('zsZakat').textContent = 'RM 0.00';
    document.getElementById('zsKeterangan').textContent = 'Baki simpanan (RM ' + baki.toLocaleString() + ') kurang dari nisab (RM ' + nisab.toLocaleString() + ')';
    document.getElementById('zsFinal').textContent = 'RM 0.00';
    return;
  }
  var zakat = Math.round(baki * 0.025 * 100) / 100;
  document.getElementById('zsStatus').textContent = 'Wajib zakat';
  document.getElementById('zsStatus').className = 'text-lg font-bold text-green-600';
  document.getElementById('zsBakiZakat').textContent = fmt(baki);
  document.getElementById('zsZakat').textContent = fmt(zakat);
  document.getElementById('zsKeterangan').textContent = 'Zakat 2.5% atas RM ' + baki.toLocaleString();
  document.getElementById('zsFinal').textContent = fmt(zakat);
}
['zsBaki','zsNisab','zsHaul'].forEach(function(id){var el=document.getElementById(id);if(el){el.addEventListener('input',calc);el.addEventListener('change',calc);}});
calc();
</script>
</Layout>
