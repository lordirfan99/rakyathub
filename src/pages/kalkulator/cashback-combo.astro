---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import { CARDS, CATEGORIES } from '~/data/cashback-cards';

const metadata = {
  title: 'Kalkulator Cashback Kad Kredit — Combo Terbaik Malaysia',
  description: 'Cari kombinasi sehingga 3 kad kredit Malaysia yang beri cashback tertinggi berdasarkan tabiat belanja anda — petrol, runcit, makan, online shopping dan lebih.',
};

const year = new Date().getFullYear();

// Serialise card data for client script — no bank logos, just data + hex
const cardsJson = JSON.stringify(CARDS);
const categoriesJson = JSON.stringify(CATEGORIES);
---

<Layout metadata={metadata}>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-10 md:py-16">

    <!-- Breadcrumb -->
    <div class="mb-6">
      <a href="/kalkulator/" class="text-sm text-muted hover:text-primary transition-colors">← Semua Kalkulator</a>
    </div>

    <!-- Hero -->
    <div class="mb-8">
      <div class="inline-flex items-center gap-2 rounded-full bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-400 px-3 py-1 text-xs font-semibold uppercase tracking-wide mb-4">
        <Icon name="tabler:credit-card" class="w-3.5 h-3.5" />
        Kalkulator Interaktif {year}
      </div>
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-3">
        Cashback Combo Optimizer
      </h1>
      <p class="text-lg md:text-xl text-muted max-w-3xl">
        Masukkan perbelanjaan bulanan anda. Enjin kami akan uji 20,000+ kombinasi kad kredit dan cadangkan combo sehingga 3 kad untuk cashback tertinggi.
      </p>
    </div>

    <!-- ── SPEND INPUT PANEL ────────────────────────────────── -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold">Masukkan Perbelanjaan Bulanan</h2>
        <button id="btnReset" class="text-xs text-muted hover:text-primary transition-colors underline underline-offset-2">Reset</button>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="spendGrid">

        <!-- Each row: icon + label + RM input -->
