<script is:inline>
var CATEGORIES = [
  { id: 'petrol', label: 'Petrol' }, { id: 'dining', label: 'Dining' },
  { id: 'groceries', label: 'Groceries' }, { id: 'online', label: 'Online / eCommerce' },
  { id: 'others', label: 'Lain-lain' }, { id: 'utilities', label: 'Utilities' },
  { id: 'ewallet', label: 'eWallet' }, { id: 'insurance', label: 'Insurance' },
  { id: 'entertainment', label: 'Entertainment' }, { id: 'telco', label: 'Telco' },
  { id: 'education', label: 'Education' }, { id: 'government', label: 'Kerajaan' },
  { id: 'pharmacy', label: 'Pharmacy' }, { id: 'hospital', label: 'Hospital' },
  { id: 'airlines', label: 'Airlines' },
];
var CATEGORY_LABELS = {
  petrol:'⛽ Petrol', dining:'🍽️ Dining', groceries:'🛒 Groceries',
  online:'🛍️ eCommerce', others:'🧾 Lain-lain', utilities:'💡 Utilities',
  ewallet:'📱 eWallet', insurance:'🛡️ Insurance', entertainment:'🎬 Hiburan',
  telco:'📞 Telco', education:'📚 Education', government:'🏛️ Kerajaan',
  pharmacy:'💊 Pharmacy', hospital:'🏥 Hospital', airlines:'✈️ Airlines'
};
var CARDS = [], RAW_CARDS = [];
(function(){
  var el = document.getElementById('cardDataStore');
  if(el) try { CARDS = JSON.parse(el.getAttribute('data-cards')||'[]'); } catch(e){}
  var el2 = document.getElementById('rawCardDataStore');
  if(el2) try { RAW_CARDS = JSON.parse(el2.getAttribute('data-cards')||'[]'); } catch(e){}
})();
var mode='optimal', selectedCards=[];

// ═══════════════════════════════════════════════════════════════
// PORTED ENGINE — computeCombo & findBestCombos from cashback-engine.ts
// ═══════════════════════════════════════════════════════════════

function computeCombo(spending, combo) {
  // spending: { catId: amount } — same as getSpending() output
  // combo: array of raw card objects (with tiers, baseCashbackRate)
  var K = combo.length;
  var spendList = [];
  for (var catId in spending) {
    if (spending.hasOwnProperty(catId) && spending[catId] > 0) {
      spendList.push({ category: catId, amount: spending[catId] });
    }
  }
  if (spendList.length === 0) {
    return { cards: [], totalCashback: 0, monthlyFeeAmortized: 0, netCashback: 0 };
  }

  // Step 1: Build category priority (best card per category by rate)
  var categoryPriority = {};
  for (var si = 0; si < spendList.length; si++) {
    var cat = spendList[si].category;
    var entries = [];
    for (var ci = 0; ci < K; ci++) {
      var card = combo[ci];
      var bestRate = card.baseCashbackRate;
      var bestTierIdx = -1;
      for (var t = 0; t < card.tiers.length; t++) {
        var tier = card.tiers[t];
        if (tier.categories.indexOf(cat) >= 0) {
          var effectiveRate = tier.isWeekendOnly ? tier.rate * 0.5 : tier.rate;
          if (effectiveRate > bestRate) {
            bestRate = effectiveRate;
            bestTierIdx = t;
          }
        }
      }
      entries.push({ cardIdx: ci, tierIdx: bestTierIdx, rate: bestRate });
    }
    entries.sort(function(a, b) { return b.rate - a.rate; });
    categoryPriority[cat] = entries;
  }

  // State
  var allocatedSpend = new Array(K).fill(0);
  var tierCashback = [];
  for (var ci = 0; ci < K; ci++) {
    tierCashback.push(new Array(combo[ci].tiers.length).fill(0));
  }
  var catCashback = {};
  for (var si = 0; si < spendList.length; si++) {
    catCashback[spendList[si].category] = new Array(K).fill(0);
  }
  var breakdowns = [];
  for (var ci = 0; ci < K; ci++) breakdowns.push([]);

  // Step 2 & 3: Greedy allocation with cap tracking
  for (var si = 0; si < spendList.length; si++) {
    var cat = spendList[si].category;
    var amount = spendList[si].amount;
    var remainingSpend = amount;
    var priority = categoryPriority[cat];

    for (var pi = 0; pi < priority.length; pi++) {
      if (remainingSpend <= 0) break;
      var entry = priority[pi];
      var cardIdx = entry.cardIdx;
      var tierIdx = entry.tierIdx;
      var rate = entry.rate;
      var card = combo[cardIdx];

      if (tierIdx === -1) {
        // Base rate — no tier covers this category
        var cashback = remainingSpend * rate;
        allocatedSpend[cardIdx] += remainingSpend;
        breakdowns[cardIdx].push({ category: cat, spend: remainingSpend, rate: rate, cashback: cashback, cappedBy: 'none' });
        remainingSpend = 0;
        break;
      }

      var tier = card.tiers[tierIdx];
      var effectiveRate = tier.isWeekendOnly ? tier.rate * 0.5 : tier.rate;

      var tierEarnedSoFar = tierCashback[cardIdx][tierIdx];
      var tierRemaining = tier.poolCap > 0 ? Math.max(0, tier.poolCap - tierEarnedSoFar) : Infinity;

      var catEarnedSoFar = catCashback[cat][cardIdx];
      var catRemaining = tier.categoryCap > 0 ? Math.max(0, tier.categoryCap - catEarnedSoFar) : Infinity;

      var maxCashback = Math.min(tierRemaining, catRemaining);
      if (maxCashback <= 0) continue;

      var spendToHitCap = maxCashback / effectiveRate;
      var spendHere = Math.min(remainingSpend, spendToHitCap);
      var cashbackHere = Math.min(spendHere * effectiveRate, maxCashback);

      var cappedBy = 'none';
      if (cashbackHere < remainingSpend * effectiveRate) {
        cappedBy = catRemaining <= tierRemaining ? 'categoryCap' : 'poolCap';
      }

      allocatedSpend[cardIdx] += spendHere;
      tierCashback[cardIdx][tierIdx] += cashbackHere;
      catCashback[cat][cardIdx] += cashbackHere;
      remainingSpend -= spendHere;

      breakdowns[cardIdx].push({ category: cat, spend: spendHere, rate: effectiveRate, cashback: cashbackHere, cappedBy: cappedBy });
    }

    // Unallocated remainder → highest base-rate card
    if (remainingSpend > 0 && priority.length > 0) {
      var bestBase = priority[0];
      var baseRate = combo[bestBase.cardIdx].baseCashbackRate;
      var cb = remainingSpend * baseRate;
      allocatedSpend[bestBase.cardIdx] += remainingSpend;
      breakdowns[bestBase.cardIdx].push({ category: cat, spend: remainingSpend, rate: baseRate, cashback: cb, cappedBy: 'none' });
    }
  }

  // Step 4: Check minMonthlySpend
  var cardDetails = [];
  for (var ci = 0; ci < K; ci++) {
    var card = combo[ci];
    var maxMinSpend = 0;
    for (var t = 0; t < card.tiers.length; t++) {
      if (card.tiers[t].minMonthlySpend > maxMinSpend) maxMinSpend = card.tiers[t].minMonthlySpend;
    }
    var metMinSpend = allocatedSpend[ci] >= maxMinSpend;

    var earnedCashback;
    var finalBreakdowns;

    if (metMinSpend) {
      earnedCashback = 0;
      for (var t = 0; t < tierCashback[ci].length; t++) earnedCashback += tierCashback[ci][t];
      // Base-rate spends
      for (var b = 0; b < breakdowns[ci].length; b++) {
        var bd = breakdowns[ci][b];
        var isTiered = false;
        for (var t = 0; t < card.tiers.length; t++) {
          if (card.tiers[t].categories.indexOf(bd.category) >= 0) { isTiered = true; break; }
        }
        if (!isTiered) earnedCashback += bd.cashback;
      }
      finalBreakdowns = breakdowns[ci];
    } else {
      earnedCashback = allocatedSpend[ci] * card.baseCashbackRate;
      finalBreakdowns = [];
      for (var b = 0; b < breakdowns[ci].length; b++) {
        var bd = breakdowns[ci][b];
        finalBreakdowns.push({ category: bd.category, spend: bd.spend, rate: card.baseCashbackRate, cashback: bd.spend * card.baseCashbackRate, cappedBy: 'none' });
      }
    }

    cardDetails.push({
      cardId: card.id,
      cardName: card.cardName,
      bank: card.bank,
      hexColor: card.hexColor,
      allocatedSpend: allocatedSpend[ci],
      earnedCashback: Math.round(earnedCashback * 100) / 100,
      breakdown: finalBreakdowns,
      metMinSpend: metMinSpend,
    });
  }

  var totalCashback = 0;
  for (var ci = 0; ci < cardDetails.length; ci++) totalCashback += cardDetails[ci].earnedCashback;
  var monthlyFee = 0;
  for (var ci = 0; ci < K; ci++) monthlyFee += combo[ci].annualFee / 12;

  return {
    cards: cardDetails,
    totalCashback: Math.round(totalCashback * 100) / 100,
    monthlyFeeAmortized: Math.round(monthlyFee * 100) / 100,
    netCashback: Math.round((totalCashback - monthlyFee) * 100) / 100,
  };
}

function engineToOldShape(comboResult, cardIds) {
  // Convert ComboResult to the shape renderResults expects:
  // { cards: [id], breakdown: { id: { catId: {amount, cashback} } }, total: net, gross: gross, fee: monthly }
  var old = {
    cards: cardIds,
    total: comboResult.netCashback,
    gross: comboResult.totalCashback,
    fee: comboResult.monthlyFeeAmortized,
    breakdown: {},
  };
  for (var ci = 0; ci < comboResult.cards.length; ci++) {
    var cd = comboResult.cards[ci];
    old.breakdown[cd.cardId] = {};
    for (var b = 0; b < cd.breakdown.length; b++) {
      var bd = cd.breakdown[b];
      old.breakdown[cd.cardId][bd.category] = { amount: bd.spend, cashback: bd.cashback };
    }
  }
  return old;
}

function runOptimizer() {
  var s = getSpending();
  var ts = 0;
  for (var k in s) ts += s[k] || 0;
  if (ts <= 0) { document.getElementById('status').textContent = '⚠️ Sila masukkan jumlah perbelanjaan.'; return; }
  var ld = document.getElementById('loading'), rs = document.getElementById('results'), st = document.getElementById('status');
  ld.classList.remove('hidden'); rs.classList.add('hidden'); rs.innerHTML = ''; st.textContent = '';
  setTimeout(function(){
    var ac = RAW_CARDS, co = [];
    if (mode === 'owned') {
      if (selectedCards.length < 3) { ld.classList.add('hidden'); st.textContent = '⚠️ Sila pilih minimum 3 kad.'; return; }
      ac = RAW_CARDS.filter(function(c) { return selectedCards.indexOf(c.id) >= 0; });
    }
    if (!ac || ac.length < 3) { ld.classList.add('hidden'); st.textContent = '⚠️ Perlu minimum 3 kad.'; return; }

    // Filter relevant cards (those matching spend categories)
    var spendCats = {};
    for (var k in s) { if (s[k] > 0) spendCats[k] = true; }
    var relevant = ac.filter(function(card) {
      if (card.baseCashbackRate > 0) return true;
      for (var t = 0; t < card.tiers.length; t++) {
        for (var c = 0; c < card.tiers[t].categories.length; c++) {
          if (spendCats[card.tiers[t].categories[c]]) return true;
        }
      }
      return false;
    });

    var n = relevant.length;
    for (var i = 0; i < n - 2; i++) {
      for (var j = i + 1; j < n - 1; j++) {
        for (var k = j + 1; k < n; k++) {
          var comboResult = computeCombo(s, [relevant[i], relevant[j], relevant[k]]);
          var cardIds = [relevant[i].id, relevant[j].id, relevant[k].id];
          co.push(engineToOldShape(comboResult, cardIds));
        }
      }
    }
    co.sort(function(a, b) { return b.total - a.total; });
    var tp = co.slice(0, 20);

    ld.classList.add('hidden');
    if (tp.length === 0) { st.textContent = 'Tiada kombinasi yang sah.'; return; }
    renderResults(tp, CARDS, s);
    rs.classList.remove('hidden');
    st.textContent = 'Menilai ' + co.length.toLocaleString() + ' kombinasi dari ' + relevant.length + ' kad.';
    try { localStorage.setItem('rh_combo', JSON.stringify({cards: tp[0].cards, total: tp[0].total})); } catch(e) {}
  }, 50);
}

function setMode(m) {
  mode=m;
  ['modeOptimal','modeOwned'].forEach(function(id){
    document.getElementById(id).className='flex-1 flex items-center justify-center gap-2 px-4 py-4 text-sm font-semibold border-b-2 transition-all duration-200 border-transparent text-muted hover:text-primary hover:border-primary/30';
  });
  var a=document.getElementById(m==='optimal'?'modeOptimal':'modeOwned');
  a.classList.add('bg-primary','text-white','border-primary','shadow-sm');
  document.getElementById('cardSelector').classList.toggle('hidden',m!=='owned');
  document.getElementById('runBtn').innerHTML=m==='optimal'
    ? '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>Cari Combo Terbaik'
    : '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>Optimumkan Kad Saya';
}

function getSpending() {
  var s={},total=0;
  CATEGORIES.forEach(function(c){
    var el=document.getElementById('sp-'+c.id);
    if(!el)return;
    var v=parseFloat(el.value)||0; s[c.id]=v; total+=v;
  });
  document.getElementById('totalSpend').textContent='RM '+total.toLocaleString();
  var bar=document.getElementById('spendBar');
  if(bar) bar.style.width=Math.min(total/5000*100,100)+'%';
  try{localStorage.setItem('rh_spend',JSON.stringify(s));}catch(e){}
  return s;
}
window.calc=getSpending;

function cardFace(card) {
  var p=card.primaryHex||'#333', s=card.secondaryHex||'#666', g=card.gradientStyle||'solid', l=card.logoLabel||(card.bank||'').substring(0,4).toUpperCase(), im=card.imageUrl||'', net=card.network||'';
  var bg=g==='diagonal'?'linear-gradient(135deg,'+p+','+s+')':g==='horizontal'?'linear-gradient(90deg,'+p+','+s+')':'linear-gradient(135deg,'+p+','+darken(p,20)+')';
  var cl=card.id?' onclick="showCardDetail(\''+card.id+'\')"':'';
  var networkIcon = net==='Visa'?'VISA':net==='Mastercard'?'MC':net==='Amex'?'AMEX':net;
  if(im)return '<div'+cl+' class="relative rounded-xl overflow-hidden mb-1 shadow-sm bg-gray-50 card-clickable" style="aspect-ratio:1.586/1;display:flex;align-items:center;justify-content:center"><img src="'+im+'" alt="'+(card.name||'')+'" loading="lazy" style="width:100%;height:auto;object-fit:contain"/></div>';
  return '<div'+cl+' class="relative rounded-xl overflow-hidden mb-1 shadow-sm card-clickable" style="background:'+bg+';aspect-ratio:1.586/1"><div class="absolute inset-0 bg-white/10" style="background:radial-gradient(circle at 80% 20%, rgba(255,255,255,0.15) 0%, transparent 60%)"></div><div class="relative p-2.5 flex flex-col justify-between h-full"><div class="flex justify-between items-start"><span class="text-[10px] font-bold tracking-widest text-white/80">'+l+'</span><span class="text-[10px] font-bold text-white/60">'+networkIcon+'</span></div><div><div class="text-[9px] font-semibold text-white/70">'+(card.bank||'')+'</div><div class="text-[11px] font-bold text-white leading-tight truncate">'+(card.name||'').replace(/Credit Card.*$/i,'').replace(/Card-i.*$/i,'').trim()+'</div></div><div class="flex justify-between items-end"><span class="text-[7px] text-white/40 font-mono">•••• 4582</span><div class="flex gap-0.5"><span class="w-5 h-3 rounded-sm bg-yellow-400/50"></span><span class="w-5 h-3 rounded-sm bg-yellow-400/50" style="opacity:0.7"></span></div></div></div></div>';
  function darken(hex,pct){var c=parseInt(hex.slice(1),16),r=c>>16&255,g=c>>8&255,b=c&255;return'#'+((r*(100-pct)/100<<16)+(g*(100-pct)/100<<8)+(b*(100-pct)/100<<0)).toString(16).padStart(6,'0');}
}
function renderResults(combos,allCards,spending) {
  var best=combos[0],bestCards=best.cards.map(function(id){return allCards.find(function(c){return c.id===id})});
  var ts=0;for(var k in spending)ts+=spending[k]||0;
  var h='';
  h+='<div class="rounded-2xl bg-gradient-to-br from-teal-50 to-orange-50 dark:from-teal-950/40 dark:to-orange-950/40 border border-teal-100 dark:border-teal-800/30 p-5 mb-6"><div class="flex items-center gap-3 mb-3"><div class="w-10 h-10 rounded-xl bg-gradient-to-br from-teal-500 to-orange-500 flex items-center justify-center text-white text-lg shadow-lg">🏆</div><div><div class="text-xs font-semibold text-muted uppercase tracking-wider">Combo Terbaik</div><div class="text-2xl font-bold text-heading">RM '+best.total.toFixed(2)+' <span class="text-sm font-normal text-muted">/ bulan</span></div></div></div><div class="grid grid-cols-3 gap-2 mb-3">';
  bestCards.forEach(function(c){h+='<div class="min-w-0">'+cardFace(c)+'</div>';});
  h+='</div><div class="flex justify-between items-center pt-3 border-t border-teal-200/50 dark:border-teal-700/30"><span class="text-xs text-muted">Belanja: <strong class="tabular-nums">RM '+ts.toLocaleString()+'</strong></span><span class="text-xs font-medium text-primary">Eff: <strong class="tabular-nums">'+(best.total/ts*100).toFixed(1)+'%</strong> <span class="cursor-help text-muted" title="Kadar pulangan efektif = jumlah cashback \u00f7 jumlah perbelanjaan \u00d7 100. Contoh: RM71 \u00f7 RM1,650 = 4.3%">\u24d8</span></span></div></div>'+
  '<div class="flex gap-2 mb-4"><a href="/kalkulator/kad-kredit/?cards='+best.cards.join(',')+'" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-teal-500/10 text-teal-700 dark:text-teal-300 text-[11px] font-semibold hover:bg-teal-500/20 transition">\u{1F4CB} Lihat kad ini dalam Direktori \u2192</a></div>';
  h+='<div class="flex items-center justify-between mb-4"><h3 class="text-sm font-bold text-heading">Kedudukan Combo</h3><span class="text-[11px] text-muted">Klik kad untuk detail</span></div><div class="space-y-2">';
  combos.forEach(function(combo,idx){
    if(idx===0)return; // skip — already rendered as "Combo Terbaik" hero above
    var cards=combo.cards.map(function(id){return allCards.find(function(c){return c.id===id})});
    var rankDisplay=idx===1?'\uD83E\uDD48':idx===2?'\uD83E\uDD49':'<span class="w-6 h-6 rounded-full bg-gray-100 dark:bg-slate-800 flex items-center justify-center text-[11px] font-bold text-muted">'+(idx+1)+'</span>';
    h+='<article class="group rounded-xl border transition-all duration-200 hover:shadow-md '+(idx===1?'border-gray-200 dark:border-slate-700/50 bg-white dark:bg-slate-900/40':'border-gray-100 dark:border-slate-800 bg-gray-50/50 dark:bg-slate-900/20')+'" aria-label="Combo '+(idx+1)+': RM '+combo.total.toFixed(2)+'/bln"><div class="p-4"><div class="flex items-center justify-between mb-3"><div class="flex items-center gap-2.5">'+rankDisplay+'<strong class="font-bold text-base text-heading tabular-nums">RM '+combo.total.toFixed(2)+'</strong><span class="text-[11px] text-muted">/bln</span></div><span class="text-[11px] font-medium text-primary">+<strong class="tabular-nums">'+(combo.total/ts*100).toFixed(1)+'%</strong></span></div><div class="grid grid-cols-3 gap-2">';
    cards.forEach(function(c){h+='<div class="min-w-0">'+cardFace(c)+'</div>';});
    h+='</div><details class="mt-2"><summary class="flex items-center gap-1.5 text-[11px] text-muted cursor-pointer hover:text-primary transition pt-2">Lihat agihan kategori<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></summary><div class="mt-2 space-y-1.5 pt-2 border-t border-gray-100 dark:border-slate-800">';
    cards.forEach(function(card){
      var bd=combo.breakdown[card.id];if(!bd)return;var o='';
      for(var c in bd){if(bd[c].cashback>0)o+='<div class="flex justify-between text-xs py-1 px-2 rounded-lg bg-gray-50 dark:bg-slate-800/40"><span>'+(CATEGORY_LABELS[c]||c)+' <span class="text-[10px] text-muted">(RM '+bd[c].amount+')</span></span><span class="text-primary font-semibold">+RM '+bd[c].cashback.toFixed(2)+'</span></div>';}
      if(o)h+='<div class="text-[11px] font-semibold text-muted mt-2 mb-1">'+(card.bank||'')+' — '+(card.name||'').replace(/Credit Card.*$/i,'').trim()+'</div>'+o;
    });
    if(combo.fee>0)h+='<div class="flex justify-between text-xs py-1 px-2 mt-1.5 rounded-lg bg-red-50/50 dark:bg-red-900/10"><span class="text-muted">Yuran tahunan (÷12)</span><span class="text-red-500 font-semibold">−RM '+combo.fee.toFixed(2)+'</span></div>';
    h+='</div></details></div></div>';
  });
  h+='</div>';
  document.getElementById('results').innerHTML=h;
}
function clearResults(){document.getElementById('results').classList.add('hidden');document.getElementById('results').innerHTML='';document.getElementById('status').textContent='';}
function initCardSelector() {
  var l=document.getElementById('cardList'),h='';
  CARDS.forEach(function(card){
    h+='<label class="flex items-center gap-2.5 p-2.5 rounded-lg hover:bg-gray-50 dark:hover:bg-slate-800/60 cursor-pointer transition border border-transparent hover:border-gray-100 dark:hover:border-slate-700/50"><input type="checkbox" value="'+card.id+'" onchange="toggleCard(\''+card.id+'\')" class="w-4 h-4 rounded border-gray-300 text-primary focus:ring-primary/30"><span class="w-1.5 h-5 rounded-full shrink-0" style="background:'+(card.primaryHex||'#333')+'"></span><div class="flex-1 min-w-0"><span class="text-xs font-semibold text-primary block">'+(card.bank||'')+'</span><span class="text-sm truncate block">'+(card.name||'')+'</span></div></label>';
  });
  l.innerHTML=h;
}
function toggleCard(id){var i=selectedCards.indexOf(id);if(i>=0)selectedCards.splice(i,1);else if(selectedCards.length>=5){document.getElementById('status').textContent='⚠️ Maksimum 5 kad.';return;}else selectedCards.push(id);document.getElementById('selectedCount').textContent=selectedCards.length+' / 5';}
function selectAllCards(){selectedCards=[];document.querySelectorAll('#cardList input[type=checkbox]').forEach(function(cb,i){if(i<5){cb.checked=true;selectedCards.push(cb.value);}});document.getElementById('selectedCount').textContent=selectedCards.length+' / 5';}
function deselectAllCards(){selectedCards=[];document.querySelectorAll('#cardList input[type=checkbox]').forEach(function(cb){cb.checked=false;});document.getElementById('selectedCount').textContent='0 / 5';}
// Run on initial load AND View-Transitions navigation (DOMContentLoaded doesn't
// fire on SPA nav, which left the card selector + spend totals uninitialised).
function ccInit(){
  initCardSelector();getSpending();
  // ── Phase 2: Read URL params ──
  var p=new URLSearchParams(window.location.search);
  var cardsParam=p.get('cards');var modeParam=p.get('mode');var spendParam=p.get('spend');
  if(modeParam==='owned'||cardsParam){setMode('owned');}
  if(cardsParam){var ids=cardsParam.split(',');ids.forEach(function(id){
    var cb=document.querySelector('#cardList input[value="'+id+'"]');
    if(cb){cb.checked=true;toggleCard(id);}
  });if(ids.length>=3)runOptimizer();}
  if(spendParam){try{var sd=JSON.parse(atob(spendParam));CATEGORIES.forEach(function(c){
    var el=document.getElementById('sp-'+c.id);if(el&&sd[c.id]!==undefined)el.value=sd[c.id];
  });getSpending();}catch(e){}}
  // ── Phase 2: Load saved spend profile from localStorage ──
  try{var saved=localStorage.getItem('rh_spend');if(saved&&!cardsParam&&!spendParam){
    var sd=JSON.parse(saved);CATEGORIES.forEach(function(c){
      var el=document.getElementById('sp-'+c.id);if(el&&sd[c.id]!==undefined)el.value=sd[c.id];
    });getSpending();
  }}catch(e){}
}
if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', ccInit);
else ccInit();
function showCardDetail(cardId) {
  var card=CARDS.find(function(c){return c.id===cardId});if(!card)return;
  var img=document.getElementById('modalCardImage');
  if(card.imageUrl)img.innerHTML='<img src="'+card.imageUrl+'" alt="'+(card.name||'')+'" style="width:auto;height:100%;max-height:180px;object-fit:contain;border-radius:12px"/>';
  else{var p=card.primaryHex||'#333',s=card.secondaryHex||'#666',g=card.gradientStyle||'solid',bg=g==='diagonal'?'linear-gradient(135deg,'+p+','+s+')':g==='horizontal'?'linear-gradient(90deg,'+p+','+s+')':p;img.style.background=bg;img.innerHTML='<div class="text-white/80 text-4xl font-bold tracking-wider">'+(card.logoLabel||(card.bank||'').substring(0,4).toUpperCase())+'</div>';}
  document.getElementById('modalBank').textContent=card.bank||'';document.getElementById('modalCardName').textContent=card.name||'';
  document.getElementById('modalCardType').textContent=card.type==='cashback'?'💵 Cash Back':card.type==='points'?'⭐ Rewards Points':'';
  document.getElementById('modalAnnualFee').textContent=(card.annual_fee||0)===0?'RM 0':'RM '+card.annual_fee;
  document.getElementById('modalMonthlyFee').textContent=(card.monthly_fee||0)===0?'RM 0':'RM '+card.monthly_fee;
  document.getElementById('modalMinSpend').textContent = (function(){
    var rawCard = RAW_CARDS.find(function(c){ return c.id === cardId; });
    if (rawCard && rawCard.tiers) {
      var maxMs = 0;
      for (var t = 0; t < rawCard.tiers.length; t++) {
        if (rawCard.tiers[t].minMonthlySpend > maxMs) maxMs = rawCard.tiers[t].minMonthlySpend;
      }
      return maxMs > 0 ? 'RM ' + maxMs.toLocaleString() : 'Tiada';
    }
    return 'Tiada';
  })();
  var pc=document.getElementById('modalPoolCapRow');
  if(card.pool_cap&&card.pool_cap>0){document.getElementById('modalPoolCap').textContent='RM '+card.pool_cap+'/month';pc.classList.remove('hidden');}else{pc.classList.add('hidden');}
  var th='';
  if(card.cashback&&card.cashback.length>0){card.cashback.forEach(function(cb){th+='<div class="flex justify-between py-1.5 px-3 rounded-lg bg-gray-50 dark:bg-slate-800/40 text-sm"><span>'+(cb.category==='*'?'✨ All Categories (Base)':CATEGORY_LABELS[cb.category]||cb.category)+(cb.merchant?' @ '+cb.merchant:'')+'</span><span class="font-semibold text-primary">'+cb.rate+'%'+(cb.cap?' (cap RM '+cb.cap+')':'')+(cb.min_spend?' [min RM '+cb.min_spend+']':'')+'</span></div>';});}else th='<div class="text-sm text-muted py-2">No cashback data available.</div>';
  document.getElementById('modalCashbackTable').innerHTML=th;
  var nr=document.getElementById('modalNotesRow');
  if(card.notes){document.getElementById('modalNotes').textContent=card.notes;nr.classList.remove('hidden');}else{nr.classList.add('hidden');}
  var modal=document.getElementById('cardModal'),content=document.getElementById('cardModalContent');
  modal.classList.remove('hidden');requestAnimationFrame(function(){content.classList.remove('scale-95','opacity-0');content.classList.add('scale-100','opacity-100');});
}
function closeCardDetail(){var m=document.getElementById('cardModal'),c=document.getElementById('cardModalContent');c.classList.remove('scale-100','opacity-100');c.classList.add('scale-95','opacity-0');setTimeout(function(){m.classList.add('hidden');},200);}
(function(){var s=document.createElement('style');s.textContent='.card-clickable{cursor:pointer;transition:transform .2s ease,box-shadow .2s ease}.card-clickable:hover{transform:scale(1.03);box-shadow:0 8px 25px rgba(0,0,0,.12)}';document.head.appendChild(s);})();
</script>
</Layout>
