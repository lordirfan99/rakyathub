          <span class="flex-shrink-0 w-9 h-9 rounded-lg bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-orange-600 dark:text-orange-400">
            <Icon name="tabler:gas-station" class="w-5 h-5" stroke-width="1.5" />
          </span>
          <div class="flex-1 min-w-0">
            <label for="spend-Petrol" class="block text-xs font-semibold text-default mb-0.5">Petrol</label>
            <div class="flex items-center gap-1">
              <span class="text-xs text-muted">RM</span>
