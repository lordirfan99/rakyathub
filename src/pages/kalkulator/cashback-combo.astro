                value="200" min="0" step="50" placeholder="0" />
            </div>
          </div>
        </div>

        <!-- Groceries -->
        <div class="flex items-center gap-3 rounded-xl border border-gray-100 dark:border-slate-700 bg-gray-50 dark:bg-slate-800/60 px-4 py-3">
