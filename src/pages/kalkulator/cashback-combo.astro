<!-- ══════════════════════════════════════════════════════════
     CLIENT SCRIPT — runs entirely in the browser, no SSR
     All card data passed via inline JSON from the Astro build.
     ══════════════════════════════════════════════════════════ -->
<script define:vars={{ cardsJson, categoriesJson }}>

// ── Type notes (JSDoc for editor hints, stripped at runtime) ──
/** @type {import('~/data/cashback-cards').CreditCard[]} */
const CARDS = JSON.parse(cardsJson);

// ─────────────────────────────────────────────────────────────
// CORE ENGINE (mirrored from cashback-engine.ts for browser use)
// ─────────────────────────────────────────────────────────────

function computeCombo(spend, combo) {
  const K = combo.length;
  const categoryPriority = {};

  for (const { category } of spend) {
    const entries = [];
    for (let i = 0; i < K; i++) {
      const card = combo[i];
      let bestRate = card.baseCashbackRate;
      let bestTierIdx = -1;
      for (let t = 0; t < card.tiers.length; t++) {
        const tier = card.tiers[t];
        if (tier.categories.includes(category)) {
          const effectiveRate = tier.isWeekendOnly ? tier.rate * 0.5 : tier.rate;
          if (effectiveRate > bestRate) {
            bestRate = effectiveRate;
            bestTierIdx = t;
          }
        }
      }
      entries.push({ cardIdx: i, tierIdx: bestTierIdx, rate: bestRate });
    }
    entries.sort((a, b) => b.rate - a.rate);
    categoryPriority[category] = entries;
  }

  const allocatedSpend = new Array(K).fill(0);
  const tierCashback = combo.map(c => new Array(c.tiers.length).fill(0));
  const catCashback = {};
  for (const { category } of spend) catCashback[category] = new Array(K).fill(0);
  const breakdowns = combo.map(() => []);

  for (const { category, amount } of spend) {
    let remainingSpend = amount;
    const priority = categoryPriority[category];

    for (const { cardIdx, tierIdx, rate } of priority) {
      if (remainingSpend <= 0) break;
      const card = combo[cardIdx];

      if (tierIdx === -1) {
        const cashback = remainingSpend * rate;
        allocatedSpend[cardIdx] += remainingSpend;
        breakdowns[cardIdx].push({ category, spend: remainingSpend, rate, cashback, cappedBy: 'none' });
        remainingSpend = 0;
        break;
      }

      const tier = card.tiers[tierIdx];
      const effectiveRate = tier.isWeekendOnly ? tier.rate * 0.5 : tier.rate;
      const tierEarnedSoFar = tierCashback[cardIdx][tierIdx];
      const tierRemaining = tier.poolCap > 0 ? Math.max(0, tier.poolCap - tierEarnedSoFar) : Infinity;
      const catEarnedSoFar = catCashback[category][cardIdx];
      const catRemaining = tier.categoryCap > 0 ? Math.max(0, tier.categoryCap - catEarnedSoFar) : Infinity;
      const maxCashback = Math.min(tierRemaining, catRemaining);
      if (maxCashback <= 0) continue;

      const spendToHitCap = maxCashback / effectiveRate;
      const spendHere = Math.min(remainingSpend, spendToHitCap);
      const cashbackHere = Math.min(spendHere * effectiveRate, maxCashback);

      let cappedBy = 'none';
      if (cashbackHere < remainingSpend * effectiveRate) {
        cappedBy = catRemaining <= tierRemaining ? 'categoryCap' : 'poolCap';
      }

      allocatedSpend[cardIdx] += spendHere;
      tierCashback[cardIdx][tierIdx] += cashbackHere;
      catCashback[category][cardIdx] += cashbackHere;
      remainingSpend -= spendHere;
      breakdowns[cardIdx].push({ category, spend: spendHere, rate: effectiveRate, cashback: cashbackHere, cappedBy });
    }

    // Overflow to highest-base card
    if (remainingSpend > 0) {
      const best = priority[0];
      const baseRate = combo[best.cardIdx].baseCashbackRate;
      const cashback = remainingSpend * baseRate;
      allocatedSpend[best.cardIdx] += remainingSpend;
      breakdowns[best.cardIdx].push({ category, spend: remainingSpend, rate: baseRate, cashback, cappedBy: 'none' });
    }
  }

  const cardDetails = combo.map((card, i) => {
    const maxMinSpend = card.tiers.reduce((m, t) => Math.max(m, t.minMonthlySpend), 0);
    const metMinSpend = allocatedSpend[i] >= maxMinSpend;
    let earnedCashback, finalBreakdowns;

    if (metMinSpend) {
      earnedCashback = tierCashback[i].reduce((s, v) => s + v, 0);
      const categoriesInTiers = new Set(card.tiers.flatMap(t => t.categories));
      const baseExtra = breakdowns[i]
        .filter(b => !categoriesInTiers.has(b.category))
        .reduce((s, b) => s + b.cashback, 0);
      earnedCashback += baseExtra;
      finalBreakdowns = breakdowns[i];
    } else {
      earnedCashback = allocatedSpend[i] * card.baseCashbackRate;
      finalBreakdowns = breakdowns[i].map(b => ({
        ...b, rate: card.baseCashbackRate, cashback: b.spend * card.baseCashbackRate, cappedBy: 'none',
      }));
    }

    return {
      cardId: card.id, cardName: card.cardName, bank: card.bank, hexColor: card.hexColor,
      network: card.network, allocatedSpend: allocatedSpend[i],
      earnedCashback: Math.round(earnedCashback * 100) / 100,
      breakdown: finalBreakdowns, metMinSpend,
    };
  });

  const totalCashback = cardDetails.reduce((s, c) => s + c.earnedCashback, 0);
  const monthlyFeeAmortized = combo.reduce((s, c) => s + c.annualFee / 12, 0);
  return {
    cards: cardDetails,
    totalCashback: Math.round(totalCashback * 100) / 100,
    monthlyFeeAmortized: Math.round(monthlyFeeAmortized * 100) / 100,
    netCashback: Math.round((totalCashback - monthlyFeeAmortized) * 100) / 100,
  };
}

function findBestCombos(spend, cards, topK = 5) {
  const spendCategories = new Set(spend.filter(s => s.amount > 0).map(s => s.category));
  const relevant = cards.filter(card =>
    card.tiers.some(t => t.categories.some(c => spendCategories.has(c))) || card.baseCashbackRate > 0
  );
  const N = relevant.length;
  const results = [];
  let totalCombos = 0;
  for (let i = 0; i < N; i++) {
    results.push({ combo: [relevant[i]], result: computeCombo(spend, [relevant[i]]) });
    totalCombos++;
    for (let j = i + 1; j < N; j++) {
      results.push({ combo: [relevant[i], relevant[j]], result: computeCombo(spend, [relevant[i], relevant[j]]) });
      totalCombos++;
      for (let k = j + 1; k < N; k++) {
        results.push({ combo: [relevant[i], relevant[j], relevant[k]], result: computeCombo(spend, [relevant[i], relevant[j], relevant[k]]) });
        totalCombos++;
      }
    }
  }
  results.sort((a, b) => b.result.netCashback - a.result.netCashback);
  return { results: results.slice(0, topK), totalCombos };
}

// ─────────────────────────────────────────────────────────────
// CREDIT CARD BADGE — trademark-safe SVG render
// ─────────────────────────────────────────────────────────────
function buildCardBadge(card, cashback) {
  const hex = card.hexColor || '#1a1a2e';
  // Derive a slightly lighter variant for the gradient
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b2 = parseInt(hex.slice(5,7),16);
  const lighter = `rgba(${Math.min(r+60,255)},${Math.min(g+60,255)},${Math.min(b2+60,255)},0.9)`;

  const networkSvg = card.network === 'Mastercard'
    ? `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 50 30" width="38" height="22">
        <circle cx="19" cy="15" r="11" fill="#EB001B" opacity="0.9"/>
        <circle cx="31" cy="15" r="11" fill="#F79E1B" opacity="0.9"/>
        <path d="M25 7.5a11 11 0 0 1 0 15 11 11 0 0 1 0-15z" fill="#FF5F00" opacity="0.9"/>
      </svg>`
    : card.network === 'Visa'
    ? `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 20" width="44" height="15">
        <text x="0" y="16" font-family="Arial,sans-serif" font-size="16" font-weight="bold" font-style="italic" fill="white" letter-spacing="-1" opacity="0.9">VISA</text>
      </svg>`
    : card.network === 'Amex'
    ? `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 20" width="50" height="14">
        <text x="0" y="14" font-family="Arial,sans-serif" font-size="11" font-weight="bold" fill="white" letter-spacing="1" opacity="0.9">AMEX</text>
      </svg>`
    : `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 90 20" width="56" height="14">
        <text x="0" y="14" font-family="Arial,sans-serif" font-size="10" font-weight="bold" fill="white" opacity="0.9">UnionPay</text>
      </svg>`;

  // EMV chip SVG
  const chipSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 30" width="32" height="24" class="flex-shrink-0">
    <rect x="2" y="2" width="36" height="26" rx="3" fill="#CFB53B" stroke="#B8A030" stroke-width="1"/>
    <rect x="6" y="2" width="28" height="26" rx="2" fill="none" stroke="#B8A030" stroke-width="0.5"/>
    <line x1="20" y1="2" x2="20" y2="28" stroke="#B8A030" stroke-width="0.5"/>
    <line x1="2" y1="10" x2="38" y2="10" stroke="#B8A030" stroke-width="0.5"/>
    <line x1="2" y1="20" x2="38" y2="20" stroke="#B8A030" stroke-width="0.5"/>
  </svg>`;

  return `
    <div class="relative rounded-2xl overflow-hidden shadow-md w-full max-w-xs"
         style="background: linear-gradient(135deg, ${hex} 0%, ${lighter} 60%, ${hex}cc 100%); aspect-ratio: 1.586; min-height: 120px;">
      <!-- Decorative circles -->
      <div class="absolute top-0 right-0 w-32 h-32 rounded-full opacity-10" style="background: white; transform: translate(30%,-30%);"></div>
      <div class="absolute bottom-0 left-0 w-24 h-24 rounded-full opacity-10" style="background: white; transform: translate(-30%,30%);"></div>

      <div class="relative z-10 h-full p-4 flex flex-col justify-between">
        <!-- Top row: chip + network -->
        <div class="flex items-start justify-between">
          ${chipSvg}
          <div class="flex-shrink-0">${networkSvg}</div>
        </div>

        <!-- Card name -->
        <div>
          <p class="text-[9px] text-white/60 uppercase tracking-widest mb-0.5">${card.bank}</p>
          <p class="text-white font-semibold text-xs leading-tight">${card.cardName}</p>
        </div>
      </div>

      <!-- Cashback overlay badge -->
      <div class="absolute top-2 right-2 bg-black/30 backdrop-blur-sm rounded-lg px-2 py-1 text-center">
        <p class="text-[9px] text-white/70">Cashback</p>
        <p class="text-white font-bold text-sm">RM ${cashback.toFixed(2)}</p>
      </div>
    </div>`;
}

// ─────────────────────────────────────────────────────────────
// RESULT RENDERER
// ─────────────────────────────────────────────────────────────
function renderResults(results, totalCombos) {
  const container = document.getElementById('resultCards');
  const combosEl = document.getElementById('combosChecked');
  if (combosEl) combosEl.textContent = `${totalCombos.toLocaleString()} kombinasi dinilai`;

  container.innerHTML = results.map(({ combo, result }, idx) => {
    const rank = idx + 1;
    const isTop = rank === 1;
    const borderClass = isTop
      ? 'border-2 border-primary'
      : 'border border-gray-100 dark:border-slate-700/30';

    const cardBadges = result.cards.map(c =>
      buildCardBadge({ ...c, network: combo.find(x=>x.id===c.cardId).network }, c.earnedCashback)
    ).join('');

    // Per-card breakdown table rows
    const breakdownRows = result.cards.map(c => {
      const topCats = c.breakdown
        .filter(b => b.cashback > 0)
        .sort((a,b) => b.cashback - a.cashback)
        .slice(0,4);
      return `
        <div class="mb-3">
          <p class="text-xs font-semibold text-default mb-1">${c.cardName}</p>
          <table class="w-full text-[11px]">
            ${topCats.map(b => `
              <tr>
                <td class="py-0.5 text-muted pr-2">${b.category}</td>
                <td class="py-0.5 tabular-nums text-right pr-2">RM ${b.spend.toFixed(0)}</td>
                <td class="py-0.5 tabular-nums text-right text-emerald-700 dark:text-emerald-400">${(b.rate*100).toFixed(1)}%</td>
                <td class="py-0.5 tabular-nums text-right font-semibold">RM ${b.cashback.toFixed(2)}</td>
                ${b.cappedBy!=='none' ? `<td class="py-0.5 pl-1 text-amber-600 dark:text-amber-400 text-[10px]">[capped]</td>` : '<td></td>'}
              </tr>`).join('')}
          </table>
          ${!c.metMinSpend ? '<p class="text-[10px] text-amber-600 dark:text-amber-400 mt-1">Perbelanjaan minimum tidak capai — cashback dikira pada kadar asas</p>' : ''}
        </div>`;
    }).join('');

    const feeNote = result.monthlyFeeAmortized > 0
      ? `<span class="text-xs text-muted ml-2">(Fee bulanan: −RM ${result.monthlyFeeAmortized.toFixed(2)})</span>`
      : '';

    return `
      <div class="rounded-2xl bg-white dark:bg-slate-900/60 ${borderClass} shadow-sm overflow-hidden mb-5">
        ${isTop ? '<div class="bg-primary text-white text-xs font-bold text-center py-1.5 tracking-wide uppercase">Combo Terbaik</div>' : ''}

        <div class="p-5 md:p-6">
          <!-- Header: rank + total cashback -->
          <div class="flex items-start justify-between mb-5">
            <div>
              <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-primary/10 text-primary font-bold text-sm mr-2">#${rank}</span>
              <span class="text-sm text-muted">${combo.map(c=>c.bank).join(' + ')}</span>
            </div>
            <div class="text-right">
              <p class="text-2xl font-bold text-primary">RM ${result.totalCashback.toFixed(2)}</p>
              <p class="text-xs text-muted">Cashback bersih: <strong class="text-emerald-600 dark:text-emerald-400">RM ${result.netCashback.toFixed(2)}</strong>/bulan${feeNote}</p>
            </div>
          </div>

          <!-- Card badges grid -->
          <div class="grid grid-cols-${result.cards.length} gap-3 mb-5">
            ${cardBadges}
          </div>

          <!-- Breakdown accordion -->
          <details class="group">
            <summary class="cursor-pointer list-none flex items-center justify-between text-sm font-semibold text-default hover:text-primary transition-colors">
              <span>Lihat pecahan perbelanjaan</span>
              <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="mt-4 pt-4 border-t border-gray-100 dark:border-slate-700">
              ${breakdownRows}
            </div>
          </details>
        </div>
      </div>`;
  }).join('');
}

// ─────────────────────────────────────────────────────────────
// UI WIRING
// ─────────────────────────────────────────────────────────────

function getSpend() {
  const inputs = document.querySelectorAll('.spend-input');
  const spend = [];
  inputs.forEach(el => {
    const category = el.dataset.category;
    const amount = parseFloat(el.value) || 0;
    if (amount > 0) spend.push({ category, amount });
  });
  return spend;
}

function updateTotalSpend() {
  const total = getSpend().reduce((s, x) => s + x.amount, 0);
  const el = document.getElementById('totalSpend');
  if (el) el.textContent = 'RM ' + total.toLocaleString('ms-MY', { minimumFractionDigits: 0 });
}

function runCalculation() {
  const spend = getSpend();
  if (spend.length === 0) {
    alert('Sila masukkan sekurang-kurangnya satu kategori perbelanjaan.');
    return;
  }

  // Show loading
  document.getElementById('loadingState').classList.remove('hidden');
  document.getElementById('resultsPanel').classList.add('hidden');
  const progress = document.getElementById('progressText');

  // Use setTimeout to yield to browser for loading spinner, then run
  setTimeout(() => {
    try {
      if (progress) progress.textContent = '50%';
      const { results, totalCombos } = findBestCombos(spend, CARDS, 5);
      if (progress) progress.textContent = '100%';
      setTimeout(() => {
        document.getElementById('loadingState').classList.add('hidden');
        renderResults(results, totalCombos);
        document.getElementById('resultsPanel').classList.remove('hidden');
        document.getElementById('resultsPanel').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 50);
    } catch (e) {
      document.getElementById('loadingState').classList.add('hidden');
      console.error('Calculation error:', e);
    }
  }, 30);
}

// Bind events
document.getElementById('btnCalculate').addEventListener('click', runCalculation);
document.getElementById('btnReset').addEventListener('click', () => {
  document.querySelectorAll('.spend-input').forEach(el => { el.value = '0'; });
  document.getElementById('spend-Petrol').value = '200';
  document.getElementById('spend-Groceries').value = '400';
  document.getElementById('spend-Dining').value = '300';
  document.getElementById('spend-eWallet').value = '150';
  document.getElementById('spend-Online Shopping').value = '200';
  document.getElementById('spend-Utilities').value = '150';
  updateTotalSpend();
  document.getElementById('resultsPanel').classList.add('hidden');
});
document.querySelectorAll('.spend-input').forEach(el => {
  el.addEventListener('input', updateTotalSpend);
});

// Run on load with defaults
updateTotalSpend();
</script>
