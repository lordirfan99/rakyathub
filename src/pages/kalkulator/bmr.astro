---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator BMR — Kalori Harian Malaysia | RakyatHub',
  description: 'Kira BMR (Basal Metabolic Rate) dan keperluan kalori harian. Guna formula Mifflin-St Jeor dengan 5 tahap aktiviti.',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8"><a href="/kalkulator" class="text-sm text-muted hover:text-primary transition-colors">← Semua Kalkulator</a></div>
    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Kalkulator BMR & Kalori Harian</h1>
    <p class="text-lg md:text-xl text-muted mb-8">Kira Basal Metabolic Rate (BMR) dan jumlah kalori harian (TDEE) berdasarkan berat, tinggi, umur, jantina dan tahap aktiviti.</p>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <div class="grid md:grid-cols-2 gap-4 md:gap-6">
        <div><label for="bmrBerat" class="block text-sm font-semibold text-default mb-1.5">Berat (kg)</label><input type="number" id="bmrBerat" value="65" min="1" step="0.1" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" /></div>
        <div><label for="bmrTinggi" class="block text-sm font-semibold text-default mb-1.5">Tinggi (cm)</label><input type="number" id="bmrTinggi" value="170" min="50" step="0.5" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" /></div>
        <div><label for="bmrUmur" class="block text-sm font-semibold text-default mb-1.5">Umur (tahun)</label><input type="number" id="bmrUmur" value="28" min="10" max="120" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" /></div>
        <div><label class="block text-sm font-semibold text-default mb-1.5">Jantina</label><div class="flex gap-3"><button id="bmrLelaki" class="flex-1 rounded-xl border-2 border-primary bg-primary/10 px-4 py-3 text-sm font-semibold text-primary" onclick="setGender(true)">Lelaki</button><button id="bmrPerempuan" class="flex-1 rounded-xl border-2 border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm font-semibold text-default" onclick="setGender(false)">Perempuan</button></div></div>
      </div>
      <div class="mt-4"><label class="block text-sm font-semibold text-default mb-1.5">Tahap Aktiviti</label><select id="bmrAktiviti" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"><option value="1.2">Tidak Aktif</option><option value="1.375" selected>Ringan</option><option value="1.55">Sederhana</option><option value="1.725">Aktif</option><option value="1.9">Sangat Aktif</option></select></div>
      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl bg-blue-50 dark:bg-blue-900/20 p-4 text-center"><p class="text-xs text-muted uppercase tracking-wide">BMR</p><p class="text-lg font-bold text-default" id="bmrNilai">1,550</p><p class="text-[10px] text-muted">kcal/hari</p></div>
        <div class="rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4 text-center"><p class="text-xs text-muted uppercase tracking-wide">TDEE</p><p class="text-lg font-bold text-emerald-700" id="bmrTdee">2,131</p><p class="text-[10px] text-muted">kcal/hari</p></div>
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center"><p class="text-xs text-muted uppercase tracking-wide">Turun 0.5kg/minggu</p><p class="text-lg font-bold text-amber-700" id="bmrTurun">0</p><p class="text-[10px] text-muted">kcal/hari</p></div>
        <div class="rounded-xl bg-indigo-50 dark:bg-indigo-900/20 p-4 text-center"><p class="text-xs text-muted uppercase tracking-wide">Naik 0.5kg/minggu</p><p class="text-lg font-bold text-indigo-700" id="bmrNaik">0</p><p class="text-[10px] text-muted">kcal/hari</p></div>
      </div>
      <div class="mt-4 p-5 rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/5 border border-primary/20 text-center"><p class="text-sm text-muted">BMR = <span id="bmrFormula">(10×65)+(6.25×170)−(5×28)+5</span></p><p class="text-2xl font-bold text-primary mt-1" id="bmrFinal">1,550 kcal/hari</p></div>
    </div>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">Cara Kira BMR</h2>
      <p class="text-muted text-sm mb-3"><strong>Mifflin-St Jeor (1990):</strong></p>
      <ul class="text-muted text-sm space-y-1"><li>• <strong>Lelaki:</strong> BMR = (10×kg)+(6.25×cm)−(5×umur)+5</li><li>• <strong>Perempuan:</strong> BMR = (10×kg)+(6.25×cm)−(5×umur)−161</li></ul>
      <p class="text-muted text-sm mt-3">TDEE = BMR × Faktor Aktiviti. BMR adalah kalori minima untuk fungsi asas tubuh.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover"><h3 class="font-semibold text-lg mb-2">BMR</h3><p class="text-muted text-sm">Kalori minima untuk hidup. Tubuh bakar ni walaupun tidur. Jangan makan kurang dari BMR tanpa nasihat doktor.</p></div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover"><h3 class="font-semibold text-lg mb-2">TDEE</h3><p class="text-muted text-sm">Jumlah kalori harian untuk kekalkan berat. Nak turun: kurang 300-500 kcal. Nak naik: tambah 300-500 kcal.</p></div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover"><h3 class="font-semibold text-lg mb-2">Faktor Individu</h3><p class="text-muted text-sm">Metabolisme setiap orang berbeza. Guna angka ini sebagai panduan permulaan.</p></div>
    </div>

    <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-4 mb-8 text-xs text-muted">
      <strong>Penafian:</strong> Anggaran sahaja. Rujuk pakar diet untuk nasihat pemakanan peribadi.
      <br /><em>Sumber: PubMed 2305711 — Mifflin MD, et al. 1990</em>
    </div>

    <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6 md:p-8">
      <h3 class="text-xl font-bold mb-4">Alat Kesihatan Lain</h3>
      <ul class="space-y-2"><li><a href="/kalkulator/bmi/" class="text-primary font-medium hover:underline text-sm">→ Kalkulator BMI</a></li><li><a href="/kalkulator/berat-ideal/" class="text-primary font-medium hover:underline text-sm">→ Kalkulator Berat Badan Ideal</a></li></ul>
    </div>
  </section>

  <CallToAction actions={[{ variant: 'primary', text: 'Kira BMI', href: '/kalkulator/bmi' },{ variant: 'secondary', text: 'Berat Ideal', href: '/kalkulator/berat-ideal' }]}>
    <Fragment slot="title">Nak semak BMI atau berat ideal?</Fragment><Fragment slot="subtitle">Guna kalkulator kesihatan percuma kami.</Fragment>
  </CallToAction>

  <script is:inline>
function fmtK(v) { return typeof v === 'number' && !isNaN(v) && isFinite(v) ? Math.round(v).toLocaleString() : '0'; }
function sn(v, d) { var n = parseFloat(v); return (!isNaN(n) && isFinite(n) && n >= 0) ? n : (d || 0); }
var isMale = true;
function setGender(male) {
  isMale = male;
  var l = document.getElementById('bmrLelaki'), p = document.getElementById('bmrPerempuan');
  if (male) { l.className='flex-1 rounded-xl border-2 border-primary bg-primary/10 px-4 py-3 text-sm font-semibold text-primary'; p.className='flex-1 rounded-xl border-2 border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm font-semibold text-default'; }
  else { p.className='flex-1 rounded-xl border-2 border-primary bg-primary/10 px-4 py-3 text-sm font-semibold text-primary'; l.className='flex-1 rounded-xl border-2 border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm font-semibold text-default'; }
  calc();
}
function calc() {
  var w = sn(document.getElementById('bmrBerat').value, 65);
  var h = sn(document.getElementById('bmrTinggi').value, 170);
  var a = sn(document.getElementById('bmrUmur').value, 28);
  var act = parseFloat(document.getElementById('bmrAktiviti').value) || 1.375;
  if (w===0||h===0||a===0) {['bmrNilai','bmrTdee','bmrTurun','bmrNaik'].forEach(function(id){document.getElementById(id).textContent='—'}); document.getElementById('bmrFinal').textContent='Sila masukkan nilai'; return; }
  var bmr = isMale ? (10*w+6.25*h-5*a+5) : (10*w+6.25*h-5*a-161);
  var tdee = bmr * act;
  document.getElementById('bmrNilai').textContent = fmtK(bmr);
  document.getElementById('bmrTdee').textContent = fmtK(tdee);
  // Defisit sebenar 500 kcal = ~0.5kg/minggu (padan dengan label). Tidak diapit pada
  // 1,200 supaya angka konsisten dengan maksudnya.
  document.getElementById('bmrTurun').textContent = fmtK(Math.max(tdee-500,0));
  document.getElementById('bmrNaik').textContent = fmtK(tdee+500);
  document.getElementById('bmrFormula').textContent = '(10×'+w+')+(6.25×'+h+')−(5×'+a+')'+(isMale?'+5':'−161');
  document.getElementById('bmrFinal').textContent = fmtK(bmr)+' kcal/hari';
}
['bmrBerat','bmrTinggi','bmrUmur','bmrAktiviti'].forEach(function(id){var el=document.getElementById(id);if(el){el.addEventListener('input',calc);el.addEventListener('change',calc);}});
calc();
</script>
</Layout>
