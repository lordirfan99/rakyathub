---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator Loan Rumah — Ansuran & Kelayakan',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/" class="text-sm text-muted hover:text-primary transition-colors">← Laman Utama</a>
    </div>

    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">
      Kalkulator Loan Rumah
    </h1>
    <p class="text-lg md:text-xl text-muted mb-8">
      Kira ansuran pinjaman rumah bulanan & kelayakan berdasarkan harga rumah dan kadar interest.
    </p>

    <!-- Calculator Card -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <div class="grid md:grid-cols-2 gap-4 md:gap-6">
        <div>
          <label for="harga" class="block text-sm font-semibold text-default mb-1.5">Harga Rumah (RM)</label>
          <input type="number" id="harga" value="300000" min="0" step="10000"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="dp" class="block text-sm font-semibold text-default mb-1.5">Downpayment (%)</label>
          <input type="number" id="dp" value="10" min="0" max="50" step="5"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="interest" class="block text-sm font-semibold text-default mb-1.5">Kadar Interest (% setahun)</label>
          <input type="number" id="interest" value="4.5" min="0" max="10" step="0.1"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="tempoh" class="block text-sm font-semibold text-default mb-1.5">Tempoh Loan (Tahun)</label>
          <select id="tempoh"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
            <option value="15">15 Tahun</option>
            <option value="20">20 Tahun</option>
            <option value="25" selected>25 Tahun</option>
            <option value="30">30 Tahun</option>
            <option value="35">35 Tahun</option>
          </select>
        </div>
        <div>
          <label for="gaji" class="block text-sm font-semibold text-default mb-1.5">Gaji Bulanan (RM) — untuk DSR</label>
          <input type="number" id="gaji" value="5000" min="0" step="500"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="komitmen" class="block text-sm font-semibold text-default mb-1.5">Komitmen Lain (RM/bln)</label>
          <input type="number" id="komitmen" value="500" min="0" step="100"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
      </div>

      <!-- Results -->
      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl bg-blue-50 dark:bg-blue-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Jumlah Pinjaman</p>
          <p class="text-lg font-bold text-default" id="hasilLoan">RM 270,000.00</p>
        </div>
        <div class="rounded-xl bg-primary/10 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Ansuran Bulanan</p>
          <p class="text-lg font-bold text-primary" id="hasilAnsuran">RM 0.00</p>
        </div>
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Jumlah Interest</p>
          <p class="text-lg font-bold text-amber-600" id="hasilInterest">RM 0.00</p>
        </div>
        <div class="rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">DSR</p>
          <p class="text-lg font-bold text-emerald-700" id="hasilDSR">0%</p>
        </div>
      </div>

      <!-- DSR Gauge -->
      <div class="mt-6 grid md:grid-cols-2 gap-4">
        <div class="p-5 rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/5 border border-primary/20 text-center">
          <p class="text-sm text-muted">Anggaran Ansuran Bulanan</p>
          <p class="text-3xl md:text-4xl font-bold text-primary" id="hasilProjected">RM 0.00</p>
        </div>
        <div class="rounded-xl border" id="dsrCard">
          <div class="p-5 text-center">
            <p class="text-sm text-muted">Debt Service Ratio (DSR)</p>
            <p class="text-2xl font-bold" id="hasilDSRLabel">0%</p>
            <p class="text-xs text-muted mt-1" id="dsrStatus">Gaji tak mencukupi</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Amortization Table -->
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">Jadual Pelunasan Tahunan</h2>
      <div class="overflow-x-auto -mx-5 md:-mx-0">
        <div class="min-w-[500px] px-5 md:px-0">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100 dark:border-slate-700">
                <th class="text-left py-3 px-2 font-semibold text-muted">Tahun</th>
                <th class="text-right py-3 px-2 font-semibold text-muted">Baki Loan</th>
                <th class="text-right py-3 px-2 font-semibold text-muted">Bayaran</th>
                <th class="text-right py-3 px-2 font-semibold text-muted">Interest</th>
                <th class="text-right py-3 px-2 font-semibold text-muted">Principal</th>
                <th class="text-right py-3 px-2 font-semibold text-muted">Baki</th>
              </tr>
            </thead>
            <tbody id="amortBody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- DocuKilat CTA -->
    <div class="rounded-2xl bg-gradient-to-br from-primary/10 via-primary/[0.03] to-secondary/10 border border-primary/20 p-6 md:p-8 text-center mb-8">
      <h3 class="text-xl md:text-2xl font-bold mb-2">Perlukan Surat Tawaran Rumah?</h3>
      <p class="text-muted mb-4">Guna DocuKilat untuk bina surat tawaran, perjanjian sewa, atau dokumen hartanah lain.</p>
      <a href="https://docukilat.rakyathub.my" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-primary to-secondary text-white font-semibold text-sm transition-all duration-300 hover:shadow-lg hover:shadow-primary/30 hover:scale-[1.02]">
        Bina Dokumen di DocuKilat
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

    <!-- Info Cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">Ansuran Bulanan</h3>
        <p class="text-muted text-sm">Kira bayaran bulanan rumah berdasarkan interest rate dan tempoh loan.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">DSR</h3>
        <p class="text-muted text-sm">Debt Service Ratio — nisbah komitmen vs gaji untuk kelayakan loan.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">Interest Tetap vs Terapung</h3>
        <p class="text-muted text-sm">Bandingkan kadar interest tetap dan terapung untuk buat keputusan bijak.</p>
      </div>
    </div>

    <!-- Artikel -->
    <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-rose-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6 md:p-8">
      <h3 class="text-xl font-bold mb-4">Artikel Berkaitan Loan Rumah</h3>
      <ul class="space-y-2">
        <li>
          <a href="/loan-rumah-calculator-kiraan-ansuran-perancangan-kewangan/" class="text-primary font-medium hover:underline text-sm">
            → Kiraan Ansuran Loan Rumah — Perancangan Kewangan
          </a>
        </li>
        <li>
          <a href="/cadangan-bajet-50-30-20-di-malaysia/" class="text-primary font-medium hover:underline text-sm">
            → Panduan Bajet 50/30/20 — Cara Urus Gaji & Simpanan
          </a>
        </li>
        <li>
          <a href="/cara-semak-baki-kwsp-online-tanpa-pergi-kaunter-2025-panduan-lengkap/" class="text-primary font-medium hover:underline text-sm">
            → Cara Guna KWSP untuk Bayaran Pendahuluan Rumah
          </a>
        </li>
      </ul>
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Kalkulator Kereta', href: '/kalkulator/kereta' },
      { variant: 'secondary', text: 'Kalkulator KWSP', href: '/kalkulator/kwsp' },
    ]}
  >
    <Fragment slot="title">Nak Kira Kereta atau KWSP?</Fragment>
    <Fragment slot="subtitle">Semua kalkulator percuma — guna sekarang.</Fragment>
  </CallToAction>
  <script is:inline>
function fmt(v) { return 'RM ' + (typeof v === 'number' && !isNaN(v) && isFinite(v) ? v.toLocaleString('ms-MY', {minimumFractionDigits:2,maximumFractionDigits:2}) : '0.00'); }
function sn(v, d) { var n = parseFloat(v); return (!isNaN(n) && isFinite(n) && n >= 0) ? n : (d || 0); }

function calc() {
  var harga = sn(document.getElementById('harga').value, 300000);
  var dpPct = sn(document.getElementById('dp').value, 10);
  var rate = sn(document.getElementById('interest').value, 4.5);
  var tempoh = parseInt(document.getElementById('tempoh').value) || 25;
  var gaji = sn(document.getElementById('gaji').value, 5000);
  var komitmen = sn(document.getElementById('komitmen').value, 500);

  if (harga === 0 || dpPct >= 100) {
    ['hasilLoan','hasilAnsuran','hasilInterest','hasilProjected'].forEach(function(id) {
      document.getElementById(id).textContent = 'RM 0.00';
    });
    document.getElementById('hasilDSR').textContent = '0%';
    document.getElementById('hasilDSRLabel').textContent = '0%';
    var tb = document.getElementById('amortBody');
    tb.textContent = '';
    var er = document.createElement('tr'); var et = document.createElement('td');
    et.colSpan = 6; et.className = 'text-center py-8 text-muted'; et.textContent = 'Sila masukkan nilai yang sah.';
    er.appendChild(et); tb.appendChild(er);
    return;
  }

  var dpAmount = harga * (dpPct / 100);
  var loan = harga - dpAmount;
  var monthlyRate = (rate / 100) / 12;
  var months = tempoh * 12;

  // Monthly payment formula: P * r * (1+r)^n / ((1+r)^n - 1)
  var monthly;
  if (monthlyRate === 0) {
    monthly = loan / months;
  } else {
    var factor = Math.pow(1 + monthlyRate, months);
    monthly = loan * (monthlyRate * factor) / (factor - 1);
  }

  var totalPayment = monthly * months;
  var totalInterest = totalPayment - loan;

  document.getElementById('hasilLoan').textContent = fmt(loan);
  document.getElementById('hasilAnsuran').textContent = fmt(monthly);
  document.getElementById('hasilInterest').textContent = fmt(totalInterest);
  document.getElementById('hasilProjected').textContent = fmt(monthly);

  // DSR calculation
  var dsr = ((monthly + komitmen) / gaji) * 100;
  if (!isFinite(dsr) || dsr < 0) dsr = 0;
  var dsrFormatted = (typeof dsr === 'number' && !isNaN(dsr) ? dsr.toFixed(1) : '0') + '%';
  document.getElementById('hasilDSR').textContent = dsrFormatted;
  document.getElementById('hasilDSRLabel').textContent = dsrFormatted;

  var dsrCard = document.getElementById('dsrCard');
  var dsrStatusEl = document.getElementById('dsrStatus');
  if (dsr <= 60) {
    dsrCard.className = 'rounded-xl border border-emerald-200 dark:border-emerald-800 bg-green-50 dark:bg-emerald-900/20';
    dsrStatusEl.textContent = 'Layak — DSR dalam lingkungan selamat';
    dsrStatusEl.className = 'text-xs mt-1 text-emerald-700 dark:text-emerald-300';
  } else if (dsr <= 70) {
    dsrCard.className = 'rounded-xl border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-900/20';
    dsrStatusEl.textContent = 'Mungkin layak — DSR agak tinggi';
    dsrStatusEl.className = 'text-xs mt-1 text-amber-700 dark:text-amber-300';
  } else {
    dsrCard.className = 'rounded-xl border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-900/20';
    dsrStatusEl.textContent = 'Tak layak — DSR terlalu tinggi (>70%)';
    dsrStatusEl.className = 'text-xs mt-1 text-red-700 dark:text-red-300';
  }

  // Amortization table (yearly) — DOM construction avoids innerHTML XSS surface
  var remaining = loan;
  var tbody = document.getElementById('amortBody');
  var frag = document.createDocumentFragment();
  for (var t = 1; t <= tempoh; t++) {
    var yearlyPrincipal = 0;
    var yearlyInterest = 0;
    for (var m = 1; m <= 12; m++) {
      if (remaining <= 0) break;
      var interestMonth = remaining * monthlyRate;
      var principalMonth = monthly - interestMonth;
      if (principalMonth > remaining) principalMonth = remaining;
      yearlyInterest += interestMonth;
      yearlyPrincipal += principalMonth;
      remaining -= principalMonth;
      if (remaining < 0) remaining = 0;
    }
    var isLast = t === tempoh || remaining <= 0;
    var bakiSebelum = remaining + yearlyPrincipal;
    var tr = document.createElement('tr');
    tr.className = (isLast ? 'font-bold bg-primary/5' : '') + ' border-b border-gray-50 dark:border-slate-800';
    [
      { text: String(t), cls: 'py-2.5 px-2' },
      { text: fmt(bakiSebelum), cls: 'text-right py-2.5 px-2' },
      { text: fmt(monthly * 12), cls: 'text-right py-2.5 px-2' },
      { text: fmt(yearlyInterest), cls: 'text-right py-2.5 px-2 text-amber-600' },
      { text: fmt(yearlyPrincipal), cls: 'text-right py-2.5 px-2 text-primary' },
      { text: fmt(remaining), cls: 'text-right py-2.5 px-2 text-default' },
    ].forEach(function(c) {
      var td = document.createElement('td');
      td.className = c.cls; td.textContent = c.text; tr.appendChild(td);
    });
    frag.appendChild(tr);
    if (remaining <= 0) break;
  }
  tbody.textContent = '';
  tbody.appendChild(frag);

  if (tempoh > 30) { tbody.style.maxHeight = '400px'; tbody.style.overflowY = 'auto'; tbody.style.display = 'block'; }
  else { tbody.style.maxHeight = ''; tbody.style.overflowY = ''; tbody.style.display = ''; }
}

// Script is inline at page bottom — DOM already available, no DOMContentLoaded needed
['harga','dp','interest','tempoh','gaji','komitmen'].forEach(function(id) {
  var el = document.getElementById(id);
  if (el) { el.addEventListener('input', calc); el.addEventListener('change', calc); }
});
calc();
</script>
<script is:inline>
(function(){var x=new XMLHttpRequest();x.open('GET','/.netlify/functions/kewangan',true);x.onload=function(){if(x.status!==200)return;try{var d=JSON.parse(x.responseText);if(!d)return;if(d.kadar&&d.kadar.housing_loan_pct){['interest','bf'].forEach(function(id){var el=document.getElementById(id);if(!el)return;var v=parseFloat(el.value);if(id==='interest'&&(v===4.5||v===4||v===4.25))el.value=d.kadar.housing_loan_pct;if(id==='bf'&&(v===4||v===4.5||v===3.5))el.value=d.kadar.housing_loan_pct;});}if(typeof calc==='function')calc();}catch(e){}};x.send();})();
</script>
</Layout>
