---
import { Icon } from 'astro-icon/components';
import Layout from '~/layouts/PageLayout.astro';

interface CalcCard {
  title: string;
  description: string;
  icon: string;
  href: string;
  gradient: string;
  badge?: string;
}

const metadata = {
  title: 'Kalkulator RakyatHub — Alat Kewangan Malaysia',
};

const newCalcs: CalcCard[] = [
  {
    title: 'STR & SARA Checker',
    description: 'Semak anggaran bantuan STR dan SARA kerajaan Malaysia.',
    icon: 'tabler:gift',
    href: '/kalkulator/str-sara/',
    gradient: 'from-primary to-secondary',
    badge: 'Baru',
  },
  {
    title: 'Gaji Bersih Malaysia',
    description: 'Kira take-home pay selepas potongan EPF, SOCSO dan PCB.',
    icon: 'tabler:coin',
    href: '/kalkulator/gaji-bersih/',
    gradient: 'from-blue-500 to-blue-700',
    badge: 'Baru',
  },
  {
    title: 'Kalkulator SST',
    description: 'Kira cukai SST 6% & 8% untuk barangan dan perkhidmatan.',
    icon: 'tabler:receipt-tax',
    href: '/kalkulator/sst/',
    gradient: 'from-amber-500 to-amber-700',
    badge: 'Baru',
  },
  {
    title: 'Zakat Pendapatan',
    description: 'Kira zakat pendapatan 2.5% mengikut kadar emas semasa.',
    icon: 'tabler:heart',
    href: '/kalkulator/zakat-pendapatan/',
    gradient: 'from-emerald-500 to-emerald-700',
    badge: 'Baru',
  },
  {
    title: 'Beli vs Sewa Rumah',
    description: 'Bandingkan kos beli rumah vs sewa dalam jangka panjang.',
    icon: 'tabler:building-bank',
    href: '/kalkulator/beli-sewa-rumah/',
    gradient: 'from-rose-500 to-rose-700',
    badge: 'Baru',
  },
  {
    title: 'Emas vs ASB vs FD',
    description: 'Bandingkan pulangan pelaburan emas, ASB dan fixed deposit.',
    icon: 'tabler:trending-up',
    href: '/kalkulator/pelaburan/',
    gradient: 'from-amber-500 to-yellow-600',
    badge: 'Baru',
  },
];

const existingCalcs: CalcCard[] = [
  {
    title: 'Kalkulator KWSP',
    description: 'Kira caruman, pengeluaran fleksibel dan dividen KWSP. Simulasi simpanan persaraan anda.',
    icon: 'tabler:wallet',
    href: '/kalkulator/kwsp/',
    gradient: 'from-blue-600 to-blue-800',
  },
  {
    title: 'Kalkulator ASB',
    description: 'Kira dividen ASB, bonus dan simpanan automatik. Optimalkan pelaburan ASB loan anda.',
    icon: 'tabler:chart-bar',
    href: '/kalkulator/asb/',
    gradient: 'from-emerald-500 to-teal-600',
  },
  {
    title: 'Kalkulator Emas',
    description: 'Semak harga emas harian, spread, dan beza harga Public Gold vs kedai emas.',
    icon: 'tabler:coins',
    href: '/kalkulator/emas/',
    gradient: 'from-amber-500 to-yellow-600',
  },
  {
    title: 'Kalkulator Kereta',
    description: 'Kira ansuran bulanan kereta berdasarkan harga loan, kadar interest dan tempoh bayaran.',
    icon: 'tabler:car',
    href: '/kalkulator/kereta/',
    gradient: 'from-indigo-500 to-purple-600',
  },
  {
    title: 'Kalkulator Loan Rumah',
    description: 'Kira ansuran bulanan rumah, banding kadar interest tetap vs terapung.',
    icon: 'tabler:home',
    href: '/kalkulator/loan-rumah/',
    gradient: 'from-rose-500 to-pink-600',
  },
  {
    title: 'Kalkulator Zakat',
    description: 'Kira zakat pendapatan, zakat simpanan dan zakat emas mengikut kadar terkini.',
    icon: 'tabler:calculator',
    href: '/kalkulator/zakat/',
    gradient: 'from-sky-500 to-cyan-600',
  },
];
---

<Layout metadata={metadata}>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/" class="text-sm text-muted hover:text-primary transition-colors">← Laman Utama</a>
    </div>

    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">
      Kalkulator RakyatHub
    </h1>
    <p class="text-lg md:text-xl text-muted mb-8 max-w-3xl">
      Koleksi alat kiraan kewangan Malaysia 💪 — percuma, mudah, tanpa daftar. Kira KWSP, ASB, emas, gaji bersih dan banyak lagi.
    </p>

    <!-- All Calculators -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {[...newCalcs, ...existingCalcs].map((calc) => (
        <a href={calc.href} class="block h-full group">
          <div class="relative h-full rounded-xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 p-5 transition-all duration-300 ease-out hover:-translate-y-2 hover:shadow-xl hover:border-primary/40 hover:shadow-primary/5">
            <!-- Icon in gradient circle -->
            <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${calc.gradient} flex items-center justify-center shadow-md`}>
              <Icon name={calc.icon} class="w-6 h-6 text-white" />
            </div>

            <!-- Badge + Title row -->
            <div class="mt-4 flex items-start justify-between gap-2">
              <h3 class="text-lg font-bold text-default group-hover:text-primary transition-colors">
                {calc.title}
              </h3>
              {calc.badge && (
                <span class="shrink-0 text-xs font-semibold bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 px-2.5 py-1 rounded-full ring-1 ring-emerald-200/50 dark:ring-emerald-700/30">
                  {calc.badge}
                </span>
              )}
            </div>

            <!-- Description -->
            <p class="mt-2 text-sm text-muted leading-relaxed line-clamp-3">
              {calc.description}
            </p>

            <!-- CTA -->
            <div class="mt-4 pt-3 border-t border-gray-100 dark:border-slate-700/20">
              <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary dark:text-blue-400 group-hover:text-secondary dark:group-hover:text-blue-300 transition-colors duration-200">
                Guna Alat
                <svg class="w-4 h-4 transition-transform duration-300 ease-out group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
