---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Kalkulator RakyatHub — Alat Kewangan Malaysia',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/" class="text-sm text-muted hover:text-primary transition-colors">← Laman Utama</a>
    </div>

    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">
      Kalkulator RakyatHub
    </h1>
    <p class="text-lg md:text-xl text-muted mb-8">
      Koleksi alat kiraan kewangan Malaysia 💪 — percuma, mudah, tanpa daftar. Kira KWSP, ASB, emas, gaji bersih dan banyak lagi.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <!-- New calculators -->
      <a href="/kalkulator/str-sara/" class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-900/80 border border-gray-100 dark:border-slate-700/40 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-primary/5 to-transparent rounded-bl-full"></div>
        <div class="p-6">
          <div class="flex items-center gap-4">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-primary/20 to-secondary/10 ring-1 ring-primary/10 shrink-0">
              <span class="text-xl font-bold text-primary">STR</span>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-lg text-default group-hover:text-primary transition-colors">💰 STR &amp; SARA Checker</h3>
              <p class="text-sm text-muted mt-0.5">Semak anggaran bantuan STR dan SARA</p>
            </div>
            <span class="relative shrink-0 text-xs font-semibold bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 px-2.5 py-1 rounded-full ring-1 ring-emerald-200/50 dark:ring-emerald-700/30">Baru</span>
          </div>
        </div>
      </a>

      <a href="/kalkulator/gaji-bersih/" class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-900/80 border border-gray-100 dark:border-slate-700/40 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-blue-500/5 to-transparent rounded-bl-full"></div>
        <div class="p-6">
          <div class="flex items-center gap-4">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500/20 to-blue-600/10 ring-1 ring-blue-500/10 shrink-0">
              <span class="text-xl font-bold text-blue-600">Gaji</span>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-lg text-default group-hover:text-blue-600 transition-colors">💵 Gaji Bersih Malaysia</h3>
              <p class="text-sm text-muted mt-0.5">Take-home pay selepas potongan</p>
            </div>
            <span class="relative shrink-0 text-xs font-semibold bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 px-2.5 py-1 rounded-full ring-1 ring-emerald-200/50 dark:ring-emerald-700/30">Baru</span>
          </div>
        </div>
      </a>

      <a href="/kalkulator/sst/" class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-900/80 border border-gray-100 dark:border-slate-700/40 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-amber-500/5 to-transparent rounded-bl-full"></div>
        <div class="p-6">
          <div class="flex items-center gap-4">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-amber-500/20 to-amber-600/10 ring-1 ring-amber-500/10 shrink-0">
              <span class="text-xl font-bold text-amber-600">SST</span>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-lg text-default group-hover:text-amber-600 transition-colors">🧾 Kalkulator SST</h3>
              <p class="text-sm text-muted mt-0.5">Kira SST 6% &amp; 8%</p>
            </div>
            <span class="relative shrink-0 text-xs font-semibold bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 px-2.5 py-1 rounded-full ring-1 ring-emerald-200/50 dark:ring-emerald-700/30">Baru</span>
          </div>
        </div>
      </a>

      <a href="/kalkulator/zakat-pendapatan/" class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-900/80 border border-gray-100 dark:border-slate-700/40 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-emerald-500/5 to-transparent rounded-bl-full"></div>
        <div class="p-6">
          <div class="flex items-center gap-4">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-500/20 to-emerald-600/10 ring-1 ring-emerald-500/10 shrink-0">
              <span class="text-xl font-bold text-emerald-600">Zakat</span>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-lg text-default group-hover:text-emerald-600 transition-colors">🕌 Zakat Pendapatan</h3>
              <p class="text-sm text-muted mt-0.5">Kira zakat 2.5%</p>
            </div>
            <span class="relative shrink-0 text-xs font-semibold bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 px-2.5 py-1 rounded-full ring-1 ring-emerald-200/50 dark:ring-emerald-700/30">Baru</span>
          </div>
        </div>
      </a>

      <a href="/kalkulator/beli-sewa-rumah/" class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-900/80 border border-gray-100 dark:border-slate-700/40 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-rose-500/5 to-transparent rounded-bl-full"></div>
        <div class="p-6">
          <div class="flex items-center gap-4">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-rose-500/20 to-rose-600/10 ring-1 ring-rose-500/10 shrink-0">
              <span class="text-xl font-bold text-rose-600">Rumah</span>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-lg text-default group-hover:text-rose-600 transition-colors">🏠 Beli vs Sewa Rumah</h3>
              <p class="text-sm text-muted mt-0.5">Bandingkan kos beli vs sewa</p>
            </div>
            <span class="relative shrink-0 text-xs font-semibold bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 px-2.5 py-1 rounded-full ring-1 ring-emerald-200/50 dark:ring-emerald-700/30">Baru</span>
          </div>
        </div>
      </a>

      <a href="/kalkulator/pelaburan/" class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-900/80 border border-gray-100 dark:border-slate-700/40 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
        <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-amber-500/5 to-transparent rounded-bl-full"></div>
        <div class="p-6">
          <div class="flex items-center gap-4">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-amber-500/20 to-yellow-600/10 ring-1 ring-amber-500/10 shrink-0">
              <span class="text-xl font-bold text-amber-600">Emas</span>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-lg text-default group-hover:text-amber-600 transition-colors">📈 Emas vs ASB vs FD</h3>
              <p class="text-sm text-muted mt-0.5">Bandingkan pulangan pelaburan</p>
            </div>
            <span class="relative shrink-0 text-xs font-semibold bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 px-2.5 py-1 rounded-full ring-1 ring-emerald-200/50 dark:ring-emerald-700/30">Baru</span>
          </div>
        </div>
      </a>
    </div>

    <!-- Existing calculators -->
    <h2 class="text-2xl font-bold mt-14 mb-6">📐 Kalkulator Sedia Ada</h2>
    <div class="grid md:grid-cols-3 gap-5">
      <a href="/kalkulator/kwsp/" class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-900/80 border border-gray-100 dark:border-slate-700/40 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 p-5">
        <div class="flex items-center gap-3">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-gradient-to-br from-orange-500/20 to-orange-600/10 ring-1 ring-orange-500/10 shrink-0">
            <span class="text-sm font-bold text-orange-600">KW</span>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-default group-hover:text-orange-600 transition-colors">KWSP</h3>
            <p class="text-xs text-muted mt-0.5">Simpanan persaraan &amp; dividen</p>
          </div>
          <svg class="w-4 h-4 text-muted group-hover:text-orange-600 group-hover:translate-x-0.5 transition-all shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>
      <a href="/kalkulator/asb/" class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-900/80 border border-gray-100 dark:border-slate-700/40 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 p-5">
        <div class="flex items-center gap-3">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500/20 to-blue-600/10 ring-1 ring-blue-500/10 shrink-0">
            <span class="text-sm font-bold text-blue-600">AS</span>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-default group-hover:text-blue-600 transition-colors">ASB</h3>
            <p class="text-xs text-muted mt-0.5">Dividen &amp; simpanan ASB/ASM</p>
          </div>
          <svg class="w-4 h-4 text-muted group-hover:text-blue-600 group-hover:translate-x-0.5 transition-all shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>
      <a href="/kalkulator/emas/" class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-900/80 border border-gray-100 dark:border-slate-700/40 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 p-5">
        <div class="flex items-center gap-3">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-gradient-to-br from-amber-500/20 to-amber-600/10 ring-1 ring-amber-500/10 shrink-0">
            <span class="text-sm font-bold text-amber-600">Em</span>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-default group-hover:text-amber-600 transition-colors">Emas</h3>
            <p class="text-xs text-muted mt-0.5">Harga &amp; pelaburan emas</p>
          </div>
          <svg class="w-4 h-4 text-muted group-hover:text-amber-600 group-hover:translate-x-0.5 transition-all shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>
      <a href="/kalkulator/kereta/" class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-900/80 border border-gray-100 dark:border-slate-700/40 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 p-5">
        <div class="flex items-center gap-3">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-gradient-to-br from-sky-500/20 to-sky-600/10 ring-1 ring-sky-500/10 shrink-0">
            <span class="text-sm font-bold text-sky-600">Kr</span>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-default group-hover:text-sky-600 transition-colors">Kereta</h3>
            <p class="text-xs text-muted mt-0.5">Ansuran pinjaman kereta</p>
          </div>
          <svg class="w-4 h-4 text-muted group-hover:text-sky-600 group-hover:translate-x-0.5 transition-all shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>
      <a href="/kalkulator/loan-rumah/" class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-900/80 border border-gray-100 dark:border-slate-700/40 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 p-5">
        <div class="flex items-center gap-3">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-gradient-to-br from-rose-500/20 to-rose-600/10 ring-1 ring-rose-500/10 shrink-0">
            <span class="text-sm font-bold text-rose-600">LR</span>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-default group-hover:text-rose-600 transition-colors">Loan Rumah</h3>
            <p class="text-xs text-muted mt-0.5">Ansuran pinjaman rumah</p>
          </div>
          <svg class="w-4 h-4 text-muted group-hover:text-rose-600 group-hover:translate-x-0.5 transition-all shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>
      <a href="/kalkulator/zakat/" class="group relative overflow-hidden rounded-2xl bg-white dark:bg-slate-900/80 border border-gray-100 dark:border-slate-700/40 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 p-5">
        <div class="flex items-center gap-3">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-gradient-to-br from-emerald-500/20 to-emerald-600/10 ring-1 ring-emerald-500/10 shrink-0">
            <span class="text-sm font-bold text-emerald-600">Za</span>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-default group-hover:text-emerald-600 transition-colors">Zakat</h3>
            <p class="text-xs text-muted mt-0.5">Zakat pendapatan &amp; simpanan</p>
          </div>
          <svg class="w-4 h-4 text-muted group-hover:text-emerald-600 group-hover:translate-x-0.5 transition-all shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>
    </div>
  </section>
</Layout>
