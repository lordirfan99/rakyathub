---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator ASB',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/" class="text-sm text-muted hover:text-amber-600 transition-colors">← Laman Utama</a>
    </div>
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
      <span class="text-4xl mr-2">📐</span> Kalkulator ASB
    </h1>
    <p class="text-xl text-muted mb-8">
      Kira dividen ASB, bonus dan simpanan automatik. Optimalkan pelaburan ASB loan anda.
    </p>

    <div class="bg-amber-50 dark:bg-slate-800/50 rounded-2xl p-8 mb-8 text-center">
      <p class="text-lg text-muted">Kalkulator interaktif sedang dibina. Nantikan!</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6">
        <h3 class="font-semibold text-lg mb-2">💰 Dividen ASB</h3>
        <p class="text-muted text-sm">Kira dividen tahunan ASB berdasarkan simpanan dan kadar dividen semasa.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6">
        <h3 class="font-semibold text-lg mb-2">🏦 ASB Loan</h3>
        <p class="text-muted text-sm">Simulasi pulangan pelaburan ASB loan — berapa untung vs simpan sendiri.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6">
        <h3 class="font-semibold text-lg mb-2">🎯 Target Simpanan</h3>
        <p class="text-muted text-sm">Berapa lama nak capai target simpanan ASB berdasarkan caruman bulanan.</p>
      </div>
    </div>

    <div class="bg-gradient-to-r from-amber-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 rounded-2xl p-8">
      <h3 class="text-xl font-bold mb-2">📚 Artikel Berkaitan ASB</h3>
      <p class="text-muted mb-4">Baca panduan lengkap tentang ASB di blog kami.</p>
      <a href="/blog/asb" class="inline-flex items-center text-amber-600 font-medium hover:underline">Lihat Artikel ASB →</a>
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Kalkulator Lain', href: '/' },
    ]}
  >
    <Fragment slot="title">Nak Kira KWSP atau Kereta?</Fragment>
    <Fragment slot="subtitle">Kami ada kalkulator lengkap untuk semua keperluan kewangan anda.</Fragment>
  </CallToAction>
</Layout>
