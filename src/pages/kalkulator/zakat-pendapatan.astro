---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator Zakat Pendapatan — 2.5%',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/kalkulator" class="text-sm text-muted hover:text-primary transition-colors">← Semua Kalkulator</a>
    </div>
    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Kalkulator Zakat Pendapatan</h1>
    <p class="text-lg md:text-xl text-muted mb-8">Kira zakat pendapatan 2.5% berdasarkan pendapatan bersih tahunan dan nisab terkini.</p>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <div class="grid md:grid-cols-2 gap-4 md:gap-6">
        <div><label for="zp" class="block text-sm font-semibold text-default mb-1.5">Pendapatan Setahun (RM)</label><input type="number" id="zp" value="48000" min="0" step="1000" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"></div>
        <div><label for="zk" class="block text-sm font-semibold text-default mb-1.5">KWSP Setahun (RM)</label><input type="number" id="zk" value="5280" min="0" step="100" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"></div>
        <div><label for="zd" class="block text-sm font-semibold text-default mb-1.5">Belanja Diri (RM/bln)</label><input type="number" id="zd" value="800" min="0" step="50" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"></div>
        <div><label for="zi" class="block text-sm font-semibold text-default mb-1.5">Belanja Isteri (RM/bln)</label><input type="number" id="zi" value="500" min="0" step="50" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"></div>
        <div><label for="za" class="block text-sm font-semibold text-default mb-1.5">Belanja Seorang Anak (RM/bln)</label><input type="number" id="za" value="300" min="0" step="50" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"></div>
        <div><label for="zb" class="block text-sm font-semibold text-default mb-1.5">Bilangan Anak</label><input type="number" id="zb" value="2" min="0" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"></div>
        <div><label for="zl" class="block text-sm font-semibold text-default mb-1.5">Belanja Lain (RM/bln)</label><input type="number" id="zl" value="200" min="0" step="50" class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"><p class="text-xs text-muted mt-1">Ibu bapa, pendidikan, dll</p></div>
      </div>

      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl bg-blue-50 dark:bg-blue-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Pendapatan Bersih</p>
          <p class="text-lg font-bold text-default" id="zkBersih">RM 0.00</p>
        </div>
        <div class="rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Nisab 2026</p>
          <p class="text-lg font-bold text-emerald-700" id="zkNisab">RM 29,961</p>
        </div>
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Status</p>
          <p class="text-lg font-bold" id="zkStatus">-</p>
        </div>
        <div class="rounded-xl bg-primary/10 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Zakat Wajib</p>
          <p class="text-lg font-bold text-primary" id="zkZakat">RM 0.00</p>
        </div>
      </div>

      <div class="mt-6 p-5 rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/5 border border-primary/20 text-center">
        <p class="text-sm text-muted" id="zkLabel">Zakat Pendapatan 2.5%</p>
        <p class="text-3xl md:text-4xl font-bold text-primary" id="zkProjected">RM 0</p>
        <p class="text-xs text-muted mt-1" id="zkDetail">*Nisab 2026: RM 29,961 (nilai 86g emas).</p>
      </div>
    </div>

    <div class="rounded-2xl bg-gradient-to-br from-primary/10 via-primary/[0.03] to-secondary/10 border border-primary/20 p-6 md:p-8 text-center mb-8">
      <h3 class="text-xl md:text-2xl font-bold mb-2">📜 Perlu Resit Zakat atau Surat Pengesahan?</h3>
      <p class="text-muted mb-4">Guna DocuKilat untuk hasilkan dokumen berkaitan zakat dan kewangan.</p>
      <a href="https://docukilat.netlify.app" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-primary to-secondary text-white font-semibold text-sm transition-all duration-300 hover:shadow-lg hover:shadow-primary/30 hover:scale-[1.02]">Bina Dokumen di DocuKilat<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg></a>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover"><h3 class="font-semibold text-lg mb-2">🕌 Zakat Pendapatan</h3><p class="text-muted text-sm">2.5% dari pendapatan bersih tahunan jika melebihi nisab. Wajib bagi Muslim.</p></div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover"><h3 class="font-semibold text-lg mb-2">💰 Rebat Cukai</h3><p class="text-muted text-sm">Bayaran zakat melalui institusi zakat negeri layak mendapat rebat cukai LHDN.</p></div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover"><h3 class="font-semibold text-lg mb-2">📅 Nisab 2026</h3><p class="text-muted text-sm">RM 29,961 — berdasarkan nilai 86g emas. Nisab dikemaskini setiap tahun.</p></div>
    </div>

    <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6 md:p-8">
      <h3 class="text-xl font-bold mb-4">📚 Artikel Berkaitan</h3>
      <ul class="space-y-2">
        <li><a href="/cara-kira-zakat-pendapatan-gaji-bulanan/" class="text-primary font-medium hover:underline text-sm">→ Cara Kira Zakat Pendapatan dari Gaji Bulanan</a></li>
        <li><a href="/cadangan-bajet-50-30-20-di-malaysia/" class="text-primary font-medium hover:underline text-sm">→ Bajet 50/30/20 — Cara Urus Wang Dengan Bijak</a></li>
        <li><a href="/cara-simpan-duit-gaji-rm2500/" class="text-primary font-medium hover:underline text-sm">→ Cara Simpan Duit Gaji RM2,500 Sebulan</a></li>
      </ul>
    </div>
  </section>

  <CallToAction actions={[ { variant: 'primary', text: 'Kalkulator Gaji Bersih', href: '/kalkulator/gaji-bersih' }, { variant: 'secondary', text: 'Kalkulator SST', href: '/kalkulator/sst' } ]}>
    <Fragment slot="title">Nak Kira Gaji Bersih?</Fragment>
    <Fragment slot="subtitle">Semua kalkulator percuma — guna sekarang.</Fragment>
  </CallToAction>
  <script is:inline>
function fmt(v) { return 'RM ' + (typeof v === 'number' && !isNaN(v) && isFinite(v) ? v.toLocaleString('ms-MY', {minimumFractionDigits:2,maximumFractionDigits:2}) : '0.00'); }
function sn(v, d) { var n = parseFloat(v); return (!isNaN(n) && isFinite(n) && n >= 0) ? n : (d || 0); }
function calc() {
  var p = sn(document.getElementById('zp').value, 48000);
  var k = sn(document.getElementById('zk').value, 5280);
  var d = sn(document.getElementById('zd').value, 800);
  var i = sn(document.getElementById('zi').value, 500);
  var a = sn(document.getElementById('za').value, 300);
  var ba = parseInt(document.getElementById('zb').value) || 2;
  var l = sn(document.getElementById('zl').value, 200);
  var perbelanjaan = (d + i + a*ba + l) * 12;
  var bersih = p - k - perbelanjaan;
  var nisab = 29961;
  var zakat = bersih > nisab ? Math.round(bersih * 0.025) : 0;
  document.getElementById('zkBersih').textContent = fmt(bersih);
  document.getElementById('zkNisab').textContent = fmt(nisab);
  var st = document.getElementById('zkStatus');
  st.textContent = bersih > nisab ? 'WAJIB ZAKAT' : 'TIDAK WAJIB';
  st.className = 'text-lg font-bold ' + (bersih > nisab ? 'text-emerald-600' : 'text-amber-600');
  document.getElementById('zkZakat').textContent = fmt(zakat);
  document.getElementById('zkProjected').textContent = fmt(zakat);
  document.getElementById('zkLabel').textContent = zakat > 0 ? 'Zakat Wajib: RM ' + zakat.toLocaleString() + '/tahun' : 'Anda tidak diwajibkan zakat';
  document.getElementById('zkDetail').textContent = 'Pendapatan bersih RM ' + bersih.toLocaleString() + ' (nisab: RM ' + nisab.toLocaleString() + ')';
}
['zp','zk','zd','zi','za','zb','zl'].forEach(function(id){var el=document.getElementById(id);if(el){el.addEventListener('input',calc);el.addEventListener('change',calc);}});
calc();
</script>
</Layout>
