---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator Kereta',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8">
      <a href="/" class="text-sm text-muted hover:text-amber-600 transition-colors">← Laman Utama</a>
    </div>
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
      <span class="text-4xl mr-2">🚗</span> Kalkulator Kereta
    </h1>
    <p class="text-xl text-muted mb-8">
      Kira ansuran bulanan kereta berdasarkan harga loan, kadar interest dan tempoh bayaran.
    </p>

    <div class="bg-amber-50 dark:bg-slate-800/50 rounded-2xl p-8 mb-8 text-center">
      <p class="text-lg text-muted">Kalkulator interaktif sedang dibina. Nantikan!</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6">
        <h3 class="font-semibold text-lg mb-2">💰 Ansuran Bulanan</h3>
        <p class="text-muted text-sm">Kira bayaran bulanan berdasarkan harga kereta, downpayment dan interest rate.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6">
        <h3 class="font-semibold text-lg mb-2">📋 Total Bayaran</h3>
        <p class="text-muted text-sm">Lihat jumlah keseluruhan bayaran termasuk interest sepanjang tempoh loan.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6">
        <h3 class="font-semibold text-lg mb-2">📊 Perbandingan</h3>
        <p class="text-muted text-sm">Bandingkan 2-3 pilihan kereta dengan spesifikasi loan berbeza.</p>
      </div>
    </div>

    <div class="bg-gradient-to-r from-amber-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 rounded-2xl p-8">
      <h3 class="text-xl font-bold mb-2">📚 Artikel Berkaitan Kereta</h3>
      <p class="text-muted mb-4">Baca tips dan panduan pembelian kereta di blog kami.</p>
      <a href="/blog/kerajaan" class="inline-flex items-center text-amber-600 font-medium hover:underline">Lihat Artikel Kerajaan →</a>
    </div>
  </section>

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Kalkulator Lain', href: '/' },
    ]}
  >
    <Fragment slot="title">Nak Kira Emas atau ASB?</Fragment>
    <Fragment slot="subtitle">Semua kalkulator percuma — guna sekarang.</Fragment>
  </CallToAction>
</Layout>
