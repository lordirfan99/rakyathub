---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator Cukai Jalan — Kadar JPJ 2026 Malaysia | RakyatHub',
  description: 'Kira cukai jalan (road tax) kereta dan motosikal Malaysia 2026. Kadar JPJ untuk Semenanjung, Sabah & Sarawak ikut CC. Percuma.',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8"><a href="/kalkulator" class="text-sm text-muted hover:text-primary transition-colors">← Semua Kalkulator</a></div>
    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Kalkulator Cukai Jalan Malaysia 2026</h1>
    <p class="text-lg md:text-xl text-muted mb-8">Kira kadar cukai jalan (road tax) tahunan kereta dan motosikal Malaysia ikut kapasiti enjin (CC) dan kawasan. Kadar JPJ terkini untuk Semenanjung & Sabah/Sarawak.</p>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <label for="rtCC" class="block text-sm font-semibold text-default mb-1.5">Kapasiti Enjin (CC)</label>
          <input type="number" id="rtCC" value="1500" min="0" max="10000" step="100"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="rtJenis" class="block text-sm font-semibold text-default mb-1.5">Jenis Kenderaan</label>
          <select id="rtJenis"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
            <option value="car">Kereta Persendirian</option>
            <option value="motor">Motosikal</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-semibold text-default mb-1.5">Kawasan</label>
          <div class="flex gap-3">
            <button id="rtSemenanjung" class="flex-1 rounded-xl border-2 border-primary bg-primary/10 px-4 py-3 text-sm font-semibold text-primary" onclick="setRegion('peninsular')">Semenanjung</button>
            <button id="rtSabah" class="flex-1 rounded-xl border-2 border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm font-semibold text-default" onclick="setRegion('sabah')">Sabah/Sarawak</button>
          </div>
        </div>
      </div>

      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl bg-blue-50 dark:bg-blue-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Enjin</p>
          <p class="text-lg font-bold text-default" id="rtCCDisplay">1,500 cc</p>
        </div>
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Cukai Jalan</p>
          <p class="text-lg font-bold text-amber-700" id="rtNilai">RM 90.00</p>
        </div>
        <div class="rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Kawasan</p>
          <p class="text-lg font-bold text-emerald-700" id="rtKawasan">Semenanjung</p>
        </div>
        <div class="rounded-xl bg-primary/10 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Jenis</p>
          <p class="text-lg font-bold text-primary" id="rtJenisDisplay">Kereta</p>
        </div>
      </div>

      <div class="mt-4 p-5 rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/5 border border-primary/20 text-center">
        <p class="text-sm text-muted">Cukai jalan tahunan untuk <strong id="rtLabel">1,500cc Kereta (Semenanjung)</strong></p>
        <p class="text-3xl md:text-4xl font-bold text-primary" id="rtFinal">RM 90.00</p>
        <p class="text-xs text-muted mt-1">*Kadar JPJ 2026. Bayar sebelum lesen kenderaan tamat tempoh.</p>
      </div>
    </div>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">📊 Kadar Cukai Jalan JPJ 2026</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-semibold mb-2 text-sm">Kereta Persendirian (Semenanjung)</h3>
          <table class="w-full text-xs">
            <thead><tr class="border-b border-gray-100 dark:border-slate-700"><th class="text-left py-1.5">CC</th><th class="text-right py-1.5">Kadar</th></tr></thead>
            <tbody>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>&lt;1,000</td><td class="text-right">RM 20</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>1,001–1,200</td><td class="text-right">RM 55</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>1,201–1,400</td><td class="text-right">RM 70</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>1,401–1,600</td><td class="text-right">RM 90</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>1,601–1,800</td><td class="text-right">RM 150</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>1,801–2,000</td><td class="text-right">RM 200</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>2,001–2,500</td><td class="text-right">RM 300</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>2,501–3,000</td><td class="text-right">RM 450</td></tr>
              <tr><td>&gt;3,000</td><td class="text-right">RM450 + RM5/cc lebih</td></tr>
            </tbody>
          </table>
        </div>
        <div>
          <h3 class="font-semibold mb-2 text-sm">Kereta Persendirian (Sabah/Sarawak)</h3>
          <table class="w-full text-xs">
            <thead><tr class="border-b border-gray-100 dark:border-slate-700"><th class="text-left py-1.5">CC</th><th class="text-right py-1.5">Kadar</th></tr></thead>
            <tbody>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>&lt;1,000</td><td class="text-right">RM 10</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>1,001–1,200</td><td class="text-right">RM 27.50</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>1,201–1,400</td><td class="text-right">RM 35</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>1,401–1,600</td><td class="text-right">RM 45</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>1,601–1,800</td><td class="text-right">RM 75</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>1,801–2,000</td><td class="text-right">RM 100</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>2,001–2,500</td><td class="text-right">RM 150</td></tr>
              <tr class="border-b border-gray-50 dark:border-slate-800"><td>2,501–3,000</td><td class="text-right">RM 225</td></tr>
              <tr><td>&gt;3,000</td><td class="text-right">RM225 + RM2.50/cc lebih</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-8">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">🛵 Motosikal</h3>
        <p class="text-muted text-sm">Cukai jalan motosikal &lt;250cc: RM30 (Semenanjung) / RM15 (Sabah/Sarawak). &gt;250cc guna formula berbeza. Bayaran lebih murah dari kereta — rata-rata RM30–RM200 setahun.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">🗓️ Bila Bayar?</h3>
        <p class="text-muted text-sm">Cukai jalan perlu dibayar sebelum tarikh luput lesen kenderaan (LKM). Bayaran lewat dikenakan kompaun. Boleh bayar online di MyJPJ atau kaunter POS/Pejabat JPJ.</p>
      </div>
    </div>

    <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-4 mb-8 text-xs text-muted">
      <strong>⚠️ Penafian:</strong> Anggaran sahaja berdasarkan kadar JPJ 2026. Kadar sebenar mungkin berbeza untuk kenderaan komersial atau kenderaan lama. Semak di portal MyJPJ untuk pengesahan.
      <br /><em>Sumber: JPJ Malaysia — jpj.gov.my</em>
    </div>

    <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6 md:p-8">
      <h3 class="text-xl font-bold mb-4">📚 Alat Kenderaan</h3>
      <ul class="space-y-2">
        <li><a href="/kalkulator/kos-minyak/" class="text-primary font-medium hover:underline text-sm">→ Kalkulator Kos Minyak</a></li>
        <li><a href="/kalkulator/kereta/" class="text-primary font-medium hover:underline text-sm">→ Kalkulator Loan Kereta</a></li>
        <li><a href="/kalkulator/insurans-kereta/" class="text-primary font-medium hover:underline text-sm">→ Kalkulator Insurans Kereta</a></li>
      </ul>
    </div>
  </section>

  <CallToAction actions={[
    { variant: 'primary', text: 'Kos Minyak', href: '/kalkulator/kos-minyak' },
    { variant: 'secondary', text: 'Insurans Kereta', href: '/kalkulator/insurans-kereta' },
  ]}>
    <Fragment slot="title">Nak kira kos minyak bulanan?</Fragment>
    <Fragment slot="subtitle">Guna kalkulator kenderaan percuma kami.</Fragment>
  </CallToAction>

  <script is:inline>
function fmt(v) { return 'RM ' + (typeof v === 'number' && !isNaN(v) && isFinite(v) ? v.toLocaleString('ms-MY', {minimumFractionDigits:2,maximumFractionDigits:2}) : '0.00'); }
function sn(v, d) { var n = parseFloat(v); return (!isNaN(n) && isFinite(n) && n >= 0) ? n : (d || 0); }
var region = 'peninsular';

function setRegion(r) {
  region = r;
  var sem = document.getElementById('rtSemenanjung');
  var sab = document.getElementById('rtSabah');
  if (r === 'peninsular') {
    sem.className = 'flex-1 rounded-xl border-2 border-primary bg-primary/10 px-4 py-3 text-sm font-semibold text-primary';
    sab.className = 'flex-1 rounded-xl border-2 border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm font-semibold text-default';
  } else {
    sab.className = 'flex-1 rounded-xl border-2 border-primary bg-primary/10 px-4 py-3 text-sm font-semibold text-primary';
    sem.className = 'flex-1 rounded-xl border-2 border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm font-semibold text-default';
  }
  calc();
}

function kiraRoadTax(cc, jenis, kawasan) {
  if (jenis === 'motor') return cc <= 250 ? (kawasan === 'peninsular' ? 30 : 15) : 60;
  var table = kawasan === 'peninsular' ? 
    [[1000,20],[1200,55],[1400,70],[1600,90],[1800,150],[2000,200],[2500,300],[3000,450],[Infinity,-1]] :
    [[1000,10],[1200,27.5],[1400,35],[1600,45],[1800,75],[2000,100],[2500,150],[3000,225],[Infinity,-1]];
  for (var i = 0; i < table.length; i++) {
    if (cc <= table[i][0]) return table[i][1] >= 0 ? table[i][1] : (kawasan === 'peninsular' ? 450 + (cc-3000)*5 : 225 + (cc-3000)*2.5);
  }
  return 0;
}

function calc() {
  var cc = Math.round(sn(document.getElementById('rtCC').value, 1500));
  var jenis = document.getElementById('rtJenis').value;
  if (cc <= 0) { document.getElementById('rtFinal').textContent = 'RM 0.00'; return; }
  var tax = kiraRoadTax(cc, jenis, region);
  document.getElementById('rtCCDisplay').textContent = cc.toLocaleString() + ' cc';
  document.getElementById('rtNilai').textContent = fmt(tax);
  document.getElementById('rtKawasan').textContent = region === 'peninsular' ? 'Semenanjung' : 'Sabah/Sarawak';
  document.getElementById('rtJenisDisplay').textContent = jenis === 'car' ? 'Kereta' : 'Motosikal';
  document.getElementById('rtLabel').textContent = cc + 'cc ' + (jenis==='car'?'Kereta':'Motosikal') + ' (' + (region==='peninsular'?'Semenanjung':'Sabah/Sarawak') + ')';
  document.getElementById('rtFinal').textContent = fmt(tax);
}
['rtCC','rtJenis'].forEach(function(id){var el=document.getElementById(id);if(el){el.addEventListener('input',calc);el.addEventListener('change',calc);}});
calc();
</script>
</Layout>
