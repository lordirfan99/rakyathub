---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Kalkulator Zakat Emas — Kira Zakat Emas Pakai & Simpan | RakyatHub',
  description: 'Kira zakat emas dipakai dan emas simpanan. Panduan uruf, nisab, dan kadar 2.5% ikut PPZ & JAKIM. Percuma.',
};
---

<Layout metadata={metadata}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="mb-8"><a href="/kalkulator" class="text-sm text-muted hover:text-primary transition-colors">← Semua Kalkulator</a></div>
    <h1 class="text-3xl md:text-5xl font-bold tracking-tight mb-4">Kalkulator Zakat Emas</h1>
    <p class="text-lg md:text-xl text-muted mb-8">Kira zakat emas — emas dipakai (uruf) dan emas simpanan (tidak dipakai). Kadar 2.5% mengikut panduan PPZ Selangor dan JAKIM.</p>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <div class="grid md:grid-cols-2 gap-4 md:gap-6">
        <div>
          <label for="zeGram" class="block text-sm font-semibold text-default mb-1.5">Jumlah Emas (gram)</label>
          <input type="number" id="zeGram" value="100" min="0" step="0.5"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div>
          <label for="zeHarga" class="block text-sm font-semibold text-default mb-1.5">Harga Emas Semasa (RM/g)</label>
          <input type="number" id="zeHarga" value="580" min="0" step="1"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
      </div>

      <div class="mt-4">
        <label class="block text-sm font-semibold text-default mb-1.5">Jenis Emas</label>
        <div class="flex gap-3">
          <button id="zeSimpanan" class="flex-1 rounded-xl border-2 border-primary bg-primary/10 px-4 py-3 text-sm font-semibold text-primary" onclick="setType('simpanan')">Emas Simpanan</button>
          <button id="zePakai" class="flex-1 rounded-xl border-2 border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm font-semibold text-default" onclick="setType('pakai')">Emas Dipakai</button>
        </div>
      </div>

      <div class="mt-4 hidden" id="zeUrufRow">
        <label for="zeUruf" class="block text-sm font-semibold text-default mb-1.5">Uruf (g) — had pemakaian</label>
        <input type="number" id="zeUruf" value="800" min="0" step="10"
          class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-base focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        <p class="text-[10px] text-muted mt-1">*Negeri-negeri: Selangor/PPZ 800g, WP 800g, Pulau Pinang 200g</p>
      </div>

      <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="rounded-xl bg-blue-50 dark:bg-blue-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Emas Kena Zakat</p>
          <p class="text-lg font-bold text-default" id="zeGramZakat">0 g</p>
        </div>
        <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Nilai Kena Zakat</p>
          <p class="text-lg font-bold text-amber-700" id="zeNilai">RM 0</p>
        </div>
        <div class="rounded-xl bg-emerald-50 dark:bg-emerald-900/20 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Zakat (2.5%)</p>
          <p class="text-lg font-bold text-emerald-700" id="zeZakat">RM 0.00</p>
        </div>
        <div class="rounded-xl bg-primary/10 p-4 text-center">
          <p class="text-xs text-muted uppercase tracking-wide">Kadar</p>
          <p class="text-lg font-bold text-primary">2.5%</p>
        </div>
      </div>

      <div class="mt-4 p-5 rounded-2xl bg-gradient-to-br from-primary/10 to-secondary/5 border border-primary/20 text-center">
        <p class="text-sm text-muted" id="zeKeterangan">Sila masukkan jumlah emas</p>
        <p class="text-3xl md:text-4xl font-bold text-primary" id="zeFinal">RM 0.00</p>
      </div>
    </div>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 border border-gray-100 dark:border-slate-700/30 shadow-sm p-5 md:p-8 mb-8">
      <h2 class="text-xl font-bold mb-4">Panduan Zakat Emas</h2>
      <ul class="text-muted text-sm space-y-2">
        <li><strong>Emas Simpanan</strong> — Zakat 2.5% atas jumlah gram jika mencapai nisab (85g).</li>
        <li><strong>Emas Dipakai</strong> — Zakat 2.5% atas gram yang melebihi uruf (kadar pemakaian setempat).</li>
        <li><strong>Nisab:</strong> 85g emas. Jika harga emas RM580/g, nisab = 85 × RM580 = RM49,300.</li>
        <li><strong>Uruf Selangor/PPZ:</strong> 800g — emas dipakai bawah 800g tidak dikenakan zakat.</li>
      </ul>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-8">
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">Emas Dipakai (Uruf)</h3>
        <p class="text-muted text-sm">Emas yang dipakai seperti cincin, rantai, gelang. Had uruf berbeza ikut negeri. PPZ Selangor tetapkan 800g. Bermakna emas dipakai bawah 800g tidak kena zakat — hanya lebihan dikenakan 2.5%.</p>
      </div>
      <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-xl p-6 card-hover">
        <h3 class="font-semibold text-lg mb-2">Emas Simpanan</h3>
        <p class="text-muted text-sm">Emas yang disimpan untuk pelaburan atau simpanan — termasuk emas fizikal, akaun emas (Public Gold GAP), dan ETF emas. Zakat 2.5% dikenakan jika cukup nisab dan haul.</p>
      </div>
    </div>

    <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-4 mb-8 text-xs text-muted">
      <strong>Penafian:</strong> Kadar uruf berbeza mengikut negeri. Rujuk pusat zakat negeri masing-masing untuk fatwa tepat. Sumber: PPZ Selangor — zakat.com.my
    </div>

    <div class="rounded-2xl bg-gradient-to-br from-blue-50 to-emerald-50 dark:from-slate-800 dark:to-slate-800 border border-blue-100 dark:border-slate-700 p-6 md:p-8">
      <h3 class="text-xl font-bold mb-4">Zakat Lain</h3>
      <ul class="space-y-2">
        <li><a href="/kalkulator/zakat-simpanan/" class="text-primary font-medium hover:underline text-sm">→ Zakat Simpanan</a></li>
        <li><a href="/kalkulator/zakat-fitrah/" class="text-primary font-medium hover:underline text-sm">→ Zakat Fitrah</a></li>
        <li><a href="/kalkulator/zakat-pendapatan/" class="text-primary font-medium hover:underline text-sm">→ Zakat Pendapatan</a></li>
      </ul>
    </div>
  </section>

  <CallToAction actions={[
    { variant: 'primary', text: 'Zakat Simpanan', href: '/kalkulator/zakat-simpanan' },
    { variant: 'secondary', text: 'Zakat Fitrah', href: '/kalkulator/zakat-fitrah' },
  ]}>
    <Fragment slot="title">Kira zakat lain yang wajib dibayar</Fragment>
    <Fragment slot="subtitle">Zakat simpanan, fitrah, dan pendapatan.</Fragment>
  </CallToAction>

  <script is:inline>
function fmt(v) { return 'RM ' + (typeof v === 'number' && !isNaN(v) && isFinite(v) ? v.toLocaleString('ms-MY', {minimumFractionDigits:2,maximumFractionDigits:2}) : '0.00'); }
function sn(v, d) { var n = parseFloat(v); return (!isNaN(n) && isFinite(n) && n >= 0) ? n : (d || 0); }
var zeType = 'simpanan';
function setType(t) {
  zeType = t;
  var sim = document.getElementById('zeSimpanan');
  var pak = document.getElementById('zePakai');
  var urfRow = document.getElementById('zeUrufRow');
  if (t === 'simpanan') {
    sim.className = 'flex-1 rounded-xl border-2 border-primary bg-primary/10 px-4 py-3 text-sm font-semibold text-primary';
    pak.className = 'flex-1 rounded-xl border-2 border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm font-semibold text-default';
    urfRow.classList.add('hidden');
  } else {
    pak.className = 'flex-1 rounded-xl border-2 border-primary bg-primary/10 px-4 py-3 text-sm font-semibold text-primary';
    sim.className = 'flex-1 rounded-xl border-2 border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-4 py-3 text-sm font-semibold text-default';
    urfRow.classList.remove('hidden');
  }
  calc();
}
function calc() {
  var gram = sn(document.getElementById('zeGram').value, 100);
  var harga = sn(document.getElementById('zeHarga').value, 580);
  if (gram <= 0) { document.getElementById('zeFinal').textContent = 'RM 0.00'; return; }
  var chargeableGram = gram;
  if (zeType === 'pakai') {
    var uruf = sn(document.getElementById('zeUruf').value, 800);
    chargeableGram = Math.max(0, gram - uruf);
  }
  var nisabG = 85;
  if (chargeableGram < nisabG && zeType === 'simpanan') {
    document.getElementById('zeGramZakat').textContent = '0 g';
    document.getElementById('zeNilai').textContent = 'RM 0';
    document.getElementById('zeZakat').textContent = 'RM 0.00';
    document.getElementById('zeKeterangan').textContent = 'Emas kurang dari nisab 85g';
    document.getElementById('zeFinal').textContent = 'RM 0.00';
    return;
  }
  var nilai = chargeableGram * harga;
  var zakat = Math.round(nilai * 0.025 * 100) / 100;
  document.getElementById('zeGramZakat').textContent = chargeableGram.toFixed(1) + ' g';
  document.getElementById('zeNilai').textContent = fmt(nilai);
  document.getElementById('zeZakat').textContent = fmt(zakat);
  document.getElementById('zeKeterangan').textContent = 'Zakat 2.5% × ' + chargeableGram + 'g × RM' + harga + '/g';
  document.getElementById('zeFinal').textContent = fmt(zakat);
}
['zeGram','zeHarga','zeUruf'].forEach(function(id){var el=document.getElementById(id);if(el){el.addEventListener('input',calc);el.addEventListener('change',calc);}});
calc();
</script>
</Layout>
