---
import Layout from '~/layouts/PageLayout.astro';

const priceData = (await import('~/data/harga-makanan.json')).default;
const items = priceData.items || [];
const latestDate = priceData.latest_date || '';

// Normalise premise chain names
function normChain(name) {
  const n = name.toUpperCase();
  if (n.includes("LOTUS'S") || n.includes('LOTUSS') || n.includes('TESCO')) return "Lotus's";
  if (n.includes('ECONSAVE')) return 'Econsave';
  if (n.includes('GIANT')) return 'Giant';
  if (n.includes('MYDIN')) return 'Mydin';
  if (n.includes('AEON') || n.includes('JUSCO')) return 'AEON';
  if (n.includes('NSK')) return 'NSK';
  if (n.includes('99 SPEEDMART') || n.includes('99 SPEED')) return '99 Speedmart';
  if (n.includes('TF VALUE') || n.includes('TFVALUE')) return 'TF Value-Mart';
  if (n.includes('COLD STORAGE')) return 'Cold Storage';
  if (n.includes('BILLION')) return 'Billion';
  if (n.includes('THE STORE')) return 'The Store';
  if (n.includes('PASARAYA') || n.includes('ECONO') || n.includes('E-FAMILY') || n.includes('FAMILY STORE') || n.includes('FAMILY GROCER') || n.includes('FAMILY W')) return 'Pasaraya Lain';
  if (n.includes('LOT ')) return 'Pasar Mini / Kedai';
  return 'Lain-lain';
}

// Basket items (common essentials — exclude specialty meats & fish)
const basketItems = items.filter(i => {
  const ex = ['Daging Kambing', 'Daging Lembu Import', 'Ikan Haruan', 'Santan Kelapa'];
  return !ex.some(x => i.name.includes(x));
});

// Build chain pricing per state
function buildChainIndex() {
  const chainPrices = {}; // chain -> { total, count, items: {}, states: {} }
  const stateChains = {}; // state -> { chain -> { total, count } }

  for (const item of basketItems) {
    const itemName = item.name;
    for (const p of (item.premises || [])) {
      const chain = normChain(p.name);
      const state = p.state;
      if (chain === 'Lain-lain') continue;

      if (!chainPrices[chain]) chainPrices[chain] = { total: 0, count: 0, items: {}, states: {} };
      if (!chainPrices[chain].items[itemName]) chainPrices[chain].items[itemName] = [];
      chainPrices[chain].items[itemName].push(p.price);
      chainPrices[chain].total += p.price;
      chainPrices[chain].count++;

      if (!stateChains[state]) stateChains[state] = {};
      if (!stateChains[state][chain]) stateChains[state][chain] = { total: 0, count: 0 };
      stateChains[state][chain].total += p.price;
      stateChains[state][chain].count++;

      if (!chainPrices[chain].states[state]) chainPrices[chain].states[state] = { total: 0, count: 0 };
      chainPrices[chain].states[state].total += p.price;
      chainPrices[chain].states[state].count++;
    }
  }

  // Calculate avg per chain
  const chainAvg = {};
  for (const [chain, data] of Object.entries(chainPrices)) {
    const itemAvgs = {};
    for (const [itemName, prices] of Object.entries(data.items)) {
      itemAvgs[itemName] = prices.reduce((a, b) => a + b, 0) / prices.length;
    }
    // Basket total = sum of avg prices for each item
    let basketTotal = 0;
    let basketCount = 0;
    for (const item of basketItems) {
      if (itemAvgs[item.name]) {
        basketTotal += itemAvgs[item.name];
        basketCount++;
      }
    }
    chainAvg[chain] = { basketTotal, basketCount, states: data.states };
  }

  return { chainAvg, stateChains };
}

const { chainAvg, stateChains } = buildChainIndex();

// Sort chains by basket total
const chainRanking = Object.entries(chainAvg)
  .filter(([_, d]) => d.basketCount >= 10)
  .sort((a, b) => a[1].basketTotal - b[1].basketTotal);

const chains = chainRanking.map(([name, data]) => ({ name, ...data }));

// Price movers
const topUp = [...items].filter(i => i.change_pct > 0.5).sort((a, b) => b.change_pct - a.change_pct).slice(0, 5);
const topDown = [...items].filter(i => i.change_pct < -0.5).sort((a, b) => a.change_pct - b.change_pct).slice(0, 5);

const year = new Date().getFullYear();

const metadata = {
  title: `Indeks Harga Pasaraya Malaysia ${year} — Paling Murah Ikut Negeri`,
  description: `Bandingkan harga pasaraya di Malaysia — Lotus's vs Econsave vs Giant vs Mydin. Cari pasaraya termurah ikut negeri untuk 20+ barangan asas. Dikemaskini harian.`,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Laman Utama', item: 'https://rakyathub.my/' },
    { '@type': 'ListItem', position: 2, name: 'Indeks Harga Pasaraya', item: 'https://rakyathub.my/indeks-harga-pasaraya/' },
  ],
};
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-8 md:py-12">
    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-xs text-muted/60 mb-1">
      <a href="/" class="hover:text-primary">Laman Utama</a> <span>/</span> <span>Indeks Harga Pasaraya</span>
    </div>
    <h1 class="text-2xl sm:text-4xl font-bold tracking-tight mb-3">🏪 Indeks Harga Pasaraya Malaysia</h1>
    <p class="text-sm text-muted/80 max-w-3xl mb-5">
      Bandingkan harga <strong>{basketItems.length} barangan asas</strong> antara pasaraya utama seluruh Malaysia. Dikemaskini harian dari <strong>KPDN PriceCatcher</strong>.
    </p>

    <!-- Stats -->
    <div class="flex flex-wrap gap-2 mb-6">
      <span class="px-3 py-1.5 rounded-lg bg-blue-50 dark:bg-blue-900/20 text-xs font-semibold text-blue-700 dark:text-blue-400 border border-blue-100 dark:border-blue-800/30 tabular-nums">{chains.length} rangkaian</span>
      <span class="px-3 py-1.5 rounded-lg bg-purple-50 dark:bg-purple-900/20 text-xs font-semibold text-purple-700 dark:text-purple-400 border border-purple-100 dark:border-purple-800/30 tabular-nums">{basketItems.length} barangan</span>
      <span class="px-3 py-1.5 rounded-lg bg-amber-50 dark:bg-amber-900/20 text-xs font-semibold text-amber-700 dark:text-amber-400 border border-amber-100 dark:border-amber-800/30 tabular-nums">{latestDate}</span>
    </div>

    <!-- Chain Ranking -->
    <h2 class="text-lg font-bold mb-3">🥇 Paling Murah hingga Paling Mahal</h2>
    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm overflow-hidden mb-8">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 dark:border-slate-700/50 bg-gray-50/50 dark:bg-slate-800/30">
              <th class="text-left py-3.5 px-4 font-semibold text-muted text-[11px] uppercase tracking-wider">#</th>
              <th class="text-left py-3.5 px-3 font-semibold text-muted text-[11px] uppercase tracking-wider">Pasaraya</th>
              <th class="text-right py-3.5 px-3 font-semibold text-muted text-[11px] uppercase tracking-wider tabular-nums">Basket Total</th>
              <th class="text-right py-3.5 px-3 font-semibold text-muted text-[11px] uppercase tracking-wider hidden sm:table-cell tabular-nums">Item</th>
            </tr>
          </thead>
          <tbody>
            {chains.map((chain, i) => {
              const isCheapest = i === 0;
              const isMostExp = i === chains.length - 1;
              return (
              <tr class="item-row border-b border-gray-50 dark:border-slate-800/50 transition-colors">
                <td class="py-3 px-4 font-bold tabular-nums text-muted">
                  {i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : `#${i + 1}`}
                </td>
                <td class="py-3 px-3">
                  <span class="font-semibold text-gray-900 dark:text-gray-100">{chain.name}</span>
                  <span class="text-[11px] ml-2 text-muted/60">({chain.basketCount} item)</span>
                </td>
                <td class="text-right py-3 px-3 font-bold tabular-nums" class:list={[isCheapest ? 'text-green-600 dark:text-green-400' : isMostExp ? 'text-red-600 dark:text-red-400' : 'text-gray-900 dark:text-gray-100']}>
                  RM {chain.basketTotal.toFixed(2)}
                </td>
                <td class="text-right py-3 px-3 hidden sm:table-cell tabular-nums text-muted">
                  {chain.basketCount}
                </td>
              </tr>
            )})}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Price Movers -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
      <div class="rounded-xl bg-gradient-to-br from-red-50 to-red-100/50 dark:from-red-950/30 dark:to-red-900/20 border border-red-100 dark:border-red-800/30 p-4">
        <h3 class="text-sm font-bold text-red-700 dark:text-red-300 mb-2">▲ Paling Naik</h3>
        {topUp.length > 0 ? (
          <ul class="space-y-1">
            {topUp.map(i => (
              <li class="flex justify-between items-center text-sm">
                <span class="text-muted">{i.name}</span>
                <span class="font-semibold tabular-nums text-red-600 dark:text-red-400">+{i.change_pct.toFixed(1)}%</span>
              </li>
            ))}
          </ul>
        ) : <p class="text-xs text-muted/60">Tiada perubahan ketara</p>}
      </div>
      <div class="rounded-xl bg-gradient-to-br from-green-50 to-green-100/50 dark:from-green-950/30 dark:to-green-900/20 border border-green-100 dark:border-green-800/30 p-4">
        <h3 class="text-sm font-bold text-green-700 dark:text-green-300 mb-2">▼ Paling Turun</h3>
        {topDown.length > 0 ? (
          <ul class="space-y-1">
            {topDown.map(i => (
              <li class="flex justify-between items-center text-sm">
                <span class="text-muted">{i.name}</span>
                <span class="font-semibold tabular-nums text-green-600 dark:text-green-400">{i.change_pct.toFixed(1)}%</span>
              </li>
            ))}
          </ul>
        ) : <p class="text-xs text-muted/60">Tiada perubahan ketara</p>}
      </div>
    </div>

    <!-- State Dropdown -->
    <h2 class="text-lg font-bold mb-3">📍 Paling Murah Ikut Negeri</h2>
    <p class="text-xs text-muted/70 mb-3">Pilih negeri untuk lihat rangkaian pasaraya termurah di kawasan anda.</p>
    <select id="stateSelect" onchange="filterState()" class="w-full sm:w-72 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800/60 px-4 py-3 text-sm mb-4 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
      <option value="">— Pilih Negeri —</option>
      {Object.keys(stateChains).sort().map(s => (
        <option value={s}>{s}</option>
      ))}
    </select>

    <div class="rounded-2xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 shadow-sm overflow-hidden mb-8">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 dark:border-slate-700/50 bg-gray-50/50 dark:bg-slate-800/30">
              <th class="text-left py-3.5 px-4 font-semibold text-muted text-[11px] uppercase tracking-wider">Pasaraya</th>
              <th class="text-right py-3.5 px-3 font-semibold text-muted text-[11px] uppercase tracking-wider tabular-nums">Anggaran Basket</th>
            </tr>
          </thead>
          <tbody id="stateBody">
            <!-- Filled by JS -->
          </tbody>
        </table>
        <p id="stateEmpty" class="text-center py-8 text-sm text-muted/50 hidden">Pilih negeri untuk lihat data.</p>
      </div>
    </div>

    <!-- About -->
    <div class="rounded-xl bg-gray-50 dark:bg-slate-800/40 border border-gray-100 dark:border-slate-700/30 p-4 mb-8 text-xs text-muted/70">
      <div class="flex items-center gap-2 mb-2">
        <span class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center text-[10px] font-bold text-primary">i</span>
        <span class="font-semibold text-muted">Tentang Indeks Ini</span>
      </div>
      <p><strong>Basket Total</strong> = jumlah harga purata setiap barangan di rangkaian tersebut. Semakin rendah, semakin murah. Harga mungkin berbeza mengikut cawangan. Sumber: <a href="https://data.gov.my" class="text-primary hover:underline" target="_blank" rel="noopener">data.gov.my</a> — KPDN PriceCatcher.</p>
    </div>
  </section>

  <!-- Data injected at build time -->
  <script set:html={`const stateData = ${JSON.stringify(stateChains)};`}></script>

  <script is:inline>
  function filterState() {
    const sel = document.getElementById('stateSelect');
    const state = sel.value;
    const body = document.getElementById('stateBody');
    const empty = document.getElementById('stateEmpty');
    if (!state) { body.innerHTML = ''; empty.classList.remove('hidden'); return; }
    empty.classList.add('hidden');

    const chains = stateData[state];
    if (!chains) { body.innerHTML = '<tr><td colspan="2" class="text-center py-4 text-sm text-muted/50">Tiada data.</td></tr>'; return; }

    const sorted = Object.entries(chains)
      .filter(([_, d]) => d.count > 0)
      .map(([name, d]) => ({ name, avg: d.total / d.count }))
      .sort((a, b) => a.avg - b.avg);

    body.innerHTML = sorted.map((c, i) => {
      const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : '';
      const isBest = i === 0;
      return '<tr class="border-b border-gray-50 dark:border-slate-800/50">' +
        '<td class="py-3 px-4"><span class="font-semibold text-gray-900 dark:text-gray-100">' + medal + ' ' + c.name + '</span></td>' +
        '<td class="text-right py-3 px-3 font-bold tabular-nums ' + (isBest ? 'text-green-600 dark:text-green-400' : 'text-gray-900 dark:text-gray-100') + '">RM ' + c.avg.toFixed(2) + '</td>' +
        '</tr>';
    }).join('');
  }
  </script>
</Layout>
