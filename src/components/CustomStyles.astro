---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* DocuKilat synchronized palette */
    --aw-color-primary: rgb(30 64 175);      /* #1e40af — blue-800 */
    --aw-color-secondary: rgb(37 99 235);      /* #2563eb — blue-600 */
    --aw-color-accent: rgb(22 163 74);         /* #16a34a — green-600 */

    --aw-color-text-heading: rgb(30 41 59);    /* #1e293b — slate-800 */
    --aw-color-text-default: rgb(30 41 59);    /* #1e293b */
    --aw-color-text-muted: rgb(71 85 105);     /* #475569 — slate-600 */
    --aw-color-bg-page: rgb(248 250 252);      /* #f8fafc — slate-50 */

    --aw-color-bg-page-dark: rgb(15 23 42);    /* #0f172a — slate-900 */

    ::selection {
      background-color: rgb(37 99 235 / 20%);  /* blue-600/20% */
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(59 130 246);       /* #3b82f6 — blue-500 */
    --aw-color-secondary: rgb(96 165 250);      /* #60a5fa — blue-400 */
    --aw-color-accent: rgb(34 197 94);          /* #22c55e — green-500 */

    --aw-color-text-heading: rgb(248 250 252);  /* #f8fafc */
    --aw-color-text-default: rgb(203 213 225);  /* #cbd5e1 — slate-300 */
    --aw-color-text-muted: rgb(148 163 184);    /* #94a3b8 — slate-400 */
    --aw-color-bg-page: rgb(15 23 42);          /* #0f172a */

    ::selection {
      background-color: rgb(59 130 246 / 30%);
    }
  }

  html {
    scroll-behavior: smooth;
  }

  /* DocuKilat hero gradient */
  .hero-gradient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    background: linear-gradient(135deg, rgb(30 64 175 / 0.95) 0%, rgb(37 99 235 / 0.95) 50%, rgb(59 130 246 / 0.95) 100%);
  }
  .hero-gradient::before {
    content: '';
    position: absolute;
    inset: -50%;
    background: radial-gradient(circle at 30% 50%, rgba(255,255,255,0.05) 0%, transparent 50%);
  }
  .dark .hero-gradient {
    background: linear-gradient(135deg, rgb(15 23 42 / 0.98) 0%, rgb(30 41 59 / 0.98) 50%, rgb(30 64 175 / 0.95) 100%);
  }
  .dark .hero-gradient::before {
    background: radial-gradient(circle at 30% 50%, rgba(59,130,246,0.08) 0%, transparent 60%);
  }

  /* Floating orb effects — sync'd to blue palette */
  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.25;
    pointer-events: none;
  }
  .hero-orb:nth-child(1) {
    width: 300px; height: 300px;
    background: rgba(59, 130, 246, 0.15);
    top: 10%; left: 5%;
    animation: float 8s ease-in-out infinite;
  }
  .hero-orb:nth-child(2) {
    width: 200px; height: 200px;
    background: rgba(37, 99, 235, 0.12);
    bottom: 20%; right: 10%;
    animation: float 6s ease-in-out infinite reverse;
  }
  .hero-orb:nth-child(3) {
    width: 150px; height: 150px;
    background: rgba(30, 64, 175, 0.1);
    top: 40%; left: 60%;
    animation: float 7s ease-in-out infinite 2s;
  }
  .dark .hero-orb:nth-child(1) { background: rgba(96, 165, 250, 0.15); }
  .dark .hero-orb:nth-child(2) { background: rgba(59, 130, 246, 0.12); }
  .dark .hero-orb:nth-child(3) { background: rgba(37, 99, 235, 0.1); }

  @keyframes float {
    0%, 100% { transform: translateY(0px) scale(1); }
    50% { transform: translateY(-30px) scale(1.05); }
  }

  /* Shimmer skeleton for blog images */
  @keyframes skeleton-shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  .skeleton {
    background: linear-gradient(90deg, #e2e8f0 25%, #f1f5f9 50%, #e2e8f0 75%);
    background-size: 200% 100%;
    animation: skeleton-shimmer 1.5s ease-in-out infinite;
    border-radius: 0.5rem;
  }
  .dark .skeleton {
    background: linear-gradient(90deg, #1e293b 25%, #334155 50%, #1e293b 75%);
  }
</style>
