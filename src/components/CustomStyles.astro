---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(15 23 42);
    --aw-color-secondary: rgb(30 58 95);
    --aw-color-accent: rgb(245 158 11);

    --aw-color-text-heading: rgb(15 23 42);
    --aw-color-text-default: rgb(30 41 59);
    --aw-color-text-muted: rgb(100 116 139);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(2 6 23);

    ::selection {
      background-color: rgb(245 158 11 / 20%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(245 158 11);
    --aw-color-secondary: rgb(251 191 36);
    --aw-color-accent: rgb(16 185 129);

    --aw-color-text-heading: rgb(248 250 252);
    --aw-color-text-default: rgb(203 213 225);
    --aw-color-text-muted: rgb(148 163 184);
    --aw-color-bg-page: rgb(2 6 23);

    ::selection {
      background-color: rgb(245 158 11 / 30%);
    }
  }
</style>
