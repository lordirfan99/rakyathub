---
// AppDashboard.astro — Premium App Dashboard Grid (RakyatHub Conversion Engine)
// Replaces plain-text/emoji app list with glassmorphism app cards
import { Icon } from 'astro-icon/components';

interface AppCard {
  title: string;
  description: string;
  icon: string;
  href: string;
  gradient: string;        // icon bg gradient
  borderGlow: string;      // hover border highlight
  shadowGlow: string;       // hover shadow color
}

interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  tagline?: string;
}

const {
  id = 'kalkulator',
  title = 'Alat Kewangan Untuk Rakyat Malaysia',
  subtitle = 'Guna kalkulator interaktif untuk kira simpanan KWSP, dividen ASB, harga emas, dan ansuran kereta.',
  tagline = 'Kalkulator Percuma',
} = Astro.props;

const apps: AppCard[] = [
  {
    title: 'Kalkulator KWSP',
    description: 'Kira caruman, pengeluaran fleksibel dan dividen KWSP. Simulasi simpanan persaraan anda.',
    icon: 'tabler:wallet',
    href: '/kalkulator/kwsp',
    gradient: 'from-blue-600 to-blue-800',
    borderGlow: 'hover:border-blue-400/50',
    shadowGlow: 'hover:shadow-blue-500/10',
  },
  {
    title: 'Kalkulator ASB',
    description: 'Kira dividen ASB, bonus dan simpanan automatik. Optimalkan pelaburan ASB loan anda.',
    icon: 'tabler:chart-bar',
    href: '/kalkulator/asb',
    gradient: 'from-emerald-500 to-teal-600',
    borderGlow: 'hover:border-emerald-400/50',
    shadowGlow: 'hover:shadow-emerald-500/10',
  },
  {
    title: 'Kalkulator Emas',
    description: 'Semak harga emas harian, spread, dan beza harga Public Gold vs kedai emas.',
    icon: 'tabler:coins',
    href: '/kalkulator/emas',
    gradient: 'from-amber-500 to-yellow-600',
    borderGlow: 'hover:border-amber-400/50',
    shadowGlow: 'hover:shadow-amber-500/10',
  },
  {
    title: 'Kalkulator Kereta',
    description: 'Kira ansuran bulanan kereta berdasarkan harga loan, kadar interest dan tempoh bayaran.',
    icon: 'tabler:car',
    href: '/kalkulator/kereta',
    gradient: 'from-indigo-500 to-purple-600',
    borderGlow: 'hover:border-indigo-400/50',
    shadowGlow: 'hover:shadow-indigo-500/10',
  },
  {
    title: 'Kalkulator Loan Rumah',
    description: 'Kira ansuran bulanan rumah, banding kadar interest tetap vs terapung.',
    icon: 'tabler:home',
    href: '/kalkulator/loan-rumah',
    gradient: 'from-rose-500 to-pink-600',
    borderGlow: 'hover:border-rose-400/50',
    shadowGlow: 'hover:shadow-rose-500/10',
  },
  {
    title: 'Kalkulator Zakat',
    description: 'Kira zakat pendapatan, zakat simpanan dan zakat emas mengikut kadar terkini.',
    icon: 'tabler:calculator',
    href: '/kalkulator/zakat',
    gradient: 'from-sky-500 to-cyan-600',
    borderGlow: 'hover:border-sky-400/50',
    shadowGlow: 'hover:shadow-sky-500/10',
  },
];
---

<section id={id} class="relative py-16 md:py-24 overflow-hidden">
  <!-- Subtle background shimmer -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-secondary/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    {tagline && (
      <p class="text-center text-sm font-semibold tracking-wide uppercase text-primary">
        {tagline}
      </p>
    )}
    {title && (
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-default sm:text-4xl text-center">
        {title}
      </h2>
    )}
    {subtitle && (
      <p class="mt-4 text-lg text-muted text-center max-w-2xl mx-auto">
        {subtitle}
      </p>
    )}

    <!-- Dashboard Grid -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <!-- ========== SPOTLIGHT: DocuKilat AI (double-width) ========== -->
      <div
        class="col-span-1 md:col-span-2 lg:col-span-2 relative group stagger-item opacity-0 animate-fade-in-up"
        style="animation-delay: 50ms"
      >
        <a
          href="https://docukilat.netlify.app"
          target="_blank"
          rel="noopener noreferrer"
          class="block h-full"
        >
          <div
            class="relative h-full overflow-hidden rounded-2xl bg-gradient-to-br from-primary/10 via-primary/[0.03] to-secondary/10 border border-primary/20 dark:border-primary/30 p-6 md:p-8 transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/10 group"
          >
            <!-- Decorative gradient orbs -->
            <div class="absolute -top-12 -right-12 w-40 h-40 bg-primary/10 rounded-full blur-2xl pointer-events-none"></div>
            <div class="absolute -bottom-12 -left-12 w-40 h-40 bg-secondary/10 rounded-full blur-2xl pointer-events-none"></div>

            <div class="relative flex flex-col md:flex-row items-start md:items-center gap-5">
              <!-- Icon -->
              <div class="shrink-0 w-14 h-14 rounded-2xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center shadow-lg shadow-primary/20">
                <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                </svg>
              </div>
              <!-- Content -->
              <div class="flex-1 min-w-0">
                <h3 class="text-xl md:text-2xl font-bold text-default">
                  DocuKilat AI — Penjana Dokumen
                </h3>
                <p class="mt-1.5 text-muted text-sm md:text-base">
                  Bina Surat Rasmi, Invois & Resume Profesional Dengan AI Sepantas 1 Minit.
                </p>
              </div>
              <!-- CTA -->
              <div class="shrink-0 self-start md:self-center">
                <span class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-primary to-secondary text-white font-semibold text-sm transition-all duration-300 ease-out shadow-md group-hover:shadow-lg group-hover:shadow-primary/30 group-hover:scale-[1.02]">
                  Cuba DocuKilat AI
                  <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </span>
              </div>
            </div>
          </div>
        </a>
      </div>

      <!-- ========== APP CARDS ========== -->
      {apps.map((app, index) => (
        <div
          class="relative group stagger-item opacity-0 animate-fade-in-up"
          style={`animation-delay: ${(index + 1) * 120 + 50}ms`}
        >
          <a href={app.href} class="block h-full">
            <div
              class={`h-full rounded-xl bg-white dark:bg-slate-900/60 backdrop-blur-sm border border-gray-100 dark:border-slate-700/30 p-5 transition-all duration-300 ease-out hover:-translate-y-2 hover:shadow-xl ${app.borderGlow} ${app.shadowGlow}`}
            >
              <!-- Icon in gradient circle -->
              <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${app.gradient} flex items-center justify-center shadow-md`}>
                <Icon name={app.icon} class="w-6 h-6 text-white" />
              </div>

              <!-- Title -->
              <h3 class="mt-4 text-lg font-bold text-default">
                {app.title}
              </h3>

              <!-- Description -->
              <p class="mt-2 text-sm text-muted leading-relaxed line-clamp-3">
                {app.description}
              </p>

              <!-- CTA Button -->
              <div class="mt-4 pt-3 border-t border-gray-100 dark:border-slate-700/20">
                <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary dark:text-blue-400 group-hover:text-secondary dark:group-hover:text-blue-300 transition-colors duration-200">
                  Guna Alat
                  <svg class="w-4 h-4 transition-transform duration-300 ease-out group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Staggered entrance animation for grid children */
  .stagger-item {
    animation-fill-mode: both;
  }
  /* Shimmer glow for DocuKilat spotlight card */
  @keyframes spotlight-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
  }
  @media (prefers-reduced-motion: reduce) {
    .stagger-item {
      opacity: 1 !important;
      animation: none !important;
    }
  }
</style>
