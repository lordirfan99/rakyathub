---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '' } = Astro.props;
---

<footer class="bg-gradient-to-b from-[#0f172a] to-[#0b1120] text-[#94a3b8] pt-14 pb-8 md:pt-20 md:pb-10 not-prose relative overflow-hidden">
  <!-- Subtle top accent line -->
  <div class="absolute top-0 left-0 right-0 h-[3px] bg-gradient-to-r from-primary via-secondary to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
    <div class="grid grid-cols-12 gap-6 md:gap-10">
      <!-- Brand column -->
      <div class="col-span-12 lg:col-span-4 mb-6 lg:mb-0">
        <a class="inline-flex items-center gap-2 mb-4" href={getHomePermalink()}>
          <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-white text-xs font-bold shadow-lg shadow-primary/20">
            <Icon name="tabler:trending-up" class="w-5 h-5" />
          </span>
          <span class="text-white font-bold text-xl">{SITE?.name}</span>
        </a>
        <p class="text-sm text-[#94a3b8] leading-relaxed max-w-xs">
          Jawapan kepada soalan rakyat Malaysia tentang kewangan, bantuan kerajaan, emas, KWSP, ASB dan banyak lagi.
        </p>
        <div class="mt-5 flex gap-4 text-sm">
          {
            secondaryLinks.map(({ text, href }, index) => (
              <>
                {index !== 0 ? <span class="text-[#334155]">|</span> : ''}
                <a
                  class="text-[#64748b] hover:text-primary transition duration-150 text-xs"
                  href={href}
                  set:html={text}
                />
              </>
            ))
          }
        </div>
      </div>

      <!-- Link columns -->
      {
        links.map(({ title, links }) => (
          <div class="col-span-6 md:col-span-3 lg:col-span-2">
            <h4 class="text-white text-xs uppercase tracking-widest font-semibold mb-4 flex items-center gap-1.5">
              <span class="w-1 h-4 rounded-full bg-primary"></span>
              {title}
            </h4>
            {links && Array.isArray(links) && links.length > 0 && (
              <ul class="text-sm space-y-2.5">
                {links.map(({ text, href, ariaLabel }) => {
                  // Render "---" as a visual divider instead of text
                  if (text === '---') {
                    return (
                      <li class="py-0.5">
                        <hr class="border-[#1e293b] border-t" />
                      </li>
                    );
                  }
                  return (
                    <li>
                      <a
                        class="text-[#94a3b8] hover:text-white hover:translate-x-0.5 transition-all duration-150 inline-block"
                        href={href}
                        aria-label={ariaLabel}
                      >
                        <Fragment set:html={text} />
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </div>
        ))
      }
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-[#1e293b] mt-10 md:mt-14 pt-6 md:pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      {
        socialLinks?.length ? (
          <ul class="flex gap-2">
            {socialLinks.map(({ ariaLabel, href, text, icon }) => (
              <li>
                <a
                  class="text-[#64748b] hover:text-primary hover:bg-white/5 rounded-lg text-sm p-2.5 inline-flex items-center transition-all border border-transparent hover:border-primary/20"
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="w-5 h-5" />}
                  <Fragment set:html={text} />
                </a>
              </li>
            ))}
          </ul>
        ) : (
          ''
        )
      }

      <div class="text-sm text-[#475569]">
        <Fragment set:html={footNote || `Hak cipta terpelihara ${SITE?.name} · 2025`} />
      </div>
    </div>
  </div>
</footer>
