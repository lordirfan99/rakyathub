---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer class="bg-[#1e293b] text-[#94a3b8] pt-12 pb-8 md:pt-16 md:pb-10 not-prose">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-12 gap-6 md:gap-8">
      <!-- Brand column -->
      <div class="col-span-12 lg:col-span-4 mb-6 lg:mb-0">
        <a class="inline-block mb-3" href={getHomePermalink()}>
          <span class="text-white font-bold text-xl">{SITE?.name}</span>
        </a>
        <p class="text-sm text-[#94a3b8] leading-relaxed max-w-xs">
          Jawapan kepada soalan rakyat Malaysia tentang kewangan, bantuan kerajaan, emas, KWSP, ASB dan banyak lagi.
        </p>
        <div class="mt-4 flex gap-3 text-sm">
          {
            secondaryLinks.map(({ text, href }, index) => (
              <>
                {index !== 0 ? <span class="text-[#475569]">·</span> : ''}
                <a
                  class="text-[#94a3b8] hover:text-white transition duration-150"
                  href={href}
                  set:html={text}
                />
              </>
            ))
          }
        </div>
      </div>

      <!-- Link columns -->
      {
        links.map(({ title, links }) => (
          <div class="col-span-6 md:col-span-3 lg:col-span-2">
            <h4 class="text-white font-semibold mb-3 text-sm">{title}</h4>
            {links && Array.isArray(links) && links.length > 0 && (
              <ul class="text-sm space-y-2">
                {links.map(({ text, href, ariaLabel }) => (
                  <li>
                    <a
                      class="text-[#94a3b8] hover:text-white transition duration-150"
                      href={href}
                      aria-label={ariaLabel}
                    >
                      <Fragment set:html={text} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-[#334155] mt-8 md:mt-12 pt-6 md:pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      {
        socialLinks?.length ? (
          <ul class="flex gap-1">
            {socialLinks.map(({ ariaLabel, href, text, icon }) => (
              <li>
                <a
                  class="text-[#94a3b8] hover:text-white hover:bg-[#334155] rounded-lg text-sm p-2 inline-flex items-center transition"
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="w-5 h-5" />}
                  <Fragment set:html={text} />
                </a>
              </li>
            ))}
          </ul>
        ) : (
          ''
        )
      }

      <div class="text-sm text-[#64748b]">
        <Fragment set:html={footNote || `Hak cipta terpelihara ${SITE?.name} · 2025`} />
      </div>
    </div>
  </div>
</footer>
