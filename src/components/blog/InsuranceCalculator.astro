---
export interface Props {
  title?: string;
}

const { title = '🚗 Kira Premium Insurans Kereta Anda' } = Astro.props;
---

<div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-indigo-50 via-white to-blue-50 dark:from-slate-900 dark:via-slate-900 dark:to-indigo-950 border-2 border-primary/10 dark:border-primary/20 shadow-lg shadow-primary/5 my-8" id="calc-insurans-kereta">
  <!-- Premium decorative top bar -->
  <div class="h-1.5 w-full bg-gradient-to-r from-primary via-blue-500 to-indigo-400"></div>
  
  <div class="p-5 md:p-7">
    <!-- Header with icon -->
    <div class="flex items-center gap-3 mb-5">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary to-indigo-600 flex items-center justify-center text-white text-lg shadow-md shadow-primary/20 shrink-0">🛡️</div>
      <div>
        <h3 class="text-lg md:text-xl font-bold text-default">{title}</h3>
        <p class="text-xs text-muted">Isi maklumat — dapatkan anggaran segera</p>
      </div>
    </div>

    <!-- Input Grid -->
    <div class="grid grid-cols-2 gap-3 md:gap-4 mb-5">
      <div class="md:col-span-1">
        <label class="block text-xs font-semibold text-default mb-1.5">Nilai Pasaran (RM)</label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-muted font-semibold">RM</span>
          <input type="number" id="ic-marketValue" value="50000" min="5000" max="500000" step="1000"
            class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 pl-10 pr-3 py-2.5 text-sm font-semibold focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition" />
        </div>
        <div class="flex justify-between text-xs text-muted mt-1 px-1">
          <span>RM5k</span>
          <span>RM500k</span>
        </div>
      </div>
      <div>
        <label class="block text-xs font-semibold text-default mb-1.5">Kapasiti Enjin</label>
        <select id="ic-engineCC"
          class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-3 py-2.5 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
          <option value="below1000">Bawah 1,000cc</option>
          <option value="1000-1400">1,000 - 1,400cc</option>
          <option value="1401-1600" selected>1,401 - 1,600cc</option>
          <option value="1601-1800">1,601 - 1,800cc</option>
          <option value="1801-2000">1,801 - 2,000cc</option>
          <option value="2001-2500">2,001 - 2,500cc</option>
          <option value="2501-3000">2,501 - 3,000cc</option>
          <option value="above3000">Atas 3,000cc</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-semibold text-default mb-1.5">NCD (Diskaun)</label>
        <select id="ic-ncd"
          class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-3 py-2.5 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
          <option value="0">0% — Baru / Selepas Tuntut</option>
          <option value="25">25% — 1 tahun bersih</option>
          <option value="30">30% — 2 tahun bersih</option>
          <option value="38.33">38.33% — 3 tahun bersih</option>
          <option value="45">45% — 4 tahun bersih</option>
          <option value="55" selected>55% — 5+ tahun bersih 🏆</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-semibold text-default mb-1.5">Jenis & Lokasi</label>
        <select id="ic-options"
          class="w-full rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 px-3 py-2.5 text-sm focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
          <option value="comp-peninsular">Komprehensif — Semenanjung</option>
          <option value="comp-sabah">Komprehensif — Sabah/Sarawak</option>
          <option value="third-peninsular">Third Party — Semenanjung</option>
          <option value="third-sabah">Third Party — Sabah/Sarawak</option>
        </select>
      </div>
    </div>

    <!-- Results Grid - Premium styled -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2.5 md:gap-3 mb-5">
      <div class="rounded-xl bg-gradient-to-br from-indigo-50 to-blue-50 dark:from-indigo-900/30 dark:to-blue-900/20 border border-indigo-100 dark:border-indigo-800/30 p-3 text-center">
        <p class="text-[10px] text-indigo-600 dark:text-indigo-400 uppercase tracking-wider font-semibold">Premium</p>
        <p class="text-xl md:text-2xl font-bold text-indigo-700 dark:text-indigo-300" id="ic-premium">RM 0</p>
      </div>
      <div class="rounded-xl bg-gradient-to-br from-sky-50 to-cyan-50 dark:from-sky-900/30 dark:to-cyan-900/20 border border-sky-100 dark:border-sky-800/30 p-3 text-center">
        <p class="text-[10px] text-sky-600 dark:text-sky-400 uppercase tracking-wider font-semibold">Cukai Jalan</p>
        <p class="text-xl md:text-2xl font-bold text-sky-700 dark:text-sky-300" id="ic-roadtax">RM 0</p>
      </div>
      <div class="rounded-xl bg-gradient-to-br from-emerald-50 to-teal-50 dark:from-emerald-900/30 dark:to-teal-900/20 border border-emerald-100 dark:border-emerald-800/30 p-3 text-center">
        <p class="text-[10px] text-emerald-600 dark:text-emerald-400 uppercase tracking-wider font-semibold">Selepas NCD</p>
        <p class="text-xl md:text-2xl font-bold text-emerald-700 dark:text-emerald-300" id="ic-afterNcd">RM 0</p>
      </div>
      <div class="rounded-xl bg-gradient-to-br from-amber-50 to-orange-50 dark:from-amber-900/30 dark:to-orange-900/20 border border-amber-100 dark:border-amber-800/30 p-3 text-center">
        <p class="text-[10px] text-amber-600 dark:text-amber-400 uppercase tracking-wider font-semibold">Jumlah Setahun</p>
        <p class="text-xl md:text-2xl font-bold text-amber-700 dark:text-amber-300" id="ic-total">RM 0</p>
      </div>
    </div>

    <!-- CTA Buttons - Premium style with gradient -->
    <div class="rounded-xl bg-gradient-to-r from-indigo-500/5 via-purple-500/5 to-blue-500/5 dark:from-indigo-900/20 dark:via-purple-900/20 dark:to-blue-900/20 border border-indigo-100/50 dark:border-indigo-800/20 p-4">
      <div class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-center justify-center">
        <a href="https://bjak.my/?p=MUHAMMAD-IRFAN-BIN-AZWARI-QR9RAS" target="_blank" rel="noopener noreferrer"
          class="flex-1 inline-flex items-center justify-center gap-2 px-5 py-3.5 rounded-xl bg-gradient-to-r from-primary via-primary to-indigo-600 text-white font-bold text-sm transition-all duration-300 hover:shadow-xl hover:shadow-primary/30 hover:scale-[1.02] active:scale-[0.98]">
          <span class="text-base">🛡️</span>
          <span>Dapatkan Sebut Harga Percuma</span>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
        <a href="https://s.shopee.com.my/60PGlFjuSv" target="_blank" rel="noopener noreferrer"
          class="flex-inline items-center justify-center gap-2 px-5 py-3.5 rounded-xl bg-white dark:bg-slate-800 border-2 border-orange-200 dark:border-orange-700/50 text-default font-bold text-sm transition-all duration-300 hover:shadow-lg hover:border-orange-400 hover:scale-[1.02] active:scale-[0.98] whitespace-nowrap">
          <span>🎉</span>
          <span>Percuma Cukai Jalan</span>
        </a>
      </div>
      <p class="text-[11px] text-muted text-center mt-3">*Anggaran indikatif berdasarkan BNM Motor Tariff. Premium sebenar mungkin berbeza mengikut insurer.</p>
    </div>
  </div>
</div>

<script is:inline>
(function(){
var R={peninsular:{below1000:{b:213,r:2.6},'1000-1400':{b:248.3,r:2.6},'1401-1600':{b:279.7,r:3},'1601-1800':{b:306.5,r:3.2},'1801-2000':{b:331.3,r:3.5},'2001-2500':{b:386.9,r:4.2},'2501-3000':{b:451.9,r:6.3},above3000:{b:487.4,r:6.7}},sabah:{below1000:{b:191.7,r:2.34},'1000-1400':{b:223.47,r:2.34},'1401-1600':{b:251.73,r:2.7},'1601-1800':{b:275.85,r:2.88},'1801-2000':{b:298.17,r:3.15},'2001-2500':{b:348.21,r:3.78},'2501-3000':{b:406.71,r:5.67},above3000:{b:438.66,r:6.03}}};
var T={peninsular:{below1000:150,'1000-1400':175,'1401-1600':200,'1601-1800':225,'1801-2000':250,'2001-2500':300,'2501-3000':350,above3000:400},sabah:{below1000:135,'1000-1400':157,'1401-1600':180,'1601-1800':202,'1801-2000':225,'2001-2500':270,'2501-3000':315,above3000:360}};
var X={below1000:20,'1000-1400':70,'1401-1600':90,'1601-1800':150,'1801-2000':200,'2001-2500':300,'2501-3000':450,above3000:500};
var $=function(id){return document.getElementById(id);};
var e={mv:$('ic-marketValue'),cc:$('ic-engineCC'),ncd:$('ic-ncd'),opts:$('ic-options')};
function fmt(v){return'RM '+(typeof v==='number'&&!isNaN(v)&&isFinite(v)?Math.round(v).toLocaleString('ms-MY'):'0');}
function calc(){
 var mv=parseFloat(e.mv.value)||50000,cc=e.cc.value,ncd=parseFloat(e.ncd.value)||55,opt=e.opts.value;
 var isComp=opt.startsWith('comp'),reg=opt.endsWith('sabah')?'sabah':'peninsular';
 if(mv<5000){['ic-premium','ic-roadtax','ic-afterNcd','ic-total'].forEach(function(id){$(id).textContent='RM 0';});return;}
 var gross=isComp?R[reg][cc].b+Math.max(0,mv-5000)/1000*R[reg][cc].r:T[reg][cc];
 var ncdPct=ncd/100,after=gross*(1-ncdPct),sst=after*0.08,total=after+sst+10,rt=X[cc]||90;
 $('ic-premium').textContent=fmt(gross);$('ic-roadtax').textContent=fmt(rt);
 $('ic-afterNcd').textContent=fmt(after);$('ic-total').textContent=fmt(total+rt);
}
[e.mv,e.cc,e.ncd,e.opts].forEach(function(el){if(el){el.addEventListener('input',calc);el.addEventListener('change',calc);}});
calc();
})();
</script>
