---
import { Icon } from 'astro-icon/components';

export interface Props {
  /** Article category slug for context-aware cross-selling */
  category?: string;
  /** Optional custom title override */
  title?: string;
  /** Optional custom description override */
  description?: string;
  /** Optional variant: 'inline' (mid-article), 'sidebar' (desktop sidebar) */
  variant?: 'inline' | 'sidebar';
  class?: string;
}

const { category, title, description, variant = 'inline', class: className } = Astro.props;

// Category-based cross-sell mapping
const crossSellMap: Record<string, { title: string; desc: string; cta: string; url: string }> = {
  kwsp: {
    title: 'Perlukan Dokumen Rasmi atau Invois untuk Urusan Kewangan?',
    desc: 'Jana penyata KWSP, slip gaji, atau invois syarikat secara automatik menggunakan AI.',
    cta: 'Bina Dokumen di DocuKilat.my',
    url: 'https://docukilat.netlify.app',
  },
  pelaburan: {
    title: 'Urus Dokumen Pelaburan Anda dengan Pantas',
    desc: 'Bina surat perjanjian, penyata pelaburan, dan kontrak simpanan dalam beberapa saat.',
    cta: 'Guna DocuKilat Sekarang',
    url: 'https://docukilat.netlify.app',
  },
  bantuan: {
    title: 'Perlukan Dokumen untuk Permohonan Bantuan Kerajaan?',
    desc: 'Jana surat permohonan, borang rasmi, dan dokumen sokongan dengan AI.',
    cta: 'Bina Dokumen di DocuKilat.my',
    url: 'https://docukilat.netlify.app',
  },
  kerjaya: {
    title: 'Bina Resume Profesional & Surat Permohonan Kerja',
    desc: 'Gunakan AI untuk hasilkan resume dan cover letter yang menarik perhatian majikan.',
    cta: 'Bina Resume di DocuKilat.my',
    url: 'https://docukilat.netlify.app',
  },
  default: {
    title: 'Perlukan Dokumen Profesional dengan Pantas?',
    desc: 'DocuKilat.my — platform penjanaan dokumen berkuasa AI. Invois, surat rasmi, resume, dan banyak lagi.',
    cta: 'Cuba DocuKilat Percuma',
    url: 'https://docukilat.netlify.app',
  },
};

const cat = category?.toLowerCase() || '';
const match = crossSellMap[cat] || crossSellMap.default;

const finalTitle = title || match.title;
const finalDesc = description || match.desc;
const finalCta = match.cta;
const finalUrl = match.url;

const isSidebar = variant === 'sidebar';
---

{
  isSidebar ? (
    <aside class={`rounded-xl border border-blue-900/30 bg-gradient-to-br from-blue-950 to-slate-900 p-5 shadow-lg ${className || ''}`}>
      <div class="flex items-center gap-2 mb-3">
        <Icon name="tabler:sparkles" class="w-5 h-5 text-blue-400" />
        <span class="text-xs font-semibold tracking-wider uppercase text-blue-300">Alat Disyorkan</span>
      </div>
      <h4 class="text-base font-bold text-white mb-2 leading-snug">{finalTitle}</h4>
      <p class="text-sm text-slate-400 mb-4 leading-relaxed">{finalDesc}</p>
      <a
        href={finalUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white transition-all hover:bg-blue-500 hover:shadow-lg hover:shadow-blue-600/25 active:scale-[0.97]"
      >
        {finalCta}
        <Icon name="tabler:external-link" class="w-3.5 h-3.5" />
      </a>
    </aside>
  ) : (
    <div class={`rounded-xl border border-blue-900/30 bg-gradient-to-r from-blue-950 via-slate-900 to-blue-950 p-6 sm:p-8 ${className || ''}`}>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-6">
        <div class="flex-shrink-0 hidden sm:flex items-center justify-center w-12 h-12 rounded-xl bg-blue-600/20">
          <Icon name="tabler:sparkles" class="w-6 h-6 text-blue-400" />
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1 sm:hidden">
            <Icon name="tabler:sparkles" class="w-4 h-4 text-blue-400" />
            <span class="text-xs font-semibold tracking-wider uppercase text-blue-300">Alat Disyorkan</span>
          </div>
          <h3 class="text-lg sm:text-xl font-bold text-white leading-snug mb-1.5">{finalTitle}</h3>
          <p class="text-sm sm:text-base text-slate-400 leading-relaxed">{finalDesc}</p>
        </div>
        <a
          href={finalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex-shrink-0 inline-flex items-center gap-2 rounded-lg bg-blue-600 px-5 py-3 text-sm font-semibold text-white transition-all hover:bg-blue-500 hover:shadow-lg hover:shadow-blue-600/25 active:scale-[0.97]"
        >
          {finalCta}
          <Icon name="tabler:external-link" class="w-4 h-4" />
        </a>
      </div>
      <div class="mt-5 pt-4 border-t border-blue-900/30">
        <p class="text-xs text-slate-500">
          <Icon name="tabler:tools" class="w-3 h-3 inline-block -mt-0.5 mr-1" />
          Lagi Alat Percuma: {' '}
          <a href="https://docukilat.netlify.app/tools/merge-pdf/" target="_blank" rel="noopener" class="text-primary dark:text-blue-400 hover:underline font-medium">Gabung PDF</a>
          {' · '}
          <a href="https://docukilat.netlify.app/tools/compress-image/" target="_blank" rel="noopener" class="text-primary dark:text-blue-400 hover:underline font-medium">Mampat Imej</a>
          {' · '}
          <a href="https://docukilat.netlify.app" target="_blank" rel="noopener" class="text-primary dark:text-blue-400 hover:underline font-medium">Semua Alat</a>
        </p>
      </div>
    </div>
  )
}
