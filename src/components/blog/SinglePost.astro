---
import { Icon } from 'astro-icon/components';

import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';
import SocialShare from '~/components/common/SocialShare.astro';
import CrossSellBanner from '~/components/blog/CrossSellBanner.astro';
import AppDashboard from '~/components/widgets/AppDashboard.astro';

import { getPermalink } from '~/utils/permalinks';
import { getFormattedDate } from '~/utils/utils';

import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;
---

<section class="py-8 sm:py-16 lg:py-20 mx-auto">
  <article>
    <header
      class={post.image
        ? 'intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade'
        : 'intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade'}
    >
      <div class="flex justify-between flex-col sm:flex-row max-w-3xl mx-auto mt-0 mb-3 px-4 sm:px-6 sm:items-center">
        <p class="text-sm text-muted dark:text-slate-400">
          {
            post.author && (
              <span class="inline-block">{post.author}</span>
            )
          }
          {
            post.category && (
              <>
                {' '}
                ·{' '}
                <a class="hover:underline inline-block" href={getPermalink(post.category.slug, 'category')}>
                  {post.category.title}
                </a>
              </>
            )
          }
          {
            post.readingTime && (
              <>
                &nbsp;· <span>{post.readingTime}</span> min bacaan
              </>
            )
          }
        </p>
      </div>

      <h1
        class="px-4 sm:px-6 max-w-3xl mx-auto text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading"
      >
        {post.title}
      </h1>
      <p
        class="max-w-3xl mx-auto mt-4 mb-8 px-4 sm:px-6 text-xl md:text-2xl text-muted dark:text-slate-400 text-justify"
      >
        {post.excerpt}
      </p>

      {
        post.image ? (
          <Image
            src={post.image}
            class="max-w-full lg:max-w-[900px] mx-auto mb-6 sm:rounded-md bg-gray-400 dark:bg-slate-700"
            widths={[400, 900]}
            sizes="(max-width: 900px) 400px, 900px"
            alt={post.title}
            width={900}
            height={506}
            format="webp"
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="max-w-3xl mx-auto px-4 sm:px-6">
            <div class="border-t dark:border-slate-700" />
          </div>
        )
      }
    </header>
    <!-- Article body with cross-linking -->
    <div
      class="mx-auto px-6 sm:px-6 max-w-3xl prose prose-md lg:prose-xl dark:prose-invert dark:prose-headings:text-slate-300 prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter prose-headings:font-bold prose-a:text-primary dark:prose-a:text-blue-400 prose-img:rounded-md prose-img:shadow-lg mt-8 prose-headings:scroll-mt-[80px] prose-li:my-0"
      id="article-body"
    >
      <slot />
    </div>
    <!-- App Dashboard — premium grid -->
    <AppDashboard
      tagline="Alat RakyatHub"
      title="Kalkulator Percuma Untuk Anda"
      subtitle="Guna kalkulator interaktif untuk kira simpanan KWSP, dividen ASB, harga emas, dan banyak lagi."
    />
    <div class="mx-auto px-6 sm:px-6 max-w-3xl mt-10">
      <CrossSellBanner category={post.category?.slug} variant="inline" />
    </div>
    <div class="mx-auto px-6 sm:px-6 max-w-3xl mt-8 flex justify-between flex-col sm:flex-row">
      <PostTags tags={post.tags} class="mr-5 rtl:mr-0 rtl:ml-5" />
      <SocialShare url={url} text={post.title} class="mt-5 sm:mt-1 align-middle text-gray-500 dark:text-slate-600" />
    </div>
  </article>
</section>

<script>
// Cross-linking engine: injects contextual internal links into article text
(function() {
  const body = document.getElementById('article-body');
  if (!body) return;

  // Skip if user prefers reduced motion (accessibility)
  const crossLinks = [
    { word: 'KWSP', url: '/blog/', title: 'baca panduan KWSP', keywords: ['KWSP', 'caruman KWSP', 'pengeluaran KWSP'] },
    { word: 'ASB', url: '/blog/', title: 'baca panduan ASB', keywords: ['ASB', 'dividen ASB', 'ASB loan', 'pelaburan ASB'] },
    { word: 'Emas', url: '/blog/', title: 'panduan emas', keywords: ['Emas', 'harga emas', 'Public Gold', 'pelaburan emas'] },
    { word: 'Bajet 50/30/20', url: '/cadangan-bajet-50-30-20-di-malaysia/', title: 'panduan bajet 50/30/20', keywords: ['bajet 50/30/20', '50 30 20'] },
    { word: 'Pelaburan', url: '/blog/', title: 'panduan pelaburan', keywords: ['pelaburan', 'DCA', 'lump sum', 'robo-advisor'] },
    { word: 'Bantuan Kerajaan', url: '/blog/', title: 'bantuan kerajaan', keywords: ['bantuan kerajaan', 'subsidi', 'STR', 'SARA'] },
    { word: 'Loan Rumah', url: '/kalkulator/loan-rumah', title: 'kira loan rumah', keywords: ['loan rumah', 'pinjaman rumah'] },
    { word: 'Kereta', url: '/kalkulator/kereta', title: 'kira kereta', keywords: ['kereta', 'ansuran kereta', 'loan kereta'] },
  ];

  // Process text nodes only (skip <a>, <code>, <script>)
  function walkTextNodes(node, callback) {
    if (node.nodeType === Node.TEXT_NODE) {
      callback(node);
    } else if (node.nodeType === Node.ELEMENT_NODE) {
      var tag = node.tagName.toLowerCase();
      if (tag === 'a' || tag === 'code' || tag === 'pre' || tag === 'script' || tag === 'style') return;
      var children = Array.prototype.slice.call(node.childNodes);
      for (var i = 0; i < children.length; i++) {
        walkTextNodes(children[i], callback);
      }
    }
  }

  var linkCount = 0;
  var MAX_LINKS = 2;

  for (var l = 0; l < crossLinks.length; l++) {
    if (linkCount >= MAX_LINKS) break;
    var link = crossLinks[l];

    walkTextNodes(body, function(textNode) {
      if (linkCount >= MAX_LINKS) return;

      var text = textNode.textContent || '';
      var idx = text.toLowerCase().indexOf(link.word.toLowerCase());
      if (idx === -1) return;

      linkCount++;
      var before = text.slice(0, idx);
      var matched = text.slice(idx, idx + link.word.length);
      var after = text.slice(idx + link.word.length);

      var linkEl = document.createElement('a');
      linkEl.href = link.url;
      linkEl.className = 'text-primary dark:text-blue-400 hover:underline font-medium';
      linkEl.title = link.title;
      linkEl.target = '_self';
      linkEl.textContent = matched;

      var fragment = document.createDocumentFragment();
      fragment.appendChild(document.createTextNode(before));
      fragment.appendChild(linkEl);
      fragment.appendChild(document.createTextNode(after));

      textNode.parentNode.replaceChild(fragment, textNode);
    });
  }
})();
</script>
