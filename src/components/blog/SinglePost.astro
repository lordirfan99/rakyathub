---
import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';
import SocialShare from '~/components/common/SocialShare.astro';
import CrossSellBanner from '~/components/blog/CrossSellBanner.astro';
import AppDashboard from '~/components/widgets/AppDashboard.astro';

import { getPermalink, getHomePermalink } from '~/utils/permalinks';
import { getAuthor } from '~/data/author';
import type { Post } from '~/types';

const cpiData = (await import('~/data/cpi.json')).default;

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;
const author = getAuthor(post.author);
---

<section class="py-8 sm:py-16 lg:py-20 mx-auto">
  <article>
    <header
      class={post.image
        ? 'intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade'
        : 'intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade'}
    >
      <div class="flex justify-between flex-col sm:flex-row max-w-3xl mx-auto mt-0 mb-3 px-4 sm:px-6 sm:items-center">
        <p class="text-sm text-muted dark:text-slate-400">
          {
            post.author && (
              <a href={getHomePermalink()} class="inline-flex items-center gap-2 group">
                <span class="w-7 h-7 rounded-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-white text-[10px] font-bold shadow-sm">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
                </span>
                <span class="font-medium text-default group-hover:text-primary transition-colors">{author.name}</span>
                <span class="text-muted">·</span>
                <span class="text-muted text-xs">{author.title}</span>
              </a>
            )
          }
          {
            post.category && (
              <>
                {' '}
                ·{' '}
                <a class="hover:underline inline-block" href={getPermalink(post.category.slug, 'category')}>
                  {post.category.title}
                </a>
              </>
            )
          }
          {
            post.readingTime && (
              <>
                &nbsp;· <span>{post.readingTime}</span> min bacaan
              </>
            )
          }
        </p>
      </div>

      <h1
        class="px-4 sm:px-6 max-w-3xl mx-auto text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading"
      >
        {post.title}
      </h1>
      <p
        class="max-w-3xl mx-auto mt-4 mb-8 px-4 sm:px-6 text-xl md:text-2xl text-muted dark:text-slate-400 text-justify"
      >
        {post.excerpt}
      </p>

      {
        post.image ? (
          <Image
            src={post.image}
            class="max-w-full lg:max-w-[900px] mx-auto mb-6 sm:rounded-md bg-gray-400 dark:bg-slate-700"
            widths={[400, 900]}
            sizes="(max-width: 900px) 400px, 900px"
            alt={post.title}
            width={900}
            height={506}
            format="webp"
            loading="eager"
            decoding="async"
          />
        ) : (
          <div class="max-w-3xl mx-auto px-4 sm:px-6">
            <div class="border-t dark:border-slate-700" />
          </div>
        )
      }
    </header>
    <!-- Article body with cross-linking -->
    <div
      class="mx-auto px-6 sm:px-6 max-w-3xl prose prose-md lg:prose-xl dark:prose-invert dark:prose-headings:text-slate-300 prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter prose-headings:font-bold prose-a:text-primary dark:prose-a:text-blue-400 prose-img:rounded-md prose-img:shadow-lg mt-8 prose-headings:scroll-mt-[80px] prose-li:my-0"
      id="article-body"
    >
      <slot />
    </div>
    <!-- CPI Data for widgets -->
    <script id="cpi-data-json" type="application/json" set:html={JSON.stringify(cpiData?.purchasing_power || {})}></script>
    <!-- App Dashboard — premium grid -->
    <AppDashboard
      tagline="Alat RakyatHub"
      title="Kalkulator Percuma Untuk Anda"
      subtitle="Guna kalkulator interaktif untuk kira simpanan KWSP, dividen ASB, harga emas, dan banyak lagi."
    />
    <div class="mx-auto px-6 sm:px-6 max-w-3xl mt-10">
      <CrossSellBanner category={post.category?.slug} variant="inline" />
    </div>
    <div class="mx-auto px-6 sm:px-6 max-w-3xl mt-8 flex justify-between flex-col sm:flex-row">
      <PostTags tags={post.tags} class="mr-5 rtl:mr-0 rtl:ml-5" />
      <SocialShare url={url} text={post.title} class="mt-5 sm:mt-1 align-middle text-gray-500 dark:text-slate-600" />
    </div>
  </article>

</section>

<script>
// Cross-linking engine: injects contextual internal links into article text
(function() {
  const body = document.getElementById('article-body');
  if (!body) return;

  const crossLinks = [
    { word: 'KWSP', url: '/info-terkini-apa-itu-kwsp-akaun-fleksibel-2025-rakyat-kini-boleh-akses-simpanan-bila-bila-masa/', title: 'panduan KWSP Akaun Fleksibel' },
    { word: 'ASB', url: '/7-kelebihan-simpanan-asb-pelaburan-bijak-pulangan-konsisten-yang-pasti-korang-tak-tahu/', title: '7 kelebihan simpanan ASB' },
    { word: 'Emas', url: '/cara-beli-emas-public-gold/', title: 'cara beli emas Public Gold' },
    { word: 'Bajet 50/30/20', url: '/cadangan-bajet-50-30-20-di-malaysia/', title: 'panduan bajet 50/30/20 di Malaysia' },
    { word: 'Pelaburan', url: '/strategi-dca-vs-lump-sum-pilihan-pelaburan-bijak-untuk-orang-muda/', title: 'strategi DCA vs Lump Sum' },
    { word: 'Bantuan Kerajaan', url: '/📉-info-bantuan-rm100-mykad-subsidi-ron95-kemas-kini-rakyathub/', title: 'info bantuan RM100 MyKad & subsidi RON95' },
    { word: 'Loan Rumah', url: '/kalkulator/loan-rumah/', title: 'kalkulator loan rumah' },
    { word: 'Kereta', url: '/kalkulator/kereta/', title: 'kalkulator ansuran kereta' },
    { word: 'DCA', url: '/strategi-dca-vs-lump-sum-pilihan-pelaburan-bijak-untuk-orang-muda/', title: 'strategi DCA untuk pelaburan konsisten' },
    { word: 'i-Saraan', url: '/💼-adakah-freelancer-boleh-carum-kwsp-sendiri/', title: 'panduan i-Saraan untuk freelancer' },
    { word: 'Scam', url: '/📘-cara-elak-scam-pinjaman-online-panduan-lengkap-tips-selamat/', title: 'cara elak scam pinjaman online' },
    { word: 'Side Hustle', url: '/7-side-hustle-paling-laku-malaysia-2026/', title: '7 side hustle paling laku Malaysia 2026' },
    { word: 'Kerjaya', url: '/7-pekerjaan-paling-laris-2026-malaysia/', title: '7 pekerjaan paling laris 2026' },
    { word: 'Subsidi', url: '/📉-info-bantuan-rm100-mykad-subsidi-ron95-kemas-kini-rakyathub/', title: 'info subsidi RON95 dan bantuan MyKad' },
    { word: 'Dividen', url: '/7-kelebihan-simpanan-asb-pelaburan-bijak-pulangan-konsisten-yang-pasti-korang-tak-tahu/', title: 'dividen ASB tahunan' },
    { word: 'STR', url: '/📉-info-bantuan-rm100-mykad-subsidi-ron95-kemas-kini-rakyathub/', title: 'info Sumbangan Tunai Rahmah STR' },
    { word: 'Robo-advisor', url: '/risiko-dan-pulangan-robo-advisor-di-malaysia/', title: 'risiko dan pulangan robo-advisor di Malaysia' },
    { word: 'Freelancer', url: '/💼-adakah-freelancer-boleh-carum-kwsp-sendiri/', title: 'panduan KWSP untuk freelancer' },
    { word: 'Beli Rumah', url: '/beli-rumah-vs-sewa-rumah-mana-lebih-untung-anak-muda/', title: 'beli rumah vs sewa untuk anak muda' },
    // === Auto-added orphan pages (34 zero internal links) ===
    { word: 'Saham', url: '/7-rahsia-bijak-beli-saham-usa-guna-moomoo-malaysia-panduan-lengkap/', title: 'panduan beli saham USA guna Moomoo Malaysia' },
    { word: 'Bajet Kahwin', url: '/bajet-kahwin-malaysia-2026-cara-simpan-dan-urus/', title: 'bajet kahwin Malaysia 2026' },
    { word: 'Internship', url: '/cara-cari-tempat-praktikal-internship/', title: 'cara cari tempat praktikal internship' },
    { word: 'Slaid Pembentangan', url: '/cara-buat-slaid-pembentangan-menarik/', title: 'cara buat slaid pembentangan menarik' },
    { word: 'Bisnes Online', url: '/bisnes-bundle-preloved-online-2026/', title: 'bisnes bundle preloved online 2026' },
    { word: 'Bursa Malaysia', url: '/bursa-malaysia-1700-peluang-melabur/', title: 'Bursa Malaysia 1700 peluang melabur' },
    { word: 'Gaji Bersih', url: '/cara-kira-gaji-bersih-panduan-potongan-kwsp-perkeso-pcb/', title: 'cara kira gaji bersih' },
    { word: 'SST', url: '/cukai-jualan-cukai-perkhidmatan-malaysia-2025-barang-dan-servis-yang-akan-terjejas/', title: 'SST Malaysia 2026 barang dan servis terjejas' },
    { word: 'e-Tunai', url: '/e-tunai-belia-rahmah-2026-cara-daftar-tebus-rm200/', title: 'e-Tunai Belia Rahmah 2026 cara daftar' },
    { word: 'Kerja Remote', url: '/kerja-remote-hibrid-malaysia-2026/', title: 'kerja remote hibrid Malaysia 2026' },
    { word: 'Gaji RM1,800', url: '/gaji-rm1800-breakdown-realistik/', title: 'gaji RM1800 breakdown realistik' },
    { word: 'PTPTN', url: '/panduan-bayar-ptptn-2026-diskaun-insentif/', title: 'panduan bayar PTPTN 2026 diskaun' },
    { word: 'Tabung Haji', url: '/panduan-tabung-haji-2026-cara-simpan-daftar-haji/', title: 'panduan tabung haji 2026' },
    { word: 'Pajak Gadai Emas', url: '/pajak-gadai-emas-ar-rahnu-panduan-kira-upah-simpan/', title: 'pajak gadai emas Ar-Rahnu panduan' },
    { word: 'Rule 78', url: '/rule-78-mansuh-akta-sewa-beli-2026/', title: 'Rule 78 mansuh akta sewa beli 2026' },
    { word: 'Quishing', url: '/quishing-scam-qr-code-malaysia-cara-lindung-diri/', title: 'quishing scam QR code Malaysia' },
    { word: 'Ringgit', url: '/ringgit-melemah-impak-belanja-anak-muda/', title: 'ringgit melemah impak belanja anak muda' },
    { word: 'Deposit Scam', url: '/scam-deposit-facebook-barang-online/', title: 'scam deposit Facebook barang online' },
    { word: 'Insurans Hayat', url: '/insurans-hayat-vs-insurans-perubatan-beza-mana-sesuai/', title: 'insurans hayat vs insurans perubatan' },
    { word: 'Takaful', url: '/takaful-vs-insurans-hayat-mana-pilihan-terbaik-perlindungan-anda/', title: 'takaful vs insurans hayat pilihan terbaik' },
  ];

  // Process text nodes only (skip <a>, <code>, <script>)
  function walkTextNodes(node, callback) {
    if (node.nodeType === Node.TEXT_NODE) {
      callback(node);
    } else if (node.nodeType === Node.ELEMENT_NODE) {
      var tag = node.tagName.toLowerCase();
      if (tag === 'a' || tag === 'code' || tag === 'pre' || tag === 'script' || tag === 'style') return;
      var children = Array.prototype.slice.call(node.childNodes);
      for (var i = 0; i < children.length; i++) {
        walkTextNodes(children[i], callback);
      }
    }
  }

  var linkCount = 0;
  var MAX_LINKS = 12;

  for (var l = 0; l < crossLinks.length; l++) {
    if (linkCount >= MAX_LINKS) break;
    var link = crossLinks[l];

    walkTextNodes(body, function(textNode) {
      if (linkCount >= MAX_LINKS) return;

      var text = textNode.textContent || '';
      var idx = text.toLowerCase().indexOf(link.word.toLowerCase());
      if (idx === -1) return;

      linkCount++;
      var before = text.slice(0, idx);
      var matched = text.slice(idx, idx + link.word.length);
      var after = text.slice(idx + link.word.length);

      var linkEl = document.createElement('a');
      linkEl.href = link.url;
      linkEl.className = 'text-primary dark:text-blue-400 hover:underline font-medium';
      linkEl.title = link.title;
      linkEl.target = '_self';
      linkEl.textContent = matched;

      var fragment = document.createDocumentFragment();
      fragment.appendChild(document.createTextNode(before));
      fragment.appendChild(linkEl);
      fragment.appendChild(document.createTextNode(after));

      textNode.parentNode.replaceChild(fragment, textNode);
    });
  }
})();
// ── Harga Makanan Widget Injection ──
(function() {
  var body = document.getElementById('article-body');
  if (!body) return;

  // Check relevance: article must mention food/prices or be in relevant categories
  var text = (body.textContent || '').toLowerCase();
  var hasPriceKeywords = /harga|barang|makanan|minyak|beras|gula|ayam|telur|belanja|groceri|inflasi|sara.?hidup|keperluan|runcit/.test(text);

  // Check breadcrumb or category hint in the article
  var hasCategoryHint = false;
  var links = body.closest('article') ? body.closest('article').querySelectorAll('a') : [];
  for (var i = 0; i < links.length; i++) {
    var href = links[i].getAttribute('href') || '';
    if (/\/category\/(kewangan|pengguna|kerajaan|bisnes)\/?$/.test(href)) {
      hasCategoryHint = true;
      break;
    }
  }

  if (!hasPriceKeywords && !hasCategoryHint) return;

  // Find midpoint — insert after the halfway paragraph
  var children = body.children;
  if (!children.length) return;
  var mid = Math.floor(children.length / 2);
  var refNode = children[mid];
  if (!refNode) return;

  // Build widget HTML
  var widget = document.createElement('div');
  widget.className = 'my-8 mx-auto max-w-2xl rounded-2xl border border-gray-200 dark:border-slate-700/50 bg-white dark:bg-slate-900/60 shadow-sm overflow-hidden not-prose';
  widget.innerHTML =
    '<div class="flex items-center justify-between px-5 py-3.5 border-b border-gray-100 dark:border-slate-700/30 bg-gradient-to-r from-blue-50/80 to-indigo-50/80 dark:from-blue-950/20 dark:to-indigo-950/20">'
    + '<div class="flex items-center gap-2.5">'
    + '<span class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-600 to-indigo-600 flex items-center justify-center text-white text-sm shadow-sm">'
    + '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"/></svg>'
    + '</span>'
    + '<div><h3 class="text-sm font-bold text-gray-900 dark:text-gray-100 leading-tight">Harga Barang Runcit Malaysia</h3>'
    + '<p class="text-[11px] text-gray-500 dark:text-gray-400" id="hw-date">KPDN PriceCatcher • loading...</p></div></div>'
    + '<span class="w-2 h-2 rounded-full bg-green-500 inline-block" style="animation:hw-pulse 2s ease-in-out infinite"></span></div>'
    + '<div id="hw-body" class="px-5 py-3.5"><div class="flex items-center justify-center py-4">'
    + '<svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">'
    + '<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>'
    + '<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg></div></div>'
    + '<a href="/harga-makanan-hari-ini/" class="block px-5 py-3 text-center text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 transition-all">'
    + '📊 Lihat Semua Harga Terkini →</a>';

  // Insert separator + widget before refNode
  var sep = document.createElement('div');
  sep.className = 'my-6';
  sep.innerHTML = '<div class="border-t border-gray-100 dark:border-slate-700/40"></div>';
  refNode.parentNode.insertBefore(sep, refNode);
  refNode.parentNode.insertBefore(widget, refNode);

  // ── Fetch live data ──
  (function(w) {
    var bodyEl = w.querySelector('#hw-body');
    var dateEl = w.querySelector('#hw-date');
    if (!bodyEl) return;

    fetch('/.netlify/functions/harga-makanan', {
      headers: { Accept: 'application/json' },
      signal: AbortSignal.timeout(10000)
    })
    .then(function(r) { if (!r.ok) throw Error('HTTP '+r.status); return r.json(); })
    .then(function(d) {
      if (!d || !d.items || !d.items.length) throw Error('no data');
      if (dateEl) dateEl.textContent = 'KPDN PriceCatcher • ' + (d.latest_date || '');

      var items = d.items;
      var keyItems = [];
      var keywords = ['AYAM STANDARD', 'TELUR GRED A', 'BERAS SUPER', 'MINYAK MASAK (1KG)', 'GULA PASIR', 'CILI MERAH', 'BAWANG MERAH', 'IKAN KEMBUNG'];
      keywords.forEach(function(kw) {
        var found = items.filter(function(i) { return i.name.toUpperCase().indexOf(kw) >= 0; });
        if (found.length) {
          found.sort(function(a,b) { return a.price - b.price; });
          keyItems.push(found[0]);
        }
      });

      // Add biggest mover if not already in list
      var sorted = items.slice().sort(function(a,b) { return Math.abs(b.change_pct||0) - Math.abs(a.change_pct||0); });
      var topMover = sorted[0];
      if (topMover && !keyItems.some(function(i) { return i.name === topMover.name; })) {
        keyItems.push(topMover);
      }

      var html = '<div class="space-y-1.5">';
      keyItems.forEach(function(item) {
        var isUp = item.change > 0.01;
        var isDown = item.change < -0.01;
        var arrow = isUp ? '▲' : isDown ? '▼' : '➡';
        var cls = isUp ? 'text-red-600' : isDown ? 'text-green-600' : 'text-gray-400';
        var slug = item.name.toLowerCase().replace(/[^a-z0-9\s-]/g,'').replace(/\s+/g,'-').replace(/-+/g,'-').trim();
        html += '<a href="/harga-makanan/'+slug+'/" class="flex items-center justify-between py-1.5 px-3 rounded-lg hover:bg-gray-50 dark:hover:bg-slate-800/40 transition-colors group">'
          + '<span class="text-sm font-medium text-gray-800 dark:text-gray-200 group-hover:text-blue-600 transition-colors">'+item.name+'</span>'
          + '<span class="flex items-center gap-2">'
          + '<span class="font-bold tabular-nums text-sm text-gray-900 dark:text-gray-100">RM'+item.price.toFixed(2)+'</span>'
          + '<span class="text-xs tabular-nums '+cls+'">'+arrow+' '+(item.change>0?'+':'')+item.change.toFixed(2)+'</span>'
          + '</span></a>';
      });
      html += '</div>';
      bodyEl.innerHTML = html;
    })
    .catch(function() {
      bodyEl.innerHTML = '<p class="text-xs text-gray-400 text-center py-2">Data harga tidak tersedia buat masa ini.</p>';
    });
  })(widget);
})();
// ── CPI Inflasi Widget Injection ──
(function() {
  var body = document.getElementById('article-body');
  if (!body) return;

  var text = (body.textContent || '').toLowerCase();
  var hasCPIKeywords = /inflasi|cpi|ringgit.*susut|nilai.*wang|harga.*naik|kos.*sara|kuasa.*beli|rm100.*dulu/.test(text);
  var hasCategoryHint = false;
  var links = body.closest('article') ? body.closest('article').querySelectorAll('a') : [];
  for (var i = 0; i < links.length; i++) {
    var href = links[i].getAttribute('href') || '';
    if (/\/category\/(kewangan|kerajaan|bisnes)\/?$/.test(href)) {
      hasCategoryHint = true;
      break;
    }
  }
  if (!hasCPIKeywords && !hasCategoryHint) return;

  // Read CPI data
  var dataEl = document.getElementById('cpi-data-json');
  if (!dataEl) return;
  var pp;
  try { pp = JSON.parse(dataEl.textContent); } catch(e) { return; }
  if (!pp || !pp['2010'] || !pp['2020']) return;

  var children = body.children;
  if (!children.length) return;
  var mid = Math.floor(children.length / 2);
  var refNode = children[mid];
  if (!refNode) return;

  var widget = document.createElement('div');
  widget.className = 'my-8 mx-auto max-w-2xl rounded-2xl border border-gray-200 dark:border-slate-700/50 bg-white dark:bg-slate-900/60 shadow-sm overflow-hidden not-prose';
  widget.innerHTML =
    '<div class="flex items-center justify-between px-5 py-3.5 border-b border-gray-100 dark:border-slate-700/30 bg-gradient-to-r from-red-50/80 to-amber-50/80 dark:from-red-950/20 dark:to-amber-950/20">'
    + '<div class="flex items-center gap-2.5">'
    + '<span class="w-8 h-8 rounded-lg bg-gradient-to-br from-red-500 to-amber-600 flex items-center justify-center text-white text-sm shadow-sm">'
    + '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>'
    + '</span>'
    + '<div><h3 class="text-sm font-bold text-gray-900 dark:text-gray-100 leading-tight">Nilai Ringgit Semakin Susut</h3>'
    + '<p class="text-[11px] text-gray-500 dark:text-gray-400">CPI Malaysia • DOSM</p></div></div>'
    + '<span class="text-xs font-semibold text-red-500">🔥 Inflasi</span></div>'
    + '<div class="px-5 py-3.5 space-y-3">'
    + '<div class="grid grid-cols-3 gap-3">'
    + '<div class="text-center p-2.5 rounded-lg bg-gray-50 dark:bg-slate-800/40"><p class="text-[10px] text-muted/60">RM100 (2000)</p><p class="text-lg font-bold text-gray-900 dark:text-gray-100">RM'+pp['2000']+'</p></div>'
