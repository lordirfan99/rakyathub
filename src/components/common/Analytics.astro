---
export interface Props {
  adsId?: string;
}

const { adsId } = Astro.props;

import { ANALYTICS } from 'astrowind:config';

const id = ANALYTICS?.vendors?.googleAnalytics?.id ? String(ANALYTICS.vendors.googleAnalytics.id) : '';
const partytown = !!ANALYTICS?.vendors?.googleAnalytics?.partytown;
const scriptType = partytown ? 'text/partytown' : undefined;
---

{
  // Consent Mode v2 — MUST run before GA script loads
  id || adsId ? (
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      // Default: all tracking denied until user consents
      gtag('consent', 'default', {
        'ad_storage': 'denied',
        'analytics_storage': 'denied',
        'ad_user_data': 'denied',
        'ad_personalization': 'denied',
        'wait_for_update': 500,
      });

      // If user already accepted in a previous session, restore grant
      // so GA processes the config call immediately
      if (localStorage.getItem('rakyathub-cookie-consent') === 'accepted') {
        gtag('consent', 'update', {
          'analytics_storage': 'granted',
          'ad_storage': 'granted',
        });
      }
    </script>
  ) : null
}

{id && <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${id}`} type={scriptType} />}

{adsId && <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${adsId}`} />}

<script is:inline id="ga-init" data-id={id} data-ads-id={adsId} type={id || adsId ? scriptType : undefined}>
  if (document.getElementById('ga-init').dataset.id) {
    var d = document.getElementById('ga-init').dataset.id;
    // Exclude hermes testing traffic (append ?hermes=1 to URLs)
    if (window.location.search.includes('hermes=1')) {
      window['ga-disable-' + d] = true;
    }
    window.dataLayer = window.dataLayer || [];
    window.gtag = function () {
      dataLayer.push(arguments);
    };
    window.gtag('js', new Date());
    window.gtag('config', d);
  }
  if (document.getElementById('ga-init').dataset.adsId) {
    var a = document.getElementById('ga-init').dataset.adsId;
    window.gtag('config', a);
  }
</script>
