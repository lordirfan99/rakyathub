<style is:inline>
  #cookie-consent {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: #0f172a;
    color: #cbd5e1;
    padding: 0.75rem 1rem;
    font-size: 0.8125rem;
    line-height: 1.4;
    transform: translateY(100%);
    transition: transform 0.35s ease;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.15);
  }
  #cookie-consent.show { transform: translateY(0); }
  #cookie-consent .inner {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  #cookie-consent p { margin: 0; flex: 1 1 240px; }
  #cookie-consent a { color: #60a5fa; text-decoration: underline; }
  #cookie-consent button {
    background: #2563eb;
    color: #fff;
    border: 0;
    border-radius: 0.375rem;
    padding: 0.4rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s ease;
  }
  #cookie-consent button:hover { background: #1d4ed8; }
</style>

<div id="cookie-consent" role="alert" aria-live="polite">
  <div class="inner">
    <p>
      Kami guna cookie Google Analytics untuk tingkatkan pengalaman anda.
      Dengan terus melayari, anda setuju. 
      <a href="/privasi" target="_blank">Dasar Privasi</a>
    </p>
    <button id="cookie-accept" aria-label="Terima cookie">Terima</button>
  </div>
</div>

<script is:inline>
(function() {
  var key = 'rakyathub-cookie-consent';
  if (localStorage.getItem(key)) return;
  var banner = document.getElementById('cookie-consent');
  var btn = document.getElementById('cookie-accept');
  if (!banner || !btn) return;
  // Show banner after a short delay
  requestAnimationFrame(function() {
    banner.classList.add('show');
  });
  btn.addEventListener('click', function() {
    localStorage.setItem(key, 'accepted');
    banner.classList.remove('show');
    // Allow transition to finish before removing from DOM
    setTimeout(function() { banner.remove(); }, 400);
  });
})();
</script>
